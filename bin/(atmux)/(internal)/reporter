#!/usr/bin/env bash
# Reporter helpers: emit the same listing twice, once as XML for agents
# and once as a column-aligned human table for CLI users.
#
# This file is sourced, never executed. Sourcing it injects:
#   reporter_mode      → echoes "xml" or "cli" based on env
#   report_open        → opens a collection
#   report_record      → emits one record (key=value attrs)
#   report_close       → closes the collection (flushes table in CLI mode)
#   report_xml_escape  → XML-escape a value (re-export for callers)
#
# Mode selection:
#   ATMUX_REPORTER=xml   → always XML
#   ATMUX_REPORTER=cli   → always CLI text
#   ATMUX_REPORTER=auto  → XML iff ATMUX_AGENT_NAME is set (default)
#   unset                → same as auto
#   ATMUX_NO_WRAP=1      → forces CLI (legacy alias, takes precedence over auto)

# Guard against double-sourcing.
if [[ -n "${__ATMUX_REPORTER_SOURCED:-}" ]]; then
  return 0 2>/dev/null || true
fi
__ATMUX_REPORTER_SOURCED=1

report_xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

reporter_mode() {
  case "${ATMUX_REPORTER:-}" in
    xml) printf 'xml\n'; return ;;
    cli) printf 'cli\n'; return ;;
  esac
  if [[ "${ATMUX_NO_WRAP:-}" == "1" ]]; then
    printf 'cli\n'
    return
  fi
  if [[ -n "${ATMUX_AGENT_NAME:-}" ]]; then
    printf 'xml\n'
  else
    printf 'cli\n'
  fi
}

# Internal CLI-mode buffering state. One collection in flight at a time.
__REPORTER_BUF=""
__REPORTER_HEADER=""
__REPORTER_ELEMENT=""
__REPORTER_INDENT=""

# report_open <element> [k=v ...]
#
# XML mode: prints `<element k="v" ...>` followed by newline.
# CLI mode: starts buffering rows; prints a header line such as
#           `agents (repo: amux)` to scope the table.
report_open() {
  local element="$1"; shift
  local mode; mode="$(reporter_mode)"
  local indent="${__REPORTER_INDENT:-}"
  if [[ "$mode" == "xml" ]]; then
    local out="${indent}<${element}"
    local kv k v
    for kv in "$@"; do
      k="${kv%%=*}"
      v="${kv#*=}"
      out+=" ${k}=\"$(report_xml_escape "$v")\""
    done
    printf '%s>\n' "$out"
    return
  fi

  # CLI mode: start a buffered collection.
  __REPORTER_ELEMENT="$element"
  __REPORTER_BUF="$(mktemp "${TMPDIR:-/tmp}/atmux-reporter-buf.XXXXXX")"
  __REPORTER_HEADER=""

  # Build a small "scope" header from the open element's attrs.
  local label="$element"
  local kv k v scope=""
  for kv in "$@"; do
    k="${kv%%=*}"
    v="${kv#*=}"
    [[ -z "$v" ]] && continue
    if [[ -n "$scope" ]]; then scope+=", "; fi
    scope+="${k}: ${v}"
  done
  if [[ -n "$scope" ]]; then
    printf '%s (%s)\n' "$label" "$scope"
  else
    printf '%s\n' "$label"
  fi
}

# report_record <element> [k=v ...]
#
# XML mode: prints `  <element k="v" ... />` (two-space indent).
# CLI mode: appends a tab-separated row to the buffer; first record's
#           keys define the header.
report_record() {
  local element="$1"; shift
  local mode; mode="$(reporter_mode)"
  if [[ "$mode" == "xml" ]]; then
    local indent="${__REPORTER_INDENT:-}  "
    local out="${indent}<${element}"
    local kv k v
    for kv in "$@"; do
      k="${kv%%=*}"
      v="${kv#*=}"
      out+=" ${k}=\"$(report_xml_escape "$v")\""
    done
    printf '%s />\n' "$out"
    return
  fi

  # CLI mode: header from first record's keys.
  if [[ -z "$__REPORTER_HEADER" ]]; then
    local hdr="" kv k
    for kv in "$@"; do
      k="${kv%%=*}"
      if [[ -n "$hdr" ]]; then hdr+=$'\t'; fi
      hdr+="$(printf '%s' "$k" | tr '[:lower:]' '[:upper:]')"
    done
    __REPORTER_HEADER="$hdr"
  fi

  local row="" kv v
  for kv in "$@"; do
    v="${kv#*=}"
    [[ -z "$v" ]] && v="-"
    # Strip embedded tabs/newlines so column alignment doesn't break.
    v="${v//$'\t'/ }"
    v="${v//$'\n'/ }"
    if [[ -n "$row" ]]; then row+=$'\t'; fi
    row+="$v"
  done
  printf '%s\n' "$row" >> "$__REPORTER_BUF"
}

# report_close <element>
#
# XML mode: prints `</element>`.
# CLI mode: prints the buffered rows as a `column -t` aligned table,
#           or "(none)" if the collection was empty.
report_close() {
  local element="$1"
  local mode; mode="$(reporter_mode)"
  if [[ "$mode" == "xml" ]]; then
    local indent="${__REPORTER_INDENT:-}"
    printf '%s</%s>\n' "$indent" "$element"
    return
  fi

  if [[ -n "$__REPORTER_BUF" ]]; then
    if [[ -s "$__REPORTER_BUF" ]]; then
      {
        printf '%s\n' "$__REPORTER_HEADER"
        cat "$__REPORTER_BUF"
      } | column -t -s $'\t'
    else
      printf '(none)\n'
    fi
    rm -f "$__REPORTER_BUF"
  fi
  __REPORTER_BUF=""
  __REPORTER_HEADER=""
  __REPORTER_ELEMENT=""
}
