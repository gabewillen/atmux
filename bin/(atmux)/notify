#!/usr/bin/env bash
# shellcheck shell=bash
# Shared helpers for exec, issue, watch --pid, watch --issue; also `atmux notify` CLI when executed.
# When sourced, only function definitions run (see bottom).

ATMUX_NOTIFY_SCRIPT_PATH="${BASH_SOURCE[0]}"

debug_notify_enabled() {
  case "${ATMUX_DEBUG_NOTIFY:-0}" in
    1|true|TRUE|yes|YES)
      return 0
      ;;
  esac
  return 1
}

debug_notify_log_file() {
  printf '%s/logs/notify-debug.log\n' "$ATMUX_HOME"
}

payload_debug_summary() {
  local payload="${1:-}"
  local compact type from cmd
  compact="$(printf '%s' "$payload" | tr '\n' ' ' | tr -s ' ')"
  type="$(printf '%s' "$compact" | sed -n 's/.*type="\([^"]*\)".*/\1/p' | head -n1)"
  from="$(printf '%s' "$compact" | sed -n 's/.*from="\([^"]*\)".*/\1/p' | head -n1)"
  cmd="$(printf '%s' "$compact" | sed -n 's/.*cmd="\([^"]*\)".*/\1/p' | head -n1)"
  compact="${compact:0:220}"
  printf 'type=%q from=%q cmd=%q payload=%q' "${type:-}" "${from:-}" "${cmd:-}" "$compact"
}

debug_notify() {
  debug_notify_enabled || return 0
  local log_file
  log_file="$(debug_notify_log_file)"
  mkdir -p "$(dirname "$log_file")"
  printf '%s pid=%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$$" "$*" >>"$log_file"
}

ensure_internal_real_tmux() {
  if [[ -n "${ATMUX_REAL_TMUX:-}" && -x "$ATMUX_REAL_TMUX" ]]; then
    export ATMUX_ALLOW_REAL_TMUX=1
  fi
}

ensure_internal_real_tmux

normalize_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

primary_pane_for_session() {
  local session="$1"
  tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }'
}

current_pane() {
  # Prefer TMUX_PANE (set by tmux per-pane) — display-message -p resolves
  # wrong without an attached client.
  if [[ -n "${TMUX_PANE:-}" ]]; then
    printf '%s\n' "$TMUX_PANE"
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return 0
  fi
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    primary_pane_for_session "$ATMUX_SESSION_NAME"
    return 0
  fi
  return 0
}

pane_queue_key() {
  local pane="$1"
  local session=""
  session="$(tmux display-message -t "$pane" -p "#{session_name}" 2>/dev/null || true)"
  if [[ -n "$session" ]]; then
    pane="${session}-${pane}"
  fi
  printf '%s\n' "${pane//[^A-Za-z0-9_.-]/_}"
}

notify_queue_dir() {
  local pane="$1"
  printf '%s/notify-queue/%s\n' "$ATMUX_HOME" "$(pane_queue_key "$pane")"
}

resolve_notify_script_path() {
  local source_root="$1"
  local notify_script="$source_root/bin/(atmux)/notify"
  if [[ -x "$notify_script" ]]; then
    printf '%s\n' "$notify_script"
  else
    printf '%s\n' "$ATMUX_NOTIFY_SCRIPT_PATH"
  fi
}

resolve_input_prompt_for_adapter() {
  local adapter="$1"
  local source_root="$2"
  local manifest_path

  local ATMUX_SOURCE_ROOT="$source_root"
  if ! manifest_path="$(resolve_manifest_path "$adapter")"; then
    return 1
  fi

  # Use python so JSON escapes (e.g. `"\\*"` for gemini's regex prompt)
  # decode to their actual bytes — sed would return the raw `\\*`,
  # which makes bash =~ expect a literal backslash in the pane.
  python3 -c '
import json, sys
try:
  d = json.load(open(sys.argv[1]))
  v = (d.get("input") or {}).get("start")
  if v is not None:
    sys.stdout.write(v)
except Exception:
  pass
' "$manifest_path"
}

# Returns the SGR sequence body that marks the end of the user-input
# region, e.g. "[0;7m" for cursor-agent (the reverse-video cursor
# cell). The full ANSI escape is `\e<value>`. When set,
# extract_prompt_input switches to a styled (`-e`) capture and stops
# at the first occurrence of this marker after the prompt prefix —
# anything past it is the cursor cell + chrome (placeholder text,
# slash-command palette, status footer) and gets dropped.
#
# Adapters that don't declare `input.end` get the legacy
# capture-to-cursor-position behavior.
resolve_input_end_for_adapter() {
  local adapter="$1"
  local source_root="$2"
  local manifest_path

  local ATMUX_SOURCE_ROOT="$source_root"
  if ! manifest_path="$(resolve_manifest_path "$adapter")"; then
    return 1
  fi

  python3 -c '
import json, sys
try:
  d = json.load(open(sys.argv[1]))
  v = (d.get("input") or {}).get("end")
  if v is not None:
    sys.stdout.write(v)
except Exception:
  pass
' "$manifest_path"
}

resolve_input_end_for_pane() {
  local pane="$1"
  local source_root="$2"
  local sess adapter

  sess="$(tmux display-message -t "$pane" -p "#{session_name}" 2>/dev/null || true)"
  [[ -n "$sess" ]] || return 1

  adapter="$(get_session_env "$sess" ATMUX_ADAPTER)"
  [[ -n "$adapter" ]] || return 1

  resolve_input_end_for_adapter "$adapter" "$source_root"
}

normalize_prompt_text() {
  local text="${1:-}"
  local nbsp=$'\u00a0'
  text="${text//$nbsp/ }"
  printf '%s' "$text"
}

pane_cursor_position() {
  local pane="$1"
  local cursor_x cursor_y

  cursor_x="$(tmux display-message -t "$pane" -p "#{cursor_x}" 2>/dev/null || true)"
  cursor_y="$(tmux display-message -t "$pane" -p "#{cursor_y}" 2>/dev/null || true)"

  [[ "$cursor_x" =~ ^[0-9]+$ ]] || return 1
  [[ "$cursor_y" =~ ^[0-9]+$ ]] || return 1

  printf '%s %s\n' "$cursor_x" "$cursor_y"
}

pane_exists() {
  local pane="$1" resolved=""
  resolved="$(tmux display-message -t "$pane" -p '#{pane_id}' 2>/dev/null || true)"
  [[ -n "$resolved" ]]
}

pane_pipe_active() {
  local pane="$1" active=""
  active="$(tmux display-message -t "$pane" -p '#{pane_pipe}' 2>/dev/null || true)"
  [[ "$active" == "1" ]]
}

start_pane_event_stream() {
  local pane="$1"
  local stream_dir output_fifo event_fifo output_q bridge_pid

  pane_exists "$pane" || return 1
  if pane_pipe_active "$pane"; then
    return 2
  fi

  mkdir -p "$ATMUX_HOME/tmp"
  stream_dir="$(mktemp -d "$ATMUX_HOME/tmp/pane-stream.XXXXXX")"
  output_fifo="$stream_dir/output.fifo"
  event_fifo="$stream_dir/event.fifo"
  mkfifo "$output_fifo" "$event_fifo"

  (
    exec 7<>"$output_fifo"
    while IFS= read -r -n 1 _ <&7; do
      printf 'output\n' > "$event_fifo" 2>/dev/null || exit 0
      sleep "${ATMUX_PANE_EVENT_DEBOUNCE_SECONDS:-0.05}"
    done
  ) &
  bridge_pid="$!"

  printf -v output_q '%q' "$output_fifo"
  if ! tmux pipe-pane -t "$pane" "cat >> $output_q" >/dev/null 2>&1; then
    kill "$bridge_pid" >/dev/null 2>&1 || true
    rm -rf "$stream_dir"
    return 1
  fi

  printf '%s\n%s\n%s\n%s\n' "$stream_dir" "$output_fifo" "$event_fifo" "$bridge_pid"
}

stop_pane_event_stream() {
  local pane="$1"
  local stream_dir="$2"
  local bridge_pid="${3:-}"

  if [[ -n "$pane" ]] && pane_exists "$pane"; then
    tmux pipe-pane -t "$pane" >/dev/null 2>&1 || true
  fi
  if [[ -n "$bridge_pid" ]]; then
    kill "$bridge_pid" >/dev/null 2>&1 || true
    wait "$bridge_pid" >/dev/null 2>&1 || true
  fi
  [[ -n "$stream_dir" ]] && rm -rf "$stream_dir"
}

pane_notification_blocked() {
  local pane="$1"
  local in_mode mode scroll_position
  local snapshot=""

  snapshot="$(tmux display-message -t "$pane" -p '#{pane_in_mode} #{pane_mode} #{scroll_position}' 2>/dev/null || true)"
  [[ -n "$snapshot" ]] || return 1

  IFS=' ' read -r in_mode mode scroll_position <<< "$snapshot"
  [[ "$in_mode" == "1" ]] || return 1

  debug_notify "pane:blocking_notifications pane=$(printf '%q' "$pane") mode=$(printf '%q' "${mode:-}") scroll_position=$(printf '%q' "${scroll_position:-}")"
  return 0
}

truncate_line_to_cursor() {
  local line="${1:-}"
  local cursor_x="${2:-}"

  [[ "$cursor_x" =~ ^[0-9]+$ ]] || {
    printf '%s' "$line"
    return 0
  }

  if (( cursor_x <= 0 )); then
    printf ''
    return 0
  fi

  # tmux's cursor_x is the visual column (character index), but bash's
  # substring expansion and `cut -c` are byte-based unless the shell
  # was started under a UTF-8 LC_CTYPE — and bash evaluates locale at
  # startup, so re-setting LC_CTYPE here is a no-op. When the captured
  # line contains a multi-byte char (e.g. the "❯" prompt prefix),
  # byte-based truncation clips the tail of saved input, which the
  # worker then types back missing characters. perl with -CS forces
  # UTF-8 on stdin/stdout regardless of the parent shell's locale, so
  # substr operates on characters and matches tmux's column count.
  printf '%s' "$line" | perl -CS -e '
    my $n = shift;
    local $/;
    my $s = <STDIN>;
    print substr($s, 0, $n);
  ' "$cursor_x"
}

split_prompt_line() {
  local line prompt leading_trimmed rest

  line="$(normalize_prompt_text "${1:-}")"
  # `prompt` is a regex pattern (manifest `input.start`). Trim whitespace
  # from the regex itself the same way we trim it from the line.
  prompt="$(normalize_prompt_text "${2:-}")"
  prompt="${prompt%"${prompt##*[![:space:]]}"}"
  prompt="${prompt#"${prompt%%[![:space:]]*}"}"
  [[ -n "$prompt" ]] || return 1

  leading_trimmed="${line#"${line%%[![:space:]]*}"}"
  # Bash =~ regex — anchored at start of leading_trimmed. Capture
  # group 1 is the matched prompt; group 2 is the rest, used to
  # return the user-visible content after the prompt.
  if [[ "$leading_trimmed" =~ ^($prompt)(.*)$ ]]; then
    rest="${BASH_REMATCH[2]}"
    rest="${rest#"${rest%%[![:space:]]*}"}"
    printf '%s' "$rest"
    return 0
  fi
  return 1
}

resolve_prompt_prefix_for_pane() {
  local pane="$1"
  local source_root="$2"
  local sess adapter

  sess="$(tmux display-message -t "$pane" -p "#{session_name}" 2>/dev/null || true)"
  [[ -n "$sess" ]] || return 1

  adapter="$(get_session_env "$sess" ATMUX_ADAPTER)"
  [[ -n "$adapter" ]] || return 1

  resolve_input_prompt_for_adapter "$adapter" "$source_root"
}

resolve_adapter_for_pane() {
  local pane="$1"
  local sess

  sess="$(tmux display-message -t "$pane" -p "#{session_name}" 2>/dev/null || true)"
  [[ -n "$sess" ]] || return 1

  get_session_env "$sess" ATMUX_ADAPTER
}

resolve_status_script_for_adapter() {
  local adapter="$1"
  local source_root="$2"
  local status_script="$source_root/adapter/$adapter/scripts/status"

  if [[ -x "$status_script" ]]; then
    printf '%s\n' "$status_script"
    return 0
  fi

  status_script="$ATMUX_HOME/adapters/$adapter/scripts/status"
  if [[ -x "$status_script" ]]; then
    printf '%s\n' "$status_script"
    return 0
  fi

  return 1
}

status_state_from_xml() {
  local xml="${1:-}"
  printf '%s\n' "$xml" | sed -n 's/.*state="\([^"]*\)".*/\1/p' | tail -n 1
}

extract_prompt_input() {
  local pane="$1"
  local prompt_prefix="$2"
  local snap line cursor_x cursor_y cursor_info
  local -a lines=()
  local end_idx
  local start_idx=-1
  local idx saved_input=""
  local has_cursor=0

  [[ -n "$prompt_prefix" ]] || return 0

  # If the adapter declares an input.end marker, use it: capture with
  # ANSI preserved, find the prompt prefix, then everything up to the
  # first input.end SGR escape on that line is the user's input. Skips
  # placeholder text, slash-command palettes, status footers, etc.
  local input_end_marker=""
  input_end_marker="$(resolve_input_end_for_pane "$pane" "${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}" 2>/dev/null || true)"
  if [[ -n "$input_end_marker" ]]; then
    # Only honor the end-marker path when perl is callable AND the
    # extractor exits 0. If perl is missing or the script blows up,
    # fall through to the legacy capture-to-cursor path below — empty
    # stdout from a crashed perl is indistinguishable from "input was
    # genuinely empty," so we can't trust it as the final answer.
    if command -v perl >/dev/null 2>&1; then
      local marker_out marker_rc=0
      marker_out="$(extract_prompt_input_with_end_marker "$pane" "$prompt_prefix" "$input_end_marker")" || marker_rc=$?
      if (( marker_rc == 0 )); then
        printf '%s' "$marker_out"
        return 0
      fi
    fi
    # else: drop into the legacy path
  fi

  snap="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
  while IFS= read -r line; do
    lines+=("$line")
  done <<< "$snap"
  [[ ${#lines[@]} -gt 0 ]] || return 0

  cursor_info="$(pane_cursor_position "$pane" 2>/dev/null || true)"
  if [[ -n "$cursor_info" ]]; then
    has_cursor=1
    cursor_x="${cursor_info%% *}"
    cursor_y="${cursor_info##* }"
    if (( cursor_y >= ${#lines[@]} )); then
      cursor_y=$((${#lines[@]} - 1))
    fi
    lines[cursor_y]="$(truncate_line_to_cursor "${lines[cursor_y]}" "$cursor_x")"
    end_idx=$cursor_y
  else
    end_idx=$((${#lines[@]} - 1))
  fi

  for (( idx=end_idx; idx>=0; idx-- )); do
    if split_prompt_line "${lines[idx]}" "$prompt_prefix" >/dev/null; then
      start_idx=$idx
      break
    fi
  done
  (( start_idx >= 0 )) || return 0
  if (( has_cursor == 0 )); then
    end_idx="$start_idx"
  fi

  saved_input="$(split_prompt_line "${lines[start_idx]}" "$prompt_prefix" || true)"
  for (( idx=start_idx + 1; idx<=end_idx; idx++ )); do
    saved_input+="${lines[idx]}"
  done
  printf '%s' "$saved_input"
}

# extract_prompt_input_with_end_marker: styled-capture variant used
# when the adapter manifest declares `input.end`. Captures with `-e`,
# walks lines bottom-up to find the prompt prefix, then takes
# everything between the prefix and the first occurrence of the
# end marker (`\e<end_marker>`) on the same logical input region.
# ANSI codes are stripped from the captured text.
extract_prompt_input_with_end_marker() {
  local pane="$1"
  local prompt_prefix="$2"
  local end_marker="$3"
  local snap

  snap="$(tmux capture-pane -p -e -t "$pane" 2>/dev/null || true)"
  [[ -n "$snap" ]] || return 0

  # Both `input.start` and `input.end` are regex patterns (so a single
  # manifest entry can match all forms an adapter renders, e.g.
  # cursor-agent's cursor cell is `\e[0;7m` in placeholder mode and
  # `\e[7m` once typed → `\[(?:0;)?7m` matches both). The end-marker
  # regex is anchored after the escape: manifest writes the body that
  # comes after `\e`.
  ATMUX_PROMPT_PREFIX="$prompt_prefix" \
  ATMUX_INPUT_END="$end_marker" \
  perl -e '
    use strict; use warnings;
    my $prompt_re = qr/$ENV{ATMUX_PROMPT_PREFIX}/;
    my $end_re    = qr/\e$ENV{ATMUX_INPUT_END}/;
    my $snap      = do { local $/; <STDIN> };
    my @lines     = split /\r?\n/, $snap, -1;

    # Walk lines bottom-up; first line whose ANSI-stripped form
    # contains the prompt prefix is the input prompt line.
    my $idx = -1;
    my $bare_match;
    for (my $i = $#lines; $i >= 0; $i--) {
      my $bare = $lines[$i];
      $bare =~ s/\e\[[0-9;]*[a-zA-Z]//g;
      if ($bare =~ $prompt_re) {
        $idx = $i;
        last;
      }
    }
    exit 0 if $idx < 0;

    my $line = $lines[$idx];
    # Locate the prompt prefix in the styled bytes by skipping ANSI
    # escapes (and leading whitespace) byte-by-byte until the prompt
    # regex matches at the start of what remains.
    my $scan = $line;
    while ($scan ne "") {
      # Skip ANSI CSI sequences so the prompt regex sees plain bytes.
      if ($scan =~ /^\e\[[0-9;]*[a-zA-Z]/) {
        $scan = substr($scan, length($&));
        next;
      }
      # Skip leading whitespace (the rendered input box always has a
      # left margin before the prompt prefix glyph).
      if ($scan =~ /^\s+/) {
        $scan = substr($scan, length($&));
        next;
      }
      # Try the prompt regex.
      if ($scan =~ /^$prompt_re/) {
        $scan = substr($scan, length($&));
        last;
      }
      # Some other byte before the prompt — drop it and retry.
      $scan = substr($scan, 1);
    }
    # $scan now starts immediately after the prompt prefix.
    my $rest = $scan;

    # Stop at the first end-marker match. Everything before is the
    # user input.
    my $captured;
    if ($rest =~ /^(.*?)(?:$end_re)/s) {
      $captured = $1;
    } else {
      # No end marker on the prompt line — adapter promised one but
      # render is in an unexpected state. Be conservative and return
      # empty so we never re-paste chrome.
      exit 0;
    }
    $captured =~ s/\e\[[0-9;]*[a-zA-Z]//g;
    $captured =~ s/^\s+//;
    $captured =~ s/\s+$//;
    print $captured;
  ' <<< "$snap"
}

pane_has_prompt_line() {
  local pane="$1"
  local prompt_prefix="$2"
  local snap line cursor_y cursor_info
  local -a lines=()
  local idx

  [[ -n "$prompt_prefix" ]] || return 1

  snap="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
  while IFS= read -r line; do
    lines+=("$line")
  done <<< "$snap"
  [[ ${#lines[@]} -gt 0 ]] || return 1

  cursor_info="$(pane_cursor_position "$pane" 2>/dev/null || true)"
  if [[ -n "$cursor_info" ]]; then
    cursor_y="${cursor_info##* }"
    if (( cursor_y >= ${#lines[@]} )); then
      cursor_y=$((${#lines[@]} - 1))
    fi
  else
    cursor_y=$((${#lines[@]} - 1))
  fi

  for (( idx=cursor_y; idx>=0; idx-- )); do
    if split_prompt_line "${lines[idx]}" "$prompt_prefix" >/dev/null; then
      return 0
    fi
  done

  return 1
}

restore_prompt_input() {
  local pane="$1"
  local prompt_prefix="$2"
  local saved_input="$3"
  local settle submit_wait
  local attempt

  [[ -n "$saved_input" ]] || return 0

  settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"
  submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.3}"

  if [[ -n "$prompt_prefix" ]]; then
    for (( attempt=0; attempt<20; attempt++ )); do
      if pane_has_prompt_line "$pane" "$prompt_prefix"; then
        break
      fi
      sleep 0.1
    done
  fi

  sleep "$settle"
  tmux send-keys -t "$pane" -l "$saved_input" >/dev/null 2>&1 || true
  sleep "$submit_wait"
}

restore_after_failed_delivery() {
  local pane="$1"
  local prompt_prefix="$2"
  local saved_input="$3"
  local settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"

  tmux send-keys -t "$pane" C-u >/dev/null 2>&1 || true
  sleep "$settle"
  restore_prompt_input "$pane" "$prompt_prefix" "$saved_input"
}

wait_for_pane_ready() {
  local pane="$1"
  local source_root="$2"
  local prompt_prefix="${3:-}"
  local timeout="${4:-${ATMUX_SEND_READY_TIMEOUT_SECONDS:-45}}"
  local deadline now adapter status_script status_xml state

  [[ "$timeout" =~ ^[0-9]+$ ]] || timeout=45
  deadline=$(( $(date +%s) + timeout ))
  adapter="$(resolve_adapter_for_pane "$pane" 2>/dev/null || true)"
  status_script=""
  if [[ -n "$adapter" ]]; then
    status_script="$(resolve_status_script_for_adapter "$adapter" "$source_root" 2>/dev/null || true)"
  fi

  while true; do
    if [[ -n "$prompt_prefix" ]] && ! pane_has_prompt_line "$pane" "$prompt_prefix"; then
      :
    else
      if [[ -n "$status_script" ]]; then
        status_xml="$(ATMUX_HOME="$ATMUX_HOME" ATMUX_SOURCE_ROOT="$source_root" ATMUX_STATUS_PASSIVE=1 \
          ATMUX_TARGET_PANE="$pane" "$status_script" 2>/dev/null || true)"
        state="$(status_state_from_xml "$status_xml")"
        case "$state" in
          idle|errored|usage-limit) return 0 ;;
        esac
      else
        return 0
      fi
    fi

    now="$(date +%s)"
    if (( now >= deadline )); then
      debug_notify "ready:timeout pane=$(printf '%q' "$pane") prompt_prefix=$(printf '%q' "$prompt_prefix") adapter=$(printf '%q' "$adapter")"
      return 1
    fi
    sleep 0.2
  done
}

wait_for_prompt_input_settled() {
  local pane="$1"
  local prompt_prefix="$2"
  local fallback_wait="$3"
  local timeout="${ATMUX_SEND_PASTE_READY_TIMEOUT_SECONDS:-12}"
  local deadline now input cursor_info
  local last_input="" last_cursor="" stable_count=0

  if [[ -z "$prompt_prefix" ]]; then
    sleep "$fallback_wait"
    return 0
  fi

  if ! pane_has_prompt_line "$pane" "$prompt_prefix"; then
    debug_notify "deliver:paste_ready_no_prompt pane=$(printf '%q' "$pane")"
    sleep "$fallback_wait"
    return 0
  fi

  deadline=$(( $(date +%s) + timeout ))
  while true; do
    input="$(extract_prompt_input "$pane" "$prompt_prefix" 2>/dev/null || true)"
    cursor_info="$(pane_cursor_position "$pane" 2>/dev/null || true)"

    if [[ -n "$input" && "$input" == "$last_input" && "$cursor_info" == "$last_cursor" ]]; then
      stable_count=$((stable_count + 1))
      if (( stable_count >= 2 )); then
        debug_notify "deliver:paste_ready pane=$(printf '%q' "$pane") input_len=${#input} cursor=$(printf '%q' "$cursor_info")"
        return 0
      fi
    else
      stable_count=0
    fi

    last_input="$input"
    last_cursor="$cursor_info"
    now="$(date +%s)"
    if (( now >= deadline )); then
      debug_notify "deliver:paste_ready_timeout pane=$(printf '%q' "$pane") input_len=${#input} cursor=$(printf '%q' "$cursor_info")"
      return 0
    fi
    sleep 0.1
  done
}

submit_notification_input() {
  local pane="$1"
  local prompt_prefix="$2"
  local submit_keys="$3"
  local submit_wait="$4"
  local attempts="${ATMUX_SEND_SUBMIT_RETRY_ATTEMPTS:-4}"
  local attempt sk
  local before_input before_cursor before_y
  local after_input after_cursor after_y
  local deadline now
  local submit_verify_timeout="${ATMUX_SEND_SUBMIT_VERIFY_SECONDS:-2}"

  [[ "$attempts" =~ ^[0-9]+$ ]] || attempts=4
  (( attempts > 0 )) || attempts=1
  [[ "$submit_verify_timeout" =~ ^[0-9]+$ ]] || submit_verify_timeout=2

  for (( attempt=1; attempt<=attempts; attempt++ )); do
    before_input=""
    before_cursor=""
    before_y=""
    if [[ -n "$prompt_prefix" ]]; then
      before_input="$(extract_prompt_input "$pane" "$prompt_prefix" 2>/dev/null || true)"
      before_cursor="$(pane_cursor_position "$pane" 2>/dev/null || true)"
      before_y="${before_cursor##* }"
    fi

    debug_notify "deliver:submit_attempt pane=$(printf '%q' "$pane") attempt=$attempt input_len=${#before_input} cursor=$(printf '%q' "$before_cursor")"
    for sk in $submit_keys; do
      tmux send-keys -t "$pane" "$sk" >/dev/null 2>&1 || {
        debug_notify "deliver:submit_failed pane=$(printf '%q' "$pane") key=$(printf '%q' "$sk")"
        return 1
      }
    done

    if [[ -z "$prompt_prefix" ]] || ! pane_has_prompt_line "$pane" "$prompt_prefix"; then
      sleep "$submit_wait"
      debug_notify "deliver:submit_unverified_no_prompt pane=$(printf '%q' "$pane") attempt=$attempt"
      return 0
    fi

    deadline=$(( $(date +%s) + submit_verify_timeout ))
    while true; do
      after_input="$(extract_prompt_input "$pane" "$prompt_prefix" 2>/dev/null || true)"
      after_cursor="$(pane_cursor_position "$pane" 2>/dev/null || true)"
      after_y="${after_cursor##* }"

      if [[ -n "$before_y" && -n "$after_y" && "$before_y" =~ ^[0-9]+$ && "$after_y" =~ ^[0-9]+$ && "$after_y" -gt "$before_y" ]]; then
        sleep "$submit_wait"
        debug_notify "deliver:submit_accepted pane=$(printf '%q' "$pane") attempt=$attempt reason=cursor_advanced before=$(printf '%q' "$before_cursor") after=$(printf '%q' "$after_cursor")"
        return 0
      fi
      if [[ -n "$before_input" && -z "$after_input" ]]; then
        sleep "$submit_wait"
        debug_notify "deliver:submit_accepted pane=$(printf '%q' "$pane") attempt=$attempt reason=input_cleared"
        return 0
      fi
      if [[ -n "$before_input" ]] && ! pane_has_prompt_line "$pane" "$prompt_prefix"; then
        sleep "$submit_wait"
        debug_notify "deliver:submit_accepted pane=$(printf '%q' "$pane") attempt=$attempt reason=prompt_gone"
        return 0
      fi

      now="$(date +%s)"
      if (( now >= deadline )); then
        break
      fi
      sleep 0.1
    done

    if (( attempt < attempts )); then
      debug_notify "deliver:submit_retry pane=$(printf '%q' "$pane") attempt=$attempt before_len=${#before_input} after_len=${#after_input} before_cursor=$(printf '%q' "$before_cursor") after_cursor=$(printf '%q' "$after_cursor")"
      wait_for_prompt_input_settled "$pane" "$prompt_prefix" "$submit_wait"
    fi
  done

  debug_notify "deliver:submit_unverified pane=$(printf '%q' "$pane") attempts=$attempts"
  sleep "$submit_wait"
  return 1
}

deliver_notification_to_pane() {
  local pane="$1"
  local payload="$2"
  local submit_keys="$3"
  local prompt_prefix="${4:-}"
  local pre_keys="${5:-}"
  local settle paste_submit_wait submit_wait no_prompt_ready_wait
  local interrupt_settle

  settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"
  paste_submit_wait="${ATMUX_SEND_PASTE_TO_SUBMIT_WAIT_SECONDS:-0.8}"
  submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.3}"
  no_prompt_ready_wait="${ATMUX_SEND_NO_PROMPT_READY_SECONDS:-0.6}"
  interrupt_settle="${ATMUX_SEND_INTERRUPT_SETTLE_SECONDS:-0.6}"

  debug_notify "deliver:start pane=$(printf '%q' "$pane") submit_keys=$(printf '%q' "$submit_keys") pre_keys=$(printf '%q' "$pre_keys") $(payload_debug_summary "$payload")"

  if [[ -n "$pre_keys" ]]; then
    local pk
    for pk in $pre_keys; do
      tmux send-keys -t "$pane" "$pk" >/dev/null 2>&1 || {
        debug_notify "deliver:pre_key_failed pane=$(printf '%q' "$pane") key=$(printf '%q' "$pk")"
        return 1
      }
    done
    sleep "$interrupt_settle"
    debug_notify "deliver:pre_keys_sent pane=$(printf '%q' "$pane") settle=$interrupt_settle"
  elif [[ -z "$prompt_prefix" ]]; then
    sleep "$no_prompt_ready_wait"
  fi

  tmux send-keys -t "$pane" C-u >/dev/null 2>&1 || {
    debug_notify "deliver:clear_failed pane=$(printf '%q' "$pane")"
    return 1
  }
  sleep "$settle"
  tmux send-keys -t "$pane" -l "$payload" >/dev/null 2>&1 || {
    debug_notify "deliver:payload_failed pane=$(printf '%q' "$pane")"
    return 1
  }
  wait_for_prompt_input_settled "$pane" "$prompt_prefix" "$paste_submit_wait"

  # Large payloads can fool wait_for_prompt_input_settled: tmux flushes the
  # paste in chunks, so the captured input briefly looks stable while more
  # bytes are still in flight, and the adapter (claude/codex) needs extra
  # time to ingest the full input before submit. Add a length-scaled pause
  # before pressing Enter. Tunable via ATMUX_SEND_PASTE_PER_KB_SECONDS
  # (default 0.05s/KB; capped via ATMUX_SEND_PASTE_BONUS_MAX_SECONDS at 5s).
  # Skipped for payloads under ATMUX_SEND_PASTE_BONUS_MIN_BYTES (default 1024).
  local payload_len=${#payload}
  local bonus_min="${ATMUX_SEND_PASTE_BONUS_MIN_BYTES:-1024}"
  local per_kb="${ATMUX_SEND_PASTE_PER_KB_SECONDS:-0.05}"
  local bonus_max="${ATMUX_SEND_PASTE_BONUS_MAX_SECONDS:-5}"
  [[ "$bonus_min" =~ ^[0-9]+$ ]] || bonus_min=1024
  if (( payload_len >= bonus_min )); then
    local bonus
    bonus="$(awk -v len="$payload_len" -v rate="$per_kb" -v cap="$bonus_max" '
      BEGIN {
        b = (len / 1024) * rate
        if (b > cap) b = cap
        if (b < 0) b = 0
        printf "%.3f", b
      }')"
    if [[ -n "$bonus" && "$bonus" != "0.000" ]]; then
      debug_notify "deliver:length_bonus pane=$(printf '%q' "$pane") payload_len=$payload_len bonus=${bonus}s per_kb=${per_kb}s cap=${bonus_max}s"
      sleep "$bonus"
    fi
  fi

  submit_notification_input "$pane" "$prompt_prefix" "$submit_keys" "$submit_wait" || return 1
  debug_notify "deliver:done pane=$(printf '%q' "$pane")"
  return 0
}

next_notification_queue_id() {
  local qdir="$1"
  local lock_dir="$qdir/seq.lock"
  local payload_dir="$qdir/payloads"
  local current="0"
  local next=1
  local item_dir item_base item_num

  mkdir -p "$qdir"
  while ! mkdir "$lock_dir" 2>/dev/null; do
    sleep 0.01
  done

  if [[ -f "$qdir/next_id" ]]; then
    current="$(tr -d '\r\n' < "$qdir/next_id" 2>/dev/null || printf '0')"
    [[ "$current" =~ ^[0-9]+$ ]] || current="0"
  fi

  if [[ -d "$payload_dir" ]]; then
    while IFS= read -r item_dir; do
      item_base="$(basename "$item_dir")"
      [[ "$item_base" =~ ^[0-9]+$ ]] || continue
      item_num="$(( 10#$item_base ))"
      if (( item_num > current )); then
        current="$item_num"
      fi
    done < <(find "$payload_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)
  fi

  next="$(( 10#$current + 1 ))"
  while [[ -e "$payload_dir/$(printf '%010d' "$next")" ]]; do
    next="$(( next + 1 ))"
  done

  printf '%s\n' "$next" > "$qdir/next_id"
  rmdir "$lock_dir" >/dev/null 2>&1 || true

  printf '%010d\n' "$next"
}

queue_notification_payload() {
  local pane="$1"
  local payload="$2"
  local submit_key_str="$3"
  local qdir payload_dir queue_id item_dir tmp_dir
  local pre_key_str="${ATMUX_NOTIFY_PRE_KEYS:-}"
  local bypass_idle="${ATMUX_NOTIFY_BYPASS_IDLE:-0}"

  qdir="$(notify_queue_dir "$pane")"
  payload_dir="$qdir/payloads"
  mkdir -p "$payload_dir"

  queue_id="$(next_notification_queue_id "$qdir")"
  item_dir="$payload_dir/$queue_id"
  tmp_dir="$payload_dir/.${queue_id}.tmp.$$"
  mkdir -p "$tmp_dir"
  write_field "$tmp_dir/payload" "$payload"
  write_field "$tmp_dir/submit_keys" "$submit_key_str"
  write_field "$tmp_dir/state" "queued"
  write_field "$tmp_dir/attempts" "0"
  write_field "$tmp_dir/created_at" "$(timestamp_utc)"
  if [[ -n "$pre_key_str" ]]; then
    write_field "$tmp_dir/pre_keys" "$pre_key_str"
  fi
  if [[ "$bypass_idle" == "1" ]]; then
    write_field "$tmp_dir/bypass_idle" "1"
  fi
  mv "$tmp_dir" "$item_dir"
  debug_notify "queue:enqueued pane=$(printf '%q' "$pane") qdir=$(printf '%q' "$qdir") queue_id=$(printf '%q' "$queue_id") submit_keys=$(printf '%q' "$submit_key_str") pre_keys=$(printf '%q' "$pre_key_str") bypass_idle=$bypass_idle $(payload_debug_summary "$payload")"
}

notification_item_attempts() {
  local item_dir="$1" attempts=""
  attempts="$(read_state_field "$item_dir/attempts")"
  [[ "$attempts" =~ ^[0-9]+$ ]] || attempts=0
  printf '%s\n' "$attempts"
}

notification_retry_delay_seconds() {
  local attempts="$1"
  local base="${ATMUX_NOTIFY_RETRY_BASE_SECONDS:-1}"
  local max="${ATMUX_NOTIFY_RETRY_MAX_SECONDS:-60}"
  [[ "$base" =~ ^[0-9]+$ ]] || base=1
  [[ "$max" =~ ^[0-9]+$ ]] || max=60
  (( base > 0 )) || base=1
  (( max >= base )) || max="$base"

  local delay="$base"
  local idx
  for (( idx=1; idx<attempts; idx++ )); do
    delay=$(( delay * 2 ))
    if (( delay >= max )); then
      delay="$max"
      break
    fi
  done
  printf '%s\n' "$delay"
}

notification_item_due() {
  local item_dir="$1" now next_attempt
  next_attempt="$(read_state_field "$item_dir/next_attempt_at")"
  [[ "$next_attempt" =~ ^[0-9]+$ ]] || return 0
  now="$(date +%s)"
  (( now >= next_attempt ))
}

mark_notification_attempt_failed() {
  local item_dir="$1"
  local attempts delay now
  attempts="$(notification_item_attempts "$item_dir")"
  attempts=$(( attempts + 1 ))
  delay="$(notification_retry_delay_seconds "$attempts")"
  now="$(date +%s)"
  write_field "$item_dir/state" "retrying"
  write_field "$item_dir/attempts" "$attempts"
  write_field "$item_dir/last_attempt_at" "$now"
  write_field "$item_dir/next_attempt_at" "$(( now + delay ))"
  write_field "$item_dir/last_error" "delivery_unverified"
}

mark_notification_delivered() {
  local item_dir="$1"
  write_field "$item_dir/state" "delivered"
  write_field "$item_dir/delivered_at" "$(timestamp_utc)"
}

notification_worker_pid_file() {
  local qdir="$1"
  printf '%s/worker.pid\n' "$qdir"
}

notification_wake_fifo() {
  local qdir="$1"
  printf '%s/wake.fifo\n' "$qdir"
}

notification_worker_running() {
  local qdir="$1"
  local pid=""

  if [[ -f "$(notification_worker_pid_file "$qdir")" ]]; then
    pid="$(tr -d '\r\n' < "$(notification_worker_pid_file "$qdir")" 2>/dev/null || true)"
  fi
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    return 0
  fi
  return 1
}

acquire_notification_worker_lock() {
  local qdir="$1"
  local lock_dir="$qdir/lock"
  local pid_file
  pid_file="$(notification_worker_pid_file "$qdir")"
  local pid=""

  if mkdir "$lock_dir" 2>/dev/null; then
    printf '%s\n' "$$" > "$pid_file"
    debug_notify "worker:lock_acquired qdir=$(printf '%q' "$qdir")"
    return 0
  fi

  if [[ -f "$pid_file" ]]; then
    pid="$(tr -d '\r\n' < "$pid_file" 2>/dev/null || true)"
  fi
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    debug_notify "worker:lock_busy qdir=$(printf '%q' "$qdir") existing_pid=$(printf '%q' "$pid")"
    return 1
  fi

  rm -rf "$lock_dir" "$pid_file"
  if mkdir "$lock_dir" 2>/dev/null; then
    printf '%s\n' "$$" > "$pid_file"
    debug_notify "worker:stale_lock_recovered qdir=$(printf '%q' "$qdir")"
    return 0
  fi
  return 1
}

cleanup_notification_worker() {
  local qdir="$1"
  local payload_dir="$qdir/payloads"

  rm -f "$(notification_wake_fifo "$qdir")"
  rm -rf "$qdir/lock" "$(notification_worker_pid_file "$qdir")"
  if rmdir "$payload_dir" >/dev/null 2>&1; then
    rm -f "$qdir/next_id"
    rmdir "$qdir" >/dev/null 2>&1 || true
  fi
}

open_notification_wake_fifo() {
  local qdir="$1"
  local fifo

  fifo="$(notification_wake_fifo "$qdir")"
  if [[ -e "$fifo" && ! -p "$fifo" ]]; then
    rm -f "$fifo"
  fi
  if [[ ! -p "$fifo" ]]; then
    mkfifo "$fifo" || return 1
  fi
}

signal_notification_worker() {
  local pane="$1"
  local qdir fifo

  qdir="$(notify_queue_dir "$pane")"
  fifo="$(notification_wake_fifo "$qdir")"
  [[ -p "$fifo" ]] || return 0

  { printf 'wake\n' > "$fifo"; } >/dev/null 2>&1 &
}

wait_for_notification_wake() {
  local qdir="$1"
  local timeout="$2"
  local fifo

  fifo="$(notification_wake_fifo "$qdir")"
  [[ -p "$fifo" ]] || return 0

  if [[ "$timeout" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    sleep "$timeout"
  fi
}

wait_for_notification_wake_fd() {
  local timeout="$1"
  read -r -t "$timeout" _ <&8 || true
}

serve_notification_queue() {
  local pane="$1"
  local source_root="$2"
  local qdir payload_dir item_dir payload submit_keys
  local prompt_prefix="" saved_input=""
  local batch_active=0
  local poll_interval="${ATMUX_NOTIFY_WORKER_POLL_SECONDS:-1}"
  local idle_timeout="${ATMUX_NOTIFY_WORKER_IDLE_TIMEOUT_SECONDS:-300}"
  local mode_poll_interval="${ATMUX_NOTIFY_WORKER_MODE_POLL_SECONDS:-0.2}"
  local last_activity
  local wake_timeout="${ATMUX_NOTIFY_WORKER_WAKE_TIMEOUT_SECONDS:-1}"
  local wake_fd_open=0
  local mode_hook_index="$(( ($$ + RANDOM) % 1000000 ))"
  local mode_hook_installed=0
  local pane_session="" pane_command="" bootstrap_state="" adapter_state=""
  local -a items=()

  qdir="$(notify_queue_dir "$pane")"
  payload_dir="$qdir/payloads"
  mkdir -p "$payload_dir"

  acquire_notification_worker_lock "$qdir" || return 0

  cleanup_worker_runtime() {
    if (( mode_hook_installed == 1 )) && pane_exists "$pane"; then
      tmux set-hook -p -t "$pane" -u "pane-mode-changed[$mode_hook_index]" >/dev/null 2>&1 || true
    fi
    exec 8>&- 8<&- || true
    cleanup_notification_worker "$qdir"
  }

  trap cleanup_worker_runtime EXIT
  debug_notify "worker:start pane=$(printf '%q' "$pane") qdir=$(printf '%q' "$qdir") source_root=$(printf '%q' "$source_root")"
  last_activity="$(date +%s)"
  if open_notification_wake_fifo "$qdir" && exec 8<>"$(notification_wake_fifo "$qdir")"; then
    wake_fd_open=1
    debug_notify "worker:wake_fifo_ready pane=$(printf '%q' "$pane") fifo=$(printf '%q' "$(notification_wake_fifo "$qdir")")"
    local wake_fifo_q
    printf -v wake_fifo_q '%q' "$(notification_wake_fifo "$qdir")"
    if tmux set-hook -p -t "$pane" "pane-mode-changed[$mode_hook_index]" "run-shell -b 'printf wake\\\\n > $wake_fifo_q'" >/dev/null 2>&1; then
      mode_hook_installed=1
      debug_notify "worker:mode_hook_ready pane=$(printf '%q' "$pane") hook_index=$mode_hook_index"
    fi
  else
    debug_notify "worker:wake_fifo_unavailable pane=$(printf '%q' "$pane") fifo=$(printf '%q' "$(notification_wake_fifo "$qdir")")"
  fi

  while true; do
    if ! pane_exists "$pane"; then
      debug_notify "worker:pane_gone pane=$(printf '%q' "$pane")"
      break
    fi

    items=()
    while IFS= read -r item_dir; do
      [[ -n "$item_dir" ]] || continue
      case "$(basename "$item_dir")" in
        .*) continue ;;
      esac
      items+=("$item_dir")
    done < <(find "$payload_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)

    if [[ ${#items[@]} -eq 0 ]]; then
      if (( batch_active == 1 )); then
        restore_prompt_input "$pane" "$prompt_prefix" "$saved_input"
        debug_notify "worker:restore pane=$(printf '%q' "$pane") saved_input_len=${#saved_input}"
        prompt_prefix=""
        saved_input=""
        batch_active=0
        last_activity="$(date +%s)"
        continue
      fi

      if [[ "$idle_timeout" =~ ^[0-9]+$ ]] && (( idle_timeout > 0 )); then
        local now
        now="$(date +%s)"
        if (( now - last_activity >= idle_timeout )); then
          debug_notify "worker:idle_timeout pane=$(printf '%q' "$pane") idle_timeout=$idle_timeout"
          break
        fi
      fi

      if (( wake_fd_open == 1 )); then
        wait_for_notification_wake_fd "$wake_timeout"
      elif [[ -p "$(notification_wake_fifo "$qdir")" ]]; then
        wait_for_notification_wake "$qdir" "$wake_timeout"
      else
        sleep "$poll_interval"
      fi
      continue
    fi

    if pane_notification_blocked "$pane"; then
      if (( wake_fd_open == 1 )); then
        wait_for_notification_wake_fd "$wake_timeout"
      else
        sleep "$mode_poll_interval"
      fi
      continue
    fi

    prompt_prefix="$(resolve_prompt_prefix_for_pane "$pane" "$source_root" 2>/dev/null || true)"
    pane_session="$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null || true)"
    pane_command="$(tmux display-message -t "$pane" -p '#{pane_current_command}' 2>/dev/null || true)"
    bootstrap_state=""
    adapter_state=""
    if [[ -n "$pane_session" ]]; then
      bootstrap_state="$(get_session_env "$pane_session" ATMUX_BOOTSTRAP_STATE)"
      adapter_state="$(get_session_env "$pane_session" ATMUX_ADAPTER)"
    fi
    if [[ "$adapter_state" == "auto" || ( "$bootstrap_state" == "pending" && -z "$prompt_prefix" ) ]]; then
      debug_notify "worker:bootstrap_pending pane=$(printf '%q' "$pane") session=$(printf '%q' "$pane_session") command=$(printf '%q' "$pane_command") adapter=$(printf '%q' "$adapter_state") bootstrap=$(printf '%q' "$bootstrap_state")"
      sleep "$mode_poll_interval"
      continue
    fi
    # If any due item has bypass_idle=1 (--steer / --interrupt), skip the
    # wait-for-pane-ready gate so the message goes through even mid-tool.
    local _has_bypass_due=0
    local _scan_item
    for _scan_item in "${items[@]}"; do
      [[ -d "$_scan_item" ]] || continue
      if ! notification_item_due "$_scan_item"; then
        continue
      fi
      if [[ -f "$_scan_item/bypass_idle" ]]; then
        _has_bypass_due=1
        break
      fi
    done
    if (( _has_bypass_due == 0 )) && [[ -n "$prompt_prefix" ]] && ! wait_for_pane_ready "$pane" "$source_root" "$prompt_prefix"; then
      debug_notify "worker:not_ready pane=$(printf '%q' "$pane") prompt_prefix=$(printf '%q' "$prompt_prefix")"
      sleep "$mode_poll_interval"
      continue
    fi

    if (( batch_active == 0 )); then
      if [[ -n "$prompt_prefix" ]]; then
        saved_input="$(extract_prompt_input "$pane" "$prompt_prefix")"
      else
        saved_input=""
      fi
      batch_active=1
      debug_notify "worker:prompt pane=$(printf '%q' "$pane") prompt_prefix=$(printf '%q' "$prompt_prefix") saved_input_len=${#saved_input}"
    fi
    last_activity="$(date +%s)"

    local due_item_count=0
    for item_dir in "${items[@]}"; do
      [[ -d "$item_dir" ]] || continue
      if ! notification_item_due "$item_dir"; then
        continue
      fi
      due_item_count=$((due_item_count + 1))
      if pane_notification_blocked "$pane"; then
        break
      fi
      prompt_prefix="$(resolve_prompt_prefix_for_pane "$pane" "$source_root" 2>/dev/null || true)"
      pane_session="$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null || true)"
      pane_command="$(tmux display-message -t "$pane" -p '#{pane_current_command}' 2>/dev/null || true)"
      bootstrap_state=""
      adapter_state=""
      if [[ -n "$pane_session" ]]; then
        bootstrap_state="$(get_session_env "$pane_session" ATMUX_BOOTSTRAP_STATE)"
        adapter_state="$(get_session_env "$pane_session" ATMUX_ADAPTER)"
      fi
      if [[ "$adapter_state" == "auto" || ( "$bootstrap_state" == "pending" && -z "$prompt_prefix" ) ]]; then
        debug_notify "worker:item_bootstrap_pending pane=$(printf '%q' "$pane") session=$(printf '%q' "$pane_session") command=$(printf '%q' "$pane_command") adapter=$(printf '%q' "$adapter_state") bootstrap=$(printf '%q' "$bootstrap_state")"
        break
      fi
      # Outer loop already ran wait_for_pane_ready when batch_active was set,
      # and submit_input_with_keys falls back to unverified delivery when the
      # prompt has scrolled out of view. Skipping a redundant 45s ready-poll
      # here keeps a long burst from stalling on every item once the cursor
      # rolls past the viewport.
      payload="$(cat "$item_dir/payload" 2>/dev/null || true)"
      submit_keys="$(cat "$item_dir/submit_keys" 2>/dev/null || printf 'Enter')"
      local pre_keys=""
      if [[ -f "$item_dir/pre_keys" ]]; then
        pre_keys="$(cat "$item_dir/pre_keys" 2>/dev/null || true)"
      fi
      debug_notify "worker:item pane=$(printf '%q' "$pane") item_dir=$(printf '%q' "$item_dir") submit_keys=$(printf '%q' "$submit_keys") pre_keys=$(printf '%q' "$pre_keys") $(payload_debug_summary "$payload")"
      if deliver_notification_to_pane "$pane" "$payload" "$submit_keys" "$prompt_prefix" "$pre_keys"; then
        mark_notification_delivered "$item_dir"
        rm -rf "$item_dir"
      else
        debug_notify "worker:item_failed pane=$(printf '%q' "$pane") item_dir=$(printf '%q' "$item_dir")"
        mark_notification_attempt_failed "$item_dir"
        if (( batch_active == 1 )); then
          restore_after_failed_delivery "$pane" "$prompt_prefix" "$saved_input"
          prompt_prefix=""
          saved_input=""
          batch_active=0
        fi
      fi
      last_activity="$(date +%s)"
    done

    if (( due_item_count == 0 )); then
      if (( batch_active == 1 )); then
        restore_prompt_input "$pane" "$prompt_prefix" "$saved_input"
        debug_notify "worker:restore_waiting_retry pane=$(printf '%q' "$pane") saved_input_len=${#saved_input}"
        prompt_prefix=""
        saved_input=""
        batch_active=0
        last_activity="$(date +%s)"
      fi
      if (( wake_fd_open == 1 )); then
        wait_for_notification_wake_fd "$wake_timeout"
      else
        sleep "$poll_interval"
      fi
    fi
  done

  trap - EXIT
  cleanup_worker_runtime
  debug_notify "worker:done pane=$(printf '%q' "$pane")"
}

ensure_notification_worker() {
  local pane="$1"
  local source_root="$2"
  local qdir
  local notify_script
  local attempt

  qdir="$(notify_queue_dir "$pane")"
  mkdir -p "$qdir/payloads"

  if notification_worker_running "$qdir"; then
    return 0
  fi

  notify_script="$(resolve_notify_script_path "$source_root")"

  # The queue worker MUST live in the recipient pane's session. The
  # worker is keyed to that pane (polls its queue and tmux send-keys
  # to it). When the recipient session is killed the worker has
  # nothing useful to do, so binding its lifetime to that session is
  # correct — kill-session cascade-kills the worker, no orphan.
  #
  # If we can't resolve the recipient's session (the pane id is bogus
  # or the session is already gone), we fail to spawn rather than
  # falling back to a nohup'd worker — that fallback would either
  # deliver to a dead pane (pointless) or accumulate as an orphan.
  local recipient_session=""
  recipient_session="$(tmux display-message -p -t "$pane" '#{session_name}' 2>/dev/null || true)"

  debug_notify "worker:spawn pane=$(printf '%q' "$pane") qdir=$(printf '%q' "$qdir") session=$(printf '%q' "${recipient_session:-<none>}")"

  if [[ -z "$recipient_session" ]] || ! tmux has-session -t "$recipient_session" 2>/dev/null; then
    debug_notify "worker:spawn_failed pane=$(printf '%q' "$pane") reason=no_recipient_session"
    return 1
  fi

  # Build a small launcher script (avoids quoting issues across tmux's
  # `sh -c` re-parse) and spawn it as a tmux window in the recipient's
  # session. `-a` appends after the current window so we never collide
  # with the adapter pane at index 0.
  mkdir -p "$qdir"
  local runner="$qdir/worker-runner.sh"
  {
    printf '#!/usr/bin/env bash\n'
    printf 'export ATMUX_HOME=%q\n' "$ATMUX_HOME"
    printf 'export ATMUX_SOURCE_ROOT=%q\n' "$source_root"
    printf 'export ATMUX_REAL_TMUX=%q\n' "${ATMUX_REAL_TMUX:-}"
    printf 'export ATMUX_ALLOW_REAL_TMUX=1\n'
    printf 'export ATMUX_DEBUG_NOTIFY=%q\n' "${ATMUX_DEBUG_NOTIFY:-0}"
    printf 'exec %q __serve-queue --pane %q --source-root %q\n' \
      "$notify_script" "$pane" "$source_root"
  } > "$runner"
  chmod +x "$runner"

  local window_name="notify-${pane#%}"
  if ! tmux new-window -a -d \
          -t "${recipient_session}:" \
          -n "$window_name" \
          "$runner" 2>/dev/null; then
    debug_notify "worker:spawn_failed pane=$(printf '%q' "$pane") reason=tmux_new_window_failed session=$(printf '%q' "$recipient_session")"
    return 1
  fi

  for (( attempt=0; attempt<20; attempt++ )); do
    if notification_worker_running "$qdir"; then
      return 0
    fi
    sleep 0.05
  done

  return 0
}

# Send a notification to a pane in the background. Delivery is serialized per
# pane so rapid sends cannot interleave or clobber restored input.
send_notification() {
  local pane="$1"
  local payload="$2"
  shift 2
  local submit_key_str="${*:-Enter}"
  [[ -n "$pane" ]] || {
    debug_notify "send_notification:missing_pane $(payload_debug_summary "$payload")"
    return 1
  }
  if ! pane_exists "$pane"; then
    debug_notify "send_notification:invalid_pane pane=$(printf '%q' "$pane") $(payload_debug_summary "$payload")"
    return 1
  fi

  local source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME:-$HOME/.atmux}/src/atmux}"
  local notify_script
  notify_script="$(resolve_notify_script_path "$source_root")"
  debug_notify "send_notification:start pane=$(printf '%q' "$pane") source_root=$(printf '%q' "$source_root") submit_keys=$(printf '%q' "$submit_key_str") $(payload_debug_summary "$payload")"

  queue_notification_payload "$pane" "$payload" "$submit_key_str" || return 1
  ensure_notification_worker "$pane" "$source_root"
  signal_notification_worker "$pane"
  debug_notify "send_notification:worker_ready pane=$(printf '%q' "$pane")"
}

# Unified notification builder.
# Usage: build_notification <type> <from> <cmd> [key=value ...]
# Output: <notification type="..." from="..." cmd="..." key="value" ...>text</notification>
build_notification() {
  local type="$1" from="$2" cmd="$3"
  shift 3
  local attrs=""
  local body=""
  local has_body=0
  local kv k v
  for kv in "$@"; do
    k="${kv%%=*}"
    v="${kv#*=}"
    if [[ "$k" == "text" ]]; then
      body="$v"
      has_body=1
      continue
    fi
    attrs+=" ${k}=\"$(xml_escape "$v")\""
  done
  local cmd_attr=""
  if [[ -n "$cmd" ]]; then
    cmd_attr=" cmd=\"$(xml_escape "$cmd")\""
  fi
  if [[ "$has_body" -eq 1 ]]; then
    printf '<notification type="%s" from="%s"%s%s>%s</notification>' \
      "$(xml_escape "$type")" \
      "$(xml_escape "$from")" \
      "$cmd_attr" \
      "$attrs" \
      "$(xml_escape "$body")"
  else
    # Self-closing tag with NO space before `/>`. cursor-agent treats
    # ` /<chars>` in its input box as a slash-command invocation; the
    # space + `/` of ` />` would arm a stray `/notification` slash
    # command and Enter would run that instead of submitting the
    # message. The XML spec accepts both `<x />` and `<x/>` so this
    # is purely a defensive tightening for adapters with sticky
    # slash-command parsers.
    printf '<notification type="%s" from="%s"%s%s/>' \
      "$(xml_escape "$type")" \
      "$(xml_escape "$from")" \
      "$cmd_attr" \
      "$attrs"
  fi
}

get_session_env() {
  local session="$1" key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

session_short_name() {
  local session="$1" repo="$2"
  local prefix="atmux-${repo}-"
  if [[ -n "$repo" && "$session" == "$prefix"* ]]; then
    printf '%s\n' "${session#"$prefix"}"
  else
    printf '%s\n' "$session"
  fi
}

resolve_manifest_path() {
  local adapter="$1"
  local source_root manifest_path

  source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"
  manifest_path="$source_root/adapter/$adapter/manifest.json"
  if [[ -f "$manifest_path" ]]; then
    printf '%s\n' "$manifest_path"
    return 0
  fi
  manifest_path="$ATMUX_HOME/adapters/$adapter/manifest.json"
  if [[ -f "$manifest_path" ]]; then
    printf '%s\n' "$manifest_path"
    return 0
  fi
  return 1
}

resolve_submit_keys() {
  local adapter="$1"
  local mode="${2:-steer}"
  local manifest_path compact raw_keys

  if ! manifest_path="$(resolve_manifest_path "$adapter")"; then
    printf 'Enter\n'
    return 0
  fi

  compact="$(tr -d '\n\r\t ' < "$manifest_path")"
  raw_keys="$(printf '%s' "$compact" | sed -n "s/.*\"${mode}\":\[\([^]]*\)\].*/\1/p")"
  if [[ -z "$raw_keys" ]]; then
    printf 'Enter\n'
    return 0
  fi

  printf '%s' "$raw_keys" | sed 's/"//g; s/,/\n/g'
}

# Like resolve_submit_keys, but emits nothing (and returns 1) when the
# manifest doesn't define the requested mode. Used by --interrupt to detect
# adapters that lack an abort key, instead of silently falling back to Enter.
resolve_submit_keys_strict() {
  local adapter="$1"
  local mode="${2:-steer}"
  local manifest_path compact raw_keys

  manifest_path="$(resolve_manifest_path "$adapter")" || return 1
  compact="$(tr -d '\n\r\t ' < "$manifest_path")"
  raw_keys="$(printf '%s' "$compact" | sed -n "s/.*\"${mode}\":\[\([^]]*\)\].*/\1/p")"
  [[ -n "$raw_keys" ]] || return 1
  printf '%s' "$raw_keys" | sed 's/"//g; s/,/\n/g'
}

timestamp_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

id() {
  local s
  s="$(head -c 12 /dev/urandom | base64 | tr '+/' '-_' | tr -d '=')"
  # Avoid IDs starting with '-' — they get interpreted as flags by
  # grep, rm, mv, find, and most other CLI tools, breaking any caller
  # that passes the id as the first positional argument.
  printf '%s\n' "${s/#-/x}"
}

repo_name_from_context() {
  local repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  normalize_name "$repo_name"
}

write_field() {
  local file="$1"
  local value="${2:-}"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" > "$file"
}

exec_root_for_repo() {
  local repo_name="$1"
  printf '%s/exec/%s\n' "$ATMUX_HOME" "$repo_name"
}

exec_dir_for_repo_pid() {
  local repo_name="$1"
  local pid="$2"
  printf '%s/%s\n' "$(exec_root_for_repo "$repo_name")" "$pid"
}

read_state_field() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    printf ''
    return 0
  fi
  tr -d '\r\n' <"$file" 2>/dev/null || printf ''
}

validate_exec_ownership() {
  local exec_dir="$1"
  local expect_pid="$2"
  local expect_repo="$3"
  local got_pid got_repo

  [[ -d "$exec_dir" ]] || return 1
  got_pid="$(read_state_field "$exec_dir/pid")"
  got_repo="$(read_state_field "$exec_dir/repo")"
  [[ -n "$got_pid" && "$got_pid" == "$expect_pid" ]] || return 1
  [[ -n "$got_repo" && "$got_repo" == "$expect_repo" ]] || return 1
  return 0
}

issue_root_for_repo() {
  local repo="$1"
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  printf '%s/issues/%s\n' "$atmux_home" "$repo"
}

issue_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

pull_request_root_for_repo() {
  local repo="$1"
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  printf '%s/pull-requests/%s\n' "$atmux_home" "$repo"
}

pull_request_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

notify_exec_watchers() {
  local exec_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$exec_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    signal_watcher_event_file "$f"
    pane="$(watcher_record_pane "$f")"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    send_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_issue_watchers() {
  local issue_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$issue_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    signal_watcher_event_file "$f"
    pane="$(watcher_record_pane "$f")"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    send_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_pull_request_watchers() {
  local pr_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$pr_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    signal_watcher_event_file "$f"
    pane="$(watcher_record_pane "$f")"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    send_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

watcher_record_pane() {
  local file="$1" raw=""
  raw="$(tr -d '\r\n' <"$file" 2>/dev/null || true)"
  printf '%s\n' "${raw%%|*}"
}

watcher_record_signal_path() {
  local file="$1" raw="" rest=""
  raw="$(tr -d '\r\n' <"$file" 2>/dev/null || true)"
  [[ "$raw" == *"|"* ]] || return 0
  rest="${raw#*|}"
  printf '%s\n' "${rest%%|*}"
}

signal_watcher_event_file() {
  local file="$1" signal_path=""
  signal_path="$(watcher_record_signal_path "$file")"
  [[ -n "$signal_path" && -p "$signal_path" ]] || return 0

  printf 'event\n' > "$signal_path" 2>/dev/null || true
}

signal_exec_watchers() {
  local exec_dir="$1"
  local wdir="$exec_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f
  while IFS= read -r f; do
    [[ -n "$f" && -f "$f" ]] || continue
    signal_watcher_event_file "$f"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

# Convenience wrapper — callers pass submit_keys as an array.
send_payload_to_pane() {
  local target="$1"
  local payload="$2"
  shift 2
  local submit_keys=("$@")
  [[ ${#submit_keys[@]} -gt 0 ]] || submit_keys=("Enter")
  send_notification "$target" "$payload" "${submit_keys[@]}"
}

notify_cli_usage() {
  cat <<'USAGE'
Usage:
  atmux notify --pane <tmux-pane-id> --xml <payload> [--interrupt]

Description:
  Send an ATMUX XML notification to a tmux pane. Without --interrupt, the
  notification is queued and delivered when the pane's adapter is at its
  idle prompt.
  --interrupt  Hard interrupt: send the adapter's abort key sequence
               (`submit_keys.interrupt` in the manifest) before the message,
               then submit. Resolves adapter from the pane's session, or from
               --session if provided. Use sparingly — this aborts whatever
               the agent is doing.

Examples:
  atmux notify --pane %12 --xml '<notification type="test" from="manual" cmd="atmux message read abc" />'
  atmux notify --pane %12 --xml '<notification type="abort" from="mgr" />' --interrupt
USAGE
}

notify_cli_main() {
  local pane=""
  local xml_payload=""
  local interrupt=0
  local session=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane)
        pane="${2:-}"
        shift 2
        ;;
      --xml)
        xml_payload="${2:-}"
        shift 2
        ;;
      --interrupt)
        interrupt=1
        shift
        ;;
      --session)
        session="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        notify_cli_usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        notify_cli_usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
  [[ -n "$xml_payload" ]] || { echo "missing --xml" >&2; exit 2; }

  local submit_keys=()
  local pre_keys_str=""
  local bypass=""

  if (( interrupt == 1 )); then
    local adapter="" resolve_session="$session"
    if [[ -z "$resolve_session" && -n "$pane" ]]; then
      resolve_session="$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null || true)"
    fi
    if [[ -n "$resolve_session" ]]; then
      adapter="$(get_session_env "$resolve_session" ATMUX_ADAPTER)"
    fi
    if [[ -n "$adapter" ]]; then
      while IFS= read -r __qk_line; do
        submit_keys+=("$__qk_line")
      done < <(resolve_submit_keys "$adapter" "steer")
      while IFS= read -r __pk_line; do
        [[ -n "$__pk_line" ]] || continue
        if [[ -n "$pre_keys_str" ]]; then
          pre_keys_str+=" "
        fi
        pre_keys_str+="$__pk_line"
      done < <(resolve_submit_keys_strict "$adapter" "interrupt" || true)
    fi
    bypass=1
  fi

  ATMUX_NOTIFY_PRE_KEYS="$pre_keys_str" \
  ATMUX_NOTIFY_BYPASS_IDLE="$bypass" \
    send_notification "$pane" "$xml_payload" ${submit_keys[@]+"${submit_keys[@]}"}
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail
  ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
  case "${1:-}" in
    __drain-queue|__serve-queue)
      shift
      pane=""
      source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --pane)
            pane="${2:-}"
            shift 2
            ;;
          --source-root)
            source_root="${2:-}"
            shift 2
            ;;
          *)
            echo "unknown flag: $1" >&2
            exit 2
            ;;
        esac
      done
      [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
      serve_notification_queue "$pane" "$source_root"
      ;;
    build)
      shift
      build_notification "$@"
      ;;
    --pane|--xml|-h|--help|help|"")
      notify_cli_main "$@"
      ;;
    *)
      notify_cli_main "$@"
      ;;
  esac
fi
