#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(amux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  amux exec [--] <command> [args...]

Description:
  Execute a command with passthrough stdio and unchanged exit behavior.
  After the command exits or is interrupted, send an AMUX notification back
  to the current agent pane with the exit code.

Examples:
  amux exec sleep 30
  amux exec -- make test
  amux exec -- bash -lc 'sleep 30'
USAGE
}

record_exec_start() {
  local pid="$1"
  local repo_name="$2"
  local command_text="$3"
  local started_at="$4"
  exec_dir="$(exec_dir_for_repo_pid "$repo_name" "$pid")"
  mkdir -p "$exec_dir"
  write_field "$exec_dir/pid" "$pid"
  write_field "$exec_dir/repo" "$repo_name"
  write_field "$exec_dir/command" "$command_text"
  write_field "$exec_dir/started_at" "$started_at"
  write_field "$exec_dir/session_name" "${AMUX_SESSION_NAME:-}"
  write_field "$exec_dir/agent_name" "${AMUX_AGENT_NAME:-}"
  write_field "$exec_dir/state" "running"
}

record_exec_finish() {
  local finished_at="$1"
  local exit_code="$2"
  [[ -n "${exec_dir:-}" ]] || return 0
  write_field "$exec_dir/finished_at" "$finished_at"
  write_field "$exec_dir/exit_code" "$exit_code"
  write_field "$exec_dir/state" "exited"
}

terminate_child_with_signal() {
  local signal="$1"
  if [[ -n "${child_pid:-}" ]]; then
    kill "-$signal" "$child_pid" >/dev/null 2>&1 || true
  fi
}

if [[ $# -eq 0 ]]; then
  usage
  exit 2
fi

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  --)
    shift
    ;;
esac

if [[ $# -eq 0 ]]; then
  echo "missing command" >&2
  exit 2
fi

cmd=( "$@" )
command_text="$(printf '%q ' "${cmd[@]}")"
command_text="${command_text% }"
notify_pane="$(current_pane)"
repo_name="$(repo_name_from_context)"

child_pid=""
trap 'terminate_child_with_signal INT' INT
trap 'terminate_child_with_signal TERM' TERM
trap 'terminate_child_with_signal HUP' HUP
trap 'terminate_child_with_signal QUIT' QUIT

"${cmd[@]}" &
child_pid=$!
exec_dir=""
record_exec_start "$child_pid" "$repo_name" "$command_text" "$(timestamp_utc)"

set +e
wait "$child_pid"
exit_code=$?
set -e

record_exec_finish "$(timestamp_utc)" "$exit_code"
notification_xml="$(build_notification_xml "$command_text" "$(timestamp_utc)" "$exit_code")"
queue_self_notification "$notify_pane" "$notification_xml"
notify_exec_watchers "$exec_dir" "$notify_pane" "$notification_xml"

exit "$exit_code"
