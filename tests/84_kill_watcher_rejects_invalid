#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

set +e
out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" kill --watcher bogus 2>&1)"
rc=$?
set -e
[[ "$rc" -eq 2 ]] || { echo "expected exit 2 for invalid watcher id, got $rc: $out" >&2; exit 1; }

set +e
out2="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" kill --watcher foo:bar:baz 2>&1)"
rc2=$?
set -e
[[ "$rc2" -eq 2 ]] || { echo "expected exit 2 for unsupported watcher type, got $rc2: $out2" >&2; exit 1; }

echo "ok: kill --watcher rejects invalid ids"
