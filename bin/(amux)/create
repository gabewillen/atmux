#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"

usage() {
  cat <<'USAGE'
Usage:
  amux create --agent <name> --role <role> --intelligence <0-100> [--team <team>] [--adapter <adapter>] [--task --description <desc> --todo <todo>...] [-- <adapter-args...>]
  amux create --team <name>
  amux create --issue --title <title> [--description <description>] [--todo <todo>...] [--repo <repo>]

Description:
  Unified create entrypoint for agents, teams, and issues.
  For agents, --team defaults to AMUX_TEAM when set (for example after `amux create --team <name>` in a tmux session).
USAGE
}

resolve_script() {
  local name="$1"
  if [[ -n "${AMUX_SOURCE_ROOT:-}" && -x "${AMUX_SOURCE_ROOT}/bin/amux/${name}" ]]; then
    printf '%s\n' "${AMUX_SOURCE_ROOT}/bin/amux/${name}"
    return 0
  fi

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "${repo_root}/bin/amux/${name}" ]]; then
      printf '%s\n' "${repo_root}/bin/amux/${name}"
      return 0
    fi
  fi

  if [[ -x "${AMUX_HOME}/src/amux/bin/amux/${name}" ]]; then
    printf '%s\n' "${AMUX_HOME}/src/amux/bin/amux/${name}"
    return 0
  fi

  if [[ -x "${AMUX_HOME}/bin/scripts/${name}" ]]; then
    printf '%s\n' "${AMUX_HOME}/bin/scripts/${name}"
    return 0
  fi

  return 1
}

mode=""
agent_name=""
agent_role=""
agent_team=""
agent_adapter=""
agent_intelligence=""
agent_task=0
agent_task_description=""
agent_todos=()
agent_forward=()

team_name=""

issue_mode=0
issue_title=""
issue_description=""
issue_todos=()
issue_repo=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      if [[ -n "$mode" && "$mode" != "agent" ]]; then
        echo "cannot combine --agent with --${mode}" >&2
        exit 2
      fi
      mode="agent"
      agent_name="${2:-}"
      shift 2
      ;;
    --team)
      if [[ -z "$mode" ]]; then
        mode="team"
        team_name="${2:-}"
        shift 2
      elif [[ "$mode" == "agent" ]]; then
        agent_team="${2:-}"
        shift 2
      else
        echo "cannot combine --team with --${mode}" >&2
        exit 2
      fi
      ;;
    --issue)
      if [[ -n "$mode" && "$mode" != "issue" ]]; then
        echo "cannot combine --issue with --${mode}" >&2
        exit 2
      fi
      mode="issue"
      issue_mode=1
      shift
      ;;
    --role)
      agent_role="${2:-}"
      shift 2
      ;;
    --adapter)
      agent_adapter="${2:-}"
      shift 2
      ;;
    --intelligence)
      agent_intelligence="${2:-}"
      shift 2
      ;;
    --task)
      agent_task=1
      shift
      ;;
    --description)
      if [[ "$mode" == "issue" ]]; then
        issue_description="${2:-}"
      else
        agent_task_description="${2:-}"
      fi
      shift 2
      ;;
    --todo|--todos)
      if [[ "$mode" == "issue" ]]; then
        issue_todos+=("${2:-}")
      else
        agent_todos+=("${2:-}")
      fi
      shift 2
      ;;
    --title)
      issue_title="${2:-}"
      shift 2
      ;;
    --repo)
      issue_repo="${2:-}"
      shift 2
      ;;
    --)
      shift
      agent_forward=("$@")
      break
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

case "$mode" in
  agent)
    if [[ -z "$agent_name" ]]; then
      echo "missing required flag: --agent <name>" >&2
      exit 2
    fi
    agent_script="$(resolve_script agent || true)"
    if [[ -z "$agent_script" ]]; then
      echo "agent subcommand script not found" >&2
      exit 127
    fi

    cmd=("$agent_script" _create --name "$agent_name")
    if [[ -n "$agent_role" ]]; then
      cmd+=(--role "$agent_role")
    fi
    if [[ -n "$agent_team" ]]; then
      cmd+=(--team "$agent_team")
    fi
    if [[ -n "$agent_adapter" ]]; then
      cmd+=(--adapter "$agent_adapter")
    fi
    if [[ -n "$agent_intelligence" ]]; then
      cmd+=(--intelligence "$agent_intelligence")
    fi
    if [[ "$agent_task" -eq 1 ]]; then
      cmd+=(--task)
    fi
    if [[ -n "$agent_task_description" ]]; then
      cmd+=(--description "$agent_task_description")
    fi
    if [[ "${#agent_todos[@]}" -gt 0 ]]; then
      todo=""
      for todo in "${agent_todos[@]}"; do
        cmd+=(--todo "$todo")
      done
    fi
    if [[ "${#agent_forward[@]}" -gt 0 ]]; then
      cmd+=(-- "${agent_forward[@]}")
    fi
    "${cmd[@]}"
    ;;
  team)
    if [[ -z "$team_name" ]]; then
      echo "missing required flag: --team <name>" >&2
      exit 2
    fi
    team_script="$(resolve_script team || true)"
    if [[ -z "$team_script" ]]; then
      echo "team subcommand script not found" >&2
      exit 127
    fi
    "$team_script" _create "$team_name"
    ;;
  issue)
    if [[ "$issue_mode" -ne 1 ]]; then
      echo "missing required flag: --issue" >&2
      exit 2
    fi
    if [[ -z "$issue_title" ]]; then
      echo "missing required flag: --title <title>" >&2
      exit 2
    fi

    issue_script="$(resolve_script issue || true)"
    if [[ -z "$issue_script" ]]; then
      echo "issue subcommand script not found" >&2
      exit 127
    fi

    final_description="$issue_description"
    if [[ "${#issue_todos[@]}" -gt 0 ]]; then
      if [[ -n "$final_description" ]]; then
        final_description+=$'\n\n'
      fi
      final_description+="Todos:"
      for todo in "${issue_todos[@]}"; do
        [[ -n "$todo" ]] || continue
        final_description+=$'\n'
        final_description+="- $todo"
      done
    fi

    cmd=("$issue_script" create --title "$issue_title")
    if [[ -n "$final_description" ]]; then
      cmd+=(--description "$final_description")
    fi
    if [[ -n "$issue_repo" ]]; then
      cmd+=(--repo "$issue_repo")
    fi
    "${cmd[@]}"
    ;;
  *)
    echo "missing mode: use one of --agent, --team, --issue" >&2
    usage >&2
    exit 2
    ;;
esac
