#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

eval "$("$SCRIPTS_DIR/setup")"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"" EXIT

if out="$(ATMUX_REPO="$REPO_NAME" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="$AGENT1_SESSION" \
  "$ATMUX_BIN" schedule --to receiver --once 1s --notification "hello" 2>&1)"; then
  echo "schedule unexpectedly allowed --to in notification mode" >&2
  printf '%s\n' "$out" >&2
  exit 1
fi

printf '%s\n' "$out" | grep -Fq -- "--to is not valid for schedule"

echo "ok: schedule rejects --to"
