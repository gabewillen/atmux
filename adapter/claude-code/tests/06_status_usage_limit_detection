#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"

command -v claude >/dev/null 2>&1 || { echo "claude command not found in PATH" >&2; exit 1; }

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-claude-test-home.XXXXXX")"
cleanup() {
  [[ -n "${session_name:-}" ]] && "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$atmux_home"
}
trap cleanup EXIT

start_cmd="ATMUX_HOME='$atmux_home' '$ADAPTER_DIR/scripts/start'"
setup_out="$("$SCRIPTS_DIR/setup" --command "$start_cmd" --wait-text 'Claude Code v')"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

tmux send-keys -t "$pane_id" C-u
sleep 0.2
tmux send-keys -t "$pane_id" -l '/status'
sleep 0.2
tmux send-keys -t "$pane_id" ENTER

for _ in $(seq 1 120); do
  snap="$(tmux capture-pane -p -t "$pane_id" -S -320 2>/dev/null | tr -d '\r' || true)"
  if printf '%s\n' "$snap" | grep -F 'Model:' >/dev/null 2>&1; then
    break
  fi
  sleep 0.2
done

status_out="$(ATMUX_HOME="$atmux_home" ATMUX_TARGET_PANE="$pane_id" "$ADAPTER_DIR/scripts/status")"

echo "$status_out" | grep -F '<status ' >/dev/null
echo "$status_out" | grep -F 'adapter="claude-code"' >/dev/null
echo "$status_out" | grep -F 'owner="agent"' >/dev/null
echo "$status_out" | grep -F 'state="idle"' >/dev/null

echo "PASS 06_status_usage_limit_detection"
