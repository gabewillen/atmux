#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"
# shellcheck source=bin/(atmux)/(internal)/reporter
source "$HERE/(internal)/reporter"

usage() {
  cat <<'USAGE'
Usage:
  atmux message read <id> [--repo <repo>]
  atmux message list [--unread]

Description:
  Read or list filesystem-backed messages.
  Messages are stored at: ~/.atmux/messages/<repo>/<id>/
USAGE
}

resolve_repo_name() {
  local explicit_repo="${1:-}"
  local repo=""
  if [[ -n "$explicit_repo" ]]; then
    repo="$explicit_repo"
  elif [[ -n "${ATMUX_REPO:-}" ]]; then
    repo="${ATMUX_REPO}"
  elif [[ -n "${TMUX:-}" ]]; then
    repo="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo="$(basename "$repo_root")"
    fi
  fi
  if [[ -z "$repo" ]]; then
    echo "unable to resolve repo; pass --repo <repo> or run inside a git repo" >&2
    exit 2
  fi
  normalize_name "$repo"
}

message_root_for_repo() {
  local repo="$1"
  printf '%s/messages/%s\n' "$ATMUX_HOME" "$repo"
}

current_session_name() {
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    printf '%s\n' "$ATMUX_SESSION_NAME"
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#S' 2>/dev/null || true
  fi
}

current_message_recipients() {
  local repo="$1"
  local session="" short=""
  local -a recipients=()

  if [[ -n "${ATMUX_AGENT_NAME:-}" ]]; then
    recipients+=("${ATMUX_AGENT_NAME}")
    recipients+=("atmux-${repo}-${ATMUX_AGENT_NAME}")
  fi

  session="$(current_session_name)"
  if [[ -n "$session" ]]; then
    recipients+=("$session")
    short="$(session_short_name "$session" "$repo")"
    if [[ -n "$short" ]]; then
      recipients+=("$short")
      recipients+=("atmux-${repo}-${short}")
    fi
  fi

  printf '%s\n' "${recipients[@]}" | awk 'NF && !seen[$0]++'
}

message_is_for_current_agent() {
  local to="$1"
  local repo="$2"
  local recipients_text candidate
  local any=1

  recipients_text="$(current_message_recipients "$repo")"

  # Iterate via here-string instead of `< <(...)`. Bash 3.2 (still shipped
  # by macOS) can SIGABRT cleaning up the producer when this function returns
  # early from inside a process-substitution loop.
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    any=0
    [[ "$to" == "$candidate" ]] && return 0
  done <<< "$recipients_text"

  # Outside an agent/session context, keep the old broad view.
  (( any == 1 )) && return 0
  return 1
}

read_message() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux message read <id> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(message_root_for_repo "$repo")"
  dir="$root/$id"

  if [[ ! -d "$dir" ]]; then
    echo "message not found: $id" >&2
    exit 1
  fi

  local from to body reply_required timestamp stopped
  from="$(cat "$dir/from" 2>/dev/null || true)"
  to="$(cat "$dir/to" 2>/dev/null || true)"
  body="$(cat "$dir/body" 2>/dev/null || true)"
  reply_required="$(cat "$dir/reply_required" 2>/dev/null || true)"
  timestamp="$(cat "$dir/timestamp" 2>/dev/null || true)"
  stopped="$(cat "$dir/stopped" 2>/dev/null || true)"

  if ! message_is_for_current_agent "$to" "$repo"; then
    echo "message not found: $id" >&2
    exit 1
  fi

  local stopped_attr=""
  [[ -n "$stopped" ]] && stopped_attr=" stopped=\"$(xml_escape "$stopped")\""

  printf '<message id="%s" from="%s" to="%s" reply_required="%s" timestamp="%s"%s>\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$from")" \
    "$(xml_escape "$to")" \
    "$(xml_escape "$reply_required")" \
    "$(xml_escape "$timestamp")" \
    "$stopped_attr"
  printf '  <body>%s</body>\n' "$body"
  printf '</message>\n'

  # Mark read exactly once (no notification to author — avoids agent loops)
  if [[ ! -f "$dir/read_at" ]]; then
    write_field "$dir/read_at" "$(timestamp_utc)"
  fi
}

list_messages() {
  local explicit_repo=""
  local unread_only=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      --unread)
        unread_only=1
        shift
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(message_root_for_repo "$repo")"

  report_open messages repo="$repo"
  if [[ -d "$root" ]]; then
    local dir id from to reply_required timestamp
    while IFS= read -r dir; do
      [[ -d "$dir" ]] || continue
      id="$(basename "$dir")"
      from="$(cat "$dir/from" 2>/dev/null || true)"
      to="$(cat "$dir/to" 2>/dev/null || true)"
      if ! message_is_for_current_agent "$to" "$repo"; then
        continue
      fi
      if [[ "$unread_only" -eq 1 && -f "$dir/read_at" ]]; then
        continue
      fi
      reply_required="$(cat "$dir/reply_required" 2>/dev/null || true)"
      timestamp="$(cat "$dir/timestamp" 2>/dev/null || true)"
      report_record message \
        id="$id" \
        from="$from" \
        to="$to" \
        reply_required="$reply_required" \
        timestamp="$timestamp"
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d | sort)
  fi
  report_close messages
}

sub="${1:-}"
shift || true

case "$sub" in
  read|get)
    read_message "$@"
    ;;
  list|ls)
    list_messages "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown message command: $sub" >&2
    exit 2
    ;;
esac
