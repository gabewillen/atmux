#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"

usage() {
  cat <<'USAGE'
Usage:
  amux session list
  amux session ls
  amux session start [--name <name>] [--adapter <adapter>] [-- <adapter-args...>]
  amux session attach <name|session>

Description:
  List amux sessions, start a session, or attach to an existing one.

Examples:
  amux session list
  amux session start
  amux session start --name planner
  amux session attach planner
  amux session start --adapter claude-code -- --dangerously-skip-permissions
USAGE
}

attach_or_switch() {
  local session="$1"
  if [[ ! -t 0 || ! -t 1 ]]; then
    printf '%s\n' "$session"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

get_session_env() {
  local session="$1"
  local key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

start_monitor_if_needed() {
  local repo_root="$1"
  local session="$2"
  local manager
  manager="$(get_session_env "$session" AMUX_MANAGER)"
  [[ -n "$manager" ]] || return 0

  local pid
  pid="$(get_session_env "$session" AMUX_MONITOR_PID)"
  if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
    return 0
  fi

  local log_file
  log_file="${TMPDIR:-/tmp}/amux-monitor-${session}.log"
  nohup "$repo_root/bin/scripts/session" _monitor "$session" >>"$log_file" 2>&1 </dev/null &
  local new_pid=$!
  tmux set-environment -t "$session" AMUX_MONITOR_PID "$new_pid"
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "amux session start must be run from a git repository" >&2
    exit 1
  fi
  repo_name="$(basename "$repo_root")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

collect_agent_help() {
  local runner="$1"
  local runner_cwd="${2:-}"
  local out=""
  local cmd
  for cmd in agent manager env; do
    local cmd_out=""
    if [[ -n "$runner_cwd" ]]; then
      cmd_out="$(cd "$runner_cwd" && "$runner" "$cmd" --help 2>/dev/null || true)"
    else
      cmd_out="$("$runner" "$cmd" --help 2>/dev/null || true)"
    fi
    if [[ -n "$cmd_out" ]] && printf '%s\n' "$cmd_out" | grep -Eq "^  amux ${cmd}( |$)"; then
      out+=$'## '"$cmd"$'\n'
      out+="$cmd_out"$'\n\n'
    fi
  done
  printf '%s' "$out"
}

render_managed_block() {
  local repo_root="$1"
  local role_name="${AMUX_ROLE:-}"
  local repo_value="${AMUX_REPO:-}"
  local manager_value="${AMUX_MANAGER:-}"
  local amux_runner=""
  local amux_help=""
  local source_root="${AMUX_SOURCE_ROOT:-}"

  if [[ -n "$source_root" && -x "$source_root/bin/amux" ]]; then
    amux_runner="$source_root/bin/amux"
  elif [[ -x "$repo_root/bin/amux" ]]; then
    amux_runner="$repo_root/bin/amux"
  elif command -v amux >/dev/null 2>&1; then
    amux_runner="amux"
  fi

  if [[ -n "$amux_runner" ]]; then
    if [[ -n "$source_root" && -d "$source_root" ]]; then
      amux_help="$(collect_agent_help "$amux_runner" "$source_root")"
    else
      amux_help="$(collect_agent_help "$amux_runner")"
    fi
  fi

  {
    echo "<!-- AMUX:BEGIN -->"
    if [[ -n "$role_name" ]]; then
      echo "# Role"
      echo "- ROLE: $role_name"
      echo
    fi
    echo "# Amux Env"
    echo "AMUX_REPO=${repo_value}"
    echo "AMUX_MANAGER=${manager_value}"
    echo
    echo "# Amux Help"
    if [[ -n "$amux_help" ]]; then
      printf '%s\n' "$amux_help"
    fi
    echo "<!-- AMUX:END -->"
  }
}

inject_control_file() {
  local repo_root="$1"
  local adapter="${AMUX_ADAPTER:-codex}"
  local adapter_cmd="$repo_root/adapter/$adapter/cmd"

  [[ -x "$adapter_cmd" ]] || return 0

  local control_file
  control_file="$("$adapter_cmd" control-file 2>/dev/null || true)"
  [[ -n "$control_file" ]] || return 0

  local target_file="$repo_root/$control_file"
  [[ -f "$target_file" ]] || : > "$target_file"

  local tmp_base managed_file stripped_file
  tmp_base="${TMPDIR:-/tmp}/amux-control-$RANDOM-$$"
  managed_file="${tmp_base}.managed"
  stripped_file="${tmp_base}.stripped"

  render_managed_block "$repo_root" > "$managed_file"

  if grep -Fq '<!-- AMUX:BEGIN -->' "$target_file" 2>/dev/null; then
    awk '
      BEGIN { in_block=0 }
      /<!-- AMUX:BEGIN -->/ { in_block=1; next }
      /<!-- AMUX:END -->/ { in_block=0; next }
      in_block==0 { print }
    ' "$target_file" > "$stripped_file"
  else
    awk '
      /^# Default Rules$/ { exit }
      /^# Amux Help$/ { exit }
      { print }
    ' "$target_file" > "$stripped_file"
  fi

  {
    cat "$stripped_file"
    if [[ -s "$stripped_file" ]]; then
      echo
    fi
    cat "$managed_file"
    echo
  } > "$target_file"

  rm -f "$managed_file" "$stripped_file"
}

run_adapter() {
  local adapter="codex"
  local -a adapter_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --adapter)
        adapter="${2:-}"
        shift 2
        ;;
      --)
        shift
        adapter_args=("$@")
        break
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  export AMUX_ADAPTER="$adapter"

  # Ensure source-root amux commands win over stale worktree copies.
  if [[ -z "${AMUX_SOURCE_ROOT:-}" ]]; then
    AMUX_SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
    export AMUX_SOURCE_ROOT
  fi
  if [[ -d "$AMUX_SOURCE_ROOT/bin" ]]; then
    export PATH="$AMUX_SOURCE_ROOT/bin:$(pwd)/bin:$PATH"
  else
    export PATH="$(pwd)/bin:$PATH"
  fi

  # tmux session env is authoritative; current shell env may be stale/missing.
  local current_session=""
  if [[ -n "${TMUX:-}" ]]; then
    current_session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$current_session" ]]; then
    while IFS= read -r line; do
      [[ "$line" == AMUX_*=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      export "$key=$value"
    done < <(tmux show-environment -t "$current_session" 2>/dev/null || true)
  fi

  local adapter_cmd="$(pwd)/adapter/$adapter/cmd"
  if [[ ! -x "$adapter_cmd" ]]; then
    echo "adapter start not found: $adapter_cmd" >&2
    exit 1
  fi

  inject_control_file "$(pwd)"

  local rc=0
  if ((${#adapter_args[@]})); then
    "$adapter_cmd" start "${adapter_args[@]}" || rc=$?
  else
    "$adapter_cmd" start || rc=$?
  fi

  local session_name="${AMUX_SESSION_NAME:-}"
  if [[ -z "$session_name" && -n "${TMUX:-}" ]]; then
    session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$session_name" ]] && tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
  fi
  exit "$rc"
}

start_session() {
  local name=""
  local adapter="codex"
  local name_explicit=0
  local -a forward_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name="${2:-}"
        name_explicit=1
        shift 2
        ;;
      --adapter)
        adapter="${2:-}"
        shift 2
        ;;
      --)
        shift
        forward_args=("$@")
        break
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  if [[ "$name_explicit" -eq 0 ]]; then
    local n
    n="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | awk -v p="^amux-"$repo_name"-agent-[0-9]+$" '$0 ~ p { c++ } END { print c+0 }')"
    name="agent-$n"
    while tmux has-session -t "amux-${repo_name}-${name}" 2>/dev/null; do
      n=$((n + 1))
      name="agent-$n"
    done
  fi

  local session="amux-${repo_name}-${name}"
  local worktree="$AMUX_HOME/agents/${repo_name}-${name}"
  local branch="amux-${repo_name}-${name}"

  if tmux has-session -t "$session" 2>/dev/null; then
    local existing_adapter existing_worktree existing_source_root existing_manager
    existing_adapter="$(tmux show-environment -t "$session" AMUX_ADAPTER 2>/dev/null | sed -n 's/^AMUX_ADAPTER=//p' || true)"
    existing_worktree="$(tmux show-environment -t "$session" AMUX_WORKTREE 2>/dev/null | sed -n 's/^AMUX_WORKTREE=//p' || true)"
    existing_source_root="$(tmux show-environment -t "$session" AMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^AMUX_SOURCE_ROOT=//p' || true)"
    existing_manager="$(tmux show-environment -t "$session" AMUX_MANAGER 2>/dev/null | sed -n 's/^AMUX_MANAGER=//p' || true)"
    if [[ -n "$existing_adapter" ]]; then
      export AMUX_ADAPTER="$existing_adapter"
    else
      export AMUX_ADAPTER="$adapter"
    fi
    export AMUX_REPO="$repo_name"
    export AMUX_MANAGER="$existing_manager"
    if [[ -n "$existing_source_root" && -d "$existing_source_root" ]]; then
      export AMUX_SOURCE_ROOT="$existing_source_root"
    else
      export AMUX_SOURCE_ROOT="$repo_root"
    fi
    if [[ -n "$existing_worktree" && -d "$existing_worktree" ]]; then
      inject_control_file "$existing_worktree"
    else
      inject_control_file "$repo_root"
    fi
    start_monitor_if_needed "$repo_root" "$session"
    attach_or_switch "$session"
    return
  fi

  mkdir -p "$AMUX_HOME/agents"

  if [[ -e "$worktree" ]]; then
    if ! git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo "path exists and is not a git worktree: $worktree" >&2
      exit 1
    fi
  else
    worktree_err="$(
      git -C "$repo_root" worktree add -B "$branch" "$worktree" HEAD 2>&1
    )" || {
      if printf '%s\n' "$worktree_err" | grep -Eq 'cannot lock ref|Operation not permitted|Permission denied'; then
        echo "branch creation failed; retrying detached worktree for $worktree" >&2
        git -C "$repo_root" worktree add "$worktree" HEAD >/dev/null
      else
        printf '%s\n' "$worktree_err" >&2
        exit 1
      fi
    }
  fi

  local session_id
  session_id="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 12 || true)"
  if [[ -z "$session_id" ]]; then
    session_id="$(date +%s)-$$"
  fi

  tmux new-session -d -s "$session" -n "$session" -c "$worktree"
  tmux set-environment -t "$session" AMUX_REPO "$repo_name"
  tmux set-environment -t "$session" AMUX_SESSION_ID "$session_id"
  tmux set-environment -t "$session" AMUX_SESSION_NAME "$session"
  tmux set-environment -t "$session" AMUX_WORKTREE "$worktree"
  tmux set-environment -t "$session" AMUX_SOURCE_ROOT "$repo_root"
  tmux set-environment -t "$session" AMUX_AGENT_NAME "$name"
  if [[ -n "${AMUX_MANAGER:-}" ]]; then
    tmux set-environment -t "$session" AMUX_MANAGER "$AMUX_MANAGER"
  fi

  local -a cmd=("$repo_root/bin/scripts/session" "_run-adapter" "--adapter" "$adapter")
  if ((${#forward_args[@]})); then
    cmd+=("--" "${forward_args[@]}")
  fi

  local launch
  printf -v launch '%q ' "${cmd[@]}"
  tmux send-keys -t "$session" "$launch" C-m
  start_monitor_if_needed "$repo_root" "$session"

  attach_or_switch "$session"
}

attach_session() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "usage: amux session attach <name|session>" >&2
    exit 2
  fi

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  local session
  if [[ "$target" == amux-* ]]; then
    session="$target"
  else
    session="amux-${repo_name}-${target}"
  fi

  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "session not found: $session" >&2
    exit 1
  fi

  local existing_adapter existing_worktree existing_source_root existing_repo existing_manager
  existing_adapter="$(tmux show-environment -t "$session" AMUX_ADAPTER 2>/dev/null | sed -n 's/^AMUX_ADAPTER=//p' || true)"
  existing_worktree="$(tmux show-environment -t "$session" AMUX_WORKTREE 2>/dev/null | sed -n 's/^AMUX_WORKTREE=//p' || true)"
  existing_source_root="$(tmux show-environment -t "$session" AMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^AMUX_SOURCE_ROOT=//p' || true)"
  existing_repo="$(tmux show-environment -t "$session" AMUX_REPO 2>/dev/null | sed -n 's/^AMUX_REPO=//p' || true)"
  existing_manager="$(tmux show-environment -t "$session" AMUX_MANAGER 2>/dev/null | sed -n 's/^AMUX_MANAGER=//p' || true)"
  if [[ -n "$existing_adapter" ]]; then
    export AMUX_ADAPTER="$existing_adapter"
  fi
  if [[ -n "$existing_repo" ]]; then
    export AMUX_REPO="$existing_repo"
  else
    export AMUX_REPO="$repo_name"
  fi
  export AMUX_MANAGER="$existing_manager"
  if [[ -n "$existing_source_root" && -d "$existing_source_root" ]]; then
    export AMUX_SOURCE_ROOT="$existing_source_root"
  else
    export AMUX_SOURCE_ROOT="$repo_root"
  fi
  if [[ -n "$existing_worktree" && -d "$existing_worktree" ]]; then
    inject_control_file "$existing_worktree"
  else
    inject_control_file "$repo_root"
  fi
  start_monitor_if_needed "$repo_root" "$session"

  attach_or_switch "$session"
}

monitor_session() {
  local session="${1:-}"
  if [[ -z "$session" ]]; then
    echo "usage: amux session _monitor <session>" >&2
    exit 2
  fi

  local interval idle_seconds
  interval="${AMUX_MONITOR_INTERVAL_SECONDS:-20}"
  idle_seconds="${AMUX_MONITOR_IDLE_SECONDS:-180}"

  local repo manager agent manager_session
  repo="$(get_session_env "$session" AMUX_REPO)"
  manager="$(get_session_env "$session" AMUX_MANAGER)"
  agent="$(get_session_env "$session" AMUX_AGENT_NAME)"
  [[ -n "$repo" && -n "$manager" && -n "$agent" ]] || exit 0
  manager_session="amux-${repo}-${manager}"

  local last_hash="" last_change_ts last_notice_ts
  last_change_ts="$(date +%s)"
  last_notice_ts=0

  while tmux has-session -t "$session" 2>/dev/null; do
    local pane
    pane="$(tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }')"
    if [[ -z "$pane" ]]; then
      sleep "$interval"
      continue
    fi

    local snap hash now idle_for
    snap="$(tmux capture-pane -p -t "$pane" -S -200 2>/dev/null | tr -d '\r' || true)"
    hash="$(printf '%s' "$snap" | shasum -a 1 | awk '{print $1}')"
    now="$(date +%s)"

    if [[ "$hash" != "$last_hash" ]]; then
      last_hash="$hash"
      last_change_ts="$now"
    fi

    idle_for=$((now - last_change_ts))
    if (( idle_for >= idle_seconds )) && (( now - last_notice_ts >= idle_seconds )); then
      if tmux has-session -t "$manager_session" 2>/dev/null; then
        local line body xml from
        line="$(printf '%s\n' "$snap" | awk 'NF { l=$0 } END { print l }')"
        line="${line//$'\n'/ }"
        from="$(xml_escape "$session")"
        body="$(xml_escape "agent=${agent} idle_seconds=${idle_for} last_line=${line}")"
        xml="<amux><message from=\"${from}\">${body}</message></amux>"
        tmux send-keys -t "$manager_session" "echo '$xml'" C-m
      fi
      last_notice_ts="$now"
    fi

    sleep "$interval"
  done
}

sub="${1:-}"
shift || true

case "$sub" in
  list|ls)
    tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '/^amux-/ { print }'
    ;;
  start)
    start_session "$@"
    ;;
  attach)
    attach_session "${1:-}"
    ;;
  _run-adapter)
    run_adapter "$@"
    ;;
  _monitor)
    monitor_session "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown session command: $sub" >&2
    exit 2
    ;;
esac
