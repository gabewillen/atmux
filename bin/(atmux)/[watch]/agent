#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/../notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux agent watch <name|session> [--idle <seconds>] [--timeout <seconds>]
                                   [--interval <seconds>] [--lines <n>]
                                   [--exec <cmd>] [--once]

Description:
  Continuously emit one notification per active→idle transition of the
  named agent. Same edge-triggered, repeat-by-default semantics as
  `atmux git watch` and `atmux path watch` — pass --once for single-shot.

  Stuck interactive prompts (e.g. "Enter to select" / "Esc to cancel")
  are always treated as idle.

  On each idle, emits a canonical notification XML to stdout:
    <notification type="agent-idle" from="<name>" reason="idle" stable_seconds="N"/>
  --exec <cmd> additionally pipes that XML to `bash -c <cmd>` (matches
  `atmux git watch` / `atmux path watch`).

  --once exits after the first emit (rc 0 = idle observed, 124 = timeout
  before idle).

  Defaults: --idle 30, --timeout 0 (no cap; --once falls back to 120),
  --interval 2, --lines 80.

Examples:
  atmux agent watch driver --idle 30 \
    --exec "atmux notify --pane %12 --xml -"
  atmux agent watch worker --idle 10 --timeout 60 --once
USAGE
}

resolve_agent_session() {
  local target="$1"
  local repo_name="$2"

  if tmux has-session -t "$target" 2>/dev/null; then
    printf '%s\n' "$target"
    return 0
  fi

  if [[ -n "$repo_name" ]]; then
    local candidate="atmux-${repo_name}-${target}"
    if tmux has-session -t "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  return 1
}

detect_stuck_prompt() {
  local recent="$1"
  if printf '%s\n' "$recent" | grep -Fq 'Enter to select' && \
     printf '%s\n' "$recent" | grep -Fq 'Esc to cancel'; then
    return 0
  fi
  return 1
}

# watch_via_status: status-script-driven idle wait. Polls the adapter's
# `scripts/status` every <interval> seconds; exits 0 once `state="idle"`
# (or "errored" / "usage-limit" — both are terminal "not actively
# working" states) has been observed continuously for <idle> seconds,
# 124 on timeout.
watch_via_status() {
  local pane="$1" status_script="$2"
  local idle_seconds="$3" timeout_sec="$4" interval="$5"

  local deadline now state status_xml first_idle_ts=0
  # timeout_sec=0 means "no timeout" — used with --repeat so the watcher
  # runs forever (until killed). Pick a far-future deadline so the
  # comparison below never trips.
  if (( timeout_sec == 0 )); then
    deadline=$(( $(date +%s) + 365 * 24 * 3600 ))
  else
    deadline=$(( $(date +%s) + timeout_sec ))
  fi

  while true; do
    now="$(date +%s)"

    status_xml="$(ATMUX_HOME="$ATMUX_HOME" \
      ATMUX_SOURCE_ROOT="${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}" \
      ATMUX_STATUS_PASSIVE=1 ATMUX_TARGET_PANE="$pane" \
      "$status_script" 2>/dev/null || true)"
    state="$(printf '%s' "$status_xml" | sed -n 's/.*state="\([^"]*\)".*/\1/p' | head -n1)"

    # Check idle BEFORE the deadline so callers using
    # `--idle 1 --timeout 1` (the idle-watch anti-spam re-arm gate)
    # observe idle on the same tick they hit the deadline. Reverse
    # ordering would always return 124 when timeout==idle.
    case "$state" in
      idle|errored|usage-limit)
        if (( first_idle_ts == 0 )); then
          first_idle_ts="$now"
        fi
        if (( now - first_idle_ts >= idle_seconds )); then
          return 0
        fi
        ;;
      *)
        first_idle_ts=0
        ;;
    esac

    if (( now >= deadline )); then
      return 124
    fi

    sleep "$interval"
  done
}

emit_idle_notification() {
  local agent="$1" idle_seconds="$2" exec_cmd="$3"
  local xml
  xml="$(printf '<notification type="agent-idle" from="%s" reason="idle" stable_seconds="%s"/>' \
    "$(xml_escape "$agent")" \
    "$(xml_escape "$idle_seconds")")"
  printf '%s\n' "$xml"
  if [[ -n "$exec_cmd" ]]; then
    printf '%s' "$xml" | bash -c "$exec_cmd" >/dev/null 2>&1 || true
  fi
}

# wait_for_active: block until the agent is NOT idle (status != idle/errored/
# usage-limit, or pane output changes). Used between --repeat emits to
# enforce edge-triggered semantics — one notification per active→idle cycle.
wait_for_active() {
  local pane="$1" status_script="$2" interval="$3"
  local snap_before snap_now state
  if [[ -n "$status_script" ]]; then
    while true; do
      state="$(ATMUX_HOME="$ATMUX_HOME" \
        ATMUX_SOURCE_ROOT="${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}" \
        ATMUX_STATUS_PASSIVE=1 ATMUX_TARGET_PANE="$pane" \
        "$status_script" 2>/dev/null | sed -n 's/.*state="\([^"]*\)".*/\1/p' | head -n1)"
      case "$state" in
        idle|errored|usage-limit) sleep "$interval" ;;
        *) return 0 ;;
      esac
    done
  fi
  snap_before="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
  while true; do
    sleep "$interval"
    snap_now="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
    [[ "$snap_now" != "$snap_before" ]] && return 0
  done
}

main() {
  local agent=""
  local idle_seconds="30"
  local timeout_sec=""
  local interval="2"
  local lines="80"
  local exec_cmd=""
  local once=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent)
        agent="${2:-}"
        shift 2
        ;;
      --idle)
        idle_seconds="${2:-}"
        shift 2
        ;;
      --timeout)
        timeout_sec="${2:-}"
        shift 2
        ;;
      --interval)
        interval="${2:-}"
        shift 2
        ;;
      --lines)
        lines="${2:-}"
        shift 2
        ;;
      --exec)
        exec_cmd="${2:-}"
        shift 2
        ;;
      --once)
        once=1
        shift
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$agent" ]] || { echo "missing --agent" >&2; exit 2; }

  # Default --timeout: 0 (no cap) in repeat mode, 120 in --once mode so
  # one-shot callers don't block forever on a never-idle agent.
  if [[ -z "$timeout_sec" ]]; then
    if (( once == 1 )); then
      timeout_sec="120"
    else
      timeout_sec="0"
    fi
  fi
  local repeat=$((1 - once))

  local repo_name session pane
  repo_name="$(repo_name_from_context)"
  session="$(resolve_agent_session "$agent" "$repo_name")"
  if [[ -z "$session" ]]; then
    echo "agent session not found: $agent" >&2
    exit 1
  fi

  pane="$(primary_pane_for_session "$session")"
  if [[ -z "$pane" ]]; then
    echo "no pane found for session: $session" >&2
    exit 1
  fi

  # Prefer the adapter's own status script when available — it reports
  # `state="idle|active|busy|..."` directly and is robust to TUI
  # animations (cursor-agent's footer ticks the context-window meter
  # and file-edit count even when reasoning is done, which makes the
  # byte-stability fallback below never satisfy `--idle`). Fall back
  # to byte-stability when the adapter doesn't ship a status script.
  local adapter status_script
  adapter="$(tmux show-environment -t "$session" ATMUX_ADAPTER 2>/dev/null | sed -n 's/^ATMUX_ADAPTER=//p' || true)"
  status_script=""
  if [[ -n "$adapter" ]]; then
    for candidate in \
      "${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}/adapter/$adapter/scripts/status" \
      "$ATMUX_HOME/adapters/$adapter/scripts/status"; do
      if [[ -x "$candidate" ]]; then
        status_script="$candidate"
        break
      fi
    done
  fi

  if [[ -n "$status_script" ]]; then
    while true; do
      local rc=0
      watch_via_status "$pane" "$status_script" "$idle_seconds" "$timeout_sec" "$interval" || rc=$?
      if (( rc != 0 )); then
        exit "$rc"
      fi
      emit_idle_notification "$agent" "$idle_seconds" "$exec_cmd"
      (( repeat == 1 )) || exit 0
      wait_for_active "$pane" "$status_script" "$interval"
    done
  fi

  local deadline last_change_ts snap recent
  if (( timeout_sec == 0 )); then
    deadline=$(( $(date +%s) + 365 * 24 * 3600 ))
  else
    deadline=$(( $(date +%s) + timeout_sec ))
  fi

  snap="$(tmux capture-pane -p -t "$pane" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
  recent="$(printf '%s\n' "$snap" | tail -n 30)"
  if detect_stuck_prompt "$recent"; then
    emit_idle_notification "$agent" "$idle_seconds" "$exec_cmd"
    (( repeat == 1 )) || exit 0
    # Repeat against a stuck prompt would loop instantly; sleep one cycle.
    sleep "$interval"
  fi

  local stream_dir="" output_fifo="" event_fifo="" bridge_pid="" stream_rc=0
  set +e
  {
    IFS= read -r stream_dir
    IFS= read -r output_fifo
    IFS= read -r event_fifo
    IFS= read -r bridge_pid
  } < <(start_pane_event_stream "$pane")
  stream_rc=$?
  set -e
  if [[ "$stream_rc" -ne 0 ]]; then
    echo "atmux agent watch: unable to attach event stream to pane $pane" >&2
    exit 1
  fi
  exec 8<>"$event_fifo"
  # Baseline "last change" at listen start so slow tmux/pipe-pane setup
  # cannot satisfy --idle before the first pane event is observed.
  last_change_ts="$(date +%s)"

  cleanup_stream() {
    exec 8>&- 8<&- || true
    stop_pane_event_stream "$pane" "$stream_dir" "$bridge_pid"
  }
  trap cleanup_stream EXIT INT TERM HUP

  while true; do
    local now idle_for next_deadline wait_for
    now="$(date +%s)"

    idle_for=$(( now - last_change_ts ))
    if (( idle_for >= idle_seconds )); then
      emit_idle_notification "$agent" "$idle_seconds" "$exec_cmd"
      (( repeat == 1 )) || exit 0
      # Re-arm: wait for the next pane change (active again), then loop
      # back into the idle wait. Blocks on the same event fifo.
      while read -r -t 1 _ <&8; do :; done   # drain
      read -r _ <&8 || true                  # block for next event
      last_change_ts="$(date +%s)"
      if (( timeout_sec == 0 )); then
        deadline=$(( last_change_ts + 365 * 24 * 3600 ))
      else
        deadline=$(( last_change_ts + timeout_sec ))
      fi
      continue
    fi

    if (( now >= deadline )); then
      exit 124
    fi

    next_deadline="$deadline"
    local idle_deadline=$(( last_change_ts + idle_seconds ))
    if (( idle_deadline < next_deadline )); then
      next_deadline="$idle_deadline"
    fi
    wait_for=$(( next_deadline - now ))
    (( wait_for > 0 )) || wait_for=1
    if ! read -r -t "$wait_for" _ <&8; then
      continue
    fi
    last_change_ts="$(date +%s)"
    snap="$(tmux capture-pane -p -t "$pane" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    recent="$(printf '%s\n' "$snap" | tail -n 30)"
    if detect_stuck_prompt "$recent"; then
      emit_idle_notification "$agent" "$idle_seconds" "$exec_cmd"
      (( repeat == 1 )) || exit 0
      # Repeat against a stuck prompt would loop instantly; sleep one
      # cycle so we don't busy-spin while the prompt persists.
      sleep "$interval"
      continue
    fi
  done
}

main "$@"
