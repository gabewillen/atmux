#!/usr/bin/env bash
set -euo pipefail
state_dir="${ATMUX_HOME:-$HOME/.atmux}/adapters/codex"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"
[[ -f "$state_file" ]] || printf 'MODEL=%s\nREASONING_LEVEL=%s\n' 'gpt-5.5' 'medium' > "$state_file"
# shellcheck disable=SC1090
source "$state_file"

normalize_model() {
  case "${1:-}" in
    gpt-5.5|gpt-5.4|gpt-5.3-codex|gpt-5.2-codex|gpt-5.1-codex-max|gpt-5.2|gpt-5.1-codex-mini) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

normalize_reasoning() {
  case "${1:-}" in
    extra_high|extra-high|extra\ high|extrahigh|xhigh) printf '%s\n' 'extra-high' ;;
    low|medium|high) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

case "${1:-}" in
  list) printf '%s\n' gpt-5.5 gpt-5.4 gpt-5.3-codex gpt-5.2-codex gpt-5.1-codex-max gpt-5.2 gpt-5.1-codex-mini ;;
  get) printf '%s\n' "$MODEL" ;;
  set)
    MODEL="$(normalize_model "${2:-}" || true)"
    [[ -n "$MODEL" ]] || { echo "missing/invalid model value" >&2; exit 2; }
    if [[ -n "${3:-}" ]]; then
      REASONING_LEVEL="$(normalize_reasoning "$3" || true)"
      [[ -n "$REASONING_LEVEL" ]] || { echo "invalid reasoning level value: $3" >&2; exit 2; }
    fi
    printf 'MODEL=%s\nREASONING_LEVEL=%s\n' "$MODEL" "$REASONING_LEVEL" > "$state_file"
    printf '%s\n' "$MODEL"
    ;;
  *) echo "usage: model list|get|set <value> [reasoning-level]" >&2; exit 2 ;;
esac
