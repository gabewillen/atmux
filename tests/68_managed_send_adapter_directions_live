#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -1600 2>/dev/null | tr -d '\r' || true)"
    if printf '%s' "$snap" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

wait_for_message_read() {
  local repo="$1"
  local message_id="$2"
  local timeout="${3:-20}"
  local deadline now path
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    path="$(find "$HOME/.atmux/messages/$repo" -type f -path "*/$message_id/read_at" 2>/dev/null | head -n1 || true)"
    [[ -n "$path" ]] && return 0
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

cleanup_adapter_session() {
  local adapter="$1"
  local session="$2"
  case "$adapter" in
    codex)
      "$REPO_ROOT/adapter/codex/tests/scripts/teardown" --session "$session" >/dev/null 2>&1 || true
      ;;
    claude-code)
      "$REPO_ROOT/adapter/claude-code/tests/scripts/teardown" --session "$session" >/dev/null 2>&1 || true
      ;;
    gemini)
      "$REPO_ROOT/adapter/gemini/tests/scripts/teardown" --session "$session" >/dev/null 2>&1 || true
      ;;
    cursor-agent)
      tmux kill-session -t "$session" >/dev/null 2>&1 || true
      ;;
  esac
}

start_adapter_session() {
  local adapter="$1"
  local label="$2"
  local wait_text="" setup_out="" start_cmd="" atmux_home="" session="" pane=""

  case "$adapter" in
    codex)
      setup_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 "$REPO_ROOT/adapter/codex/tests/scripts/setup")"
      ;;
    claude-code)
      atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-managed-claude.${label}.XXXXXX")"
      mkdir -p "$atmux_home/src" "$HOME/.atmux"
      ln -s "$REPO_ROOT" "$atmux_home/src/atmux"
      ln -s "$HOME/.atmux/messages" "$atmux_home/messages"
      start_cmd="ATMUX_HOME='$atmux_home' '$REPO_ROOT/adapter/claude-code/scripts/start'"
      setup_out="$("$REPO_ROOT/adapter/claude-code/tests/scripts/setup" --command "$start_cmd" --wait-text 'Claude Code v')"
      ;;
    gemini)
      atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-managed-gemini.${label}.XXXXXX")"
      mkdir -p "$atmux_home/src" "$HOME/.atmux"
      ln -s "$REPO_ROOT" "$atmux_home/src/atmux"
      ln -s "$HOME/.atmux/messages" "$atmux_home/messages"
      start_cmd="ATMUX_HOME='$atmux_home' '$REPO_ROOT/adapter/gemini/scripts/start'"
      setup_out="$("$REPO_ROOT/adapter/gemini/tests/scripts/setup" --command "$start_cmd" --wait-text 'Type your message')"
      ;;
    cursor-agent)
      atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-managed-cursor.${label}.XXXXXX")"
      mkdir -p "$atmux_home/src" "$HOME/.atmux"
      ln -s "$REPO_ROOT" "$atmux_home/src/atmux"
      ln -s "$HOME/.atmux/messages" "$atmux_home/messages"
      session="atmux-cursor-managed-${label}-$(date +%s)-$$"
      tmux kill-session -t "$session" >/dev/null 2>&1 || true
      tmux new-session -d -x 240 -y 60 -s "$session" -n "$session" -c "$REPO_ROOT" \
        "ATMUX_HOME='$atmux_home' '$REPO_ROOT/adapter/cursor-agent/scripts/start'"
      pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
      [[ -n "$pane" ]] || { echo "unable to resolve cursor pane id" >&2; exit 1; }
      if ! wait_for_text "$pane" 'Cursor Agent' 60; then
        tmux capture-pane -p -t "$pane" -S -220 >&2 || true
        echo "timed out waiting for Cursor Agent startup" >&2
        exit 1
      fi
      printf '%s\n' "$session|$pane|$atmux_home"
      return 0
      ;;
    *)
      echo "unknown adapter: $adapter" >&2
      exit 2
      ;;
  esac

  session="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n1)"
  pane="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n1)"
  [[ -n "$session" && -n "$pane" ]] || {
    echo "missing setup output for $adapter" >&2
    printf '%s\n' "$setup_out" >&2
    exit 1
  }
  printf '%s\n' "$session|$pane|$atmux_home"
}

TMP_DIRS=()
SESSIONS=()

cleanup() {
  local entry adapter session tmp_dir
  for entry in "${SESSIONS[@]:-}"; do
    adapter="${entry%%|*}"
    session="${entry#*|}"
    cleanup_adapter_session "$adapter" "$session"
  done
  for tmp_dir in "${TMP_DIRS[@]:-}"; do
    [[ -n "$tmp_dir" ]] || continue
    rm -rf "$tmp_dir"
  done
  rm -rf "$REPO_ROOT/.gemini"
}
trap cleanup EXIT

run_adapter_case() {
  local adapter="$1"
  local repo="managed-live-${adapter//[^A-Za-z0-9]/-}-${RANDOM}"
  local managed_info peer_info managed_session managed_pane managed_home peer_session peer_pane peer_home
  local token send_out message_id

  managed_info="$(start_adapter_session "$adapter" "managed")"
  peer_info="$(start_adapter_session "$adapter" "peer")"

  managed_session="${managed_info%%|*}"
  managed_pane="${managed_info#*|}"
  managed_pane="${managed_pane%%|*}"
  managed_home="${managed_info##*|}"
  peer_session="${peer_info%%|*}"
  peer_pane="${peer_info#*|}"
  peer_pane="${peer_pane%%|*}"
  peer_home="${peer_info##*|}"

  SESSIONS+=("$adapter|$managed_session" "$adapter|$peer_session")
  [[ -n "$managed_home" ]] && TMP_DIRS+=("$managed_home")
  [[ -n "$peer_home" ]] && TMP_DIRS+=("$peer_home")

  tmux set-environment -t "$managed_session" ATMUX_ADAPTER "$adapter"
  tmux set-environment -t "$managed_session" ATMUX_SESSION_NAME "$managed_session"
  tmux set-environment -t "$managed_session" ATMUX_REPO "$repo"
  tmux set-environment -t "$managed_session" ATMUX_MANAGER "boss"

  tmux set-environment -t "$peer_session" ATMUX_ADAPTER "$adapter"
  tmux set-environment -t "$peer_session" ATMUX_SESSION_NAME "$peer_session"
  tmux set-environment -t "$peer_session" ATMUX_REPO "$repo"

  token="peer-to-managed-${adapter}-${RANDOM}"
  send_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_REPO="$repo" ATMUX_AGENT_NAME="peer" ATMUX_SESSION_NAME="$peer_session" \
    "$ATMUX_BIN" send --to "$managed_session" "$token")"
  message_id="$(printf '%s\n' "$send_out" | sed -n 's/.*message_id="\([^"]*\)".*/\1/p')"
  [[ -n "$message_id" ]] || { echo "missing message_id for $adapter peer->managed" >&2; exit 1; }
  if ! wait_for_text "$managed_pane" '<notification type="message"' 20; then
    tmux capture-pane -p -t "$managed_pane" -S -220 >&2 || true
    echo "$adapter managed pane did not receive peer message notification" >&2
    exit 1
  fi
  if ! wait_for_message_read "$repo" "$message_id" 20; then
    tmux capture-pane -p -t "$managed_pane" -S -220 >&2 || true
    echo "$adapter managed pane did not read peer message" >&2
    exit 1
  fi

  token="managed-to-peer-${adapter}-${RANDOM}"
  send_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_REPO="$repo" ATMUX_AGENT_NAME="managed" ATMUX_SESSION_NAME="$managed_session" ATMUX_MANAGER="boss" \
    "$ATMUX_BIN" send --to "$peer_session" "$token")"
  message_id="$(printf '%s\n' "$send_out" | sed -n 's/.*message_id="\([^"]*\)".*/\1/p')"
  [[ -n "$message_id" ]] || { echo "missing message_id for $adapter managed->peer" >&2; exit 1; }
  if ! wait_for_text "$peer_pane" '<notification type="message"' 20; then
    tmux capture-pane -p -t "$peer_pane" -S -220 >&2 || true
    echo "$adapter peer pane did not receive managed message notification" >&2
    exit 1
  fi
  if ! wait_for_message_read "$repo" "$message_id" 20; then
    tmux capture-pane -p -t "$peer_pane" -S -220 >&2 || true
    echo "$adapter peer pane did not read managed message" >&2
    exit 1
  fi

  cleanup_adapter_session "$adapter" "$managed_session"
  cleanup_adapter_session "$adapter" "$peer_session"
}

run_adapter_case codex
run_adapter_case claude-code
run_adapter_case gemini
run_adapter_case cursor-agent

echo "ok: managed and unmanaged agents can exchange live adapter messages in both directions"
