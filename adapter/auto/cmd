#!/usr/bin/env bash
set -euo pipefail

root_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
scripts_dir="$root_dir/scripts"

sub="${1:-}"
shift || true

case "$sub" in
  select|status|start|control-file|prepare-prompt|model|reasoning-level)
    exec "$scripts_dir/$sub" "$@"
    ;;
  *)
    echo "usage: auto/cmd select|status|start|control-file|prepare-prompt|model|reasoning-level" >&2
    exit 2
    ;;
esac
