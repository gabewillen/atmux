#!/usr/bin/env bash
set -euo pipefail
state_dir="${ATMUX_HOME:-$HOME/.atmux}/adapters/opencode"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"
[[ -f "$state_file" ]] || printf 'MODEL=%s\nREASONING_LEVEL=%s\n' 'openai/gpt-5.5' 'medium' > "$state_file"
# shellcheck disable=SC1090
source "$state_file"

xml_escape() {
  local s="${1:-}"
  s="${s//&/&amp;}"
  s="${s//</&lt;}"
  s="${s//>/&gt;}"
  s="${s//\"/&quot;}"
  s="${s//\'/&apos;}"
  printf '%s\n' "$s"
}

# Map OpenCode --variant / JSON "variant" labels to atmux REASONING_LEVEL
# (inverse of scripts/start reasoning_to_variant).
variant_to_reasoning_level() {
  local raw v
  raw="${1:-}"
  [[ -n "$raw" ]] || return 1
  v="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"
  case "$v" in
    low) printf '%s\n' low ;;
    medium) printf '%s\n' medium ;;
    high) printf '%s\n' high ;;
    xhigh|xh|extra-high|extra_high|extrahigh|extra\ high)
      printf '%s\n' 'extra-high' ;;
    *) return 1 ;;
  esac
}

resolve_target() {
  if [[ -n "${ATMUX_TARGET_PANE:-}" ]]; then
    printf '%s\n' "$ATMUX_TARGET_PANE"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return
  fi
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    tmux list-panes -t "$ATMUX_SESSION_NAME" -F '#{pane_id}' 2>/dev/null | head -n 1
    return
  fi
  if [[ -n "${ATMUX_REPO:-}" && -n "${ATMUX_AGENT_NAME:-}" ]]; then
    sess="atmux-${ATMUX_REPO}-${ATMUX_AGENT_NAME}"
    tmux list-panes -t "$sess" -F '#{pane_id}' 2>/dev/null | head -n 1
    return
  fi
}

parse_model_and_reasoning() {
  local snapshot="$1"
  local line parsed_model parsed_variant compact lvl

  compact="$(printf '%s' "$snapshot" | tr -d '\n')"

  parsed_model="$(printf '%s\n' "$compact" | sed -n 's/.*"type":"init".*"model":"\([^"]*\)".*/\1/p')"
  if [[ -z "$parsed_model" ]]; then
    parsed_model="$(printf '%s\n' "$compact" | sed -n 's/.*"model":"\([^"]*\)".*/\1/p' | tail -n 1)"
  fi
  if [[ -n "$parsed_model" ]] && [[ "$parsed_model" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*/[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
    MODEL="$parsed_model"
  fi

  parsed_variant="$(printf '%s\n' "$compact" | sed -n 's/.*"type":"init".*"variant":"\([^"]*\)".*/\1/p')"
  if [[ -z "$parsed_variant" ]]; then
    parsed_variant="$(printf '%s\n' "$compact" | sed -n 's/.*"variant":"\([^"]*\)".*/\1/p' | tail -n 1)"
  fi
  if [[ -n "$parsed_variant" ]]; then
    lvl="$(variant_to_reasoning_level "$parsed_variant" || true)"
    if [[ -n "$lvl" ]]; then
      REASONING_LEVEL="$lvl"
    fi
  fi

  line="$(printf '%s\n' "$snapshot" | awk '/[Mm]odel:/ { l=$0 } END { print l }')"
  if [[ -n "$line" ]]; then
    parsed_model="$(printf '%s\n' "$line" | sed -nE 's/.*[Mm]odel:[[:space:]]*([^[:space:]]+).*/\1/p')"
    if [[ -n "$parsed_model" ]] && [[ "$parsed_model" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*/[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
      MODEL="$parsed_model"
    fi
  fi

  line="$(printf '%s\n' "$snapshot" | awk '/[Vv]ariant:/ { l=$0 } END { print l }')"
  if [[ -n "$line" ]]; then
    parsed_variant="$(printf '%s\n' "$line" | sed -nE 's/.*[Vv]ariant:[[:space:]]*([^[:space:]]+).*/\1/p')"
    if [[ -n "$parsed_variant" ]]; then
      lvl="$(variant_to_reasoning_level "$parsed_variant" || true)"
      if [[ -n "$lvl" ]]; then
        REASONING_LEVEL="$lvl"
      fi
    fi
  fi

  line="$(printf '%s\n' "$snapshot" | awk '/--variant[[:space:]]/ { l=$0 } END { print l }')"
  if [[ -n "$line" ]]; then
    parsed_variant="$(printf '%s\n' "$line" | sed -nE 's/.*--variant[[:space:]]+([^[:space:]]+).*/\1/p')"
    if [[ -n "$parsed_variant" ]]; then
      lvl="$(variant_to_reasoning_level "$parsed_variant" || true)"
      if [[ -n "$lvl" ]]; then
        REASONING_LEVEL="$lvl"
      fi
    fi
  fi

  line="$(printf '%s\n' "$snapshot" | awk '/--model[[:space:]]/ { l=$0 } END { print l }')"
  if [[ -n "$line" ]]; then
    parsed_model="$(printf '%s\n' "$line" | sed -nE 's/.*--model[[:space:]]+([^[:space:]]+).*/\1/p')"
    if [[ -n "$parsed_model" ]] && [[ "$parsed_model" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*/[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
      MODEL="$parsed_model"
    fi
  fi

  line="$(printf '%s\n' "$snapshot" | awk '/-m[[:space:]]/ { l=$0 } END { print l }')"
  if [[ -n "$line" ]]; then
    parsed_model="$(printf '%s\n' "$line" | sed -nE 's/.*-m[[:space:]]+([^[:space:]]+).*/\1/p')"
    if [[ -n "$parsed_model" ]] && [[ "$parsed_model" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*/[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
      MODEL="$parsed_model"
    fi
  fi
}

infer_state() {
  local snapshot="$1"

  if printf '%s\n' "$snapshot" | grep -Eqi \
    'usage.?limit|rate[-_ ]?limit(ed)?|too many requests|quota.*(exceeded|reached|exhausted)|insufficient.?credits|out of credits|credits.*(exhausted|depleted)|no credits (left|remaining)'; then
    printf '%s\n' 'usage-limit'
    return
  fi

  if printf '%s\n' "$snapshot" | grep -Eqi '"status":"success"|"type":"result".*"status":"success"'; then
    printf '%s\n' 'idle'
    return
  fi

  if printf '%s\n' "$snapshot" | grep -Eqi '"status":"error"|"type":"result".*"status":"error"'; then
    printf '%s\n' 'errored'
    return
  fi

  if printf '%s\n' "$snapshot" | grep -Eqi 'approv(e|ing)|running command|executing|thinking(\.\.\.|…)|working(\.\.\.|…)|generating'; then
    printf '%s\n' 'busy'
    return
  fi

  if [[ -n "$snapshot" ]]; then
    printf '%s\n' 'idle'
    return
  fi

  case "${ATMUX_STATE:-idle}" in
    idle|busy|errored|usage-limit) printf '%s\n' "${ATMUX_STATE:-idle}" ;;
    *) printf '%s\n' 'errored' ;;
  esac
}

owner="agent"

snapshot=""
target="$(resolve_target)"
if [[ -n "$target" ]]; then
  snapshot="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null | tr -d '\r' || true)"
  parse_model_and_reasoning "$snapshot" || true
fi

state="$(infer_state "$snapshot")"
printf 'MODEL=%s\nREASONING_LEVEL=%s\n' "$MODEL" "$REASONING_LEVEL" > "$state_file"

printf '<status adapter="%s" owner="%s" state="%s" model="%s" reasoning_level="%s" control_file="AGENTS.md" />\n' \
  "opencode" "$(xml_escape "$owner")" "$(xml_escape "$state")" "$(xml_escape "$MODEL")" "$(xml_escape "$REASONING_LEVEL")"
