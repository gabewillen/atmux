#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-8}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -300 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

pane_contains_text() {
  local target="$1"
  local needle="$2"
  local snap compact
  snap="$(tmux capture-pane -p -t "$target" -S -300 2>/dev/null || true)"
  compact="$(printf '%s' "$snap" | tr -d '\r\n')"
  printf '%s' "$compact" | grep -Fq "$needle"
}

eval "$("$SCRIPTS_DIR/setup")"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"" EXIT

sender_pane="$(tmux list-panes -t "$AGENT1_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$sender_pane" ]] || { echo "sender pane missing" >&2; exit 1; }

# Schedule returns immediately (detached by default)
out="$(ATMUX_REPO="$REPO_NAME" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="$AGENT1_SESSION" "$ATMUX_BIN" schedule --once 1s --notification "hello there")"
printf '%s\n' "$out" | grep -Fq '<schedule'
printf '%s\n' "$out" | grep -Fq 'kind="notification"'
printf '%s\n' "$out" | grep -Fq 'mode="once"'
printf '%s\n' "$out" | grep -Fq 'pid="'

if ! wait_for_text "$sender_pane" 'type="scheduled"' 15; then
  echo "scheduled notification not found in sender pane" >&2
  tmux capture-pane -p -t "$sender_pane" -S -120 >&2 || true
  exit 1
fi
if ! wait_for_text "$sender_pane" 'text="hello there"' 15; then
  echo "scheduled notification text not found in sender pane" >&2
  tmux capture-pane -p -t "$sender_pane" -S -120 >&2 || true
  exit 1
fi
sleep 2
if pane_contains_text "$sender_pane" 'type="exec"'; then
  echo "schedule notification should not emit redundant exec completion notification" >&2
  tmux capture-pane -p -t "$sender_pane" -S -120 >&2 || true
  exit 1
fi

sender_snap="$(tmux capture-pane -p -t "$sender_pane" -S -200 2>/dev/null | tr -d '\r' || true)"
if printf '%s\n' "$sender_snap" | grep -Fq 'hello\ there'; then
  echo "schedule exec notification still uses shell-escaped spacing" >&2
  printf '%s\n' "$sender_snap" >&2
  exit 1
fi

echo "ok: schedule --once notification delivered to self"
