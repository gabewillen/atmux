#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  amux capture --agent <name|session> [--lines <n>]
  amux capture --team <name|session> [--lines <n>]
  amux capture --all [--lines <n>]

Description:
  Capture tmux pane output for agents or team sessions.

Examples:
  amux capture --agent planner
  amux capture --agent amux-myrepo-planner --lines 300
  amux capture --team platform
  amux capture --team amux-myrepo-team-platform --lines 500
  amux capture --all --lines 200
USAGE
}

normalize_repo_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

repo_name_from_context() {
  local repo_name="${AMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment AMUX_REPO 2>/dev/null | sed -n 's/^AMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  if [[ -n "$repo_name" ]]; then
    repo_name="$(normalize_repo_name "$repo_name")"
  fi
  printf '%s\n' "$repo_name"
}

get_session_env() {
  local session="$1"
  local key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

session_short_name() {
  local session="$1"
  local repo_name="$2"
  local prefix="amux-${repo_name}-"
  if [[ -n "$repo_name" && "$session" == "$prefix"* ]]; then
    printf '%s\n' "${session#"$prefix"}"
  else
    printf '%s\n' "$session"
  fi
}

resolve_agent_session() {
  local target="$1"
  local repo_name="$2"
  local candidate=""

  if tmux has-session -t "$target" 2>/dev/null; then
    printf '%s\n' "$target"
    return 0
  fi

  if [[ -n "$repo_name" ]]; then
    candidate="amux-${repo_name}-${target}"
    if tmux has-session -t "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi

    if [[ "$target" == "${repo_name}-"* ]]; then
      candidate="amux-${target}"
      if tmux has-session -t "$candidate" 2>/dev/null; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  fi

  return 1
}

resolve_team_session() {
  local target="$1"
  local repo_name="$2"
  local candidate=""

  if tmux has-session -t "$target" 2>/dev/null; then
    printf '%s\n' "$target"
    return 0
  fi

  if [[ -n "$repo_name" ]]; then
    candidate="amux-${repo_name}-team-${target}"
    if tmux has-session -t "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi

    if [[ "$target" == "team-"* ]]; then
      candidate="amux-${repo_name}-${target}"
      if tmux has-session -t "$candidate" 2>/dev/null; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi

    if [[ "$target" == "${repo_name}-team-"* ]]; then
      candidate="amux-${target}"
      if tmux has-session -t "$candidate" 2>/dev/null; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  fi

  return 1
}

capture_session_panes() {
  local session="$1"
  local lines="$2"
  local extra_attrs="${3:-}"
  local pane snapshot
  while IFS= read -r pane; do
    [[ -z "$pane" ]] && continue
    snapshot="$(tmux capture-pane -p -t "$pane" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    printf '  <capture session="%s" pane="%s" lines="%s"%s>%s</capture>\n' \
      "$(xml_escape "$session")" \
      "$(xml_escape "$pane")" \
      "$(xml_escape "$lines")" \
      "$extra_attrs" \
      "$(xml_escape "$snapshot")"
  done < <(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null || true)
}

agent_target=""
team_target=""
capture_all=0
lines="200"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      agent_target="${2:-}"
      shift 2
      ;;
    --team)
      team_target="${2:-}"
      shift 2
      ;;
    --all)
      capture_all=1
      shift
      ;;
    --lines)
      lines="${2:-}"
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if ! [[ "$lines" =~ ^[0-9]+$ ]] || (( lines < 1 )); then
  echo "invalid --lines value: $lines" >&2
  exit 2
fi

selectors=0
[[ -n "$agent_target" ]] && selectors=$((selectors + 1))
[[ -n "$team_target" ]] && selectors=$((selectors + 1))
[[ "$capture_all" -eq 1 ]] && selectors=$((selectors + 1))
if (( selectors != 1 )); then
  echo "exactly one selector is required: --agent, --team, or --all" >&2
  exit 2
fi

repo_name="$(repo_name_from_context)"

if [[ "$capture_all" -eq 1 ]]; then
  current_pane=""
  if [[ -n "${TMUX:-}" ]]; then
    current_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  fi

  printf '<captures scope="all" repo="%s">\n' "$(xml_escape "$repo_name")"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    s="${line%% *}"
    p="${line##* }"
    [[ "$s" == amux-* ]] || continue
    if [[ -n "$repo_name" && "$s" != "amux-${repo_name}-"* ]]; then
      continue
    fi
    if [[ -n "$current_pane" && "$p" == "$current_pane" ]]; then
      continue
    fi
    snapshot="$(tmux capture-pane -p -t "$p" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    printf '  <capture session="%s" pane="%s" lines="%s">%s</capture>\n' \
      "$(xml_escape "$s")" \
      "$(xml_escape "$p")" \
      "$(xml_escape "$lines")" \
      "$(xml_escape "$snapshot")"
  done < <(tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null || true)
  printf '</captures>\n'
  exit 0
fi

if [[ -n "$agent_target" ]]; then
  session="$(resolve_agent_session "$agent_target" "$repo_name" || true)"
  if [[ -z "$session" ]]; then
    echo "agent session not found: $agent_target" >&2
    echo "pass absolute (amux-<repo>-<agent>) or shorthand (<agent>)" >&2
    exit 1
  fi
  if [[ "$session" == "amux-${repo_name}-team-"* ]]; then
    echo "target is a team session; use --team instead" >&2
    exit 2
  fi
  if [[ "$(get_session_env "$session" AMUX_SESSION_KIND)" == "team" ]]; then
    echo "target is a team session; use --team instead" >&2
    exit 2
  fi

  agent_name="$(get_session_env "$session" AMUX_AGENT_NAME)"
  if [[ -z "$agent_name" ]]; then
    agent_name="$(session_short_name "$session" "$repo_name")"
  fi
  printf '<captures scope="agent" agent="%s" session="%s">\n' \
    "$(xml_escape "$agent_name")" \
    "$(xml_escape "$session")"
  capture_session_panes "$session" "$lines" " agent=\"$(xml_escape "$agent_name")\""
  printf '</captures>\n'
  exit 0
fi

session="$(resolve_team_session "$team_target" "$repo_name" || true)"
if [[ -z "$session" ]]; then
  echo "team session not found: $team_target" >&2
  echo "pass absolute (amux-<repo>-team-<name>) or shorthand (<name>)" >&2
  exit 1
fi

team_name="$(get_session_env "$session" AMUX_TEAM)"
if [[ -z "$team_name" && "$session" == "amux-${repo_name}-team-"* ]]; then
  team_name="${session#amux-${repo_name}-team-}"
fi
if [[ -z "$team_name" ]]; then
  echo "session is not marked as a team: $session" >&2
  exit 2
fi

printf '<captures scope="team" team="%s" session="%s">\n' \
  "$(xml_escape "$team_name")" \
  "$(xml_escape "$session")"
capture_session_panes "$session" "$lines" " team=\"$(xml_escape "$team_name")\""
printf '</captures>\n'

