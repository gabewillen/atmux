#!/usr/bin/env bash
set -euo pipefail

if ! command -v gemini >/dev/null 2>&1; then
  echo "gemini command not found in PATH" >&2
  exit 127
fi

set_bootstrap_state() {
  local state="$1"
  local session=""
  if [[ -n "${TMUX:-}" ]]; then
    session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  [[ -n "$session" ]] || return 0
  tmux set-environment -t "$session" ATMUX_BOOTSTRAP_STATE "$state" >/dev/null 2>&1 || true
}

state_dir="${ATMUX_HOME:-$HOME/.atmux}/adapters/gemini"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"
[[ -f "$state_file" ]] || printf 'MODEL=%s\nREASONING_LEVEL=%s\n' 'gemini-3-flash-preview' 'medium' > "$state_file"
# shellcheck disable=SC1090
source "$state_file"

resolve_profile_from_manifest() {
  local intelligence="$1"
  local manifest_path="$2"
  local map item min max model reasoning compact

  [[ -f "$manifest_path" ]] || return 1
  compact="$(tr -d '\n\r\t ' < "$manifest_path")"
  map="$(printf '%s\n' "$compact" | sed -n "s/.*\"intelligence_map\":\[\(.*\)\][,}].*/\1/p")"
  [[ -n "$map" ]] || return 1

  while IFS= read -r item; do
    min="$(printf '%s\n' "$item" | sed -n 's/.*"min":\([0-9][0-9]*\).*/\1/p')"
    max="$(printf '%s\n' "$item" | sed -n 's/.*"max":\([0-9][0-9]*\).*/\1/p')"
    model="$(printf '%s\n' "$item" | sed -n 's/.*"model":"\([^"]*\)".*/\1/p')"
    reasoning="$(printf '%s\n' "$item" | sed -n 's/.*"reasoning_level":"\([^"]*\)".*/\1/p')"

    if [[ -z "$min" || -z "$max" || -z "$model" || -z "$reasoning" ]]; then
      continue
    fi
    if (( intelligence >= min && intelligence <= max )); then
      printf '%s %s\n' "$model" "$reasoning"
      return 0
    fi
  done < <(printf '%s\n' "$map" | sed 's/},{/}\n{/g')

  return 1
}

arg_present() {
  local needle="$1"
  shift || true
  local arg
  for arg in "$@"; do
    [[ "$arg" == "$needle" ]] && return 0
  done
  return 1
}

normalize_model() {
  case "${1:-}" in
    gemini-3.1-flash-lite-preview|gemini-3-flash-preview|gemini-3.1-pro-preview) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

normalize_reasoning() {
  case "${1:-}" in
    low|medium|high) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

if [[ -n "${ATMUX_INTELLIGENCE:-}" && "${ATMUX_INTELLIGENCE}" =~ ^[0-9]+$ ]] \
  && (( ATMUX_INTELLIGENCE >= 0 && ATMUX_INTELLIGENCE <= 100 )); then
  manifest_path="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/manifest.json"
  profile="$(resolve_profile_from_manifest "$ATMUX_INTELLIGENCE" "$manifest_path" || true)"
  if [[ -n "$profile" ]]; then
    prof_model="${profile%% *}"
    prof_reasoning="${profile#* }"
    MODEL="$(normalize_model "$prof_model" || printf '%s\n' "$MODEL")"
    REASONING_LEVEL="$(normalize_reasoning "$prof_reasoning" || printf '%s\n' "$REASONING_LEVEL")"
  fi
fi

if [[ -n "${ATMUX_GEMINI_MODEL:-}" ]]; then
  MODEL="$(normalize_model "$ATMUX_GEMINI_MODEL" || { echo "invalid ATMUX_GEMINI_MODEL: $ATMUX_GEMINI_MODEL" >&2; exit 2; })"
fi
if [[ -n "${ATMUX_GEMINI_REASONING_LEVEL:-}" ]]; then
  REASONING_LEVEL="$(normalize_reasoning "$ATMUX_GEMINI_REASONING_LEVEL" || { echo "invalid ATMUX_GEMINI_REASONING_LEVEL: $ATMUX_GEMINI_REASONING_LEVEL" >&2; exit 2; })"
fi

printf 'MODEL=%s\nREASONING_LEVEL=%s\n' "$MODEL" "$REASONING_LEVEL" > "$state_file"

args=("$@")
if ! arg_present --model "${args[@]-}"; then
  args=(--model "$MODEL" "${args[@]-}")
fi
if ! arg_present -y "${args[@]-}" && ! arg_present --yolo "${args[@]-}" && ! arg_present --approval-mode "${args[@]-}"; then
  args=(-y "${args[@]-}")
fi

_on_stop_script="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)/scripts/on-stop"

write_atmux_gemini_settings() {
  local settings_file="$1"
  cat > "$settings_file" <<EOF
{
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "atmux-stop-notify",
            "type": "command",
            "command": "${_on_stop_script}",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
EOF
}

is_legacy_atmux_gemini_settings() {
  local settings_file="$1"
  [[ -f "$settings_file" ]] || return 1
  grep -Fq '"atmux-stop-notify"' "$settings_file" || return 1
  grep -Fq '"hooks"' "$settings_file" || return 1
  grep -Fq '"enabled": true' "$settings_file" || return 1
  grep -Fq '"hooksConfig"' "$settings_file" && return 1
  return 0
}

# Install an AfterAgent hook (fires at end of every turn) into the worktree's
# .gemini/settings.json using Gemini CLI's current hooks schema.
install_gemini_after_agent_hook() {
  [[ -x "$_on_stop_script" ]] || return 0
  local settings_dir="${ATMUX_WORKTREE:-$(pwd)}/.gemini"
  local settings_file="$settings_dir/settings.json"
  mkdir -p "$settings_dir"

  if [[ -f "$settings_file" ]]; then
    if is_legacy_atmux_gemini_settings "$settings_file"; then
      write_atmux_gemini_settings "$settings_file"
    fi
    return 0
  fi

  write_atmux_gemini_settings "$settings_file"
}
install_gemini_after_agent_hook

set_bootstrap_state ready
echo "starting gemini in $(pwd)"
exec gemini "${args[@]-}"
