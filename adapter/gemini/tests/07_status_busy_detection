#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-gemini-test-home.XXXXXX")"

cleanup() {
  [[ -n "${session_name:-}" ]] && "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$atmux_home"
}
trap cleanup EXIT

start_cmd="ATMUX_HOME='$atmux_home' '$ADAPTER_DIR/scripts/start'"
setup_out="$("$SCRIPTS_DIR/setup" --command "$start_cmd" --wait-text 'Type your message')"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

tmux send-keys -t "$pane_id" C-u
tmux send-keys -t "$pane_id" -l 'Give a very short one-line response: READY'
tmux send-keys -t "$pane_id" Enter
"$REPO_ROOT/bin/atmux" pane watch "$pane_id" --scope pane --text "READY" --timeout 40 --interval 0.2 --lines 700 >/dev/null || true

status_out="$({
  ATMUX_HOME="$atmux_home" \
  ATMUX_TARGET_PANE="$pane_id" \
  "$ADAPTER_DIR/scripts/status"
})"

extract_attr() {
  local attr="$1"
  printf '%s\n' "$status_out" | sed -n "s/.*$attr=\"\\([^\"]*\\)\".*/\\1/p" | tail -n 1
}

echo "$status_out" | grep -F '<status ' >/dev/null
echo "$status_out" | grep -F 'adapter="gemini"' >/dev/null

state="$(extract_attr state)"
model="$(extract_attr model)"
reasoning="$(extract_attr reasoning_level)"

case "$state" in
  idle|busy|errored|usage-limit) ;;
  *)
    echo "unexpected state: $state" >&2
    exit 1
    ;;
esac
case "$model" in
  gemini-3.1-flash-lite-preview|gemini-3-flash-preview|gemini-3.1-pro-preview) ;;
  *)
    echo "unexpected model: $model" >&2
    exit 1
    ;;
esac
case "$reasoning" in
  low|medium|high) ;;
  *)
    echo "unexpected reasoning_level: $reasoning" >&2
    exit 1
    ;;
esac

echo "PASS 07_status_busy_detection"
