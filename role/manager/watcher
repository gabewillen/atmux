#!/usr/bin/env bash
set -euo pipefail

# Watches agent tabs in a manager tmux session and reports stale tabs
# back into the manager tab itself.

interval_seconds="${AMUX_WATCH_INTERVAL_SECONDS:-30}"
stale_after_seconds="${AMUX_STALE_AFTER_SECONDS:-300}"

session_name() {
  if [[ -n "${AMUX_REPO:-}" ]]; then
    printf 'amux-%s\n' "$AMUX_REPO"
    return
  fi

  tmux display-message -p '#S'
}

report_stale() {
  local session="$1"
  local window="$2"
  local pane_id="$3"
  local age="$4"

  local msg
  msg="[amux-watcher] stale tab: window=${window} pane=${pane_id} idle=${age}s"

  tmux send-keys -t "${session}:manager.0" "echo '$msg'" C-m
}

main() {
  local session
  session="$(session_name)"
  local repo="${AMUX_REPO:-}"
  local agent_pattern
  if [[ -n "$repo" ]]; then
    agent_pattern="^amux-${repo}-agent-"
  else
    agent_pattern="^amux-.*-agent-"
  fi

  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "manager session not found: $session" >&2
    exit 1
  fi

  while true; do
    local now
    now="$(date +%s)"

    while IFS='|' read -r window pane_title pane_id pane_dead pane_activity; do
      [[ -z "$window" ]] && continue

      if [[ "$pane_dead" == "1" ]]; then
        report_stale "$session" "${window}/${pane_title}" "$pane_id" "dead"
        continue
      fi

      if [[ -z "$pane_activity" || "$pane_activity" == "0" ]]; then
        continue
      fi

      local age
      age=$((now - pane_activity))
      if (( age >= stale_after_seconds )); then
        report_stale "$session" "${window}/${pane_title}" "$pane_id" "$age"
      fi
    done < <(
      tmux list-panes -a -F '#{session_name}|#{window_name}|#{pane_title}|#{pane_id}|#{pane_dead}|#{pane_activity}' \
        | awk -F'|' -v s="$session" -v p="$agent_pattern" \
          '$1 == s && ($2 ~ p || $3 ~ p) { print $2"|"$3"|"$4"|"$5"|"$6 }'
    )

    sleep "$interval_seconds"
  done
}

main "$@"
