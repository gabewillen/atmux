#!/usr/bin/env bash
# shellcheck shell=bash
# Shared helpers for exec, issue, watch --pid, watch --issue; also `atmux notify` CLI when executed.
# When sourced, only function definitions run (see bottom).

normalize_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

primary_pane_for_session() {
  local session="$1"
  tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }'
}

current_pane() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return 0
  fi
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    primary_pane_for_session "$ATMUX_SESSION_NAME"
    return 0
  fi
  return 0
}

queue_self_notification() {
  local pane="$1"
  local payload="$2"
  [[ -n "$pane" ]] || return 0

  nohup bash -lc '
    pane="$1"
    payload="$2"
    sleep 0.2
    settle="${ATMUX_SEND_SETTLE_SECONDS:-0.2}"
    submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.15}"
    tmux send-keys -t "$pane" C-u >/dev/null 2>&1 || exit 0
    sleep "$settle"
    tmux send-keys -t "$pane" -l "$payload" >/dev/null 2>&1 || exit 0
    sleep "$settle"
    tmux send-keys -t "$pane" Enter >/dev/null 2>&1 || exit 0
    sleep "$submit_wait"
  ' _ "$pane" "$payload" >/dev/null 2>&1 &
}

build_notification_xml() {
  local command_text="$1"
  local timestamp="$2"
  local exit_code="$3"

  printf '<atmux><notification from="exec %s" timestamp="%s" exitcode="%s" /></atmux>' \
    "$(xml_escape "$command_text")" \
    "$(xml_escape "$timestamp")" \
    "$(xml_escape "$exit_code")"
}

build_issue_notification_xml() {
  local action="$1"
  local issue_id="$2"
  local state="$3"
  local timestamp="$4"

  printf '<atmux><notification from="issue %s" issue_id="%s" state="%s" timestamp="%s" /></atmux>' \
    "$(xml_escape "$action")" \
    "$(xml_escape "$issue_id")" \
    "$(xml_escape "$state")" \
    "$(xml_escape "$timestamp")"
}

timestamp_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

repo_name_from_context() {
  local repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  normalize_name "$repo_name"
}

write_field() {
  local file="$1"
  local value="${2:-}"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" > "$file"
}

exec_root_for_repo() {
  local repo_name="$1"
  printf '%s/exec/%s\n' "$ATMUX_HOME" "$repo_name"
}

exec_dir_for_repo_pid() {
  local repo_name="$1"
  local pid="$2"
  printf '%s/%s\n' "$(exec_root_for_repo "$repo_name")" "$pid"
}

read_state_field() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    printf ''
    return 0
  fi
  tr -d '\r\n' <"$file" 2>/dev/null || printf ''
}

validate_exec_ownership() {
  local exec_dir="$1"
  local expect_pid="$2"
  local expect_repo="$3"
  local got_pid got_repo

  [[ -d "$exec_dir" ]] || return 1
  got_pid="$(read_state_field "$exec_dir/pid")"
  got_repo="$(read_state_field "$exec_dir/repo")"
  [[ -n "$got_pid" && "$got_pid" == "$expect_pid" ]] || return 1
  [[ -n "$got_repo" && "$got_repo" == "$expect_repo" ]] || return 1
  return 0
}

issue_root_for_repo() {
  local repo="$1"
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  printf '%s/issues/%s\n' "$atmux_home" "$repo"
}

issue_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

notify_exec_watchers() {
  local exec_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$exec_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    queue_self_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_issue_watchers() {
  local issue_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$issue_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    queue_self_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_cli_usage() {
  cat <<'USAGE'
Usage:
  atmux notify --pane <tmux-pane-id> --xml <payload>

Description:
  Queue an ATMUX XML notification to a tmux pane (same mechanism as exec/issue fan-out).

Examples:
  atmux notify --pane %12 --xml '<atmux><notification from="test" /></atmux>'
USAGE
}

notify_cli_main() {
  local pane=""
  local xml_payload=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane)
        pane="${2:-}"
        shift 2
        ;;
      --xml)
        xml_payload="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        notify_cli_usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        notify_cli_usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
  [[ -n "$xml_payload" ]] || { echo "missing --xml" >&2; exit 2; }

  queue_self_notification "$pane" "$xml_payload"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail
  ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
  notify_cli_main "$@"
fi
