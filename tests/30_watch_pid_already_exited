#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-pid-done.XXXXXX")"
repo_name="pd${RANDOM}"
atmux_home="$tmp_home/.atmux"

cleanup() {
  rm -rf "$tmp_home"
}
trap cleanup EXIT

# Run exec with a command that exits immediately
set +e
HOME="$tmp_home" ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" \
  ATMUX_AGENT_NAME="t" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
  "$ATMUX_BIN" exec bash -lc 'exit 0'
set -e

# Find the PID from metadata
exec_root="$atmux_home/exec/$repo_name"
[[ -d "$exec_root" ]] || { echo "exec root missing" >&2; exit 1; }

entry_dir="$(find "$exec_root" -mindepth 1 -maxdepth 1 -type d | head -n1)"
[[ -n "$entry_dir" ]] || { echo "exec entry missing" >&2; exit 1; }

pid="$(tr -d '\r\n' < "$entry_dir/pid")"
[[ -n "$pid" ]] || { echo "pid missing" >&2; exit 1; }

# Verify state is already exited
st="$(tr -d '\r\n' < "$entry_dir/state")"
[[ "$st" == "exited" ]] || { echo "expected exited state, got $st" >&2; exit 1; }

# Watch --pid for an already-exited process should return immediately with 0
set +e
ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
  "$ATMUX_BIN" watch --pid "$pid"
rc=$?
set -e

[[ "$rc" -eq 0 ]] || { echo "expected exit 0 for already-exited process, got $rc" >&2; exit 1; }

echo "ok: watch --pid exits 0 immediately for already-exited process"
