#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux capture --agent <name|session> [--lines <n>]
  atmux capture --team <name|session> [--lines <n>]
  atmux capture --all [--lines <n>]

Description:
  Capture tmux pane output for agents or team sessions.

Examples:
  atmux capture --agent planner
  atmux capture --agent atmux-myrepo-planner --lines 300
  atmux capture --team platform
  atmux capture --team atmux-myrepo-team-platform --lines 500
  atmux capture --all --lines 200
USAGE
}

capture_session_panes() {
  local session="$1"
  local lines="$2"
  local extra_attrs="${3:-}"
  local pane snapshot
  while IFS= read -r pane; do
    [[ -z "$pane" ]] && continue
    snapshot="$(tmux capture-pane -p -t "$pane" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    printf '  <capture session="%s" pane="%s" lines="%s"%s>%s</capture>\n' \
      "$(xml_escape "$session")" \
      "$(xml_escape "$pane")" \
      "$(xml_escape "$lines")" \
      "$extra_attrs" \
      "$snapshot"
  done < <(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null || true)
}

agent_target=""
team_target=""
capture_all=0
lines="200"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      agent_target="${2:-}"
      shift 2
      ;;
    --team)
      team_target="${2:-}"
      shift 2
      ;;
    --all)
      capture_all=1
      shift
      ;;
    --lines)
      lines="${2:-}"
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if ! [[ "$lines" =~ ^[0-9]+$ ]] || (( lines < 1 )); then
  echo "invalid --lines value: $lines" >&2
  exit 2
fi

selectors=0
[[ -n "$agent_target" ]] && selectors=$((selectors + 1))
[[ -n "$team_target" ]] && selectors=$((selectors + 1))
[[ "$capture_all" -eq 1 ]] && selectors=$((selectors + 1))
if (( selectors != 1 )); then
  echo "exactly one selector is required: --agent, --team, or --all" >&2
  exit 2
fi

repo_name="$(repo_name_from_context)"

if [[ "$capture_all" -eq 1 ]]; then
  current_pane=""
  if [[ -n "${TMUX:-}" ]]; then
    current_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  fi

  printf '<captures scope="all" repo="%s">\n' "$(xml_escape "$repo_name")"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    s="${line%% *}"
    p="${line##* }"
    [[ "$s" == atmux-* ]] || continue
    if [[ -n "$repo_name" && "$s" != "atmux-${repo_name}-"* ]]; then
      continue
    fi
    if [[ -n "$current_pane" && "$p" == "$current_pane" ]]; then
      continue
    fi
    snapshot="$(tmux capture-pane -p -t "$p" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    printf '  <capture session="%s" pane="%s" lines="%s">%s</capture>\n' \
      "$(xml_escape "$s")" \
      "$(xml_escape "$p")" \
      "$(xml_escape "$lines")" \
      "$snapshot"
  done < <(tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null || true)
  printf '</captures>\n'
  exit 0
fi

if [[ -n "$agent_target" ]]; then
  session="$("$HERE/agent" resolve "$agent_target" "$repo_name" || true)"
  if [[ -z "$session" ]]; then
    echo "agent session not found: $agent_target" >&2
    echo "pass absolute (atmux-<repo>-<agent>) or shorthand (<agent>)" >&2
    exit 1
  fi
  if [[ "$session" == "atmux-${repo_name}-team-"* ]]; then
    echo "target is a team session; use --team instead" >&2
    exit 2
  fi
  if [[ "$(get_session_env "$session" ATMUX_SESSION_KIND)" == "team" ]]; then
    echo "target is a team session; use --team instead" >&2
    exit 2
  fi

  agent_name="$(get_session_env "$session" ATMUX_AGENT_NAME)"
  if [[ -z "$agent_name" ]]; then
    agent_name="$(session_short_name "$session" "$repo_name")"
  fi
  printf '<captures scope="agent" agent="%s" session="%s">\n' \
    "$(xml_escape "$agent_name")" \
    "$(xml_escape "$session")"
  capture_session_panes "$session" "$lines" " agent=\"$(xml_escape "$agent_name")\""
  printf '</captures>\n'
  exit 0
fi

session="$("$HERE/team" resolve "$team_target" "$repo_name" || true)"
if [[ -z "$session" ]]; then
  echo "team session not found: $team_target" >&2
  echo "pass absolute (atmux-<repo>-team-<name>) or shorthand (<name>)" >&2
  exit 1
fi

team_name="$(get_session_env "$session" ATMUX_TEAM)"
if [[ -z "$team_name" && "$session" == "atmux-${repo_name}-team-"* ]]; then
  team_name="${session#atmux-${repo_name}-team-}"
fi
if [[ -z "$team_name" ]]; then
  echo "session is not marked as a team: $session" >&2
  exit 2
fi

printf '<captures scope="team" team="%s" session="%s">\n' \
  "$(xml_escape "$team_name")" \
  "$(xml_escape "$session")"
capture_session_panes "$session" "$lines" " team=\"$(xml_escape "$team_name")\""
printf '</captures>\n'

