#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
if [[ -z "${ATMUX_SOURCE_ROOT:-}" ]]; then
  if [[ -d "$ATMUX_HOME/src/atmux" ]]; then
    ATMUX_SOURCE_ROOT="$ATMUX_HOME/src/atmux"
  else
    ATMUX_SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)"
  fi
fi

state_dir="$ATMUX_HOME/adapters/auto"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"

emit_all=0
peek=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)
      emit_all=1
      shift
      ;;
    --peek)
      peek=1
      shift
      ;;
    *)
      echo "unknown flag: $1" >&2
      exit 2
      ;;
  esac
done

xml_escape() {
  local s="${1:-}"
  s="${s//&/&amp;}"
  s="${s//</&lt;}"
  s="${s//>/&gt;}"
  s="${s//\"/&quot;}"
  s="${s//\'/&apos;}"
  printf '%s\n' "$s"
}

read_cursor() {
  local cursor="0"
  if [[ -f "$state_file" ]]; then
    cursor="$(sed -n 's/^RR_CURSOR=//p' "$state_file" | tail -n 1)"
  fi
  if [[ ! "$cursor" =~ ^[0-9]+$ ]]; then
    cursor="0"
  fi
  printf '%s\n' "$cursor"
}

write_cursor() {
  local cursor="$1"
  printf 'RR_CURSOR=%s\n' "$cursor" > "$state_file"
}

in_list() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

resolve_adapter_cmd_path() {
  local adapter="$1"
  local repo_root=""

  if [[ -x "$ATMUX_SOURCE_ROOT/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "$ATMUX_SOURCE_ROOT/adapter/$adapter/cmd"
    return 0
  fi

  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/adapter/$adapter/cmd" ]]; then
      printf '%s\n' "$repo_root/adapter/$adapter/cmd"
      return 0
    fi
  fi

  if [[ -x "$ATMUX_HOME/adapters/$adapter/cmd" ]]; then
    printf '%s\n' "$ATMUX_HOME/adapters/$adapter/cmd"
    return 0
  fi

  return 1
}

adapter_available() {
  local adapter="$1"
  case "$adapter" in
    codex)
      command -v codex >/dev/null 2>&1
      ;;
    claude-code)
      command -v claude >/dev/null 2>&1
      ;;
    gemini)
      command -v gemini >/dev/null 2>&1
      ;;
    cursor-agent)
      command -v agent >/dev/null 2>&1 || command -v cursor-agent >/dev/null 2>&1
      ;;
    *)
      return 0
      ;;
  esac
}

discover_candidates() {
  local path name

  if [[ -d "$ATMUX_SOURCE_ROOT/adapter" ]]; then
    while IFS= read -r path; do
      [[ -z "$path" ]] && continue
      name="$(basename "$path")"
      [[ "$name" == "auto" ]] && continue
      [[ -x "$path/cmd" ]] || continue
      printf '%s\n' "$name"
    done < <(find "$ATMUX_SOURCE_ROOT/adapter" -mindepth 1 -maxdepth 1 -type d | sort)
  fi

  if [[ -d "$ATMUX_HOME/adapters" ]]; then
    while IFS= read -r path; do
      [[ -z "$path" ]] && continue
      name="$(basename "$path")"
      [[ "$name" == "auto" ]] && continue
      [[ -x "$path/cmd" ]] || continue
      printf '%s\n' "$name"
    done < <(find "$ATMUX_HOME/adapters" -mindepth 1 -maxdepth 1 -type d | sort)
  fi
}

state_for_session() {
  local adapter_cmd="$1"
  local session="$2"
  local pane status_out state

  pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n 1)"

  if [[ -z "$pane" ]]; then
    printf '%s\n' "errored"
    return
  fi

  status_out="$({
    ATMUX_TARGET_PANE="$pane" \
    ATMUX_STATUS_PASSIVE=1 \
    "$adapter_cmd" status 2>/dev/null || true
  })"

  state="$(printf '%s\n' "$status_out" | sed -n 's/.*state="\([^"]*\)".*/\1/p' | head -n 1)"
  case "$state" in
    idle|busy|usage-limit|errored)
      printf '%s\n' "$state"
      ;;
    *)
      printf '%s\n' "errored"
      ;;
  esac
}

rank_adapter() {
  local adapter="$1"
  local adapter_cmd="$2"
  local session session_adapter state
  local total=0
  local idle=0
  local busy=0
  local usage_limit=0
  local errored=0
  local class load

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    session_adapter="$(tmux show-environment -t "$session" ATMUX_ADAPTER 2>/dev/null | sed -n 's/^ATMUX_ADAPTER=//p' || true)"
    [[ "$session_adapter" == "$adapter" ]] || continue

    total=$((total + 1))
    state="$(state_for_session "$adapter_cmd" "$session")"
    case "$state" in
      idle) idle=$((idle + 1)) ;;
      busy) busy=$((busy + 1)) ;;
      usage-limit) usage_limit=$((usage_limit + 1)) ;;
      *) errored=$((errored + 1)) ;;
    esac
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '/^atmux-/ { print }' || true)

  # class priority:
  # 0 = available now (has idle sessions OR has no sessions yet)
  # 1 = only busy sessions
  # 2 = effectively unavailable (all usage-limit/errored)
  if (( idle > 0 || total == 0 )); then
    class=0
  elif (( usage_limit + errored >= total )); then
    class=2
  else
    class=1
  fi

  load=$((busy * 10 + usage_limit * 30 + errored * 20 + total))
  printf '%s|%s|%s\n' "$adapter" "$class" "$load"
}

candidates=()
while IFS= read -r name; do
  [[ -z "$name" ]] && continue
  if (( ${#candidates[@]} > 0 )) && in_list "$name" "${candidates[@]}"; then
    continue
  fi
  if ! adapter_available "$name"; then
    continue
  fi
  candidates+=("$name")
done < <(discover_candidates | awk 'NF' | sort -u)

if ((${#candidates[@]} == 0)); then
  echo "no available adapters" >&2
  exit 1
fi

rank_rows=""
for adapter in "${candidates[@]}"; do
  adapter_cmd="$(resolve_adapter_cmd_path "$adapter" || true)"
  [[ -x "$adapter_cmd" ]] || continue
  rank_rows+="$(rank_adapter "$adapter" "$adapter_cmd")"$'\n'
done

if [[ -z "$rank_rows" ]]; then
  echo "no available adapters" >&2
  exit 1
fi

sorted_rows="$(printf '%s' "$rank_rows" | awk 'NF' | sort -t '|' -k2,2n -k3,3n -k1,1)"

first_row="$(printf '%s\n' "$sorted_rows" | head -n 1)"
[[ -n "$first_row" ]] || { echo "no ranked adapters" >&2; exit 1; }

top_class="$(printf '%s' "$first_row" | cut -d '|' -f 2)"
top_load="$(printf '%s' "$first_row" | cut -d '|' -f 3)"

top=()
rest=()
while IFS='|' read -r adapter class load; do
  [[ -z "$adapter" ]] && continue
  if [[ "$class" == "$top_class" && "$load" == "$top_load" ]]; then
    top+=("$adapter")
  else
    rest+=("$adapter")
  fi
done <<< "$sorted_rows"

cursor="$(read_cursor)"
top_count="${#top[@]}"
if (( top_count == 0 )); then
  echo "no ranked adapters" >&2
  exit 1
fi

start_idx=$((cursor % top_count))
rotated_top=()
for ((i=0; i<top_count; i++)); do
  idx=$(((start_idx + i) % top_count))
  rotated_top+=("${top[$idx]}")
done

next_cursor=$(((start_idx + 1) % top_count))
if [[ "$peek" -ne 1 ]]; then
  write_cursor "$next_cursor"
fi

ordered=("${rotated_top[@]}")
if (( ${#rest[@]} > 0 )); then
  ordered+=("${rest[@]}")
fi

if [[ "$emit_all" -eq 1 ]]; then
  printf '%s\n' "${ordered[@]}"
else
  printf '%s\n' "${ordered[0]}"
fi
