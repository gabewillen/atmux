#!/usr/bin/env bash
set -euo pipefail

# Defense in depth: this script spawns tmux servers; isolate the socket
# even if invoked outside a test that already did.
source "$(dirname "${BASH_SOURCE[0]}")/../lib/isolate-tmux.sh"

SCRIPTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$(cd -- "$SCRIPTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="${ATMUX_TEST_ATMUX_BIN:-$REPO_ROOT/bin/atmux}"
# shellcheck source=bin/(atmux)/(lib)/resolver
source "$REPO_ROOT/bin/(atmux)/(lib)/resolver"

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

main() {
  require_cmd tmux

  if [[ ! -x "$ATMUX_BIN" ]]; then
    echo "atmux binary not found at: $ATMUX_BIN" >&2
    exit 1
  fi

  local repo_name team_name agent1 agent2 team_session pane1 pane2
  repo_name="$(atmux_resolve_normalized_name "$(basename "$REPO_ROOT")")"
  team_name="${ATMUX_TEST_TEAM_NAME:-teamtest-$RANDOM}"
  agent1="atmux-${repo_name}-sender"
  agent2="atmux-${repo_name}-receiver"
  team_session="atmux-${repo_name}-team-${team_name}"

  for s in "$agent1" "$agent2" "$team_session"; do
    if tmux has-session -t "$s" 2>/dev/null; then
      tmux kill-session -t "$s" >/dev/null 2>&1 || true
    fi
  done

  tmux new-session -d -s "$agent1" -n "$agent1" -c "$REPO_ROOT" "cat"
  tmux set-environment -t "$agent1" ATMUX_REPO "$repo_name"
  tmux set-environment -t "$agent1" ATMUX_AGENT_NAME "sender"
  tmux set-environment -t "$agent1" ATMUX_SESSION_NAME "$agent1"

  tmux new-session -d -s "$agent2" -n "$agent2" -c "$REPO_ROOT" "cat"
  tmux set-environment -t "$agent2" ATMUX_REPO "$repo_name"
  tmux set-environment -t "$agent2" ATMUX_AGENT_NAME "receiver"
  tmux set-environment -t "$agent2" ATMUX_SESSION_NAME "$agent2"

  ATMUX_REPO="$repo_name" "$ATMUX_BIN" team create "$team_name" --shared-worktree >/dev/null
  members_dir="${ATMUX_HOME:-$HOME/.atmux}/teams/$repo_name/$team_name/members"
  mkdir -p "$members_dir/$(atmux_resolve_normalized_name "$agent1")" "$members_dir/$(atmux_resolve_normalized_name "$agent2")"
  printf '%s\n' "$agent1" > "$members_dir/$(atmux_resolve_normalized_name "$agent1")/session"
  printf '%s\n' "sender" > "$members_dir/$(atmux_resolve_normalized_name "$agent1")/name"
  printf '%s\n' "$agent2" > "$members_dir/$(atmux_resolve_normalized_name "$agent2")/session"
  printf '%s\n' "receiver" > "$members_dir/$(atmux_resolve_normalized_name "$agent2")/name"

  printf 'REPO_ROOT=%q\n' "$REPO_ROOT"
  printf 'REPO_NAME=%q\n' "$repo_name"
  printf 'ATMUX_BIN=%q\n' "$ATMUX_BIN"
  printf 'TEAM_NAME=%q\n' "$team_name"
  printf 'TEAM_SESSION=%q\n' "$team_session"
  printf 'AGENT1_SESSION=%q\n' "$agent1"
  printf 'AGENT2_SESSION=%q\n' "$agent2"
}

main "$@"
