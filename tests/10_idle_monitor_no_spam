#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
SESSION_SCRIPT="$REPO_ROOT/bin/(atmux)/session"

manager="atmux-idle-spam-manager-$RANDOM"
child="atmux-idle-spam-worker-$RANDOM"
log_file="${TMPDIR:-/tmp}/atmux-idle-spam-test-$$.log"

cleanup() {
  if [[ -n "${monitor_pid:-}" ]]; then
    kill "$monitor_pid" >/dev/null 2>&1 || true
    wait "$monitor_pid" 2>/dev/null || true
  fi
  tmux kill-session -t "$child" >/dev/null 2>&1 || true
  tmux kill-session -t "$manager" >/dev/null 2>&1 || true
  rm -f "$log_file" >/dev/null 2>&1 || true
}
trap cleanup EXIT

idle_count() {
  local pane="$1"
  local snap
  snap="$(tmux capture-pane -p -t "$pane" -S -800 | tr -d '\r\n' || true)"
  printf '%s' "$snap" | { grep -o '<idle ' || true; } | wc -l | tr -d ' '
}

wait_for_idle_count() {
  local pane="$1"
  local expected="$2"
  local timeout="$3"
  local deadline cur
  deadline=$((SECONDS + timeout))
  while (( SECONDS < deadline )); do
    cur="$(idle_count "$pane")"
    if (( cur >= expected )); then
      return 0
    fi
    sleep 1
  done
  return 1
}

tmux new-session -d -s "$manager" -n "$manager" -c "$REPO_ROOT" "sh -lc 'stty -echo; cat'"
tmux set-environment -t "$manager" ATMUX_REPO idle_spam_test
tmux set-environment -t "$manager" ATMUX_AGENT_NAME manager

tmux new-session -d -s "$child" -n "$child" -c "$REPO_ROOT" "cat"
tmux set-environment -t "$child" ATMUX_REPO idle_spam_test
tmux set-environment -t "$child" ATMUX_AGENT_NAME worker
tmux set-environment -t "$child" ATMUX_MANAGER "$manager"
tmux set-environment -t "$child" ATMUX_SOURCE_ROOT "$REPO_ROOT"

ATMUX_MONITOR_INTERVAL_SECONDS=1 \
ATMUX_MONITOR_IDLE_SECONDS=3 \
"$SESSION_SCRIPT" _monitor-supervisor "$child" >"$log_file" 2>&1 &
monitor_pid=$!

manager_pane="$(tmux list-panes -t "$manager" -F '#{pane_id}' | head -n 1)"
child_pane="$(tmux list-panes -t "$child" -F '#{pane_id}' | head -n 1)"

# First idle notification should arrive.
if ! wait_for_idle_count "$manager_pane" 1 15; then
  echo "expected first idle notification was not delivered" >&2
  tmux capture-pane -p -t "$manager_pane" -S -120 >&2 || true
  tail -n 80 "$log_file" >&2 || true
  exit 1
fi

# Leave pane unchanged long enough for multiple idle intervals.
sleep 7
count_after_wait="$(idle_count "$manager_pane")"
if (( count_after_wait != 1 )); then
  echo "idle notification spam detected; expected 1, got ${count_after_wait}" >&2
  tmux capture-pane -p -t "$manager_pane" -S -200 >&2 || true
  exit 1
fi

# Change pane content; monitor should re-arm and emit one more idle notification.
tmux send-keys -t "$child_pane" "poke-$RANDOM" C-m
if ! wait_for_idle_count "$manager_pane" 2 15; then
  echo "expected second idle notification after pane change was not delivered" >&2
  tmux capture-pane -p -t "$manager_pane" -S -220 >&2 || true
  tail -n 80 "$log_file" >&2 || true
  exit 1
fi

# Verify it does not spam again after the second notification.
sleep 7
final_count="$(idle_count "$manager_pane")"
if (( final_count != 2 )); then
  echo "idle notification spam detected after re-arm; expected 2, got ${final_count}" >&2
  tmux capture-pane -p -t "$manager_pane" -S -260 >&2 || true
  exit 1
fi

echo "ok: idle monitor sends once per unchanged pane period and re-arms on change"
