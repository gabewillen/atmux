#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"

repo="codex-e2e-$(date +%s)-$$"
manager_session="amux-${repo}-manager"
worker_session="amux-${repo}-worker"
steve_session="amux-${repo}-Steve"
reply_token="REPLY_STEVE_${repo}"
task_token="TASK_STEVE_${repo}"

setup_manager_out="$(AMUX_CODEX_TEST_SESSION_NAME="$manager_session" "$SCRIPTS_DIR/setup")"
setup_worker_out="$(AMUX_CODEX_TEST_SESSION_NAME="$worker_session" "$SCRIPTS_DIR/setup")"

manager_pane="$(printf '%s\n' "$setup_manager_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
worker_pane="$(printf '%s\n' "$setup_worker_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$manager_pane" || -z "$worker_pane" ]]; then
  echo "missing pane id from setup output" >&2
  exit 1
fi

wait_for_session() {
  local target="$1"
  local timeout="${2:-120}"
  local interval="0.5"
  local deadline now
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    if tmux has-session -t "$target" 2>/dev/null; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep "$interval"
  done
}

dump_debug() {
  echo "----- manager pane -----" >&2
  tmux capture-pane -p -t "$manager_pane" -S -220 >&2 || true
  echo "----- worker pane -----" >&2
  tmux capture-pane -p -t "$worker_pane" -S -260 >&2 || true
}

cleanup() {
  AMUX_REPO="$repo" "$REPO_ROOT/bin/amux/agent" rm "$steve_session" >/dev/null 2>&1 || true
  "$SCRIPTS_DIR/teardown" --session "$manager_session" >/dev/null 2>&1 || true
  "$SCRIPTS_DIR/teardown" --session "$worker_session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

cmd_create="AMUX_NO_WRAP=1 AMUX_REPO=${repo} AMUX_AGENT_NAME=worker AMUX_SOURCE_ROOT=${REPO_ROOT} ${REPO_ROOT}/bin/amux.sh agent create --name Steve --role principal --intelligence 100"
cmd_reply="AMUX_NO_WRAP=1 AMUX_REPO=${repo} AMUX_MANAGER=manager AMUX_AGENT_NAME=worker AMUX_SESSION_NAME=${worker_session} ${REPO_ROOT}/bin/amux.sh manager send \"${reply_token} Steve created\""
instruction="${task_token}: Create the most intelligent agent named Steve. REQUIRED: run this exact command: ${cmd_create} . Then run this exact command: ${cmd_reply} . Do not ask questions."

AMUX_REPO="$repo" \
AMUX_AGENT_NAME="manager" \
AMUX_SESSION_NAME="$manager_session" \
"$REPO_ROOT/bin/amux/agent" send --to worker --reply-required "$instruction"

if ! "$REPO_ROOT/bin/amux/watch" --target "$worker_pane" --scope pane --text "reply_required=\"true\"" --timeout 30 --interval 0.2 --lines 600; then
  dump_debug
  echo "worker did not receive reply_required=true message" >&2
  exit 1
fi

if ! "$REPO_ROOT/bin/amux/watch" --target "$manager_pane" --scope pane --text "$reply_token" --timeout 240 --interval 0.5 --lines 1500; then
  dump_debug
  echo "manager did not receive required reply from worker" >&2
  exit 1
fi

if ! wait_for_session "$steve_session" 180; then
  dump_debug
  echo "expected agent session was not created: $steve_session" >&2
  exit 1
fi

echo "PASS 08_reply_required_creates_steve"
