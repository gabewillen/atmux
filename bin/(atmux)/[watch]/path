#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  atmux path watch <glob> [--timeout <seconds>] [--duration <seconds>]
                          [--interval <seconds>] [--coalesce <seconds>]
                          [--exec <cmd>] [--once]

Description:
  Watch filesystem paths matching a glob continuously, emitting one digest
  XML line per --coalesce window. Uses fswatch or inotifywait when available
  and falls back to polling.

  --timeout    Idle exit: return 124 if no change is observed for N seconds
               (0 = disabled, default 0).
  --duration   Hard cap: return 124 after N seconds total (0 = no cap).
  --interval   Poll interval (seconds) for the polling fallback (default 2).
  --coalesce   Batch change events into one digest XML line per N seconds
               (default 60). Set to 0 to emit per-event lines.
  --exec       Pipe each emitted XML line into `bash -c <cmd>`.
  --once       Single-shot: emit one XML line on the first change and exit 0.
               Disables coalescing.

Examples:
  atmux path watch 'src/**/*.sh'
  atmux path watch '/tmp/build/*.log' --timeout 60 --once
  atmux path watch 'docs/**/*.md' --exec ./on-docs-changed --coalesce 30
USAGE
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

has_glob_chars() {
  case "$1" in
    *'*'*|*'?'*|*'['*) return 0 ;;
    *) return 1 ;;
  esac
}

static_prefix() {
  local pattern="$1"
  local i char prefix=""

  for ((i=0; i<${#pattern}; i++)); do
    char="${pattern:i:1}"
    case "$char" in
      '*'|'?'|'[') break ;;
      *) prefix+="$char" ;;
    esac
  done

  printf '%s\n' "$prefix"
}

find_root_for_pattern() {
  local pattern="$1"
  local prefix root

  if ! has_glob_chars "$pattern"; then
    if [[ -d "$pattern" ]]; then
      printf '%s\n' "$pattern"
    else
      dirname -- "$pattern"
    fi
    return 0
  fi

  prefix="$(static_prefix "$pattern")"
  if [[ "$prefix" == */* ]]; then
    root="${prefix%/*}"
    [[ -n "$root" ]] || root="/"
  else
    root="."
  fi

  printf '%s\n' "$root"
}

nearest_existing_dir() {
  local path="$1"

  while [[ -n "$path" && "$path" != "." && "$path" != "/" ]]; do
    if [[ -d "$path" ]]; then
      printf '%s\n' "$path"
      return 0
    fi
    path="$(dirname -- "$path")"
  done

  if [[ "$path" == "/" ]]; then
    printf '/\n'
  else
    printf '.\n'
  fi
}

watch_roots() {
  local pattern root

  for pattern in "$@"; do
    root="$(find_root_for_pattern "$pattern")"
    nearest_existing_dir "$root"
  done | sort -u
}

stat_entry() {
  local path="$1"
  local kind mtime size

  if [[ -d "$path" ]]; then
    kind="dir"
  elif [[ -L "$path" ]]; then
    kind="link"
  elif [[ -f "$path" ]]; then
    kind="file"
  else
    kind="other"
  fi

  if stat -c '%Y %s' "$path" >/dev/null 2>&1; then
    read -r mtime size < <(stat -c '%Y %s' "$path")
  else
    read -r mtime size < <(stat -f '%m %z' "$path")
  fi

  printf '%s\t%s\t%s\t%s\n' "$path" "$kind" "$mtime" "$size"
}

path_matches() {
  local pattern="$1"
  local root="$2"
  local rel_pattern="$pattern"
  local dot_pattern="$pattern"

  if ! has_glob_chars "$pattern"; then
    [[ -e "$pattern" ]] && printf '%s\n' "$pattern"
    return 0
  fi

  [[ -d "$root" ]] || return 0

  if [[ "$pattern" != /* && "$pattern" != ./* ]]; then
    dot_pattern="./$pattern"
  fi

  find "$root" \( -path "$rel_pattern" -o -path "$dot_pattern" \) -print 2>/dev/null | sort
}

snapshot_paths() {
  local pattern
  local root
  local path

  for pattern in "$@"; do
    root="$(find_root_for_pattern "$pattern")"
    while IFS= read -r path; do
      [[ -n "$path" ]] || continue
      [[ -e "$path" || -L "$path" ]] || continue
      stat_entry "$path"
    done < <(path_matches "$pattern" "$root")
  done | sort -u
}

EXEC_CMD=""

emit_change_xml() {
  local xml="$1"
  printf '%s\n' "$xml"
  if [[ -n "$EXEC_CMD" ]]; then
    printf '%s' "$xml" | bash -c "$EXEC_CMD" >/dev/null 2>&1 || true
  fi
}

emit_change_once() {
  local backend="$1"
  shift
  local xml
  xml="$(printf '<watch type="path" path="%s" changed="true" backend="%s" />' \
    "$(xml_escape "$*")" \
    "$(xml_escape "$backend")")"
  emit_change_xml "$xml"
}

emit_change_coalesced() {
  local backend="$1"
  local events="$2"
  local window="$3"
  local reason="$4"
  shift 4
  local xml
  xml="$(printf '<watch type="path" path="%s" changed="true" backend="%s" coalesced="true" events="%s" window="%ss" reason="%s" />' \
    "$(xml_escape "$*")" \
    "$(xml_escape "$backend")" \
    "$(xml_escape "$events")" \
    "$(xml_escape "$window")" \
    "$(xml_escape "$reason")")"
  emit_change_xml "$xml"
}

wait_for_process_exit_or_duration() {
  local pid="$1"
  local duration="$2"
  local interval="$3"
  local deadline=0 now

  if [[ "$duration" -gt 0 ]]; then
    deadline=$(( $(date +%s) + duration ))
  fi

  while kill -0 "$pid" >/dev/null 2>&1; do
    if [[ "$deadline" -gt 0 ]]; then
      now="$(date +%s)"
      if (( now >= deadline )); then
        kill "$pid" >/dev/null 2>&1 || true
        wait "$pid" >/dev/null 2>&1 || true
        return 124
      fi
    fi
    sleep "$interval"
  done

  wait "$pid" >/dev/null 2>&1 || true
  return 0
}

wait_fswatch_event() {
  local duration="$1"
  local interval="$2"
  shift 2
  local roots=("$@")
  local pid

  fswatch -1 "${roots[@]}" >/dev/null 2>&1 &
  pid=$!
  wait_for_process_exit_or_duration "$pid" "$duration" "$interval"
}

wait_inotifywait_event() {
  local duration="$1"
  local interval="$2"
  shift 2
  local roots=("$@")
  local pid

  inotifywait -q -r -e create,modify,delete,move,attrib "${roots[@]}" >/dev/null 2>&1 &
  pid=$!
  wait_for_process_exit_or_duration "$pid" "$duration" "$interval"
}

# Wait for the next change event with a maximum wait of <duration> seconds.
# Returns 0 if an event candidate occurred (caller must re-snapshot to confirm),
# 124 if the wait expired, 1 if no usable backend.
#
# The caller is responsible for set +e / set -e bracketing this call: the
# helpers below intentionally do not touch errexit, since toggling it inside
# a function leaks the new setting back to the caller (a non-zero return then
# trips errexit in the caller before it can read the rc).
wait_next_event() {
  local backend="$1"
  local duration="$2"
  local interval="$3"
  shift 3
  local roots=("$@")

  case "$backend" in
    fswatch)
      wait_fswatch_event "$duration" "$interval" "${roots[@]}"
      return $?
      ;;
    inotifywait)
      wait_inotifywait_event "$duration" "$interval" "${roots[@]}"
      return $?
      ;;
    poll)
      sleep "$interval"
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

select_backend() {
  local requested="${ATMUX_WATCH_PATH_BACKEND:-auto}"

  case "$requested" in
    auto|"")
      if command -v fswatch >/dev/null 2>&1; then
        printf '%s\n' fswatch
      elif command -v inotifywait >/dev/null 2>&1; then
        printf '%s\n' inotifywait
      else
        printf '%s\n' poll
      fi
      ;;
    fswatch|inotifywait)
      if ! command -v "$requested" >/dev/null 2>&1; then
        echo "requested watch backend not found: $requested" >&2
        exit 2
      fi
      printf '%s\n' "$requested"
      ;;
    poll)
      printf '%s\n' "$requested"
      ;;
    *)
      echo "invalid ATMUX_WATCH_PATH_BACKEND: $requested" >&2
      exit 2
      ;;
  esac
}

main() {
  local timeout_sec="0"
  local duration="0"
  local interval="2"
  local coalesce="60"
  local once=0
  local paths=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path)
        paths+=("${2:-}")
        shift 2
        ;;
      --timeout)
        timeout_sec="${2:-}"
        shift 2
        ;;
      --duration)
        duration="${2:-}"
        shift 2
        ;;
      --interval)
        interval="${2:-}"
        shift 2
        ;;
      --coalesce)
        coalesce="${2:-}"
        shift 2
        ;;
      --exec)
        EXEC_CMD="${2:-}"
        shift 2
        ;;
      --once)
        once=1
        shift
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  [[ "${#paths[@]}" -gt 0 ]] || { echo "missing --path" >&2; exit 2; }
  [[ "$timeout_sec" =~ ^[0-9]+$ ]] || { echo "invalid --timeout: $timeout_sec" >&2; exit 2; }
  [[ "$duration" =~ ^[0-9]+$ ]] || { echo "invalid --duration: $duration" >&2; exit 2; }
  [[ "$coalesce" =~ ^[0-9]+$ ]] || { echo "invalid --coalesce: $coalesce" >&2; exit 2; }

  local backend
  backend="$(select_backend)"
  if [[ "$backend" != "poll" && "$backend" != "fswatch" && "$backend" != "inotifywait" ]]; then
    echo "atmux path watch: no usable backend" >&2
    exit 2
  fi

  if [[ "$backend" == "poll" && "${ATMUX_WATCH_PATH_POLL_WARNED:-0}" != "1" ]]; then
    echo "atmux path watch: using polling fallback; install fswatch or inotifywait for event-driven watching" >&2
    export ATMUX_WATCH_PATH_POLL_WARNED=1
  fi

  local roots=()
  while IFS= read -r root; do
    [[ -n "$root" ]] || continue
    roots+=("$root")
  done < <(watch_roots "${paths[@]}")

  local before
  before="$(snapshot_paths "${paths[@]}")"

  local start_ts now last_event_ts duration_deadline=0
  start_ts="$(date +%s)"
  last_event_ts="$start_ts"
  if [[ "$duration" -gt 0 ]]; then
    duration_deadline=$(( start_ts + duration ))
  fi

  local pending=0 event_count=0 flush_at=0

  flush_pending() {
    local reason="${1:-window}"
    (( pending == 1 )) || return 0
    emit_change_coalesced "$backend" "$event_count" "$coalesce" "$reason" "${paths[@]}"
    pending=0
    event_count=0
    flush_at=0
  }

  while true; do
    local next_deadline=0 wait_for after rc

    now="$(date +%s)"

    if (( duration_deadline > 0 )) && (( now >= duration_deadline )); then
      flush_pending "duration"
      exit 124
    fi

    if [[ "$timeout_sec" != "0" ]]; then
      if (( now - last_event_ts >= timeout_sec )); then
        flush_pending "idle_timeout"
        exit 124
      fi
    fi

    if (( duration_deadline > 0 )); then
      next_deadline="$duration_deadline"
    fi
    if [[ "$timeout_sec" != "0" ]]; then
      local idle_deadline=$(( last_event_ts + timeout_sec ))
      if (( next_deadline == 0 || idle_deadline < next_deadline )); then
        next_deadline="$idle_deadline"
      fi
    fi
    if (( pending == 1 )) && (( flush_at > 0 )); then
      if (( next_deadline == 0 || flush_at < next_deadline )); then
        next_deadline="$flush_at"
      fi
    fi

    if (( next_deadline > 0 )); then
      wait_for=$(( next_deadline - now ))
      (( wait_for > 0 )) || wait_for=1
    else
      wait_for=3600
    fi

    if [[ "${#roots[@]}" -eq 0 && "$backend" != "poll" ]]; then
      backend="poll"
    fi

    rc=0
    set +e
    wait_next_event "$backend" "$wait_for" "$interval" "${roots[@]}"
    rc=$?
    set -e

    if (( rc == 124 )); then
      now="$(date +%s)"
      if (( pending == 1 )) && (( now >= flush_at )); then
        flush_pending "window"
      fi
      continue
    fi

    if (( rc != 0 )); then
      # Backend failed; degrade to polling for the rest of the run.
      backend="poll"
      continue
    fi

    after="$(snapshot_paths "${paths[@]}")"
    if [[ "$after" == "$before" ]]; then
      continue
    fi
    before="$after"
    now="$(date +%s)"
    last_event_ts="$now"
    event_count=$(( event_count + 1 ))

    if (( once == 1 )); then
      emit_change_once "$backend" "${paths[@]}"
      exit 0
    fi

    if [[ "$coalesce" == "0" ]]; then
      emit_change_once "$backend" "${paths[@]}"
      event_count=0
    else
      if (( pending == 0 )); then
        pending=1
        flush_at=$(( now + coalesce ))
      fi
    fi
  done
}

main "$@"
