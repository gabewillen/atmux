#!/usr/bin/env bash
set -euo pipefail
state_dir="${ATMUX_HOME:-$HOME/.atmux}/adapters/gemini"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"
[[ -f "$state_file" ]] || printf 'MODEL=%s\nREASONING_LEVEL=%s\n' 'gemini-3-flash-preview' 'medium' > "$state_file"
# shellcheck disable=SC1090
source "$state_file"

normalize_reasoning() {
  case "${1:-}" in
    low|medium|high) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

case "${1:-}" in
  list) printf '%s\n' low medium high ;;
  get) printf '%s\n' "$REASONING_LEVEL" ;;
  set)
    REASONING_LEVEL="$(normalize_reasoning "${2:-}" || true)"
    [[ -n "$REASONING_LEVEL" ]] || { echo "missing/invalid reasoning level value" >&2; exit 2; }
    printf 'MODEL=%s\nREASONING_LEVEL=%s\n' "$MODEL" "$REASONING_LEVEL" > "$state_file"
    printf '%s\n' "$REASONING_LEVEL"
    ;;
  *) echo "usage: reasoning-level list|get|set <value>" >&2; exit 2 ;;
esac
