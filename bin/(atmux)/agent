#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux agent create [name] --role <role> --intelligence <0-100>
                     [--team <team>] [--adapter <adapter>] [--adapters <list>]
                     [--model <id>] [--reasoning <low|medium|high|extra-high>]
                     [--set <key>=<value>]...
                     [--shared-worktree] [--start <cmd>] [--stop <cmd>]
                     [--task --description <desc> --todo <todo>...]
                     [-- <adapter-args...>]
    (or `--name <name>` instead of positional; if omitted, atmux
     auto-generates `agent-N`.)
    `--shared-worktree` runs the new agent in the caller's current
    worktree instead of creating a private one for it (deprecated
    alias: `--no-worktree`).
    `--model` / `--reasoning` skip the role's intelligence_map lookup
    and force a specific model/reasoning level on the adapter. `--set
    <key>=<value>` is a generic override; known keys (model, reasoning,
    adapter, intelligence) map onto the corresponding flag, unknown
    keys emit a warning and are passed through unchanged.
  atmux agent list [--all] [--status]
  atmux agent status [<name>]
  atmux agent attach <name|session>
  atmux agent kill <name|pattern> [<name|pattern>...]
  atmux agent kill --all [--yes]
  atmux agent capture <name> [--lines <n>]
  atmux agent capture --all [--lines <n>]
  atmux agent watch <name> [--idle <seconds>] [--timeout <seconds>]
                           [--interval <seconds>] [--lines <n>]
  atmux agent resolve <name> [<repo_name>]

Description:
  Manage atmux agents — sessions running an AI CLI under tmux. Agents are
  scoped to the current repo. `create` works both as a top-level command
  (no manager required) and from inside a manager agent. When run
  interactively without a manager, the new agent is attached to.

Notes:
  agent attach must be run outside tmux.
USAGE
}

# === Repo / context helpers =================================================

normalize_repo_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "must be run from a git repository" >&2
    exit 1
  fi
  repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_repo_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

repo_name_from_context() {
  local repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  if [[ -n "$repo_name" ]]; then
    repo_name="$(normalize_repo_name "$repo_name")"
  fi
  printf '%s\n' "$repo_name"
}

# === Team helpers ===========================================================

team_session_name() {
  local repo_name="$1"
  local team_name="$2"
  printf 'atmux-%s-team-%s\n' "$repo_name" "$team_name"
}

team_member_count() {
  local team_session="$1"
  if ! tmux has-session -t "$team_session" 2>/dev/null; then
    printf '0\n'
    return 0
  fi
  tmux list-panes -t "${team_session}:0" -F '#{@atmux_agent_session}' 2>/dev/null | awk 'NF { c++ } END { print c+0 }'
}

team_contains_agent_session() {
  local team_session="$1"
  local agent_session="$2"
  tmux list-panes -t "${team_session}:0" -F '#{@atmux_agent_session}' 2>/dev/null | awk -v s="$agent_session" '$0==s { found=1 } END { exit(found?0:1) }'
}

ensure_team_has_capacity() {
  local repo_name="$1"
  local team_name="$2"
  local team_cap=4
  local team_session current_count

  [[ -n "$team_name" ]] || return 0
  team_session="$(team_session_name "$repo_name" "$team_name")"
  current_count="$(team_member_count "$team_session")"
  if ! [[ "$current_count" =~ ^[0-9]+$ ]]; then
    current_count=0
  fi
  if (( current_count >= team_cap )); then
    echo "team '${team_name}' is full (${current_count}/${team_cap}); max team size is 4" >&2
    return 1
  fi
}

# === Session resolution =====================================================

resolve_target_session() {
  local target="$1"
  local repo_name="${2:-}"
  local candidate=""

  if tmux has-session -t "$target" 2>/dev/null; then
    printf '%s\n' "$target"
    return 0
  fi

  if [[ "$target" == atmux-* ]]; then
    printf '%s\n' "$target"
    return 0
  fi

  if [[ -z "$repo_name" ]]; then
    return 1
  fi

  candidate="atmux-${repo_name}-${target}"
  if tmux has-session -t "$candidate" 2>/dev/null; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if [[ "$target" == "${repo_name}-"* ]]; then
    candidate="atmux-${target}"
    if tmux has-session -t "$candidate" 2>/dev/null; then
      printf '%s\n' "$candidate"
      return 0
    fi
  fi

  printf '%s\n' "atmux-${repo_name}-${target}"
  return 0
}

array_contains() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

has_wildcard() {
  local value="$1"
  case "$value" in
    *'*'*|*'?'*|*'['*) return 0 ;;
    *) return 1 ;;
  esac
}

manager_matches_parent() {
  local manager="$1"
  local parent_agent="$2"
  local parent_session="$3"
  local repo_name="$4"
  local parent_short=""

  [[ -n "$manager" ]] || return 1
  [[ -n "$parent_agent" || -n "$parent_session" ]] || return 1

  if [[ "$manager" == "$parent_agent" || "$manager" == "$parent_session" ]]; then
    return 0
  fi

  if [[ -n "$repo_name" && -n "$parent_agent" && "$manager" == "atmux-${repo_name}-${parent_agent}" ]]; then
    return 0
  fi

  if [[ -n "$repo_name" && -n "$parent_session" && "$parent_session" == atmux-* ]]; then
    parent_short="${parent_session#atmux-${repo_name}-}"
    if [[ "$manager" == "$parent_short" ]]; then
      return 0
    fi
  fi

  return 1
}

session_short_name() {
  local session="$1"
  local repo_name="$2"
  local prefix="atmux-${repo_name}-"
  if [[ -n "$repo_name" && "$session" == "$prefix"* ]]; then
    printf '%s\n' "${session#"$prefix"}"
  else
    printf '%s\n' "$session"
  fi
}

resolve_hierarchy_targets() {
  local pattern="$1"
  local repo_name="$2"
  local root_agent="$3"
  local root_session="$4"
  local -a frontier_agents=()
  local -a frontier_sessions=()
  local -a scanned_parents=()
  local -a hierarchy_sessions=()
  local parent_agent parent_session idx session manager child_agent short_name agent_name session_repo
  local candidate_match=0

  [[ -n "$root_agent" ]] || return 1

  frontier_agents+=("$root_agent")
  frontier_sessions+=("$root_session")

  idx=0
  while (( idx < ${#frontier_agents[@]} )); do
    parent_agent="${frontier_agents[$idx]}"
    parent_session="${frontier_sessions[$idx]}"

    if [[ -n "$parent_session" ]] && array_contains "$parent_session" "${scanned_parents[@]-}"; then
      idx=$((idx + 1))
      continue
    fi
    scanned_parents+=("$parent_session")

    while IFS= read -r session; do
      [[ -n "$session" ]] || continue
      session_repo="$(get_session_env "$session" ATMUX_REPO)"
      if [[ -n "$repo_name" && "$session_repo" != "$repo_name" ]]; then
        continue
      fi

      manager="$(get_session_env "$session" ATMUX_MANAGER)"
      if ! manager_matches_parent "$manager" "$parent_agent" "$parent_session" "$repo_name"; then
        continue
      fi

      if array_contains "$session" "${hierarchy_sessions[@]-}"; then
        continue
      fi

      hierarchy_sessions+=("$session")
      child_agent="$(get_session_env "$session" ATMUX_AGENT_NAME)"
      if [[ -z "$child_agent" ]]; then
        child_agent="$(session_short_name "$session" "$repo_name")"
      fi
      frontier_agents+=("$child_agent")
      frontier_sessions+=("$session")
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '/^atmux-/ { print }')

    idx=$((idx + 1))
  done

  for session in "${hierarchy_sessions[@]}"; do
    agent_name="$(get_session_env "$session" ATMUX_AGENT_NAME)"
    short_name="$(session_short_name "$session" "$repo_name")"
    [[ -n "$agent_name" ]] || agent_name="$short_name"

    if matches_any_pattern "$session" "$pattern" || matches_any_pattern "$short_name" "$pattern" || matches_any_pattern "$agent_name" "$pattern"; then
      printf '%s\n' "$session"
      candidate_match=1
    fi
  done

  [[ "$candidate_match" -eq 1 ]]
}

resolve_send_targets() {
  local to="$1"
  local repo_name="$2"
  local current_agent="$3"
  local current_session="$4"
  local target_session=""
  local pattern="$to"

  if [[ "$pattern" == "all" ]]; then
    pattern="*"
  fi

  if has_wildcard "$pattern"; then
    resolve_hierarchy_targets "$pattern" "$repo_name" "$current_agent" "$current_session"
    return $?
  fi

  target_session="$(resolve_target_session "$pattern" "$repo_name" || true)"
  [[ -n "$target_session" ]] || return 1
  printf '%s\n' "$target_session"
  return 0
}

# === Adapter / role / runner resolution =====================================

resolve_atmux_runner() {
  if [[ -z "${ATMUX_SOURCE_ROOT:-}" && -n "${TMUX:-}" ]]; then
    tmux_source_root="$(tmux show-environment ATMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^ATMUX_SOURCE_ROOT=//p' || true)"
    if [[ -n "$tmux_source_root" ]]; then
      ATMUX_SOURCE_ROOT="$tmux_source_root"
    fi
  fi
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/atmux" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/bin/atmux"
    return
  fi

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/bin/atmux" ]]; then
      printf '%s\n' "$repo_root/bin/atmux"
      return
    fi
  fi

  if command -v atmux >/dev/null 2>&1; then
    printf '%s\n' atmux
    return
  fi

  echo "atmux command not found" >&2
  exit 127
}

resolve_role_runner() {
  local here
  here="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$here/role" ]]; then
    printf '%s\n' "$here/role"
    return 0
  fi
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/(atmux)/role" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/bin/(atmux)/role"
    return 0
  fi
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  if [[ -x "$atmux_home/src/atmux/bin/(atmux)/role" ]]; then
    printf '%s\n' "$atmux_home/src/atmux/bin/(atmux)/role"
    return 0
  fi
  return 1
}

read_role_manifest() {
  local manifest_path="$1"
  [[ -f "$manifest_path" ]] || return 0
  (
    KIND=""
    INTELLIGENCE=""
    ADAPTERS=()
    # shellcheck source=/dev/null
    source "$manifest_path"
    case "${KIND}" in
      agent|team) printf 'KIND=%s\n' "$KIND" ;;
      "")         printf 'KIND=agent\n' ;;
      *)          printf 'KIND=agent\n' ;;
    esac
    printf 'INTELLIGENCE=%s\n' "$INTELLIGENCE"
    if [[ "${#ADAPTERS[@]}" -gt 0 ]]; then
      local IFS=,
      printf 'ADAPTERS=%s\n' "${ADAPTERS[*]}"
    else
      printf 'ADAPTERS=\n'
    fi
  )
}

resolve_adapter_cmd_path() {
  local adapter="$1"
  local source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"
  local repo_root=""

  if [[ -n "$source_root" && -x "$source_root/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "$source_root/adapter/$adapter/cmd"
    return 0
  fi

  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/adapter/$adapter/cmd" ]]; then
      printf '%s\n' "$repo_root/adapter/$adapter/cmd"
      return 0
    fi
  fi

  if [[ -x "$ATMUX_HOME/adapters/$adapter/cmd" ]]; then
    printf '%s\n' "$ATMUX_HOME/adapters/$adapter/cmd"
    return 0
  fi

  return 1
}

resolve_adapter_cmd_for_session() {
  local session="$1"
  local adapter source_root
  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  source_root="$(get_session_env "$session" ATMUX_SOURCE_ROOT)"
  [[ -n "$adapter" ]] || adapter="codex"

  if [[ -n "$source_root" && -x "$source_root/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "$source_root/adapter/$adapter/cmd"
    return 0
  fi
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/adapter/$adapter/cmd"
    return 0
  fi

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/adapter/$adapter/cmd" ]]; then
      printf '%s\n' "$repo_root/adapter/$adapter/cmd"
      return 0
    fi
  fi

  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  if [[ -x "$atmux_home/adapters/$adapter/cmd" ]]; then
    printf '%s\n' "$atmux_home/adapters/$adapter/cmd"
    return 0
  fi

  return 1
}

resolve_shim_runner() {
  local here
  here="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$here/shim" ]]; then
    printf '%s\n' "$here/shim"
    return 0
  fi
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/(atmux)/shim" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/bin/(atmux)/shim"
    return 0
  fi
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  if [[ -x "$atmux_home/src/atmux/bin/(atmux)/shim" ]]; then
    printf '%s\n' "$atmux_home/src/atmux/bin/(atmux)/shim"
    return 0
  fi
  return 1
}

default_agent_shims() {
  printf '%s\n' git
  local installed_dir="${ATMUX_HOME}/shims"
  local dir name seen=" git "
  [[ -d "$installed_dir" ]] || return 0
  while IFS= read -r dir; do
    [[ -d "$dir" ]] || continue
    name="$(basename "$dir")"
    shim_name_valid "$name" || continue
    case "$seen" in *" $name "*) continue ;; esac
    printf '%s\n' "$name"
    seen="$seen$name "
  done < <(find "$installed_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
}

read_shim_binaries() {
  local shim_dir="$1"
  local manifest="$shim_dir/manifest" kind
  kind="$(read_manifest_scalar_assignment "$manifest" KIND || true)"
  [[ "$kind" == "path-prefix" ]] || { echo "unsupported shim KIND: ${kind:-missing}" >&2; return 1; }
  read_manifest_array_assignment "$manifest" BINARIES
}

write_shim_proxy() {
  local proxy_path="$1" binary="$2" shim_dir="$3" shim_exec="$4" active_dirs="$5" proxy_dir="$6"
  {
    printf '%s\n' '#!/usr/bin/env bash'
    printf '%s\n' 'set -euo pipefail'
    printf 'binary=%q\n' "$binary"
    printf 'shim_dir=%q\n' "$shim_dir"
    printf 'shim_exec=%q\n' "$shim_exec"
    printf 'active_dirs=%q\n' "$active_dirs"
    printf 'proxy_dir=%q\n' "$proxy_dir"
    cat <<'PROXY'
strip_path() {
  local out="" part skip
  local IFS=:
  for part in $PATH; do
    [[ -n "$part" ]] || continue
    skip=0
    [[ "$part" == "$proxy_dir" ]] && skip=1
    local active
    for active in $active_dirs; do
      [[ "$part" == "$active" ]] && skip=1
    done
    [[ "$skip" -eq 0 ]] || continue
    case ":$out:" in *":$part:"*) continue ;; esac
    if [[ -z "$out" ]]; then out="$part"; else out="$out:$part"; fi
  done
  printf '%s\n' "$out"
}

sanitized_path="$(strip_path)"
real_binary="$(PATH="$sanitized_path" command -v "$binary" 2>/dev/null || true)"
if [[ -z "$real_binary" ]]; then
  echo "atmux shim proxy: cannot find real $binary executable" >&2
  exit 127
fi

export PATH="$sanitized_path"
export ATMUX_SHIM_BINARY="$binary"
export ATMUX_SHIM_REAL_BINARY="$real_binary"
export ATMUX_SHIM_DIR="$shim_dir"
export ATMUX_ACTIVE_SHIM_DIRS="$active_dirs"
export ATMUX_SHIM_PROXY_DIR="$proxy_dir"
exec "$shim_exec" "$@"
PROXY
  } > "$proxy_path"
  chmod +x "$proxy_path"
}

activate_agent_shims() {
  local shim_runner shim_name shim_dir binary active_dirs="" provided="" proxy_dir seen_shims=""
  shim_runner="$(resolve_shim_runner)" || { echo "atmux: shim command not found" >&2; return 1; }

  local -a shim_names=()
  while IFS= read -r shim_name; do
    [[ -n "$shim_name" ]] || continue
    shim_name_valid "$shim_name" || { echo "atmux: invalid default shim name: $shim_name" >&2; return 1; }
    case " $seen_shims " in *" $shim_name "*) continue ;; esac
    shim_names+=("$shim_name")
    seen_shims="$seen_shims $shim_name"
  done < <(default_agent_shims)

  ((${#shim_names[@]})) || return 0

  local state_base="${ATMUX_HOME}/agents/${ATMUX_REPO:-repo}/${ATMUX_AGENT_NAME:-agent}/shims"
  proxy_dir="$state_base/bin"
  rm -rf "$state_base"
  mkdir -p "$proxy_dir"

  local -a shim_dirs=()
  for shim_name in "${shim_names[@]}"; do
    shim_dir="$("$shim_runner" resolve "$shim_name")" || return 1
    shim_dirs+=("$shim_dir")
    if [[ -z "$active_dirs" ]]; then active_dirs="$shim_dir"; else active_dirs="$active_dirs:$shim_dir"; fi
  done

  local i
  for i in "${!shim_names[@]}"; do
    shim_name="${shim_names[$i]}"
    shim_dir="${shim_dirs[$i]}"
    while IFS= read -r binary; do
      [[ -n "$binary" ]] || continue
      shim_binary_valid "$binary" || { echo "atmux: invalid binary in shim $shim_name: $binary" >&2; return 1; }
      case " $provided " in
        *" $binary "*) echo "atmux: duplicate shim binary requested: $binary" >&2; return 1 ;;
      esac
      [[ -x "$shim_dir/$binary" ]] || { echo "atmux: shim binary is not executable: $shim_dir/$binary" >&2; return 1; }
      write_shim_proxy "$proxy_dir/$binary" "$binary" "$shim_dir" "$shim_dir/$binary" "$active_dirs" "$proxy_dir"
      provided="$provided $binary"
    done < <(read_shim_binaries "$shim_dir")
  done

  export ATMUX_ACTIVE_SHIM_DIRS="$active_dirs"
  export ATMUX_SHIM_PROXY_DIR="$proxy_dir"
  export PATH="$proxy_dir:$PATH"
}

resolve_auto_candidates() {
  local auto_cmd=""
  auto_cmd="$(resolve_adapter_cmd_path "auto" || true)"
  [[ -x "$auto_cmd" ]] || return 1

  ATMUX_HOME="$ATMUX_HOME" ATMUX_SOURCE_ROOT="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}" "$auto_cmd" select --all 2>/dev/null
}

split_adapter_list() {
  local list="$1"
  printf '%s\n' "$list" | tr ',' '\n' | awk '
    {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
      if ($0 != "") print
    }
  '
}

adapter_name_valid() {
  local adapter="$1"
  [[ "$adapter" =~ ^[A-Za-z0-9_.-]+$ ]]
}

resolve_real_tmux_bin() {
  local candidate=""

  if [[ -n "${ATMUX_REAL_TMUX:-}" && -x "$ATMUX_REAL_TMUX" ]]; then
    printf '%s\n' "$ATMUX_REAL_TMUX"
    return 0
  fi

  for candidate in /opt/homebrew/bin/tmux /usr/local/bin/tmux /usr/bin/tmux /bin/tmux; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  candidate="$(command -v tmux 2>/dev/null || true)"
  if [[ -n "$candidate" && -x "$candidate" && "$candidate" != "${ATMUX_SOURCE_ROOT:-}/bin/tmux" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

adapter_in_list() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

# === Misc utilities =========================================================

matches_any_pattern() {
  local value="$1"
  shift || true
  local pattern
  for pattern in "$@"; do
    case "$value" in
      $pattern) return 0 ;;
    esac
  done
  return 1
}

build_notification() {
  "${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}/bin/(atmux)/notify" build "$@"
}

valid_intelligence() {
  local value="${1:-}"
  [[ "$value" =~ ^[0-9]+$ ]] || return 1
  (( value >= 0 && value <= 100 ))
}

# === Attach / bootstrap helpers (from old session) ==========================

attach_or_switch() {
  local session="$1"
  if [[ ! -t 0 || ! -t 1 ]]; then
    printf '%s\n' "$session"
    return
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

ensure_tmux_pane_defaults() {
  local history_limit mouse_mode
  history_limit="${ATMUX_TMUX_HISTORY_LIMIT:-200000}"
  mouse_mode="${ATMUX_TMUX_MOUSE:-off}"
  case "$mouse_mode" in
    on|off) ;;
    *) mouse_mode="off" ;;
  esac

  tmux set-window-option -g history-limit "$history_limit" >/dev/null 2>&1 || true

  while IFS= read -r window_id; do
    [[ -z "$window_id" ]] && continue
    tmux set-window-option -t "$window_id" history-limit "$history_limit" >/dev/null 2>&1 || true
  done < <(tmux list-windows -a -F '#{window_id}' 2>/dev/null || true)

  # Default mouse off for managed agent sessions. Mouse wheel scrolling puts
  # tmux panes into copy-mode, and notification delivery intentionally waits
  # while a pane is in copy-mode so it cannot paste into the mode layer.
  if [[ -n "${1:-}" ]]; then
    tmux set-option -t "$1" mouse "$mouse_mode" >/dev/null 2>&1 || true
  fi
}

initialize_worktree_submodules() {
  local worktree="$1"
  local submodule_err=""

  [[ -f "$worktree/.gitmodules" ]] || return 0

  git -C "$worktree" submodule sync --recursive >/dev/null
  submodule_err="$(git -C "$worktree" submodule update --init --recursive 2>&1)" || {
    printf '%s\n' "$submodule_err" >&2
    exit 1
  }
}

# === Control file injection (from old session) ==============================

collect_agent_help() {
  local runner="$1"
  local runner_cwd="${2:-}"
  local out=""
  local cmd
  for cmd in create list send message schedule assign comment capture kill exec watch env; do
    local cmd_out=""
    if [[ -n "$runner_cwd" ]]; then
      cmd_out="$(cd "$runner_cwd" && ATMUX_NO_WRAP=1 ATMUX_ALLOW_OUTSIDE_TMUX=1 "$runner" "$cmd" --help 2>/dev/null || true)"
    else
      cmd_out="$(ATMUX_NO_WRAP=1 ATMUX_ALLOW_OUTSIDE_TMUX=1 "$runner" "$cmd" --help 2>/dev/null || true)"
    fi
    if [[ -n "$cmd_out" ]] && printf '%s\n' "$cmd_out" | grep -Eq "^  atmux ${cmd}( |$)"; then
      out+=$'## '"$cmd"$'\n'
      out+="$cmd_out"$'\n\n'
    fi
  done
  printf '%s' "$out"
}

render_managed_block() {
  local repo_root="$1"
  local role_name="${ATMUX_ROLE:-}"
  local manager_value="${ATMUX_MANAGER:-}"
  local atmux_runner=""
  local atmux_help=""
  local source_root="${ATMUX_SOURCE_ROOT:-}"

  if [[ -n "$source_root" && -x "$source_root/bin/atmux" ]]; then
    atmux_runner="$source_root/bin/atmux"
  elif [[ -x "$repo_root/bin/atmux" ]]; then
    atmux_runner="$repo_root/bin/atmux"
  elif command -v atmux >/dev/null 2>&1; then
    atmux_runner="atmux"
  fi

  if [[ -n "$atmux_runner" ]]; then
    if [[ -n "$source_root" && -d "$source_root" ]]; then
      atmux_help="$(collect_agent_help "$atmux_runner" "$source_root")"
    else
      atmux_help="$(collect_agent_help "$atmux_runner")"
    fi
  fi

  {
    echo "<atmux>"
    if [[ -n "$role_name" ]]; then
      echo "# Role"
      echo "- ROLE: $role_name"
      if [[ -n "${ATMUX_ROLE_DIR:-}" && -f "$ATMUX_ROLE_DIR/role.md" ]]; then
        echo
        # role.md supports a small templating vocabulary so prompts can
        # reference team-specific identifiers (e.g. peer agent names like
        # `${ATMUX_TEAM}-driver` for a multi-instance team role). Only a
        # curated whitelist of ATMUX_* vars is substituted to avoid
        # surprise expansion of unrelated env. ${VAR} form only — the
        # bare $VAR form is intentionally not supported because it
        # makes accidental matches against PATH-like prefixes too easy.
        # Values are escaped before interpolation so sed metacharacters
        # in them (`&`, `\`, the delimiter `|`) substitute literally —
        # ATMUX_WORKTREE is a filesystem path and could plausibly carry
        # any of these in user-chosen checkout locations.
        sed_escape_replacement() {
          # Escapes \, &, and | (our chosen sed delimiter) for use in
          # the replacement side of `s|pat|repl|`.
          printf '%s' "$1" | sed -e 's/[\\&|]/\\&/g'
        }
        local _t _r _a _w _ro
        _t="$(sed_escape_replacement "${ATMUX_TEAM:-}")"
        _r="$(sed_escape_replacement "${ATMUX_REPO:-}")"
        _a="$(sed_escape_replacement "${ATMUX_AGENT_NAME:-}")"
        _w="$(sed_escape_replacement "${ATMUX_WORKTREE:-}")"
        _ro="$(sed_escape_replacement "${ATMUX_ROLE:-}")"
        sed -E 's@^</?atmux>$@@' "$ATMUX_ROLE_DIR/role.md" \
          | sed \
              -e "s|\${ATMUX_TEAM}|${_t}|g" \
              -e "s|\${ATMUX_REPO}|${_r}|g" \
              -e "s|\${ATMUX_AGENT_NAME}|${_a}|g" \
              -e "s|\${ATMUX_WORKTREE}|${_w}|g" \
              -e "s|\${ATMUX_ROLE}|${_ro}|g"
      fi
      echo
    fi
    echo "# atmux Rules"
    echo "- Use plain \`atmux ...\` commands; do not prefix them with inherited session environment."
    echo
    if [[ -z "$manager_value" ]]; then
      echo "# Delegation Rules"
      echo "- ALWAYS check \`atmux agent list --all --status\` first."
      echo "- ALWAYS assign to an existing idle capable agent before creating a new one."
      echo "- ONLY create a new agent when no idle agent matches the required capability/intelligence."
      echo "- ALWAYS include clear task scope via \`--description\` and \`--todos\`."
      echo "- ALWAYS use \`--reply-required\` for decisions/blockers."
      echo "- NEVER poll agent panes unless absolutely necessary."
      echo "- NEVER do tasks yourself unless explicitly instructed."
      echo
    else
      echo "# Managed Agent Rules"
      echo "- ALWAYS acknowledge manager messages quickly with a short plan."
      echo "- ALWAYS send a message to your manager when stuck or after completing any task."
      echo "- ALWAYS message your manager with \`atmux send --to ${manager_value} \"...\"\`."
      echo "- ALWAYS coordinate with peer agents using \`atmux send --to <agent> \"...\"\`."
      echo "- ALWAYS check \`atmux agent list --all --status\` before creating new agents."
      echo "- ALWAYS reuse idle capable agents before creating new ones."
      echo "- ALWAYS spawn agents to decompose your todos if necessary."
      echo "- ALWAYS use \`--reply-required\` when a manager decision is needed."
      echo "- NEVER poll agent panes unless absolutely necessary."
      echo "- NEVER silently change scope; ask your manager first."
      echo "- NEVER report task completion without validation evidence."
      echo "- NEVER leave blockers unreported; escalate immediately."
      echo
    fi
    echo "# atmux help"
    if [[ -n "$atmux_help" ]]; then
      printf '%s\n' "$atmux_help"
    fi
    echo "</atmux>"
  }
}

prepare_atmux_prompt() {
  local repo_root="$1"
  local adapter="${ATMUX_ADAPTER:-codex}"
  local adapter_cmd=""

  adapter_cmd="$(resolve_adapter_cmd_path "$adapter" || true)"
  [[ -x "$adapter_cmd" ]] || return 0

  local prep_dir="${ATMUX_HOME:-$HOME/.atmux}/agents/${ATMUX_REPO:-repo}/${ATMUX_AGENT_NAME:-agent}/prep"
  mkdir -p "$prep_dir"
  : > "$prep_dir/args"
  : > "$prep_dir/env"
  render_managed_block "$repo_root" > "$prep_dir/prompt.md"

  ATMUX_PREP_ARGS_FILE="$prep_dir/args" \
  ATMUX_PREP_ENV_FILE="$prep_dir/env" \
    "$adapter_cmd" prepare-prompt < "$prep_dir/prompt.md" || true

  export ATMUX_PREP_DIR="$prep_dir"
  export ATMUX_PREP_ARGS_FILE="$prep_dir/args"
  export ATMUX_PREP_ENV_FILE="$prep_dir/env"
}

run_role_hook() {
  local cmd="$1"
  [[ -n "$cmd" ]] || return 0
  if [[ -x "$cmd" && -f "$cmd" ]]; then
    "$cmd"
  else
    bash -c "$cmd"
  fi
}

run_role_hook_bounded() {
  local cmd="$1"
  local budget_secs="${2:-30}"
  local pid deadline now
  [[ -n "$cmd" ]] || return 0
  ( run_role_hook "$cmd" ) &
  pid=$!
  deadline=$(( $(date +%s) + budget_secs ))
  while kill -0 "$pid" 2>/dev/null; do
    now="$(date +%s)"
    if (( now >= deadline )); then
      kill -TERM "$pid" 2>/dev/null || true
      sleep 0.5
      kill -KILL "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
      return 124
    fi
    sleep 0.2
  done
  wait "$pid"
}

# === run_adapter (the in-pane bootstrap that execs the adapter) =============

run_adapter() {
  local adapter="codex"
  local requested_adapter=""
  local adapters_list="${ATMUX_ADAPTERS_ALLOWED:-}"
  local -a adapter_args=()
  local -a allowed_adapters=()
  local real_tmux=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --adapter)
        adapter="${2:-}"
        shift 2
        ;;
      --adapters)
        adapters_list="${2:-}"
        shift 2
        ;;
      --)
        shift
        adapter_args=("$@")
        break
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -n "$adapters_list" ]]; then
    local allowed_adapter
    while IFS= read -r allowed_adapter; do
      [[ -n "$allowed_adapter" ]] || continue
      if ! adapter_name_valid "$allowed_adapter"; then
        echo "invalid adapter name in --adapters: $allowed_adapter" >&2
        exit 2
      fi
      allowed_adapters+=("$allowed_adapter")
    done < <(split_adapter_list "$adapters_list")
    if ((${#allowed_adapters[@]} == 0)); then
      echo "--adapters requires at least one adapter" >&2
      exit 2
    fi
  fi

  requested_adapter="$adapter"
  if [[ "$requested_adapter" != "auto" && ${#allowed_adapters[@]} -gt 0 ]]; then
    if ! adapter_in_list "$requested_adapter" "${allowed_adapters[@]}"; then
      echo "adapter not allowed by --adapters: $requested_adapter" >&2
      exit 2
    fi
  fi

  export ATMUX_ADAPTER_REQUESTED="$requested_adapter"
  export ATMUX_ADAPTERS_ALLOWED="$adapters_list"
  real_tmux="$(resolve_real_tmux_bin || true)"
  if [[ -n "$real_tmux" ]]; then
    export ATMUX_REAL_TMUX="$real_tmux"
  fi
  export ATMUX_ALLOW_REAL_TMUX=1

  if [[ -z "${ATMUX_SOURCE_ROOT:-}" ]]; then
    if [[ -d "${ATMUX_HOME}/src/atmux" ]]; then
      ATMUX_SOURCE_ROOT="${ATMUX_HOME}/src/atmux"
    else
      ATMUX_SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
    fi
    export ATMUX_SOURCE_ROOT
  fi
  # Non-login tmux panes often lack user-local PATH (Cursor CLI, Homebrew, etc.).
  export PATH="${HOME}/.local/bin:${HOME}/.cursor/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
  if [[ -d "$ATMUX_SOURCE_ROOT/bin" ]]; then
    export PATH="$ATMUX_SOURCE_ROOT/bin:$(pwd)/bin:$PATH"
  else
    export PATH="$(pwd)/bin:$PATH"
  fi

  local current_session=""
  if [[ -n "${TMUX:-}" ]]; then
    current_session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$current_session" ]]; then
    while IFS= read -r line; do
      [[ "$line" == ATMUX_*=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      export "$key=$value"
    done < <(tmux show-environment -t "$current_session" 2>/dev/null || true)
  fi

  local -a candidates=()
  if [[ "$requested_adapter" == "auto" ]]; then
    if ((${#allowed_adapters[@]} > 0)); then
      candidates=("${allowed_adapters[@]}")
    else
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        candidates+=("$line")
      done < <(resolve_auto_candidates || true)
    fi
  else
    candidates=("$requested_adapter")
  fi

  if ((${#candidates[@]} == 0)); then
    candidates=("codex")
  fi

  local rc=127
  local selected_adapter=""
  local adapter_cmd=""
  local candidate=""
  for candidate in "${candidates[@]}"; do
    adapter_cmd="$(resolve_adapter_cmd_path "$candidate" || true)"
    if [[ ! -x "$adapter_cmd" ]]; then
      rc=127
      if [[ "$requested_adapter" == "auto" ]]; then
        continue
      fi
      echo "adapter start not found: $candidate" >&2
      break
    fi

    selected_adapter="$candidate"
    export ATMUX_ADAPTER="$selected_adapter"
    export ATMUX_ADAPTER_SELECTED="$selected_adapter"
    if [[ -n "$current_session" ]]; then
      tmux set-environment -t "$current_session" ATMUX_ADAPTER "$selected_adapter"
      tmux set-environment -t "$current_session" ATMUX_ADAPTER_REQUESTED "$requested_adapter"
      tmux set-environment -t "$current_session" ATMUX_ADAPTER_SELECTED "$selected_adapter"
      if [[ -n "$adapters_list" ]]; then
        tmux set-environment -t "$current_session" ATMUX_ADAPTERS_ALLOWED "$adapters_list"
      else
        tmux set-environment -t "$current_session" -u ATMUX_ADAPTERS_ALLOWED >/dev/null 2>&1 || true
      fi
    fi

    prepare_atmux_prompt "$(pwd)"
    activate_agent_shims

    if [[ -n "${ATMUX_ROLE_START:-}" ]]; then
      ATMUX_ROLE_STATE_DIR="${ATMUX_HOME}/agents/${ATMUX_REPO:-repo}/${ATMUX_AGENT_NAME:-agent}/role"
      mkdir -p "$ATMUX_ROLE_STATE_DIR"
      export ATMUX_ROLE_STATE_DIR
      if [[ -n "$current_session" ]]; then
        tmux set-environment -t "$current_session" ATMUX_ROLE_STATE_DIR "$ATMUX_ROLE_STATE_DIR" >/dev/null 2>&1 || true
      fi
      role_start_rc=0
      run_role_hook_bounded "$ATMUX_ROLE_START" "${ATMUX_ROLE_START_TIMEOUT:-60}" || role_start_rc=$?
      if [[ "$role_start_rc" -eq 0 && -n "$current_session" ]]; then
        tmux set-environment -t "$current_session" ATMUX_ROLE_START_STATE ready >/dev/null 2>&1 || true
      fi
      if [[ "$role_start_rc" -ne 0 ]]; then
        if [[ "$role_start_rc" -eq 124 ]]; then
          echo "atmux: role start timed out after ${ATMUX_ROLE_START_TIMEOUT:-60}s; aborting agent" >&2
        else
          echo "atmux: role start failed (rc=$role_start_rc); aborting agent" >&2
        fi
        local fail_worktree="${ATMUX_WORKTREE:-}"
        local fail_session="$current_session"
        # Only clean up worktrees that atmux itself created. Atmux-owned
        # worktrees live under $ATMUX_HOME (e.g. agents/<repo>/<agent>/worktree
        # or teams/<repo>/<team>/worktree). Anything else is the caller's —
        # most importantly, --shared-worktree exposes the *caller's pwd*
        # as ATMUX_WORKTREE, which can be an actual user repo. Without
        # this guard, a role_start failure would `rm -rf` the user's repo
        # via the `git worktree remove` fallback path below.
        local atmux_owned_root=""
        if [[ -n "${ATMUX_HOME:-}" ]]; then
          atmux_owned_root="$(cd -- "$ATMUX_HOME" 2>/dev/null && pwd -P)" || atmux_owned_root=""
        fi
        local fail_worktree_real=""
        if [[ -n "$fail_worktree" ]]; then
          fail_worktree_real="$(cd -- "$fail_worktree" 2>/dev/null && pwd -P)" || fail_worktree_real=""
        fi
        local atmux_owned=0
        if [[ -n "$atmux_owned_root" && -n "$fail_worktree_real" \
              && "$fail_worktree_real" == "$atmux_owned_root"/* ]]; then
          atmux_owned=1
        fi
        if [[ "$atmux_owned" -eq 1 && -n "$fail_worktree" && -d "$fail_worktree" ]]; then
          local repo_for_cleanup=""
          repo_for_cleanup="$(git -C "$fail_worktree" rev-parse --show-toplevel 2>/dev/null || true)"
          if [[ -n "$repo_for_cleanup" ]] && \
             git -C "$repo_for_cleanup" worktree list --porcelain 2>/dev/null | grep -Fqx "worktree $fail_worktree"; then
            git -C "$repo_for_cleanup" worktree remove -f "$fail_worktree" >/dev/null 2>&1 || rm -rf "$fail_worktree"
          else
            rm -rf "$fail_worktree"
          fi
          if [[ -n "$repo_for_cleanup" && -n "$fail_session" ]]; then
            git -C "$repo_for_cleanup" branch -D "$fail_session" >/dev/null 2>&1 || true
          fi
        elif [[ -n "$fail_worktree" ]]; then
          # Shared / user-supplied worktree — leave the filesystem alone.
          echo "atmux: leaving worktree at $fail_worktree (not atmux-owned)" >&2
        fi
        if [[ -n "$fail_session" ]] && tmux has-session -t "$fail_session" 2>/dev/null; then
          tmux set-environment -t "$fail_session" ATMUX_ROLE_START_STATE failed >/dev/null 2>&1 || true
        fi
        if [[ -n "$fail_session" ]] && tmux has-session -t "$fail_session" 2>/dev/null; then
          tmux kill-session -t "$fail_session" >/dev/null 2>&1 || true
        fi
        exit 1
      fi
    fi

    rc=0
    (
      unset ATMUX_ALLOW_REAL_TMUX

      # Apply env directives produced by prepare-prompt so the adapter
      # inherits them (e.g. GEMINI_SYSTEM_MD).
      if [[ -n "${ATMUX_PREP_ENV_FILE:-}" && -s "$ATMUX_PREP_ENV_FILE" ]]; then
        while IFS= read -r prep_env_line; do
          [[ -n "$prep_env_line" ]] || continue
          [[ "$prep_env_line" == *=* ]] || continue
          export "${prep_env_line?}"
        done < "$ATMUX_PREP_ENV_FILE"
      fi

      # Read null-separated argv from prepare-prompt and prepend.
      declare -a prep_args=()
      if [[ -n "${ATMUX_PREP_ARGS_FILE:-}" && -s "$ATMUX_PREP_ARGS_FILE" ]]; then
        while IFS= read -r -d '' prep_arg; do
          prep_args+=("$prep_arg")
        done < "$ATMUX_PREP_ARGS_FILE"
      fi

      declare -a combined_args=()
      ((${#prep_args[@]})) && combined_args+=("${prep_args[@]}")
      ((${#adapter_args[@]})) && combined_args+=("${adapter_args[@]}")

      if ((${#combined_args[@]})); then
        "$adapter_cmd" start "${combined_args[@]}"
      else
        "$adapter_cmd" start
      fi
    ) || rc=$?
    export ATMUX_ALLOW_REAL_TMUX=1

    if [[ "$rc" -eq 0 ]]; then
      break
    fi

    if [[ "$requested_adapter" == "auto" && "$rc" -eq 127 ]]; then
      continue
    fi
    break
  done

  if [[ -z "$selected_adapter" ]]; then
    echo "no adapter available" >&2
    rc=127
  fi

  local session_name="${ATMUX_SESSION_NAME:-}"
  if [[ -z "$session_name" && -n "${TMUX:-}" ]]; then
    session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$session_name" ]] && tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
  fi
  exit "$rc"
}

# === Session lifecycle (start / attach) =====================================

# Build the new tmux session, set its environment, queue _run-adapter into
# its primary pane, and (when interactive) attach. Returns the session name
# on stdout. Used by both top-level and sub-agent `agent create`.
spawn_agent_session() {
  local name=""
  local adapter="codex"
  local adapter_explicit=0
  local adapters_list=""
  local team="${ATMUX_TEAM:-}"
  local intelligence="${ATMUX_INTELLIGENCE:-20}"
  local name_explicit=0
  local shared_worktree=0
  local real_tmux=""
  local -a forward_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name="${2:-}"
        name_explicit=1
        shift 2
        ;;
      --adapter)
        adapter="${2:-}"
        adapter_explicit=1
        shift 2
        ;;
      --adapters)
        adapters_list="${2:-}"
        shift 2
        ;;
      --shared-worktree)
        shared_worktree=1
        shift
        ;;
      --no-worktree)
        shared_worktree=1
        shift
        ;;
      --)
        shift
        forward_args=("$@")
        break
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -n "$adapters_list" && "$adapter_explicit" -eq 0 ]]; then
    adapter="auto"
  fi

  local -a allowed_adapters=()
  if [[ -n "$adapters_list" ]]; then
    local allowed_adapter
    while IFS= read -r allowed_adapter; do
      [[ -n "$allowed_adapter" ]] || continue
      if ! adapter_name_valid "$allowed_adapter"; then
        echo "invalid adapter name in --adapters: $allowed_adapter" >&2
        exit 2
      fi
      allowed_adapters+=("$allowed_adapter")
    done < <(split_adapter_list "$adapters_list")
    if ((${#allowed_adapters[@]} == 0)); then
      echo "--adapters requires at least one adapter" >&2
      exit 2
    fi
    if [[ "$adapter" != "auto" ]] && ! adapter_in_list "$adapter" "${allowed_adapters[@]}"; then
      echo "adapter not allowed by --adapters: $adapter" >&2
      exit 2
    fi
  fi

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  local source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"

  if [[ "$name_explicit" -eq 0 ]]; then
    local n
    n="$(
      (tmux list-sessions -F '#{session_name}' 2>/dev/null || true) \
        | awk -v p="^atmux-${repo_name}-agent-[0-9]+$" '$0 ~ p { c++ } END { print c+0 }'
    )"
    name="agent-$n"
    while tmux has-session -t "atmux-${repo_name}-${name}" 2>/dev/null; do
      n=$((n + 1))
      name="agent-$n"
    done
  fi

  local session="atmux-${repo_name}-${name}"
  local worktree="$ATMUX_HOME/agents/${repo_name}-${name}"
  local branch="atmux-${repo_name}-${name}"

  if tmux has-session -t "$session" 2>/dev/null; then
    local existing_adapter existing_source_root existing_manager existing_role existing_team existing_intelligence
    existing_adapter="$(tmux show-environment -t "$session" ATMUX_ADAPTER 2>/dev/null | sed -n 's/^ATMUX_ADAPTER=//p' || true)"
    existing_source_root="$(tmux show-environment -t "$session" ATMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^ATMUX_SOURCE_ROOT=//p' || true)"
    existing_manager="$(tmux show-environment -t "$session" ATMUX_MANAGER 2>/dev/null | sed -n 's/^ATMUX_MANAGER=//p' || true)"
    existing_role="$(tmux show-environment -t "$session" ATMUX_ROLE 2>/dev/null | sed -n 's/^ATMUX_ROLE=//p' || true)"
    existing_team="$(tmux show-environment -t "$session" ATMUX_TEAM 2>/dev/null | sed -n 's/^ATMUX_TEAM=//p' || true)"
    existing_intelligence="$(tmux show-environment -t "$session" ATMUX_INTELLIGENCE 2>/dev/null | sed -n 's/^ATMUX_INTELLIGENCE=//p' || true)"
    if [[ -n "$existing_adapter" ]]; then
      export ATMUX_ADAPTER="$existing_adapter"
    else
      export ATMUX_ADAPTER="$adapter"
    fi
    export ATMUX_REPO="$repo_name"
    export ATMUX_MANAGER="$existing_manager"
    export ATMUX_ROLE="$existing_role"
    if [[ -n "$existing_team" ]]; then
      export ATMUX_TEAM="$existing_team"
    else
      export ATMUX_TEAM="$team"
    fi
    if [[ -n "$existing_intelligence" ]]; then
      export ATMUX_INTELLIGENCE="$existing_intelligence"
    else
      export ATMUX_INTELLIGENCE="$intelligence"
    fi
    if [[ -n "$existing_source_root" && -d "$existing_source_root" ]]; then
      export ATMUX_SOURCE_ROOT="$existing_source_root"
    else
      export ATMUX_SOURCE_ROOT="$repo_root"
    fi
    ensure_tmux_scroll_enabled
    attach_or_switch "$session"
    return
  fi

  local work_dir="$worktree"
  local worktree_created=0

  if [[ "$shared_worktree" -eq 1 ]]; then
    # `--shared-worktree` shares the *caller's* worktree. When invoked from
    # a team session (or another agent's pane) the caller's tmux env carries
    # ATMUX_WORKTREE, which is the right path to inherit. Falling back to
    # $repo_root preserves the original outside-tmux behavior.
    if [[ -n "${ATMUX_WORKTREE:-}" && -d "$ATMUX_WORKTREE" ]]; then
      work_dir="$ATMUX_WORKTREE"
    else
      work_dir="$repo_root"
    fi
  else
    mkdir -p "$ATMUX_HOME/agents"

    if [[ -e "$worktree" ]]; then
      if ! git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "path exists and is not a git worktree: $worktree" >&2
        exit 1
      fi
    else
      worktree_err="$(
        git -C "$repo_root" worktree add -B "$branch" "$worktree" HEAD 2>&1
      )" || {
        if printf '%s\n' "$worktree_err" | grep -Eq 'cannot lock ref|Operation not permitted|Permission denied'; then
          echo "branch creation failed; retrying detached worktree for $worktree" >&2
          git -C "$repo_root" worktree add "$worktree" HEAD >/dev/null
          worktree_created=1
        else
          printf '%s\n' "$worktree_err" >&2
          exit 1
        fi
      }
      worktree_created=1
    fi
    if [[ "$worktree_created" -eq 1 ]]; then
      initialize_worktree_submodules "$worktree"
    fi
  fi

  local session_id
  session_id="$(id)"

  tmux new-session -d -s "$session" -n "$session" -c "$work_dir"
  ensure_tmux_pane_defaults "$session"
  tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
  tmux set-environment -t "$session" ATMUX_HOME "$ATMUX_HOME"
  tmux set-environment -t "$session" ATMUX_SESSION_ID "$session_id"
  tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"
  tmux set-environment -t "$session" ATMUX_WORKTREE "$work_dir"
  tmux set-environment -t "$session" ATMUX_SOURCE_ROOT "$source_root"
  real_tmux="$(resolve_real_tmux_bin || true)"
  if [[ -n "$real_tmux" ]]; then
    tmux set-environment -t "$session" ATMUX_REAL_TMUX "$real_tmux"
  fi
  tmux set-environment -t "$session" ATMUX_AGENT_NAME "$name"
  tmux set-environment -t "$session" ATMUX_ADAPTER "$adapter"
  tmux set-environment -t "$session" ATMUX_ADAPTER_REQUESTED "$adapter"
  tmux set-environment -t "$session" ATMUX_ADAPTER_SELECTED "$adapter"
  if [[ -n "$adapters_list" ]]; then
    tmux set-environment -t "$session" ATMUX_ADAPTERS_ALLOWED "$adapters_list"
  fi
  tmux set-environment -t "$session" ATMUX_INTELLIGENCE "$intelligence"
  if [[ -n "${ATMUX_MODEL:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_MODEL "$ATMUX_MODEL"
  fi
  if [[ -n "${ATMUX_REASONING_LEVEL:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_REASONING_LEVEL "$ATMUX_REASONING_LEVEL"
  fi
  if [[ -n "${ATMUX_ROLE:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_ROLE "$ATMUX_ROLE"
  fi
  if [[ -n "${ATMUX_ROLE_DIR:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_ROLE_DIR "$ATMUX_ROLE_DIR"
  fi
  if [[ -n "${ATMUX_ROLE_START:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_ROLE_START "$ATMUX_ROLE_START"
  fi
  if [[ -n "${ATMUX_ROLE_STOP:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_ROLE_STOP "$ATMUX_ROLE_STOP"
  fi
  if [[ -n "${ATMUX_MANAGER:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_MANAGER "$ATMUX_MANAGER"
  fi
  if [[ -n "${ATMUX_TEAM:-}" ]]; then
    tmux set-environment -t "$session" ATMUX_TEAM "$ATMUX_TEAM"
  fi

  local -a cmd=("$source_root/bin/(atmux)/agent" "_run-adapter" "--adapter" "$adapter")
  if [[ -n "$adapters_list" ]]; then
    cmd+=("--adapters" "$adapters_list")
  fi
  if ((${#forward_args[@]})); then
    cmd+=("--" "${forward_args[@]}")
  fi

  local launch
  printf -v launch '%q ' "${cmd[@]}"
  local launch_pane
  launch_pane="$(primary_pane_for_session "$session")"
  if [[ -z "$launch_pane" ]]; then
    echo "cannot find pane for session: $session" >&2
    exit 1
  fi
  tmux send-keys -t "$launch_pane" "$launch" C-m
  attach_or_switch "$session"
}

attach_agent() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "usage: atmux agent attach <name|session>" >&2
    exit 2
  fi
  if [[ -n "${TMUX:-}" ]]; then
    echo "atmux agent attach must be run outside tmux" >&2
    exit 2
  fi

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  local source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"

  local session
  if tmux has-session -t "$target" 2>/dev/null; then
    session="$target"
  elif [[ "$target" == atmux-* ]]; then
    session="$target"
  elif [[ "$target" == "${repo_name}-"* ]] && tmux has-session -t "atmux-${target}" 2>/dev/null; then
    session="atmux-${target}"
  else
    session="atmux-${repo_name}-${target}"
  fi

  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "session not found: $session" >&2
    exit 1
  fi

  local existing_adapter existing_source_root existing_repo existing_manager existing_role existing_team
  existing_adapter="$(tmux show-environment -t "$session" ATMUX_ADAPTER 2>/dev/null | sed -n 's/^ATMUX_ADAPTER=//p' || true)"
  existing_source_root="$(tmux show-environment -t "$session" ATMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^ATMUX_SOURCE_ROOT=//p' || true)"
  existing_repo="$(tmux show-environment -t "$session" ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  existing_manager="$(tmux show-environment -t "$session" ATMUX_MANAGER 2>/dev/null | sed -n 's/^ATMUX_MANAGER=//p' || true)"
  existing_role="$(tmux show-environment -t "$session" ATMUX_ROLE 2>/dev/null | sed -n 's/^ATMUX_ROLE=//p' || true)"
  existing_team="$(tmux show-environment -t "$session" ATMUX_TEAM 2>/dev/null | sed -n 's/^ATMUX_TEAM=//p' || true)"
  if [[ -n "$existing_adapter" ]]; then
    export ATMUX_ADAPTER="$existing_adapter"
  fi
  if [[ -n "$existing_repo" ]]; then
    export ATMUX_REPO="$existing_repo"
  else
    export ATMUX_REPO="$repo_name"
  fi
  export ATMUX_MANAGER="$existing_manager"
  export ATMUX_ROLE="$existing_role"
  export ATMUX_TEAM="$existing_team"
  if [[ -n "$existing_source_root" && -d "$existing_source_root" ]]; then
    export ATMUX_SOURCE_ROOT="$existing_source_root"
  else
    export ATMUX_SOURCE_ROOT="$repo_root"
  fi
  ensure_tmux_scroll_enabled
  attach_or_switch "$session"
}

# === Team dashboard / status / task helpers (existing) ======================

ensure_team_dashboard_for_agent() {
  local repo_root="$1"
  local repo_name="$2"
  local team_name="$3"
  local agent_session="$4"
  local agent_name="$5"
  local team_session pane_id reusable_pane current_cmd pane_agent
  local team_width team_height pane_count width height
  local hard_min_w hard_min_h
  local team_cap current_count
  local team_history_limit team_alternate_screen

  int_or_default() {
    local value="${1:-}"
    local default_value="$2"
    if [[ "$value" =~ ^[0-9]+$ ]] && (( value > 0 )); then
      printf '%s\n' "$value"
      return
    fi
    printf '%s\n' "$default_value"
  }

  max_int() {
    local a="$1"
    local b="$2"
    if (( a > b )); then
      printf '%s\n' "$a"
    else
      printf '%s\n' "$b"
    fi
  }

  team_dimensions_for_panes() {
    local panes="$1"
    local min_w min_h max_cols cols rows out_w out_h
    min_w="$(int_or_default "${ATMUX_TEAM_MIN_PANE_WIDTH:-120}" 120)"
    min_h="$(int_or_default "${ATMUX_TEAM_MIN_PANE_HEIGHT:-24}" 24)"
    min_w="$(max_int "$min_w" "$hard_min_w")"
    min_h="$(max_int "$min_h" "$hard_min_h")"
    max_cols="$(int_or_default "${ATMUX_TEAM_MAX_COLUMNS:-2}" 2)"
    if (( max_cols < 1 )); then
      max_cols=1
    fi
    if (( panes < 1 )); then
      panes=1
    fi
    cols="$panes"
    if (( cols > max_cols )); then
      cols="$max_cols"
    fi
    rows=$(( (panes + cols - 1) / cols ))
    out_w=$(( cols * min_w + (cols - 1) ))
    out_h=$(( rows * min_h + (rows - 1) ))
    # Emit cols too so apply_team_layout can pick a layout that matches
    # the actual sizing (otherwise an `ATMUX_TEAM_MAX_COLUMNS=1` setup
    # gets a 1-column window with side-by-side `even-horizontal` panes
    # — splits the configured min-width in half).
    printf '%s %s %s\n' "$out_w" "$out_h" "$cols"
  }

  apply_team_layout() {
    local panes="$1"
    local cols
    read -r width height cols < <(team_dimensions_for_panes "$panes")
    tmux set-window-option -t "${team_session}:0" window-size manual >/dev/null 2>&1 || true
    tmux resize-window -t "${team_session}:0" -x "$width" -y "$height" >/dev/null 2>&1 || true
    # Default to `tiled` (tmux's grid layout). For 2 panes in 2 columns,
    # use `even-horizontal` (side-by-side) so a typical wide monitor
    # isn't wasted on a top/bottom split. For 2 panes in 1 column
    # (ATMUX_TEAM_MAX_COLUMNS=1), use `even-vertical` (stacked) so each
    # pane gets the full configured min-width.
    local layout="tiled"
    if (( panes == 2 )); then
      if (( cols >= 2 )); then
        layout="even-horizontal"
      else
        layout="even-vertical"
      fi
    fi
    tmux select-layout -t "${team_session}:0" "$layout" >/dev/null 2>&1 || true
  }

  apply_team_scroll_settings() {
    local team_mouse_mode="${ATMUX_TMUX_MOUSE:-off}"
    case "$team_mouse_mode" in
      on|off) ;;
      *) team_mouse_mode="off" ;;
    esac
    tmux set-option -t "$team_session" mouse "$team_mouse_mode" >/dev/null 2>&1 || true
    tmux set-window-option -t "${team_session}:0" history-limit "$team_history_limit" >/dev/null 2>&1 || true
    tmux set-window-option -t "${team_session}:0" mode-keys vi >/dev/null 2>&1 || true
    tmux set-window-option -t "${team_session}:0" alternate-screen "$team_alternate_screen" >/dev/null 2>&1 || true
  }

  [[ -n "$team_name" ]] || return 0
  [[ -n "$agent_session" ]] || return 0
  if ! tmux has-session -t "$agent_session" 2>/dev/null; then
    return 0
  fi

  team_session="$(team_session_name "$repo_name" "$team_name")"
  team_cap=4
  hard_min_w=100
  hard_min_h=20
  team_width="$(int_or_default "${ATMUX_TEAM_WIDTH:-240}" 240)"
  team_height="$(int_or_default "${ATMUX_TEAM_HEIGHT:-50}" 50)"
  team_width="$(max_int "$team_width" "$hard_min_w")"
  team_height="$(max_int "$team_height" "$hard_min_h")"
  team_history_limit="$(int_or_default "${ATMUX_TEAM_HISTORY_LIMIT:-300000}" 300000)"
  team_alternate_screen="${ATMUX_TEAM_ALTERNATE_SCREEN:-off}"

  if tmux has-session -t "$team_session" 2>/dev/null; then
    current_count="$(team_member_count "$team_session")"
    if ! [[ "$current_count" =~ ^[0-9]+$ ]]; then
      current_count=0
    fi
    if ! team_contains_agent_session "$team_session" "$agent_session" && (( current_count >= team_cap )); then
      echo "team '${team_name}' is full (${current_count}/${team_cap}); max team size is 4" >&2
      return 1
    fi
  fi

  if ! tmux has-session -t "$team_session" 2>/dev/null; then
    tmux new-session -d -x "$team_width" -y "$team_height" -s "$team_session" -n "$team_session" -c "$repo_root" "TMUX= tmux attach-session -r -t \"$agent_session\""
    tmux set-environment -t "$team_session" ATMUX_REPO "$repo_name" >/dev/null 2>&1 || true
    tmux set-environment -t "$team_session" ATMUX_TEAM "$team_name" >/dev/null 2>&1 || true
    tmux set-environment -t "$team_session" ATMUX_SESSION_NAME "$team_session" >/dev/null 2>&1 || true
    tmux set-environment -t "$team_session" ATMUX_SESSION_KIND "team" >/dev/null 2>&1 || true
    pane_id="$(tmux list-panes -t "${team_session}:0" -F '#{pane_id}' 2>/dev/null | head -n1 || true)"
  else
    reusable_pane=""
    while IFS='|' read -r pane_id current_cmd pane_agent; do
      [[ -n "$pane_id" ]] || continue
      if [[ -n "$pane_agent" ]]; then
        continue
      fi
      case "$current_cmd" in
        zsh|bash|sh|fish)
          reusable_pane="$pane_id"
          break
          ;;
      esac
    done < <(tmux list-panes -t "${team_session}:0" -F '#{pane_id}|#{pane_current_command}|#{@atmux_agent_session}' 2>/dev/null || true)

    if [[ -n "$reusable_pane" ]]; then
      pane_id="$reusable_pane"
      tmux send-keys -t "$pane_id" C-c >/dev/null 2>&1 || true
      tmux send-keys -t "$pane_id" C-u >/dev/null 2>&1 || true
      tmux send-keys -t "$pane_id" "TMUX= tmux attach-session -r -t \"$agent_session\"" C-m >/dev/null 2>&1 || true
    else
      pane_count="$(tmux list-panes -t "${team_session}:0" 2>/dev/null | wc -l | tr -d ' ')"
      if ! [[ "$pane_count" =~ ^[0-9]+$ ]]; then
        pane_count=1
      fi
      apply_team_layout $(( pane_count + 1 ))
      pane_id="$(tmux split-window -d -t "${team_session}:0" -c "$repo_root" -P -F '#{pane_id}' "TMUX= tmux attach-session -r -t \"$agent_session\"" 2>/dev/null || true)"
      if [[ -z "$pane_id" ]]; then
        apply_team_layout $(( pane_count + 2 ))
        pane_id="$(tmux split-window -d -t "${team_session}:0" -c "$repo_root" -P -F '#{pane_id}' "TMUX= tmux attach-session -r -t \"$agent_session\"" 2>/dev/null || true)"
      fi
    fi
  fi

  apply_team_scroll_settings

  if [[ -n "$pane_id" && -n "$agent_name" ]]; then
    tmux select-pane -t "$pane_id" -T "$agent_name" >/dev/null 2>&1 || true
    tmux set-option -p -t "$pane_id" @atmux_agent_session "$agent_session" >/dev/null 2>&1 || true
    tmux set-option -p -t "$pane_id" @atmux_agent_name "$agent_name" >/dev/null 2>&1 || true
  fi
  pane_count="$(tmux list-panes -t "${team_session}:0" 2>/dev/null | wc -l | tr -d ' ')"
  if ! [[ "$pane_count" =~ ^[0-9]+$ ]]; then
    pane_count=1
  fi
  apply_team_layout "$pane_count"
  apply_team_scroll_settings
}

status_node_for_session() {
  local session="$1"
  local passive_status="${2:-0}"
  local pane adapter adapter_cmd manager source_root status_out node

  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  manager="$(get_session_env "$session" ATMUX_MANAGER)"
  source_root="$(get_session_env "$session" ATMUX_SOURCE_ROOT)"
  pane="$(primary_pane_for_session "$session")"
  [[ -n "$adapter" ]] || adapter="codex"

  if ! adapter_cmd="$(resolve_adapter_cmd_for_session "$session")"; then
    printf '<status adapter="%s" owner="agent" state="errored" model="" reasoning_level="" control_file="" />\n' "$(xml_escape "$adapter")"
    return 0
  fi

  status_out="$(
    ATMUX_SOURCE_ROOT="$source_root" \
    ATMUX_TARGET_PANE="$pane" \
    ATMUX_MANAGER="$manager" \
    ATMUX_STATUS_PASSIVE="$passive_status" \
    "$adapter_cmd" status 2>/dev/null || true
  )"

  node="$(printf '%s\n' "$status_out" | awk '/<status[[:space:]].*\/>/ { sub(/^[[:space:]]*/, ""); print; exit }')"
  if [[ -n "$node" ]]; then
    printf '%s\n' "$node"
  else
    printf '<status adapter="%s" owner="agent" state="errored" model="" reasoning_level="" control_file="" />\n' "$(xml_escape "$adapter")"
  fi
}

send_task_to_agent() {
  local target_session="$1"
  local description="$2"
  local todos_blob="$3"

  [[ -n "$target_session" ]] || { echo "target session is required" >&2; return 1; }
  if ! tmux has-session -t "$target_session" 2>/dev/null; then
    echo "agent session not found: $target_session" >&2
    return 1
  fi

  local target_pane=""
  target_pane="$(primary_pane_for_session "$target_session")"
  if [[ -z "$target_pane" ]]; then
    echo "agent pane not found: $target_session" >&2
    return 1
  fi

  local from_session
  from_session="${ATMUX_SESSION_NAME:-}"
  if [[ -z "$from_session" ]]; then
    local from_repo
    from_repo="$(repo_name_from_context)"
    if [[ -n "$from_repo" ]]; then
      from_session="atmux-${from_repo}-${ATMUX_AGENT_NAME:-unknown}"
    else
      from_session="atmux-unknown-${ATMUX_AGENT_NAME:-unknown}"
    fi
  fi

  local assign_cmd=("${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}/bin/atmux" issue create --title "$description" --assign-to "$target_session")
  local todo
  while IFS= read -r todo; do
    [[ -z "$todo" ]] && continue
    assign_cmd+=(--todo "$todo")
  done <<< "$todos_blob"
  ATMUX_NO_WRAP=1 "${assign_cmd[@]}" >/dev/null 2>&1 || true
}

# === do_create: top-level entry that spawns a new agent =====================

do_create() {
  local manager="${ATMUX_AGENT_NAME:-}"
  local top_level=0
  if [[ -z "$manager" ]]; then
    top_level=1
  fi

  local name=""
  local role=""
  # ATMUX_TEAM signals "this session IS a member of <team>" — only set
  # by team-spawned members. ATMUX_DEFAULT_TEAM is the soft hint a
  # manager session picks up after running `atmux team create <team>`,
  # so subsequent `atmux agent create` calls in that manager default
  # to joining the same team. Both are fallbacks for the explicit
  # `--team` flag.
  local team="${ATMUX_TEAM:-${ATMUX_DEFAULT_TEAM:-}}"
  if [[ -z "$team" && -n "${TMUX:-}" ]]; then
    current_session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
    if [[ -n "$current_session_name" ]]; then
      team="$(tmux show-environment -t "$current_session_name" ATMUX_TEAM 2>/dev/null | sed -n 's/^ATMUX_TEAM=//p' || true)"
      if [[ -z "$team" ]]; then
        team="$(tmux show-environment -t "$current_session_name" ATMUX_DEFAULT_TEAM 2>/dev/null | sed -n 's/^ATMUX_DEFAULT_TEAM=//p' || true)"
      fi
    fi
  fi
  local adapter="auto"
  local adapters_list=""
  local intelligence=""
  local model=""
  local reasoning=""
  local shared_worktree=0
  local task_mode=0
  local task_description=""
  local task_todos_blob=""
  local start_cmd=""
  local stop_cmd=""
  local -a forward=()
  local -a sets=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name="${2:-}"
        shift 2
        ;;
      --adapter)
        adapter="${2:-}"
        shift 2
        ;;
      --adapters)
        adapters_list="${2:-}"
        shift 2
        ;;
      --role)
        role="${2:-}"
        shift 2
        ;;
      --team|-t)
        team="${2:-}"
        shift 2
        ;;
      --intelligence)
        intelligence="${2:-}"
        shift 2
        ;;
      --model)
        model="${2:-}"
        shift 2
        ;;
      --reasoning)
        reasoning="${2:-}"
        shift 2
        ;;
      --set)
        sets+=("${2:-}")
        shift 2
        ;;
      --shared-worktree)
        shared_worktree=1
        shift
        ;;
      --no-worktree)
        echo "atmux agent create: --no-worktree is deprecated; use --shared-worktree instead" >&2
        shared_worktree=1
        shift
        ;;
      --task)
        task_mode=1
        shift
        ;;
      --description)
        task_description="${2:-}"
        shift 2
        ;;
      --todo|--todos)
        task_todos_blob+="${2:-}"$'\n'
        shift 2
        ;;
      --start)
        start_cmd="${2:-}"
        shift 2
        ;;
      --stop)
        stop_cmd="${2:-}"
        shift 2
        ;;
      --)
        shift
        forward=("$@")
        break
        ;;
      -*)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "unexpected argument: $1" >&2
          exit 2
        fi
        ;;
    esac
  done

  if [[ -z "$role" ]]; then
    echo "missing required flag: --role" >&2
    exit 2
  fi

  # Newline check is also re-run after the --set loop below — `--set
  # start=...` / `--set stop=...` can land here too and must not bypass
  # the same guard.
  case "$start_cmd" in
    *$'\n'*) echo "--start must be a single line; use a script file for multi-line commands" >&2; exit 2 ;;
  esac
  case "$stop_cmd" in
    *$'\n'*) echo "--stop must be a single line; use a script file for multi-line commands" >&2; exit 2 ;;
  esac

  # Resolve role directory if a role name maps to one.
  local role_dir=""
  local role_adapters=""
  if [[ -n "$role" ]]; then
    if role_runner="$(resolve_role_runner || true)" && [[ -x "$role_runner" ]]; then
      role_dir="$("$role_runner" resolve --kind agent "$role" 2>/dev/null || true)"
      if [[ -z "$role_dir" ]] && "$role_runner" private-agent "$role" >/dev/null 2>&1; then
        echo "atmux agent create: role '$role' is private to a team; use 'atmux team create --role <team-role>' instead" >&2
        exit 2
      fi
      if [[ -z "$role_dir" ]] && "$role_runner" resolve --kind team "$role" >/dev/null 2>&1; then
        echo "atmux agent create: role '$role' is KIND=team; use 'atmux team create --role $role' instead" >&2
        exit 2
      fi
    fi
  fi
  if [[ -n "$role_dir" ]]; then
    manifest_out="$(read_role_manifest "$role_dir/manifest" || true)"
    if [[ -n "$manifest_out" ]]; then
      manifest_intelligence="$(printf '%s\n' "$manifest_out" | sed -n 's/^INTELLIGENCE=//p')"
      role_adapters="$(printf '%s\n' "$manifest_out" | sed -n 's/^ADAPTERS=//p')"
      if [[ -z "$intelligence" && -n "$manifest_intelligence" ]]; then
        intelligence="$manifest_intelligence"
      fi
    fi
    if [[ -z "$start_cmd" && -x "$role_dir/start" ]]; then
      start_cmd="$role_dir/start"
    fi
    if [[ -z "$stop_cmd" && -x "$role_dir/stop" ]]; then
      stop_cmd="$role_dir/stop"
    fi
  fi

  # --set <key>=<value> (repeatable) generic overrides. Known keys map onto
  # variables that drive spawn_agent_session; unknown keys warn and skip
  # (forward-compat: a future adapter manifest field can land without
  # requiring atmux changes). Dotted keys are reserved for `team create
  # --set <member>.<field>=...` and are rejected here.
  local entry_set
  for entry_set in "${sets[@]+"${sets[@]}"}"; do
    [[ -n "$entry_set" ]] || continue
    if [[ "$entry_set" != *=* ]]; then
      echo "atmux agent create: --set requires key=value: $entry_set" >&2
      exit 2
    fi
    local set_key="${entry_set%%=*}"
    local set_val="${entry_set#*=}"
    if [[ "$set_key" == *.* ]]; then
      echo "atmux agent create: dotted --set keys are only valid for team create: $set_key" >&2
      exit 2
    fi
    case "$set_key" in
      model) model="$set_val" ;;
      reasoning|reasoning_level) reasoning="$set_val" ;;
      adapter) adapter="$set_val" ;;
      adapters) adapters_list="$set_val" ;;
      intelligence) intelligence="$set_val" ;;
      name) name="$set_val" ;;
      team) team="$set_val" ;;
      start|start_command) start_cmd="$set_val" ;;
      stop|stop_command) stop_cmd="$set_val" ;;
      *)
        echo "atmux agent create: --set $set_key=... is not a recognized field; ignoring" >&2
        ;;
    esac
  done

  # Re-validate after --set: `--set start=$'a\nb'` would otherwise bypass
  # the newline guard the literal `--start` flag enforces above.
  case "$start_cmd" in
    *$'\n'*) echo "--start must be a single line; use a script file for multi-line commands" >&2; exit 2 ;;
  esac
  case "$stop_cmd" in
    *$'\n'*) echo "--stop must be a single line; use a script file for multi-line commands" >&2; exit 2 ;;
  esac

  if [[ -n "$intelligence" ]] && ! valid_intelligence "$intelligence"; then
    echo "invalid intelligence: $intelligence" >&2
    echo "expected integer range: 0-100" >&2
    exit 2
  fi
  if [[ -z "$intelligence" ]]; then
    echo "missing required flag: --intelligence" >&2
    exit 2
  fi
  if [[ -n "$reasoning" ]]; then
    case "$reasoning" in
      low|medium|high|extra-high) ;;
      extra_high|extrahigh) reasoning="extra-high" ;;
      *)
        echo "atmux agent create: unknown --reasoning '$reasoning'; passing through to adapter" >&2
        ;;
    esac
  fi
  if [[ "$task_mode" -eq 0 && ( -n "$task_description" || -n "$task_todos_blob" ) ]]; then
    echo "--description/--todos require --task for agent create" >&2
    exit 2
  fi
  if [[ "$task_mode" -eq 1 && -z "$task_description" && -z "$task_todos_blob" ]]; then
    echo "--task requires --description and/or --todos" >&2
    exit 2
  fi

  local repo_root="" repo_name=""
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  if [[ -n "$team" ]]; then
    ensure_team_has_capacity "$repo_name" "$team"
  fi

  # Combine role-derived adapters with user-supplied --adapters (user wins).
  local effective_adapters="${adapters_list:-$role_adapters}"

  # Build the spawn args and call spawn_agent_session inline. This replaces
  # the old `session start` re-exec — agent owns its lifecycle now.
  local -a spawn_args=()
  if [[ -n "$name" ]]; then
    spawn_args+=(--name "$name")
  fi
  if [[ -n "$adapter" ]]; then
    spawn_args+=(--adapter "$adapter")
  fi
  if [[ -n "$effective_adapters" ]]; then
    spawn_args+=(--adapters "$effective_adapters")
  fi
  if [[ "$shared_worktree" -eq 1 ]]; then
    spawn_args+=(--shared-worktree)
  fi
  if [[ ${#forward[@]} -gt 0 ]]; then
    spawn_args+=(-- "${forward[@]}")
  fi

  # Top-level interactive create attaches; sub-agent create captures stdout
  # for the XML envelope. spawn_agent_session prints the session name when
  # not attached to a TTY (via attach_or_switch's TTY check) — that's what
  # we need for the sub-agent path.
  local create_out=""
  if [[ "$top_level" -eq 1 ]]; then
    # Top-level: run inline so attach_or_switch can take over the TTY.
    ATMUX_MANAGER="" \
    ATMUX_ROLE="$role" \
    ATMUX_ROLE_DIR="$role_dir" \
    ATMUX_ROLE_START="$start_cmd" \
    ATMUX_ROLE_STOP="$stop_cmd" \
    ATMUX_TEAM="$team" \
    ATMUX_INTELLIGENCE="$intelligence" \
    ATMUX_MODEL="$model" \
    ATMUX_REASONING_LEVEL="$reasoning" \
      spawn_agent_session "${spawn_args[@]}"
    return 0
  fi

  # Sub-agent: capture stdout; spawn_agent_session attaches read-only when
  # interactive and prints the session name otherwise.
  create_out="$(
    ATMUX_MANAGER="$manager" \
    ATMUX_ROLE="$role" \
    ATMUX_ROLE_DIR="$role_dir" \
    ATMUX_ROLE_START="$start_cmd" \
    ATMUX_ROLE_STOP="$stop_cmd" \
    ATMUX_TEAM="$team" \
    ATMUX_INTELLIGENCE="$intelligence" \
    ATMUX_MODEL="$model" \
    ATMUX_REASONING_LEVEL="$reasoning" \
      spawn_agent_session "${spawn_args[@]}"
  )"

  local created_session
  created_session="$(printf '%s\n' "$create_out" | awk 'NF { last=$0 } END { print last }')"
  if [[ -z "$created_session" ]]; then
    exit 0
  fi

  if [[ -n "$start_cmd" ]]; then
    role_start_check_deadline=$(( $(date +%s) + ${ATMUX_ROLE_START_TIMEOUT:-60} + 2 ))
    while (( $(date +%s) < role_start_check_deadline )); do
      if ! tmux has-session -t "$created_session" 2>/dev/null; then
        echo "atmux: agent aborted during role start (session gone)" >&2
        exit 1
      fi
      role_state="$(get_session_env "$created_session" ATMUX_ROLE_START_STATE)"
      if [[ "$role_state" == "failed" ]]; then
        echo "atmux: agent aborted during role start (role start failed)" >&2
        tmux kill-session -t "$created_session" >/dev/null 2>&1 || true
        exit 1
      fi
      if [[ "$role_state" == "ready" ]]; then
        break
      fi
      sleep 0.1
    done
  fi

  local created_name
  created_name="$(get_session_env "$created_session" ATMUX_AGENT_NAME)"
  if [[ -z "$created_name" ]]; then
    created_name="$name"
  fi
  if [[ -z "$created_name" ]]; then
    session_prefix="atmux-${repo_name}-"
    if [[ "$created_session" == "$session_prefix"* ]]; then
      created_name="${created_session#"$session_prefix"}"
    else
      created_name="$created_session"
    fi
  fi

  local created_repo
  created_repo="$(get_session_env "$created_session" ATMUX_REPO)"
  [[ -n "$created_repo" ]] || created_repo="$repo_name"

  local created_manager
  created_manager="$(get_session_env "$created_session" ATMUX_MANAGER)"
  [[ -n "$created_manager" ]] || created_manager="$manager"
  local created_team
  created_team="$(get_session_env "$created_session" ATMUX_TEAM)"
  [[ -n "$created_team" ]] || created_team="$team"

  local created_adapter
  created_adapter="$(get_session_env "$created_session" ATMUX_ADAPTER)"
  if [[ "$created_adapter" == "auto" || -z "$created_adapter" ]]; then
    for _ in $(seq 1 30); do
      sleep 0.1
      probe_adapter="$(get_session_env "$created_session" ATMUX_ADAPTER)"
      if [[ -n "$probe_adapter" && "$probe_adapter" != "auto" ]]; then
        created_adapter="$probe_adapter"
        break
      fi
    done
  fi
  if [[ -z "$created_adapter" ]]; then
    created_adapter="$adapter"
  fi
  if [[ -z "$created_adapter" ]]; then
    created_adapter="auto"
  fi

  local created_adapter_requested
  created_adapter_requested="$(get_session_env "$created_session" ATMUX_ADAPTER_REQUESTED)"
  if [[ -z "$created_adapter_requested" ]]; then
    created_adapter_requested="$adapter"
  fi

  local status_node
  status_node="$(status_node_for_session "$created_session")"
  if ! ensure_team_dashboard_for_agent "$repo_root" "$created_repo" "$created_team" "$created_session" "$created_name"; then
    exit 1
  fi
  printf '<agent name="%s" session="%s" repo="%s" manager="%s" team="%s" adapter="%s" adapter_requested="%s" role="%s" intelligence="%s">\n' \
    "$(xml_escape "$created_name")" \
    "$(xml_escape "$created_session")" \
    "$(xml_escape "$created_repo")" \
    "$(xml_escape "$created_manager")" \
    "$(xml_escape "$created_team")" \
    "$(xml_escape "$created_adapter")" \
    "$(xml_escape "$created_adapter_requested")" \
    "$(xml_escape "$role")" \
    "$(xml_escape "$intelligence")"
  printf '  %s\n' "$status_node"
  printf '</agent>\n'
}

# === Dispatch ===============================================================

sub="${1:-}"
shift || true

case "$sub" in
  create|_create)
    do_create "$@"
    ;;
  attach)
    attach_agent "$@"
    ;;
  _run-adapter)
    run_adapter "$@"
    ;;
  _render-prompt)
    # Internal diagnostic: print the rendered atmux managed block to stdout.
    # Honors ATMUX_ROLE / ATMUX_MANAGER / ATMUX_ROLE_DIR like the real flow.
    render_managed_block "${1:-$(pwd)}"
    ;;
  list)
    here_agent="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    exec "$here_agent/(list)/agents" "$@"
    ;;
  status)
    here_agent="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    exec "$here_agent/(list)/agent-status" "$@"
    ;;
  kill)
    here_agent="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ "${1:-}" == "--all" ]]; then
      exec "$here_agent/(internal)/kill" "$@"
    fi
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux agent kill <name|pattern> [...]   |   atmux agent kill --all [--yes]" >&2
      exit 2
    fi
    exec "$here_agent/(internal)/kill" --agent "$@"
    ;;
  capture)
    here_agent="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ "${1:-}" == "--all" ]]; then
      exec "$here_agent/(internal)/capture" "$@"
    fi
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux agent capture <name> [--lines N]   |   atmux agent capture --all [--lines N]" >&2
      exit 2
    fi
    target_name="$1"; shift
    exec "$here_agent/(internal)/capture" --agent "$target_name" "$@"
    ;;
  watch)
    here_agent="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux agent watch <name|session> [--idle N] [--timeout N] [--interval N] [--lines N]" >&2
      exit 2
    fi
    target_name="$1"; shift
    exec "$here_agent/[watch]/agent" --agent "$target_name" "$@"
    ;;
  resolve)
    target="${1:-}"
    if [[ -z "$target" ]]; then
      echo "usage: atmux agent resolve <name> [<repo_name>]" >&2
      exit 2
    fi
    r_repo="${2:-}"
    if [[ -z "$r_repo" ]]; then
      r_repo="$(repo_name_from_context)"
    fi

    if tmux has-session -t "$target" 2>/dev/null; then
      printf '%s\n' "$target"
      exit 0
    fi
    if [[ "$target" == atmux-* ]]; then
      printf '%s\n' "$target"
      exit 0
    fi
    if [[ -n "$r_repo" ]]; then
      candidate="atmux-${r_repo}-${target}"
      if tmux has-session -t "$candidate" 2>/dev/null; then
        printf '%s\n' "$candidate"
        exit 0
      fi
      if [[ "$target" == "${r_repo}-"* ]]; then
        candidate="atmux-${target}"
        if tmux has-session -t "$candidate" 2>/dev/null; then
          printf '%s\n' "$candidate"
          exit 0
        fi
      fi
    fi
    exit 1
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown agent command: $sub" >&2
    exit 2
    ;;
esac
