#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-8}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -500 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_exec_running() {
  local repo="$1"
  local timeout="${2:-10}"
  local deadline now state_file
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    state_file="$(find "$HOME/.atmux/exec/$repo" -mindepth 2 -maxdepth 2 -name state 2>/dev/null | head -n1 || true)"
    if [[ -n "$state_file" ]] && [[ "$(tr -d '\r\n' < "$state_file" 2>/dev/null || true)" == "running" ]]; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

repo_name="e$RANDOM"
session="atmux-${repo_name}-sender"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
# Wide session avoids tmux line-wrapping the pasted command on small client displays.
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session" ATMUX_AGENT_NAME "sender"
tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "exec interrupt pane missing" >&2; exit 1; }

tmux send-keys -t "$pane" "ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"sender\" ATMUX_SESSION_NAME=\"$session\" \"$ATMUX_BIN\" exec -- sleep 30" C-m
if ! wait_for_exec_running "$repo_name" 15; then
  echo "exec did not start before interrupt" >&2
  tmux capture-pane -p -t "$pane" -S -220 >&2 || true
  exit 1
fi
tmux send-keys -t "$pane" C-c

if ! wait_for_text "$pane" 'type="exec"' 10; then
  echo "interrupt exec notification not found in exec pane" >&2
  tmux capture-pane -p -t "$pane" -S -220 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'exit_code="130"' 10; then
  echo "interrupt exit code notification missing" >&2
  tmux capture-pane -p -t "$pane" -S -220 >&2 || true
  exit 1
fi

echo "ok: exec interrupt sends exit notification"
