#!/usr/bin/env bash
set -euo pipefail

# atmux agent status — observability into per-agent runtime state.
#
# Reads from the same on-disk sources the running system uses (tmux + the
# notify-queue directory under ATMUX_HOME). Does NOT shell out to the adapter
# `status` hook — that's `agent list --status`. This view answers "is the
# pane alive, is the worker alive, how deep is the queue, did delivery
# error out". It is the leaf data source that `team status` aggregates.
#
# Output: XML for agents, column-aligned table for humans, via reporter.

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/../notify"
# shellcheck source=bin/(atmux)/(internal)/reporter
source "$HERE/../(internal)/reporter"

now_seconds() { date +%s; }

file_mtime() {
  # Portable mtime in seconds: GNU stat, then BSD stat.
  if stat -c '%Y' "$1" >/dev/null 2>&1; then
    stat -c '%Y' "$1"
  elif stat -f '%m' "$1" >/dev/null 2>&1; then
    stat -f '%m' "$1"
  else
    printf '0\n'
  fi
}

is_team_session() {
  local session="$1" repo_name="$2"
  [[ "$session" == "atmux-${repo_name}-team-"* ]]
}

agent_local_name() {
  local repo_name="$1" session="$2"
  printf '%s\n' "${session#atmux-${repo_name}-}"
}

# Compute status fields for one agent session. Echoes seven tab-separated
# fields on a single line:
#   pane_alive worker queue oldest_age last_error_short adapter team
# Designed to be read with a single `IFS=$'\x1f' read -r` so callers can
# branch on every value without re-parsing.
agent_status_fields() {
  local session="$1"
  local pane qdir worker_pid worker queue oldest_age last_error_short
  local adapter team pane_alive

  if tmux has-session -t "$session" 2>/dev/null; then
    pane="$(atmux_resolve_primary_pane "$session")"
  else
    pane=""
  fi

  if [[ -n "$pane" ]] && tmux display-message -t "$pane" -p '#{pane_id}' >/dev/null 2>&1; then
    pane_alive="yes"
  else
    pane_alive="no"
  fi

  adapter="$(atmux_resolve_session_env "$session" ATMUX_ADAPTER)"
  team="$(atmux_resolve_session_env "$session" ATMUX_TEAM)"
  [[ -n "$adapter" ]] || adapter=""
  [[ -n "$team" ]] || team=""

  worker="none"
  queue=0
  oldest_age=""
  last_error_short=""

  if [[ -n "$pane" ]]; then
    qdir="$(notify_queue_dir "$pane")"
    if [[ -d "$qdir" ]]; then
      if [[ -f "$qdir/worker.pid" ]]; then
        worker_pid="$(tr -d '\r\n' < "$qdir/worker.pid" 2>/dev/null || true)"
        if [[ -n "$worker_pid" ]] && kill -0 "$worker_pid" 2>/dev/null; then
          worker="alive"
        else
          worker="dead"
        fi
      fi

      if [[ -d "$qdir/payloads" ]]; then
        local d oldest_mtime now mtime
        oldest_mtime=""
        for d in "$qdir/payloads"/*; do
          [[ -d "$d" ]] || continue
          queue=$((queue + 1))
          mtime="$(file_mtime "$d")"
          if [[ -z "$oldest_mtime" ]] || (( mtime < oldest_mtime )); then
            oldest_mtime="$mtime"
          fi
        done
        if [[ -n "$oldest_mtime" ]]; then
          now="$(now_seconds)"
          oldest_age=$(( now - oldest_mtime ))
          (( oldest_age < 0 )) && oldest_age=0
        fi
      fi

      if [[ -f "$qdir/last_error" && -s "$qdir/last_error" ]]; then
        # Single line, max 80 chars — error_text in XML attr can't have
        # raw newlines, and CLI columns get unreadable past ~100 chars.
        last_error_short="$(tr '\n\r\t' '   ' < "$qdir/last_error" | cut -c 1-80)"
      fi
    fi
  fi

  # Use \x1f (Unit Separator) instead of \t — `IFS=$'\t' read` collapses
  # consecutive tabs because tab is whitespace IFS, eating empty fields
  # like an unset oldest_age or empty last_error.
  printf '%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\x1f%s\n' \
    "$pane_alive" "$worker" "$queue" "$oldest_age" "$last_error_short" "$adapter" "$team"
}

# Format an age-in-seconds value for the CLI table. Empty input → "-".
format_age() {
  local s="$1"
  if [[ -z "$s" ]]; then printf '%s\n' '-'; return; fi
  if (( s < 60 )); then printf '%ds\n' "$s"
  elif (( s < 3600 )); then printf '%dm%ds\n' "$((s / 60))" "$((s % 60))"
  elif (( s < 86400 )); then printf '%dh%dm\n' "$((s / 3600))" "$(((s % 3600) / 60))"
  else printf '%dd%dh\n' "$((s / 86400))" "$(((s % 86400) / 3600))"
  fi
}

# === main ===================================================================

main() {
  local target=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        cat <<'USAGE'
Usage: atmux agent status [<name>]

Show runtime state for atmux agents in the current repo:
  pane_alive  Is the tmux pane still around?
  worker      Notify worker liveness (alive/dead/none)
  queue       Pending notification count
  oldest      Age of the oldest queued notification
  last_error  Most recent worker error (truncated)

With no argument, all agents in the repo are shown. With <name>, only
that agent. Output is XML in agent context, plain text otherwise.
USAGE
        exit 0
        ;;
      --) shift; break ;;
      -*) echo "unknown argument: $1" >&2; exit 2 ;;
      *)
        if [[ -n "$target" ]]; then
          echo "atmux agent status takes at most one <name>" >&2
          exit 2
        fi
        target="$1"
        shift
        ;;
    esac
  done

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(atmux_resolve_repo_context)

  local prefix="atmux-${repo_name}-"
  local matched=0

  report_open agents-status repo="$repo_name"

  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    [[ "$session" == "$prefix"* ]] || continue
    is_team_session "$session" "$repo_name" && continue

    local aname
    aname="$(agent_local_name "$repo_name" "$session")"
    if [[ -n "$target" && "$target" != "$aname" && "$target" != "$session" ]]; then
      continue
    fi

    local pane_alive worker queue oldest_age last_error_short adapter team
    IFS=$'\x1f' read -r pane_alive worker queue oldest_age last_error_short adapter team \
      < <(agent_status_fields "$session")

    local mode; mode="$(reporter_mode)"
    if [[ "$mode" == "cli" ]]; then
      report_record agent \
        name="$aname" \
        session="$session" \
        adapter="$adapter" \
        team="$team" \
        pane="$pane_alive" \
        worker="$worker" \
        queue="$queue" \
        oldest="$(format_age "$oldest_age")" \
        last_error="$last_error_short"
    else
      # XML keeps oldest_age in seconds (machine-friendly); humans see
      # the formatted version above.
      report_record agent \
        name="$aname" \
        session="$session" \
        adapter="$adapter" \
        team="$team" \
        pane_alive="$pane_alive" \
        worker="$worker" \
        queue_depth="$queue" \
        oldest_age_seconds="$oldest_age" \
        last_error="$last_error_short"
    fi
    matched=1
  done < <(atmux_resolve_repo_sessions "$repo_name" | sort -u || true)

  report_close agents-status

  if [[ -n "$target" && "$matched" -eq 0 ]]; then
    echo "no agent named '$target' in repo '$repo_name'" >&2
    exit 1
  fi
}

main "$@"
