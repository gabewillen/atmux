#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux kill --pid <pid> [--timeout <seconds>] [--signal <NAME>]
  atmux kill --agent <name|pattern> [name|pattern...]
  atmux kill --all [--yes]

Description:
  --pid    Stop an atmux exec-tracked child process for this repo, wait for
           executor notifications (including watcher fan-out) to finish, then
           remove metadata under ~/.atmux/exec/<repo>/<pid>/.
  --agent  Kill agent sessions and clean up their worktrees and branches.
           Accepts agent names, session names, or glob patterns.
  --all    Kill every atmux session, worktree, and branch for this repo.
           Prompts for y/N confirmation; use --yes to skip. Refuses to run
           from inside an atmux session.

Examples:
  atmux kill --pid 12345
  atmux kill --pid 12345 --timeout 30 --signal TERM
  atmux kill --agent worker
  atmux kill --agent 'agent-*'
  atmux kill --agent worker planner
  atmux kill --all
  atmux kill --all --yes
USAGE
}

# --- PID mode helpers ---

wait_for_completion_or_timeout() {
  local exec_dir="$1"
  local timeout_sec="$2"
  local deadline now st
  deadline=$(( $(date +%s) + timeout_sec ))
  while true; do
    if [[ -f "$exec_dir/notified" ]]; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      st="$(read_state_field "$exec_dir/state")"
      if [[ "$st" == "exited" ]]; then
        sleep 0.5
        return 0
      fi
      return 1
    fi
    sleep 0.05
  done
}

kill_pid() {
  local pid="$1"
  local timeout_sec="$2"
  local signal_name="$3"

  local repo_name
  repo_name="$(repo_name_from_context)"
  local exec_dir
  exec_dir="$(exec_dir_for_repo_pid "$repo_name" "$pid")"

  if ! validate_exec_ownership "$exec_dir" "$pid" "$repo_name"; then
    echo "atmux kill: not an atmux-owned exec PID for this repo: $pid" >&2
    exit 2
  fi

  local st
  st="$(read_state_field "$exec_dir/state")"

  if [[ "$st" != "exited" ]]; then
    if kill -0 "$pid" 2>/dev/null; then
      kill "-${signal_name}" "$pid" 2>/dev/null || true
      local deadline now
      deadline=$(( $(date +%s) + timeout_sec ))
      while kill -0 "$pid" 2>/dev/null; do
        now="$(date +%s)"
        if (( now >= deadline )); then
          kill -KILL "$pid" 2>/dev/null || true
          sleep 0.05
          break
        fi
        sleep 0.1
      done
    fi
  fi

  if ! wait_for_completion_or_timeout "$exec_dir" "$timeout_sec"; then
    echo "atmux kill: timeout waiting for exec completion" >&2
    exit 124
  fi

  if [[ -d "$exec_dir" ]]; then
    rm -rf "$exec_dir"
  fi
  exit 0
}

# --- Agent mode helpers ---

normalize_repo_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "must be run from a git repository" >&2
    exit 1
  fi
  repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_repo_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

matches_any_pattern() {
  local value="$1"
  shift || true
  local pattern
  for pattern in "$@"; do
    case "$value" in
      $pattern) return 0 ;;
    esac
  done
  return 1
}

kill_agents() {
  local repo_root="" repo_name=""
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  local worktree_root="$atmux_home/agents"
  local prefix="atmux-${repo_name}-"

  local candidates
  candidates="$(
    {
      tmux list-sessions -F '#{session_name}' 2>/dev/null | awk -v p="$prefix" 'index($0,p)==1 { print }'
      if [[ -d "$worktree_root" ]]; then
        find "$worktree_root" -maxdepth 1 -mindepth 1 -type d -name "${repo_name}-*" -exec basename {} \; | sed 's/^/atmux-/'
      fi
      git -C "$repo_root" for-each-ref --format='%(refname:short)' "refs/heads/${prefix}*" 2>/dev/null
    } | awk -v p="$prefix" 'index($0,p)==1 { print }' | sort -u
  )"

  local removed_any=0
  local results_xml=""
  local session
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue

    # Match against full session name, short name (without atmux-repo- prefix), or agent name
    local short_name="${session#"$prefix"}"
    if ! matches_any_pattern "$session" "$@" && \
       ! matches_any_pattern "$short_name" "$@"; then
      continue
    fi

    removed_any=1
    local state="removed"
    local removed_session="false"
    local removed_worktree="false"
    local removed_branch="false"
    local note=""

    if tmux has-session -t "$session" 2>/dev/null; then
      tmux kill-session -t "$session"
      removed_session="true"
    fi

    local suffix="${session#atmux-}"
    local worktree="$worktree_root/$suffix"
    if [[ -d "$worktree" ]]; then
      if git -C "$repo_root" worktree list --porcelain 2>/dev/null | grep -Fqx "worktree $worktree"; then
        git -C "$repo_root" worktree remove -f "$worktree" >/dev/null 2>&1 || true
        if [[ -d "$worktree" ]]; then
          state="errored"
        else
          removed_worktree="true"
        fi
      else
        rm -rf -- "$worktree"
        if [[ -d "$worktree" ]]; then
          state="errored"
          note="worktree-unregistered-remove-failed"
        else
          removed_worktree="true"
          note="worktree-unregistered-pruned"
        fi
      fi
    fi

    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$session"; then
      git -C "$repo_root" branch -D "$session" >/dev/null 2>&1 || true
      if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$session"; then
        state="errored"
      else
        removed_branch="true"
      fi
    fi

    local agent_name="${session#atmux-${repo_name}-}"
    if [[ "$agent_name" == "$session" ]]; then
      agent_name="$session"
    fi

    results_xml+="  <agent name=\"$(xml_escape "$agent_name")\" session=\"$(xml_escape "$session")\">"
    if [[ -n "$note" ]]; then
      results_xml+="<status state=\"$(xml_escape "$state")\" removed_session=\"$removed_session\" removed_worktree=\"$removed_worktree\" removed_branch=\"$removed_branch\" note=\"$(xml_escape "$note")\" />"
    else
      results_xml+="<status state=\"$(xml_escape "$state")\" removed_session=\"$removed_session\" removed_worktree=\"$removed_worktree\" removed_branch=\"$removed_branch\" />"
    fi
    results_xml+="</agent>"$'\n'
  done <<< "$candidates"

  if [[ "$removed_any" -eq 0 ]]; then
    echo "no agents matched: $*" >&2
    exit 1
  fi

  printf '<agents>\n%s</agents>\n' "$results_xml"
}

# --- Main ---

inside_atmux_session() {
  if [[ -n "${ATMUX_SESSION_NAME:-}" || -n "${ATMUX_MANAGER:-}" ]]; then
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    local cur
    cur="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    [[ "$cur" == atmux-* ]] && return 0
  fi
  return 1
}

confirm_kill_all() {
  local repo_name="$1"
  if [[ ! -t 0 ]]; then
    echo "atmux kill --all: stdin is not a tty; pass --yes to skip prompt" >&2
    exit 2
  fi
  printf 'atmux kill --all will destroy every session, worktree, and branch for repo "%s".\nContinue? [y/N] ' "$repo_name" >&2
  local reply=""
  IFS= read -r reply || reply=""
  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *)
      echo "aborted" >&2
      exit 1
      ;;
  esac
}

main() {
  local pid=""
  local timeout_sec="60"
  local signal_name="TERM"
  local agent_mode=0
  local all_mode=0
  local assume_yes=0
  local -a agent_targets=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pid)
        pid="${2:-}"
        shift 2
        ;;
      --agent)
        agent_mode=1
        shift
        # Collect all remaining non-flag args as agent targets
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --timeout|--signal)
              break
              ;;
            -h|--help|help)
              usage
              exit 0
              ;;
            *)
              agent_targets+=("$1")
              shift
              ;;
          esac
        done
        ;;
      --all)
        all_mode=1
        shift
        ;;
      --yes|-y)
        assume_yes=1
        shift
        ;;
      --timeout)
        timeout_sec="${2:-}"
        shift 2
        ;;
      --signal)
        signal_name="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  if [[ "$all_mode" -eq 1 ]]; then
    if [[ "$agent_mode" -eq 1 || -n "$pid" ]]; then
      echo "--all cannot be combined with --agent or --pid" >&2
      exit 2
    fi
    if inside_atmux_session; then
      echo "atmux kill --all: refusing to run from inside an atmux session" >&2
      exit 2
    fi
    local repo_root="" repo_name=""
    {
      IFS= read -r repo_root
      IFS= read -r repo_name
    } < <(repo_context)
    if [[ "$assume_yes" -ne 1 ]]; then
      confirm_kill_all "$repo_name"
    fi
    kill_agents '*'
    exit $?
  fi

  if [[ "$agent_mode" -eq 1 ]]; then
    if [[ "${#agent_targets[@]}" -eq 0 ]]; then
      echo "missing agent name or pattern" >&2
      usage >&2
      exit 2
    fi
    kill_agents "${agent_targets[@]}"
    exit $?
  fi

  if [[ -n "$pid" ]]; then
    kill_pid "$pid" "$timeout_sec" "$signal_name"
    exit $?
  fi

  echo "missing --pid, --agent, or --all" >&2
  usage >&2
  exit 2
}

main "$@"
