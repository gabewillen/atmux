#!/usr/bin/env bash
set -euo pipefail

if ! command -v codex >/dev/null 2>&1; then
  echo "codex command not found in PATH" >&2
  exit 127
fi

manifest_lib="${ATMUX_SOURCE_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)}/bin/(atmux)/(lib)/manifest"
# shellcheck source=bin/(atmux)/(lib)/manifest
source "$manifest_lib"

current_session_name() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#S' 2>/dev/null || true
  fi
}

set_bootstrap_state() {
  local state="$1"
  local session=""
  session="$(current_session_name)"
  [[ -n "$session" ]] || return 0
  tmux set-environment -t "$session" ATMUX_BOOTSTRAP_STATE "$state" >/dev/null 2>&1 || true
}

schedule_intelligence_profile() {
  local intelligence="${ATMUX_INTELLIGENCE:-}"
  local manifest_path profile model reasoning
  manifest_path="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/manifest"

  if [[ -n "$intelligence" && "$intelligence" =~ ^[0-9]+$ ]] \
     && (( intelligence >= 0 && intelligence <= 100 )); then
    profile="$(resolve_profile_from_manifest "$intelligence" "$manifest_path" || true)"
    if [[ -n "$profile" ]]; then
      model="${profile%% *}"
      reasoning="${profile#* }"
    fi
  fi

  # Explicit overrides win over the intelligence_map lookup.
  [[ -n "${ATMUX_MODEL:-}" ]] && model="$ATMUX_MODEL"
  [[ -n "${ATMUX_REASONING_LEVEL:-}" ]] && reasoning="$ATMUX_REASONING_LEVEL"

  if [[ -z "$model" || -z "$reasoning" ]]; then
    set_bootstrap_state ready
    return 0
  fi

  local pane_id adapter_cmd atmux_bin
  pane_id="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  if [[ -z "$pane_id" ]]; then
    set_bootstrap_state ready
    return 0
  fi

  adapter_cmd="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/cmd"
  atmux_bin="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME:-$HOME/.atmux}/src/atmux}/bin/atmux"
  set_bootstrap_state pending

  (
    success=0
    if [[ -x "$atmux_bin" ]]; then
      "$atmux_bin" pane watch "$pane_id" --scope pane --text "OpenAI Codex" --timeout 30 --interval 0.2 --lines 300 || true
    else
      sleep 2
    fi
    if ATMUX_TARGET_PANE="$pane_id" "$adapter_cmd" model set "$model" "$reasoning" >/dev/null 2>&1; then
      success=1
    fi
    if [[ "$success" -eq 1 ]]; then
      set_bootstrap_state ready
    else
      set_bootstrap_state failed
    fi
  ) >/dev/null 2>&1 &
}

_on_stop_script="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)/scripts/on-stop"

# Install a Stop hook (fires at end of every turn) for Codex.
# Requires the codex_hooks feature flag and a hooks.json file.
# Both are written into the worktree's .codex/ directory.
# Only written when the files do not yet exist.
install_codex_stop_hook() {
  [[ -x "$_on_stop_script" ]] || return 0
  local codex_dir="${ATMUX_WORKTREE:-$(pwd)}/.codex"
  mkdir -p "$codex_dir"

  local config_file="$codex_dir/config.toml"
  if [[ ! -f "$config_file" ]]; then
    cat > "$config_file" <<'EOF'
[features]
codex_hooks = true
EOF
  fi

  local hooks_file="$codex_dir/hooks.json"
  if [[ ! -f "$hooks_file" ]]; then
    cat > "$hooks_file" <<EOF
{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${_on_stop_script}",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
EOF
  fi
}
install_codex_stop_hook

schedule_intelligence_profile

echo "starting codex in $(pwd)"
# Pre-trust the worktree so codex doesn't stop at its first-time
# "Do you trust this directory?" prompt — that prompt requires keyboard
# input and would otherwise hang any non-interactive boot (scripted
# agents, fresh team worktrees, CI). The override goes to codex via -c
# and is equivalent to a `[projects."<path>"]` block in config.toml.
codex_trust_pwd="$(pwd -P 2>/dev/null || pwd)"
exec codex --dangerously-bypass-approvals-and-sandbox --search \
  -c "projects.\"${codex_trust_pwd}\".trust_level=\"trusted\"" \
  "$@"
