#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="idle${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
# Use 'cat' so there's no shell prompt — simulates an adapter CLI owning the pane
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 "cat"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

# Simulate an idle adapter prompt: just "> " on its own line
sleep 0.3
tmux send-keys -t "$pane" -l "> "
tmux send-keys -t "$pane" Enter
sleep 0.3

# wait_for_input_idle should return immediately (pattern matches)
start_ts="$(date +%s)"
if ! wait_for_input_idle "$pane" '^> *$' 5; then
  echo "idle prompt not detected" >&2
  tmux capture-pane -p -t "$pane" -S -10 >&2 || true
  exit 1
fi
elapsed=$(( $(date +%s) - start_ts ))
[[ "$elapsed" -le 2 ]] || { echo "idle detection took too long: ${elapsed}s" >&2; exit 1; }

echo "ok: wait_for_input_idle detects idle prompt immediately"
