#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -J -p -t "$target" -S -200 2>/dev/null | tr -d '\r' || true)"
    if printf '%s' "$snap" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

session="atmux-send-hint-${RANDOM}"
repo_name="send-hint-${RANDOM}"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 140 -y 30 "cat"
pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

tmux set-environment -t "$session" ATMUX_ADAPTER "codex"
tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"
sleep 0.2
tmux send-keys -t "$pane" -l "› "

send_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_REPO="$repo_name" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="atmux-${repo_name}-sender" \
  "$ATMUX_BIN" send --to "$session" "test-hint-${RANDOM}")"

printf '%s\n' "$send_out" | grep -F 'to="agent"' >/dev/null

if ! wait_for_text "$pane" '<notification type="message"' 15; then
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  echo "message notification did not arrive" >&2
  exit 1
fi

if ! wait_for_text "$pane" 'hint="run `atmux message read ' 15; then
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  echo "message notification missing hint attribute" >&2
  exit 1
fi

if ! wait_for_text "$pane" ' --repo send-hint-' 15; then
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  echo "message notification missing repo-qualified hint command" >&2
  exit 1
fi

# Legacy `cmd=` attribute must not be emitted any longer.
if wait_for_text "$pane" 'cmd="atmux' 2; then
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  echo "message notification still emits legacy cmd attribute" >&2
  exit 1
fi

echo "ok: send message notification renders hint='run \`atmux ...\`'"
