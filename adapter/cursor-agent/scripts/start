#!/usr/bin/env bash
set -euo pipefail

# tmux / non-login shells often omit ~/.local/bin where `agent` is installed.
export PATH="${HOME}/.local/bin:${HOME}/.cursor/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"
if [[ -n "${ATMUX_SHIM_PROXY_DIR:-}" ]]; then
  shim_safe_entries=()
  IFS=: read -r -a path_entries <<< "$PATH"
  for path_entry in "${path_entries[@]}"; do
    [[ -n "$path_entry" ]] || continue
    [[ "$path_entry" == "$ATMUX_SHIM_PROXY_DIR" ]] && continue
    shim_safe_entries+=("$path_entry")
  done
  if ((${#shim_safe_entries[@]})); then
    shim_safe_path=$(IFS=:; printf '%s' "${shim_safe_entries[*]}")
    export PATH="$ATMUX_SHIM_PROXY_DIR:$shim_safe_path"
  else
    export PATH="$ATMUX_SHIM_PROXY_DIR"
  fi
fi

manifest_lib="${ATMUX_SOURCE_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)}/bin/(atmux)/(lib)/manifest"
# shellcheck source=bin/(atmux)/(lib)/manifest
source "$manifest_lib"

resolve_agent_bin() {
  if command -v agent >/dev/null 2>&1; then
    printf '%s\n' agent
    return 0
  fi
  if command -v cursor-agent >/dev/null 2>&1; then
    printf '%s\n' cursor-agent
    return 0
  fi
  return 1
}

agent_bin=""
if ! agent_bin="$(resolve_agent_bin)"; then
  echo "neither 'agent' nor 'cursor-agent' found in PATH (install Cursor CLI: https://cursor.com/docs/cli/using)" >&2
  exit 127
fi

set_bootstrap_state() {
  local state="$1"
  local session=""
  if [[ -n "${TMUX:-}" ]]; then
    session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  [[ -n "$session" ]] || return 0
  tmux set-environment -t "$session" ATMUX_BOOTSTRAP_STATE "$state" >/dev/null 2>&1 || true
}

ensure_cursor_atmux_allowlist() {
  local config_dir="$HOME/.cursor"
  local config_file="$config_dir/cli-config.json"
  local tmp_file=""

  mkdir -p "$config_dir"

  if [[ ! -f "$config_file" ]]; then
    cat > "$config_file" <<'EOF'
{
  "permissions": {
    "allow": [
      "Shell(atmux)"
    ],
    "deny": []
  }
}
EOF
    return 0
  fi

  if ! command -v jq >/dev/null 2>&1; then
    return 0
  fi

  tmp_file="$(mktemp "${TMPDIR:-/tmp}/cursor-cli-config.XXXXXX")"
  if jq '
    .permissions = (.permissions // {}) |
    .permissions.allow = ((.permissions.allow // []) + ["Shell(atmux)"] | unique) |
    .permissions.deny = (.permissions.deny // [])
  ' "$config_file" > "$tmp_file"; then
    mv "$tmp_file" "$config_file"
  else
    rm -f "$tmp_file"
  fi
}

state_dir="${ATMUX_HOME:-$HOME/.atmux}/adapters/cursor-agent"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"
[[ -f "$state_file" ]] || printf 'MODEL=%s\nREASONING_LEVEL=%s\n' 'composer-2' 'medium' > "$state_file"
# shellcheck disable=SC1090
source "$state_file"

arg_present() {
  local needle="$1"
  shift || true
  local arg
  for arg in "$@"; do
    [[ "$arg" == "$needle" ]] && return 0
  done
  return 1
}

normalize_model() {
  local m="${1:-}"
  if [[ "$m" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]]; then
    printf '%s\n' "$m"
    return 0
  fi
  return 1
}

normalize_reasoning() {
  case "${1:-}" in
    low|medium|high) printf '%s\n' "$1" ;;
    extra-high|extra_high|extrahigh) printf '%s\n' 'extra-high' ;;
    *) return 1 ;;
  esac
}

if [[ -n "${ATMUX_INTELLIGENCE:-}" && "${ATMUX_INTELLIGENCE}" =~ ^[0-9]+$ ]] \
  && (( ATMUX_INTELLIGENCE >= 0 && ATMUX_INTELLIGENCE <= 100 )); then
  manifest_path="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/manifest"
  profile="$(resolve_profile_from_manifest "$ATMUX_INTELLIGENCE" "$manifest_path" || true)"
  if [[ -n "$profile" ]]; then
    prof_model="${profile%% *}"
    prof_reasoning="${profile#* }"
    MODEL="$(normalize_model "$prof_model" || printf '%s\n' "$MODEL")"
    REASONING_LEVEL="$(normalize_reasoning "$prof_reasoning" || printf '%s\n' "$REASONING_LEVEL")"
  fi
fi

if [[ -n "${ATMUX_CURSOR_AGENT_MODEL:-}" ]]; then
  MODEL="$(normalize_model "$ATMUX_CURSOR_AGENT_MODEL" || { echo "invalid ATMUX_CURSOR_AGENT_MODEL: $ATMUX_CURSOR_AGENT_MODEL" >&2; exit 2; })"
fi
if [[ -n "${ATMUX_CURSOR_AGENT_REASONING_LEVEL:-}" ]]; then
  REASONING_LEVEL="$(normalize_reasoning "$ATMUX_CURSOR_AGENT_REASONING_LEVEL" || { echo "invalid ATMUX_CURSOR_AGENT_REASONING_LEVEL: $ATMUX_CURSOR_AGENT_REASONING_LEVEL" >&2; exit 2; })"
fi

# Generic per-field overrides win over intelligence_map and adapter-specific
# legacy envvars.
if [[ -n "${ATMUX_MODEL:-}" ]]; then
  MODEL="$ATMUX_MODEL"
fi
if [[ -n "${ATMUX_REASONING_LEVEL:-}" ]]; then
  REASONING_LEVEL="$ATMUX_REASONING_LEVEL"
fi

printf 'MODEL=%s\nREASONING_LEVEL=%s\n' "$MODEL" "$REASONING_LEVEL" > "$state_file"

args=("$@")
if ! arg_present --model "${args[@]-}"; then
  args=(--model "$MODEL" "${args[@]-}")
fi

ensure_cursor_atmux_allowlist

# Pre-trust the current workspace so cursor-agent doesn't block on its
# "Workspace Trust Required" TUI prompt the first time it runs in a fresh
# dir. cursor-agent persists per-workspace trust at
#   ~/.cursor/projects/<encoded-abs-path>/.workspace-trusted
# where the encoding replaces every non-alphanumeric char in the absolute
# path with `-`, strips leading hyphens, and collapses repeats. atmux's
# agent / team worktrees are always fresh dirs, so without seeding this
# every spawn blocks until a human dismisses the dialog.
encode_cursor_project_key() {
  local path="$1"
  printf '%s' "$path" \
    | sed -E 's/[^[:alnum:]]+/-/g' \
    | sed -E 's/^-+//; s/-+$//'
}

mark_workspace_trusted() {
  local workspace=""
  workspace="$(pwd -P 2>/dev/null || pwd)"
  [[ -n "$workspace" ]] || return 0

  local key
  key="$(encode_cursor_project_key "$workspace")"
  [[ -n "$key" ]] || return 0

  local project_dir="$HOME/.cursor/projects/$key"
  mkdir -p "$project_dir" 2>/dev/null || return 0

  # cursor-agent ≥ 2026.05.01 reads .workspace-trusted as JSON:
  # `{"trustedAt": "<iso8601>", "workspacePath": "<abs-path>"}`. An
  # empty file fails parsing and cursor-agent re-prompts ("Trust this
  # workspace") — a TUI dialog that captures stdin and renders to
  # alternate-screen, invisible to non-interactive callers and to
  # tmux capture-pane, so a managed agent watching the pane sees
  # silence and sits forever.
  local trusted_at
  trusted_at="$(date -u +%Y-%m-%dT%H:%M:%S.000Z 2>/dev/null || echo '1970-01-01T00:00:00.000Z')"
  # Use python's json.dumps to encode the workspace path correctly. Hand-
  # rolled escaping previously only handled `\` and `"`, which would
  # silently emit malformed JSON for paths containing control characters
  # (U+0000–U+001F: newlines, tabs, etc) — and a malformed trust file
  # re-triggers the very prompt this fix is meant to suppress. python is
  # already a hard dep elsewhere in the codebase (notify, plenty of
  # tests). Fall back to the old sed escape if python is somehow absent.
  local trust_json=""
  if command -v python3 >/dev/null 2>&1; then
    trust_json="$(
      ATMUX_TRUSTED_AT="$trusted_at" ATMUX_WORKSPACE="$workspace" \
      python3 -c '
import json, os
print(json.dumps({
    "trustedAt": os.environ["ATMUX_TRUSTED_AT"],
    "workspacePath": os.environ["ATMUX_WORKSPACE"],
}))
' 2>/dev/null
    )"
  fi
  if [[ -z "$trust_json" ]]; then
    local workspace_json
    workspace_json="$(printf '%s' "$workspace" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    trust_json="$(printf '{"trustedAt":"%s","workspacePath":"%s"}' \
      "$trusted_at" "$workspace_json")"
  fi
  printf '%s\n' "$trust_json" > "$project_dir/.workspace-trusted" 2>/dev/null || true
}

mark_workspace_trusted

set_bootstrap_state ready
echo "starting $agent_bin in $(pwd)"
exec "$agent_bin" "${args[@]-}"
