#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"
AMUX_BIN_ORIGIN="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  local -a cmds=()
  cmds+=(start route adapter install)

  local -a script_dirs=()
  if [[ -d "$AMUX_HOME/bin/scripts" ]]; then
    script_dirs+=("$AMUX_HOME/bin/scripts")
  fi
  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -d "$repo_root/bin/scripts" ]]; then
      script_dirs+=("$repo_root/bin/scripts")
    fi
  fi

  local dir
  for dir in "${script_dirs[@]}"; do
    while IFS= read -r name; do
      [[ -z "$name" ]] && continue
      cmds+=("$name")
    done < <(find "$dir" -maxdepth 1 -type f -perm -u+x -exec basename {} \; | sort)
  done

  local -a uniq_cmds=()
  while IFS= read -r c; do
    [[ -n "$c" ]] && uniq_cmds+=("$c")
  done < <(printf '%s\n' "${cmds[@]}" | awk 'NF' | sort -u)
  cmds=("${uniq_cmds[@]}")

  echo "Usage:"
  echo "  amux <subcommand> [args...]"
  echo
  echo "Available subcommands:"
  for c in "${cmds[@]}"; do
    echo "  $c"
  done
  echo
  echo "Run:"
  echo "  amux <subcommand> --help"
  echo "for more information."
}

ensure_amux_home() {
  mkdir -p "$AMUX_HOME/bin" "$AMUX_HOME/bin/scripts" "$AMUX_HOME/roles" "$AMUX_HOME/agents" "$AMUX_HOME/adapters"
}

resolve_target() {
  case "$1" in
    agent-0) echo "agent-0:0.0" ;;
    agent-1) echo "agent-1:0.0" ;;
    agent-2) echo "agent-2:0.0" ;;
    agent-3) echo "agent-3:0.0" ;;
    agent-4) echo "agent-4:0.0" ;;
    *)
      echo "unknown agent: $1" >&2
      exit 30
      ;;
  esac
}

attach_or_switch() {
  local session="$1"
  if [[ ! -t 0 || ! -t 1 ]]; then
    printf '%s\n' "$session"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

cmd_start() {
  local repo_root
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "not in a git repository" >&2
    exit 1
  fi

  local repo_name
  repo_name="$(basename "$repo_root")"
  local agent_name
  agent_name="${AMUX_AGENT_NAME:-agent}"
  local session="amux-${repo_name}-${agent_name}"
  local session_id
  session_id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
  local adapter
  adapter="${AMUX_ADAPTER:-codex}"
  local forward_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --)
        shift
        forward_args=("$@")
        break
        ;;
      *)
        echo "unknown start argument: $1" >&2
        echo "use '--' to pass adapter arguments (example: amux start -- --search)" >&2
        exit 2
        ;;
    esac
  done

  if tmux has-session -t "$session" 2>/dev/null; then
    attach_or_switch "$session"
    return
  fi

  local agent_start="$repo_root/scripts/start"
  if [[ ! -f "$agent_start" ]]; then
    echo "start script not found: $agent_start" >&2
    exit 1
  fi
  local window_name="amux-${repo_name}-${agent_name}"
  local start_cmd
  start_cmd="bash $(printf '%q' "$agent_start")"
  if ((${#forward_args[@]})); then
    for arg in "${forward_args[@]}"; do
      start_cmd+=" $(printf '%q' "$arg")"
    done
  fi
  local -a tmux_env_args=()
  if [[ -n "${AMUX_MANAGER:-}" ]]; then
    tmux_env_args=(-e AMUX_MANAGER="$AMUX_MANAGER")
  fi

  tmux new-session -d -s "$session" -n "$window_name" -c "$repo_root" \
    -e AMUX_REPO="$repo_name" \
    -e AMUX_SESSION_ID="$session_id" \
    -e AMUX_ADAPTER="$adapter" \
    -e AMUX_AGENT_NAME="$agent_name" \
    -e AMUX_BIN_ORIGIN="$AMUX_BIN_ORIGIN" \
    -e PATH="$AMUX_BIN_ORIGIN:$PATH" \
    "${tmux_env_args[@]}" \
    "$start_cmd"
  attach_or_switch "$session"
}

cmd_route() {
  local agent=""
  local target=""
  local payload=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agent)
        agent="${2:-}"
        shift 2
        ;;
      --target)
        target="${2:-}"
        shift 2
        ;;
      --cmd)
        payload="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$payload" ]]; then
    echo "--cmd is required" >&2
    exit 2
  fi

  if [[ -n "$agent" && -n "$target" ]]; then
    echo "use only one of --agent or --target" >&2
    exit 2
  fi

  if [[ -z "$agent" && -z "$target" ]]; then
    echo "set --agent or --target" >&2
    exit 2
  fi

  if [[ -n "$agent" ]]; then
    target="$(resolve_target "$agent")"
  fi

  local session
  session="${target%%:*}"

  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "tmux session not found: $session" >&2
    exit 31
  fi

  tmux send-keys -t "$target" "$payload" C-m
  echo "routed to $target"
}

normalize_github_repo() {
  local input="$1"
  local repo_path=""

  case "$input" in
    https://github.com/*)
      repo_path="${input#https://github.com/}"
      ;;
    github.com/*)
      repo_path="${input#github.com/}"
      ;;
    */*)
      repo_path="$input"
      ;;
    *)
      echo "invalid github repo: $input" >&2
      exit 2
      ;;
  esac

  repo_path="${repo_path%.git}"
  repo_path="${repo_path%/}"
  printf '%s\n' "$repo_path"
}

cmd_adapter_install() {
  local input="${1:-}"
  if [[ -z "$input" ]]; then
    echo "missing repo argument" >&2
    exit 2
  fi

  local repo_path
  repo_path="$(normalize_github_repo "$input")"
  local adapter_name
  adapter_name="$(basename "$repo_path")"

  local adapters_root="$HOME/.amux/adapters"
  local adapter_dir="$adapters_root/$adapter_name"
  local repo_url="https://github.com/${repo_path}.git"

  mkdir -p "$adapters_root"

  if [[ -d "$adapter_dir/.git" ]]; then
    git -C "$adapter_dir" pull --ff-only >/dev/null
    echo "updated adapter at $adapter_dir"
    return
  fi

  if [[ -e "$adapter_dir" ]]; then
    echo "path exists and is not a git repo: $adapter_dir" >&2
    exit 1
  fi

  git clone "$repo_url" "$adapter_dir" >/dev/null
  echo "installed adapter at $adapter_dir"
}

cmd_adapter() {
  local sub="${1:-}"
  case "$sub" in
    install)
      shift
      cmd_adapter_install "${1:-}"
      ;;
    *)
      echo "unknown adapter command: ${sub:-}" >&2
      exit 2
      ;;
  esac
}

run_script_subcommand() {
  local cmd="$1"
  shift || true

  local installed_script="$AMUX_HOME/bin/scripts/$cmd"
  if [[ -x "$installed_script" ]]; then
    exec "$installed_script" "$@"
  fi

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    local local_script="$repo_root/bin/scripts/$cmd"
    if [[ -x "$local_script" ]]; then
      exec "$local_script" "$@"
    fi
  fi

  return 1
}

cmd_install() {
  local repo_root
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "not in a git repository" >&2
    exit 1
  fi
  local installer="$repo_root/scripts/install"
  if [[ ! -x "$installer" ]]; then
    echo "installer not found: $installer" >&2
    exit 1
  fi
  exec "$installer"
}

main() {
  ensure_amux_home

  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  case "$1" in
    start)
      shift
      cmd_start "$@"
      ;;
    route)
      shift
      cmd_route "$@"
      ;;
    adapter)
      shift
      cmd_adapter "$@"
      ;;
    install)
      shift
      cmd_install "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      cmd="$1"
      shift
      if ! run_script_subcommand "$cmd" "$@"; then
        echo "unknown command: $cmd" >&2
        usage
        exit 1
      fi
      ;;
  esac
}

main "$@"
