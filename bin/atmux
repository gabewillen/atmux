#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
ATMUX_BIN_ORIGIN="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# If running from installed launcher, pin source root to installed source tree.
if [[ "$ATMUX_BIN_ORIGIN" == "$ATMUX_HOME/bin" && -d "$ATMUX_HOME/src/atmux" ]]; then
  ATMUX_SOURCE_ROOT="$ATMUX_HOME/src/atmux"
  export ATMUX_SOURCE_ROOT
elif [[ -z "${ATMUX_SOURCE_ROOT:-}" ]]; then
  local_checkout_root="$(cd -- "$ATMUX_BIN_ORIGIN/.." && pwd)"
  if [[ -x "$local_checkout_root/bin/atmux" && -d "$local_checkout_root/bin/(atmux)" ]]; then
    ATMUX_SOURCE_ROOT="$local_checkout_root"
  elif [[ -d "$ATMUX_HOME/src/atmux" ]]; then
    ATMUX_SOURCE_ROOT="$ATMUX_HOME/src/atmux"
  else
    ATMUX_SOURCE_ROOT="$local_checkout_root"
  fi
  export ATMUX_SOURCE_ROOT
fi

# In agent sessions, always route to the source repo's atmux so help/behavior
# stays current even if the worktree copy is stale.
if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/atmux" ]]; then
  if [[ "$ATMUX_BIN_ORIGIN" != "$(cd -- "${ATMUX_SOURCE_ROOT}/bin" && pwd)" ]]; then
    exec "${ATMUX_SOURCE_ROOT}/bin/atmux" "$@"
  fi
fi

# shellcheck source=bin/(atmux)/(lib)/command-docs
source "$ATMUX_SOURCE_ROOT/bin/(atmux)/(lib)/command-docs"

# Resolve a non-shimmed `git` for internal use. Agent shim proxies keep
# PATH sanitized and export ATMUX_REAL_GIT for git, but this dispatcher can
# also run in inherited agent environments, so it still defensively skips
# active shim/proxy locations while walking PATH.
_atmux_git() {
  if [[ -n "${ATMUX_REAL_GIT:-}" && -x "$ATMUX_REAL_GIT" ]]; then
    "$ATMUX_REAL_GIT" "$@"
    return $?
  fi
  # Search the system default PATH first, then fall back to `which -a` over the current PATH and
  # finally a hardcoded list of common locations. We can't use
  # `command -v -p` because bash silently ignores `-p` when `-v` is
  # present; instead, prefix `PATH=$(getconf PATH)` so `command -v`
  # resolves against the system default PATH for that one invocation.
  local candidate resolved default_path
  default_path="$(getconf PATH 2>/dev/null || printf '/usr/bin:/bin:/usr/sbin:/sbin')"
  while IFS= read -r candidate; do
    [[ -n "$candidate" && -x "$candidate" ]] || continue
    resolved="$(cd -- "$(dirname -- "$candidate")" 2>/dev/null && pwd -P)/$(basename -- "$candidate")"
    if [[ -n "${ATMUX_SHIM_PROXY_DIR:-}" && "$resolved" == "$(cd -- "$ATMUX_SHIM_PROXY_DIR" 2>/dev/null && pwd -P)/git" ]]; then
      continue
    fi
    case ":${ATMUX_ACTIVE_SHIM_DIRS:-}:" in
      *":$(dirname -- "$resolved"):"*) continue ;;
    esac
    "$candidate" "$@"
    return $?
  done < <(PATH="$default_path" command -v git 2>/dev/null
           which -a git 2>/dev/null
           printf '%s\n' /usr/bin/git /opt/homebrew/bin/git /usr/local/bin/git)
  return 127
}

command_dir() {
  printf '%s\n' "${ATMUX_SOURCE_ROOT:-$(cd -- "$ATMUX_BIN_ORIGIN/.." && pwd)}/bin/(atmux)"
}

command_files() {
  atmux_command_files "$(command_dir)" contextual-help
}

extract_usage_block() {
  atmux_extract_usage_block "$1"
}

command_summary() {
  local block="$1"
  printf '%s\n' "$block" | atmux_split_usage_sections | atmux_extract_description_summary
}

print_commands() {
  local file name block summary
  while IFS= read -r file; do
    name="$(basename "$file")"
    block="$(extract_usage_block "$file")"
    [[ -n "$block" ]] || continue
    summary="$(command_summary "$block")"
    [[ -n "$summary" ]] || summary="Run atmux $name --help."
    printf '  %-10s %s\n' "$name" "$summary"
  done < <(command_files)
}

usage() {
  printf '%s\n' \
    "Usage:" \
    "  atmux <resource> <verb> [args...]" \
    "  atmux <verb> [args...]" \
    "" \
    "tmux-first orchestration for AI coding agents." \
    "" \
    "Commands:"
  print_commands
  printf '%s\n' "" "Run:" "  atmux <command> --help"
}

ensure_atmux_home() {
  mkdir -p "$ATMUX_HOME/bin" "$ATMUX_HOME/bin/scripts" "$ATMUX_HOME/agents" "$ATMUX_HOME/adapters" "$ATMUX_HOME/shims"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

normalize_github_repo() {
  local input="$1"
  local repo_path=""

  case "$input" in
    https://github.com/*)
      repo_path="${input#https://github.com/}"
      ;;
    github.com/*)
      repo_path="${input#github.com/}"
      ;;
    */*)
      repo_path="$input"
      ;;
    *)
      echo "invalid github repo: $input" >&2
      exit 2
      ;;
  esac

  repo_path="${repo_path%.git}"
  repo_path="${repo_path%/}"
  printf '%s\n' "$repo_path"
}

resolve_script_subcommand() {
  local cmd="$1"
  local repo_root=""
  local p=""

  if repo_root="$(_atmux_git rev-parse --show-toplevel 2>/dev/null)"; then
    p="$repo_root/bin/(atmux)/${cmd}"
    if [[ -f "$p" && -x "$p" ]]; then
      printf '%s\n' "$p"
      return 0
    fi
  fi

  p="$ATMUX_HOME/bin/scripts/${cmd}"
  if [[ -f "$p" && -x "$p" ]]; then
    printf '%s\n' "$p"
    return 0
  fi

  # Fall back to the launcher's own source tree. This makes new commands
  # work when atmux is invoked from outside its source repo and not yet
  # installed (otherwise resolution would only see the cwd's repo and the
  # ~/.atmux install, both of which may lack the new command).
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" ]]; then
    p="$ATMUX_SOURCE_ROOT/bin/(atmux)/${cmd}"
    if [[ -f "$p" && -x "$p" ]]; then
      printf '%s\n' "$p"
      return 0
    fi
  fi

  return 1
}

is_agent_context() {
  # An "agent" is any caller that has the ATMUX_AGENT_NAME export set —
  # this is how agents and their child processes identify themselves.
  [[ -n "${ATMUX_AGENT_NAME:-}" ]]
}

reporter_mode() {
  case "${ATMUX_REPORTER:-}" in
    xml|cli) printf '%s\n' "$ATMUX_REPORTER"; return ;;
  esac
  if [[ "${ATMUX_NO_WRAP:-}" == "1" ]]; then
    printf 'cli\n'
    return
  fi
  if is_agent_context; then
    printf 'xml\n'
  else
    printf 'cli\n'
  fi
}

should_wrap_command() {
  local cmd="${1:-}"
  shift || true

  if [[ "${ATMUX_NO_WRAP:-}" == "1" ]]; then
    return 1
  fi

  # Humans get raw CLI output; only wrap when the caller is an agent.
  if [[ "$(reporter_mode)" != "xml" ]]; then
    return 1
  fi

  case "$cmd" in
    exec|watch|notify|kill|install)
      return 1
      ;;
    agent)
      case "${1:-}" in
        attach|_run-adapter|create|_create)
          return 1
          ;;
      esac
      ;;
    adapter)
      if [[ "${2:-}" == "start" ]]; then
        return 1
      fi
      ;;
  esac

  return 0
}

emit_atmux_wrapper() {
  local command_text="$1"
  local stdout_file="$2"
  local stderr_file="$3"
  local rc="$4"
  local first_nonempty
  first_nonempty="$(awk 'NF { print; exit }' "$stdout_file" 2>/dev/null || true)"

  printf '<atmux command="%s" exit_code="%s" date="%s" time="%s">\n' \
    "$(xml_escape "$command_text")" "$(xml_escape "$rc")" \
    "$(date -u +%Y-%m-%d)" "$(date -u +%H:%M:%SZ)"

  if [[ -s "$stdout_file" ]]; then
    if [[ "$first_nonempty" == \<* ]]; then
      cat "$stdout_file"
      case "$(tail -c 1 "$stdout_file" 2>/dev/null || true)" in
        $'\n') ;;
        *) printf '\n' ;;
      esac
    else
      printf '  <output>%s</output>\n' "$(xml_escape "$(cat "$stdout_file")")"
    fi
  fi

  if [[ -s "$stderr_file" ]]; then
    printf '  <error>%s</error>\n' "$(xml_escape "$(cat "$stderr_file")")"
  fi

  printf '</atmux>\n'
}

maybe_auto_update() {
  local stamp="$ATMUX_HOME/.last-update-check"
  local log="$ATMUX_HOME/.update.log"
  local throttle=3600  # seconds between checks

  # Check global config, then local repo config
  local enabled=0 val cfg
  cfg="$ATMUX_HOME/config/update/auto"
  if [[ -f "$cfg" ]]; then
    val="$(cat "$cfg")"
    [[ "$val" == "1" || "$val" == "true" ]] && enabled=1
  fi
  if [[ "$enabled" -eq 0 ]]; then
    local repo_root=""
    if repo_root="$(_atmux_git rev-parse --show-toplevel 2>/dev/null)"; then
      cfg="$repo_root/.atmux/config/update/auto"
      if [[ -f "$cfg" ]]; then
        val="$(cat "$cfg")"
        [[ "$val" == "1" || "$val" == "true" ]] && enabled=1
      fi
    fi
  fi
  [[ "$enabled" -eq 1 ]] || return 0

  if [[ -f "$stamp" ]]; then
    local now mtime age
    now="$(date +%s)"
    mtime="$(stat -f %m "$stamp" 2>/dev/null || stat -c %Y "$stamp" 2>/dev/null || echo 0)"
    age=$(( now - mtime ))
    [[ "$age" -lt "$throttle" ]] && return 0
  fi

  touch "$stamp"

  local update_script=""
  if [[ -x "${ATMUX_SOURCE_ROOT:-}/bin/(atmux)/update" ]]; then
    update_script="${ATMUX_SOURCE_ROOT}/bin/(atmux)/update"
  elif [[ -x "$ATMUX_HOME/bin/scripts/update" ]]; then
    update_script="$ATMUX_HOME/bin/scripts/update"
  else
    return 0
  fi

  ( ATMUX_HOME="$ATMUX_HOME" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
      "$update_script" >> "$log" 2>&1 ) &
  disown $!
}

main() {
  ensure_atmux_home

  if [[ $# -lt 1 ]]; then
    usage
    exit 0
  fi

  maybe_auto_update

  case "$1" in
    -h|--help|help)
      if [[ "$(reporter_mode)" == "xml" ]]; then
        out_file="$(mktemp "${TMPDIR:-/tmp}/atmux-out.XXXXXX")"
        err_file="$(mktemp "${TMPDIR:-/tmp}/atmux-err.XXXXXX")"
        trap 'rm -f "$out_file" "$err_file"' EXIT
        usage >"$out_file"
        emit_atmux_wrapper "help" "$out_file" "$err_file" 0
      else
        usage
      fi
      ;;
    *)
      cmd="$1"
      shift
      # Resolve the script BEFORE checking tmux so unknown commands surface
      # as "unknown command" rather than the confusing "must be run inside
      # tmux" message.
      if ! script_path="$(resolve_script_subcommand "$cmd")"; then
        if [[ "$(reporter_mode)" == "xml" ]]; then
          out_file="$(mktemp "${TMPDIR:-/tmp}/atmux-out.XXXXXX")"
          err_file="$(mktemp "${TMPDIR:-/tmp}/atmux-err.XXXXXX")"
          trap 'rm -f "$out_file" "$err_file"' EXIT
          usage >"$out_file"
          printf 'unknown command: %s\n' "$cmd" >"$err_file"
          emit_atmux_wrapper "$cmd $*" "$out_file" "$err_file" 1
        else
          printf 'unknown command: %s\n' "$cmd" >&2
          usage >&2
        fi
        exit 1
      fi
      # All commands are allowed outside tmux. The underlying scripts
      # invoke `tmux ...` directly when they need the server, and those
      # calls fail with a clear error if no server is running — a
      # blanket up-front gate just forced callers to set
      # ATMUX_ALLOW_OUTSIDE_TMUX for plenty of legitimate uses
      # (sending to an agent from a non-tmux shell, scripted notify
      # from CI, etc).

      export ATMUX_ALLOW_REAL_TMUX=1
      if should_wrap_command "$cmd" "$@"; then
        out_file="$(mktemp "${TMPDIR:-/tmp}/atmux-out.XXXXXX")"
        err_file="$(mktemp "${TMPDIR:-/tmp}/atmux-err.XXXXXX")"
        trap 'rm -f "$out_file" "$err_file"' EXIT
        rc=0
        if "$script_path" "$@" >"$out_file" 2>"$err_file"; then
          rc=0
        else
          rc=$?
        fi
        emit_atmux_wrapper "$cmd $*" "$out_file" "$err_file" "$rc"
        exit "$rc"
      fi

      exec "$script_path" "$@"
      ;;
  esac
}

main "$@"
