#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"

amux_home="$(mktemp -d "${TMPDIR:-/tmp}/amux-gemini-test-home.XXXXXX")"

cleanup() {
  [[ -n "${session_name:-}" ]] && "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$amux_home"
}
trap cleanup EXIT

start_cmd="AMUX_HOME='$amux_home' AMUX_GEMINI_MODEL=gemini-2.5-pro AMUX_GEMINI_REASONING_LEVEL=high '$ADAPTER_DIR/scripts/start'"
setup_out="$("$SCRIPTS_DIR/setup" --command "$start_cmd" --wait-text 'Type your message')"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

status_out="$({
  AMUX_HOME="$amux_home" \
  AMUX_TARGET_PANE="$pane_id" \
  "$ADAPTER_DIR/scripts/status"
})"

extract_attr() {
  local attr="$1"
  printf '%s\n' "$status_out" | sed -n "s/.*$attr=\"\\([^\"]*\\)\".*/\\1/p" | tail -n 1
}

echo "$status_out" | grep -F '<status ' >/dev/null
echo "$status_out" | grep -F 'adapter="gemini"' >/dev/null

state="$(extract_attr state)"
model="$(extract_attr model)"
reasoning="$(extract_attr reasoning_level)"

case "$state" in
  idle|busy|errored|usage-limit) ;;
  *)
    echo "unexpected state: $state" >&2
    exit 1
    ;;
esac
echo "$status_out" | grep -F 'model="gemini-2.5-pro"' >/dev/null
echo "$status_out" | grep -F 'reasoning_level="high"' >/dev/null

echo "PASS 06_status_usage_limit_detection"
