#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-stdio-dur.XXXXXX")"
repo_name="sd${RANDOM}"
session_exec="atmux-${repo_name}-exec"
session_watch="atmux-${repo_name}-watch"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"

cleanup() {
  tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true

tmux new-session -d -s "$session_exec" -n "$session_exec" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux new-session -d -s "$session_watch" -n "$session_watch" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

pane_exec="$(tmux list-panes -t "$session_exec" -F '#{pane_id}' 2>/dev/null | head -n1)"
pane_watch="$(tmux list-panes -t "$session_watch" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_exec" && -n "$pane_watch" ]] || { echo "missing panes" >&2; exit 1; }

# Start a long-running detached exec that produces output periodically
tmux send-keys -t "$pane_exec" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"exec\" ATMUX_SESSION_NAME=\"$session_exec\" \"$ATMUX_BIN\" exec --detach -- bash -c 'while true; do echo tick-\$RANDOM; sleep 1; done'" C-m

# Wait for exec metadata
deadline=$(( $(date +%s) + 10 ))
pid=""
while [[ -z "$pid" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    for ep_dir in "$exec_root"/detach-*; do
      if [[ -d "$ep_dir" && -f "$ep_dir/pid" ]]; then
        candidate="$(tr -d '\r\n' <"$ep_dir/pid")"
        if [[ -n "$candidate" && "$candidate" != detach-* ]]; then
          pid="$candidate"
          break
        fi
      fi
    done
  fi
  sleep 0.05
done

# Run watcher with short --duration; the process keeps outputting so timeout won't fire first
tmux set-environment -t "$session_watch" ATMUX_HOME "$atmux_home"
tmux set-environment -t "$session_watch" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_watch" ATMUX_AGENT_NAME "watch"
tmux set-environment -t "$session_watch" ATMUX_SESSION_NAME "$session_watch"

rc_file="$tmp_home/watch_rc"
tmux send-keys -t "$pane_watch" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watch\" ATMUX_SESSION_NAME=\"$session_watch\" \"$ATMUX_BIN\" watch --pid \"$pid\" --stdio --duration 4 --timeout 0 --interval 1; echo \$? > \"$rc_file\"" C-m

# Wait for rc_file
deadline=$(( $(date +%s) + 30 ))
while [[ ! -f "$rc_file" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for watcher to finish" >&2
    tmux capture-pane -p -t "$pane_watch" -S -200 >&2 || true
    exit 1
  fi
  sleep 0.5
done

rc="$(tr -d '\r\n' < "$rc_file")"
[[ "$rc" == "124" ]] || { echo "expected exit 124 on duration expiry, got: $rc" >&2; exit 1; }

echo "ok: watch --stdio exits 124 on duration expiry"
