#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/../notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux process watch <pid> [--timeout <seconds>] [--interval <seconds>]

Description:
  Wait for an atmux exec process (metadata under ~/.atmux/exec/<repo>/<pid>/).
  Registers this pane to receive the same exit notification XML as the executor.
  Only PIDs tracked by atmux exec are accepted.

Examples:
  atmux process watch 12345
  atmux process watch 12345 --timeout 60 --interval 0.5
USAGE
}

main() {
  local pid=""
  local timeout_sec="0"
  local interval="0.2"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pid)
        pid="${2:-}"
        shift 2
        ;;
      --timeout)
        timeout_sec="${2:-}"
        shift 2
        ;;
      --interval)
        interval="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$pid" ]] || { echo "missing --pid" >&2; exit 2; }

  local repo_name
  repo_name="$(repo_name_from_context)"
  local exec_dir
  exec_dir="$(exec_dir_for_repo_pid "$repo_name" "$pid")"

  if ! validate_exec_ownership "$exec_dir" "$pid" "$repo_name"; then
    echo "atmux process watch: not an atmux-owned exec PID for this repo: $pid" >&2
    exit 2
  fi

  local st
  st="$(read_state_field "$exec_dir/state" || true)"
  if [[ "$st" == "exited" ]]; then
    exit 0
  fi

  mkdir -p "$exec_dir/watchers"
  watcher_file="$(mktemp "$exec_dir/watchers/watcher.XXXXXX")"
  local pane
  pane="$(current_pane)"
  event_fifo="${watcher_file}.fifo"
  mkfifo "$event_fifo"
  exec 9<>"$event_fifo"
  write_field "$watcher_file" "${pane}|${event_fifo}"

  cleanup_watcher() {
    exec 9>&- 9<&- || true
    [[ -n "${watcher_file:-}" ]] && rm -f "$watcher_file"
    [[ -n "${event_fifo:-}" ]] && rm -f "$event_fifo"
  }
  trap cleanup_watcher EXIT INT TERM HUP

  local deadline=0
  if [[ -n "$timeout_sec" && "$timeout_sec" != "0" ]]; then
    deadline=$(( $(date +%s) + timeout_sec ))
  fi

  st="$(read_state_field "$exec_dir/state" || true)"
  if [[ "$st" == "exited" ]]; then
    exit 0
  fi

  while true; do
    st="$(read_state_field "$exec_dir/state" || true)"
    if [[ "$st" == "exited" ]]; then
      break
    fi

    if [[ "$deadline" -gt 0 ]]; then
      local now
      now="$(date +%s)"
      if (( now >= deadline )); then
        exit 124
      fi
      if ! read -r -t "$(( deadline - now ))" _ <&9; then
        st="$(read_state_field "$exec_dir/state" || true)"
        [[ "$st" == "exited" ]] && break
        exit 124
      fi
    else
      read -r _ <&9 || true
    fi
  done

  exit 0
}

main "$@"
