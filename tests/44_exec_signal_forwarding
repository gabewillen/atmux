#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-exec-sig.XXXXXX")"
repo_name="sig_test_$RANDOM"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"

cleanup() {
  [[ -n "${wrapper_pid:-}" ]] && kill "$wrapper_pid" 2>/dev/null || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

# Start exec with a long-running process
(
  HOME="$tmp_home" ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" \
    ATMUX_AGENT_NAME="t" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
    exec "$ATMUX_BIN" exec sleep 120
) &
wrapper_pid=$!

# Wait for exec metadata
deadline=$(( $(date +%s) + 15 ))
child_pid=""
while [[ -z "$child_pid" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    ep_dir="$(find "$exec_root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | head -n1)"
    if [[ -n "$ep_dir" && -f "$ep_dir/pid" ]]; then
      child_pid="$(tr -d '\r\n' <"$ep_dir/pid")"
    fi
  fi
  sleep 0.05
done

# Verify child is running
kill -0 "$child_pid" 2>/dev/null || { echo "child process not running" >&2; exit 1; }

# Send TERM to the wrapper — it should forward to the child
kill -TERM "$wrapper_pid" 2>/dev/null || true

# Wait for wrapper to exit
wait "$wrapper_pid" 2>/dev/null || true

# Verify the child process was killed
sleep 0.3
if kill -0 "$child_pid" 2>/dev/null; then
  echo "child process should be terminated after TERM signal" >&2
  kill -KILL "$child_pid" 2>/dev/null || true
  exit 1
fi

# Verify exec metadata recorded the termination
entry_dir="$(find "$exec_root" -mindepth 1 -maxdepth 1 -type d | head -n1)"
[[ -n "$entry_dir" ]] || { echo "exec entry missing after signal" >&2; exit 1; }

st="$(tr -d '\r\n' < "$entry_dir/state")"
[[ "$st" == "exited" ]] || { echo "expected exited state after signal, got $st" >&2; exit 1; }

echo "ok: exec forwards TERM signal to child and records exit"
