#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"
CONTROL_FILES=(CLAUDE.md GEMINI.md)
CONTROL_SNAPSHOT=""

snapshot_control_files() {
  local file
  CONTROL_SNAPSHOT="$(mktemp -d "${TMPDIR:-/tmp}/atmux-control-files.XXXXXX")"
  for file in "${CONTROL_FILES[@]}"; do
    if [[ -e "$REPO_ROOT/$file" ]]; then
      cp "$REPO_ROOT/$file" "$CONTROL_SNAPSHOT/$file"
    else
      touch "$CONTROL_SNAPSHOT/$file.missing"
    fi
  done
}

restore_control_files() {
  local file
  [[ -n "$CONTROL_SNAPSHOT" ]] || return 0
  for file in "${CONTROL_FILES[@]}"; do
    if [[ -f "$CONTROL_SNAPSHOT/$file.missing" ]]; then
      rm -f "$REPO_ROOT/$file"
    elif [[ -f "$CONTROL_SNAPSHOT/$file" ]]; then
      cp "$CONTROL_SNAPSHOT/$file" "$REPO_ROOT/$file"
    fi
  done
  rm -rf "$CONTROL_SNAPSHOT"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-40}"
  local deadline now snap
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -1800 2>/dev/null | tr -d '\r' || true)"
    if printf '%s' "$snap" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

wait_for_message_read() {
  local repo="$1"
  local message_id="$2"
  local timeout="${3:-30}"
  local deadline now path
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    path="$atmux_home/messages/$repo/$message_id/read_at"
    [[ -f "$path" ]] && return 0
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

session_pane() {
  local session="$1"
  tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1
}

session_env() {
  local session="$1"
  local key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p"
}

wait_for_adapter_ready() {
  local pane="$1"
  local adapter="$2"
  case "$adapter" in
    codex)
      wait_for_text "$pane" 'OpenAI Codex' 60
      ;;
    claude-code)
      wait_for_text "$pane" 'Claude Code v' 60
      ;;
    gemini)
      wait_for_text "$pane" 'Type your message' 90
      ;;
    *)
      echo "unknown adapter: $adapter" >&2
      exit 2
      ;;
  esac
}

send_and_verify() {
  local target_adapter="$1"
  local worker_session="$2"
  local worker_pane="$3"
  local token send_out message_id
  local idx

  for idx in 1 2; do
    token="codex-manager-to-${target_adapter}-${idx}-${RANDOM}"
    send_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
      ATMUX_AGENT_NAME="manager" ATMUX_SESSION_NAME="$manager_session" \
      "$ATMUX_BIN" send --to "$worker_session" "$token")"
    message_id="$(printf '%s\n' "$send_out" | sed -n 's/.*message_id="\([^"]*\)".*/\1/p' | head -n1)"

    printf '%s\n' "$send_out" | grep -F 'to="agent"' >/dev/null
    [[ -n "$message_id" ]] || {
      echo "missing message_id for $target_adapter send $idx" >&2
      printf '%s\n' "$send_out" >&2
      exit 1
    }

    if ! wait_for_text "$worker_pane" '<notification type="message"' 30; then
      echo "$target_adapter subagent did not receive Codex manager message notification" >&2
      tmux capture-pane -p -t "$worker_pane" -S -260 >&2 || true
      exit 1
    fi

    if ! wait_for_message_read "$repo" "$message_id" 30; then
      echo "$target_adapter subagent did not read Codex manager message $idx" >&2
      tmux capture-pane -p -t "$worker_pane" -S -260 >&2 || true
      exit 1
    fi
  done
}

create_subagent() {
  local adapter="$1"
  local name="$2"
  local create_out session pane

  create_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
    ATMUX_AGENT_NAME="manager" ATMUX_SESSION_NAME="$manager_session" \
    "$ATMUX_BIN" create --agent "$name" --role implementer --adapter "$adapter" --intelligence 50 --no-worktree)"
  session="$(printf '%s\n' "$create_out" | sed -n 's/.*session="\([^"]*\)".*/\1/p' | head -n1)"
  [[ -n "$session" ]] || {
    echo "failed to parse $adapter subagent session" >&2
    printf '%s\n' "$create_out" >&2
    exit 1
  }
  SESSIONS+=("$session")

  pane="$(session_pane "$session")"
  [[ -n "$pane" ]] || { echo "missing pane for $adapter subagent" >&2; exit 1; }
  if ! wait_for_adapter_ready "$pane" "$adapter"; then
    echo "$adapter subagent did not become ready" >&2
    tmux capture-pane -p -t "$pane" -S -260 >&2 || true
    exit 1
  fi

  if [[ "$(session_env "$session" ATMUX_MANAGER)" != "manager" ]]; then
    echo "$adapter subagent missing ATMUX_MANAGER=manager" >&2
    exit 1
  fi

  printf '%s|%s\n' "$session" "$pane"
}

require_cmd tmux
require_cmd codex
require_cmd claude
require_cmd gemini

repo="codex-subagent-live-${RANDOM}"
atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-codex-subagents.XXXXXX")"
mkdir -p "$HOME/.atmux/messages"
ln -s "$HOME/.atmux/messages" "$atmux_home/messages"
manager_session=""
SESSIONS=()

cleanup() {
  local session
  for session in "${SESSIONS[@]:-}"; do
    [[ -n "$session" ]] || continue
    tmux kill-session -t "$session" >/dev/null 2>&1 || true
  done
  rm -rf "$atmux_home"
  rm -rf "$REPO_ROOT/.gemini"
  restore_control_files
}
trap cleanup EXIT

snapshot_control_files

manager_session="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
  "$ATMUX_BIN" session start --name manager --adapter codex --no-worktree)"
[[ -n "$manager_session" ]] || { echo "failed to create Codex manager session" >&2; exit 1; }
SESSIONS+=("$manager_session")

manager_pane="$(session_pane "$manager_session")"
[[ -n "$manager_pane" ]] || { echo "missing Codex manager pane" >&2; exit 1; }
if ! wait_for_adapter_ready "$manager_pane" codex; then
  echo "Codex manager did not become ready" >&2
  tmux capture-pane -p -t "$manager_pane" -S -260 >&2 || true
  exit 1
fi

claude_info="$(create_subagent claude-code claude-worker)"
claude_session="${claude_info%%|*}"
claude_pane="${claude_info##*|}"
send_and_verify claude-code "$claude_session" "$claude_pane"

gemini_info="$(create_subagent gemini gemini-worker)"
gemini_session="${gemini_info%%|*}"
gemini_pane="${gemini_info##*|}"
send_and_verify gemini "$gemini_session" "$gemini_pane"

echo "ok: Codex manager delivers notifications to Claude and Gemini subagents"
