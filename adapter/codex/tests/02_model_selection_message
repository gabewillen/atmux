#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-codex-test-home.XXXXXX")"
trap 'rm -rf "$atmux_home"' EXIT

ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" set gpt-5.4 high >/dev/null

current_model="$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" get)"
current_reasoning="$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" get)"

[[ "$current_model" == "gpt-5.4" ]] || {
  echo "unexpected model get value after set: $current_model" >&2
  exit 1
}
[[ "$current_reasoning" == "high" ]] || {
  echo "unexpected reasoning get value after model set: $current_reasoning" >&2
  exit 1
}

if ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" set invalid >/dev/null 2>&1; then
  echo "invalid model unexpectedly succeeded" >&2
  exit 1
fi

echo "PASS 02_model_selection_message"
