#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

eval "$("$SCRIPTS_DIR/setup")"
atmux_home_tmp="$(mktemp -d)"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"; rm -rf \"$atmux_home_tmp\"" EXIT

title="issue-assign-$RANDOM"
desc="stabilize parser"
out="$(ATMUX_HOME="$atmux_home_tmp" ATMUX_REPO="$REPO_NAME" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="$AGENT1_SESSION" "$ATMUX_BIN" issue create --title "$title" --description "$desc" --todo "write failing test first" --todo "implement fix" --assign-to receiver)"

printf '%s\n' "$out" | grep -Fq '<assignment '
printf '%s\n' "$out" | grep -Fq 'created="true"'
printf '%s\n' "$out" | grep -Fq '<issue '
printf '%s\n' "$out" | grep -Fq "state=\"assigned\""

issue_id="$(printf '%s\n' "$out" | sed -n 's/.*issue_id="\([^"]*\)".*/\1/p' | head -n1)"
if [[ -z "$issue_id" ]]; then
  # Fallback: parse from the create XML's <issue id=...>
  issue_id="$(printf '%s\n' "$out" | sed -n 's/.*<issue id="\([^"]*\)".*/\1/p' | head -n1)"
fi
[[ -n "$issue_id" ]] || { echo "failed to parse issue id from output" >&2; exit 1; }

get_out="$(ATMUX_HOME="$atmux_home_tmp" ATMUX_REPO="$REPO_NAME" "$ATMUX_BIN" issue get "$issue_id")"
printf '%s\n' "$get_out" | grep -Fq "state=\"assigned\""
printf '%s\n' "$get_out" | grep -Fq "to=\"atmux-${REPO_NAME}-receiver\""
printf '%s\n' "$get_out" | grep -Fq "<title>$title</title>"

echo "ok: issue create --assign-to creates and assigns filesystem issue"

