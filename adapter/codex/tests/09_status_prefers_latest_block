#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"

source "$REPO_ROOT/tests/lib/isolate-tmux.sh"
export ATMUX_ALLOW_REAL_TMUX=1

session_name="atmux-codex-status-parse-$(date +%s)-$$"
cleanup() {
  tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux new-session -d -s "$session_name" "cat"
pane_id="$(tmux list-panes -t "$session_name" -F '#{pane_id}' 2>/dev/null | head -n 1)"
[[ -n "$pane_id" ]] || { echo "unable to resolve pane id" >&2; exit 1; }

tmux send-keys -t "$pane_id" -l "OpenAI Codex"
tmux send-keys -t "$pane_id" ENTER
tmux send-keys -t "$pane_id" -l "Model: gpt-5.4 (reasoning high)"
tmux send-keys -t "$pane_id" ENTER
tmux send-keys -t "$pane_id" -l "OpenAI Codex"
tmux send-keys -t "$pane_id" ENTER
tmux send-keys -t "$pane_id" -l "Model: gpt-5.5 (reasoning xhigh)"
tmux send-keys -t "$pane_id" ENTER
sleep 0.2

status_out="$(
  ATMUX_TARGET_PANE="$pane_id" \
  ATMUX_STATUS_PASSIVE=1 \
  "$ADAPTER_DIR/scripts/status"
)"

echo "$status_out" | grep -F '<status ' >/dev/null
echo "$status_out" | grep -F 'adapter="codex"' >/dev/null
echo "$status_out" | grep -F 'model="gpt-5.5"' >/dev/null
echo "$status_out" | grep -F 'reasoning_level="extra-high"' >/dev/null

echo "PASS 09_status_prefers_latest_block"
