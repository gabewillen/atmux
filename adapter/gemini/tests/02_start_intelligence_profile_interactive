#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"

command -v gemini >/dev/null 2>&1 || { echo "gemini command not found in PATH" >&2; exit 1; }

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-gemini-test-home.XXXXXX")"

cleanup() {
  [[ -n "${session_name:-}" ]] && "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$atmux_home"
}
trap cleanup EXIT

start_cmd="ATMUX_HOME='$atmux_home' ATMUX_INTELLIGENCE=95 '$ADAPTER_DIR/scripts/start'"
setup_out="$("$SCRIPTS_DIR/setup" --command "$start_cmd" --wait-text 'Type your message')"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

status_out="$(ATMUX_HOME="$atmux_home" ATMUX_TARGET_PANE="$pane_id" "$ADAPTER_DIR/scripts/status")"

echo "$status_out" | grep -F '<status ' >/dev/null
echo "$status_out" | grep -F 'adapter="gemini"' >/dev/null
echo "$status_out" | grep -F 'owner="agent"' >/dev/null
echo "$status_out" | grep -F 'state="idle"' >/dev/null
echo "$status_out" | grep -F 'model="gemini-2.5-pro"' >/dev/null
echo "$status_out" | grep -F 'control_file="GEMINI.md"' >/dev/null

state_file="$atmux_home/adapters/gemini/state.env"
[[ -f "$state_file" ]] || { echo "state file missing: $state_file" >&2; exit 1; }
grep -Fx 'MODEL=gemini-2.5-pro' "$state_file" >/dev/null
grep -Fx 'REASONING_LEVEL=high' "$state_file" >/dev/null

echo "PASS 02_start_intelligence_profile_interactive"
