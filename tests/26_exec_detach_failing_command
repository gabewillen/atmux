#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-detach-fail.XXXXXX")"
repo_name="df${RANDOM}"
session="atmux-${repo_name}-agent"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "agent pane missing" >&2; exit 1; }

# Run exec --detach with a command that fails
tmux send-keys -t "$pane" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"agent\" ATMUX_SESSION_NAME=\"$session\" \"$ATMUX_BIN\" exec --detach -- bash -lc 'exit 99'" C-m

# Should see detached XML response quickly
if ! wait_for_text "$pane" 'detached="true"' 10; then
  echo "detach XML response not found" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

# Wait for exit notification with the failing exit code
if ! wait_for_text "$pane" 'type="exec"' 15; then
  echo "exit notification not received at agent pane" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'exit_code="99"' 5; then
  echo "expected exit_code=99 in notification" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

# Verify exec metadata recorded the failure
deadline=$(( $(date +%s) + 10 ))
exec_entry=""
while [[ -z "$exec_entry" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    for ep_dir in "$exec_root"/detach-*; do
      if [[ -d "$ep_dir" && -f "$ep_dir/state" ]]; then
        st="$(tr -d '\r\n' < "$ep_dir/state")"
        if [[ "$st" == "exited" ]]; then
          exec_entry="$ep_dir"
          break
        fi
      fi
    done
  fi
  sleep 0.1
done

ec="$(tr -d '\r\n' < "$exec_entry/exit_code")"
[[ "$ec" == "99" ]] || { echo "expected exit_code=99 in metadata, got: $ec" >&2; exit 1; }

echo "ok: exec --detach sends notification with non-zero exit code"
