#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_absence() {
  local target="$1"
  local needle="$2"
  local duration="${3:-1}"
  local end now
  end=$(( $(date +%s) + duration ))
  while true; do
    if wait_for_text "$target" "$needle" 1; then
      return 1
    fi
    now="$(date +%s)"
    if (( now >= end )); then
      return 0
    fi
  done
}

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-pr.XXXXXX")"
atmux_home="$tmp_root/.atmux"
repo_name="pr$RANDOM"
session="atmux-${repo_name}-watcher"
trigger_file="$tmp_root/trigger-1"
second_trigger_file="$tmp_root/trigger-2"
close_file="$tmp_root/close"
polled_file="$tmp_root/polled"
stub_dir="$tmp_root/bin"
snapshot_file="$atmux_home/watch-pr/octo_example_pr_42/snapshot"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$tmp_root"
}
trap cleanup EXIT

mkdir -p "$stub_dir"
cat > "$stub_dir/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" != "api" || "${2:-}" != "graphql" ]]; then
  echo "unexpected gh invocation: $*" >&2
  exit 1
fi

touch "${ATMUX_TEST_PR_POLLED_FILE:-/dev/null}"

if [[ -f "${ATMUX_TEST_PR_CLOSE_FILE:-}" ]]; then
  printf '%s\n' 'STATE|merged'
  printf '%s\n' '2026-04-23T00:00:02Z|issue_comment|IC_kw_test|octocat||watch-pr-marker-comment'
  printf '%s\n' '2026-04-23T00:00:03Z|review|RV_kw_test|hubot|APPROVED|watch-pr-second-comment'
elif [[ -f "${ATMUX_TEST_PR_SECOND_TRIGGER:-}" ]]; then
  printf '%s\n' 'STATE|open'
  printf '%s\n' '2026-04-23T00:00:00Z|issue_comment|IC_kw_test|octocat||watch-pr-marker-comment'
  printf '%s\n' '2026-04-23T00:00:03Z|review|RV_kw_test|hubot|APPROVED|watch-pr-second-comment'
elif [[ -f "${ATMUX_TEST_PR_TRIGGER:-}" ]]; then
  printf '%s\n' 'STATE|open'
  printf '%s\n' '2026-04-23T00:00:00Z|issue_comment|IC_kw_test|octocat||watch-pr-marker-comment'
else
  printf '%s\n' 'STATE|open'
fi
EOF
chmod +x "$stub_dir/gh"

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session" ATMUX_AGENT_NAME "watcher"
tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "missing watcher pane" >&2; exit 1; }

watchers_dir="$atmux_home/watch-pr/octo_example_pr_42/watchers"

tmux send-keys -t "$pane" \
  "ATMUX_HOME=\"$atmux_home\" ATMUX_GH_BIN=\"$stub_dir/gh\" ATMUX_TEST_PR_TRIGGER=\"$trigger_file\" ATMUX_TEST_PR_SECOND_TRIGGER=\"$second_trigger_file\" ATMUX_TEST_PR_CLOSE_FILE=\"$close_file\" ATMUX_TEST_PR_POLLED_FILE=\"$polled_file\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watcher\" ATMUX_SESSION_NAME=\"$session\" \"$ATMUX_BIN\" pr watch \"https://github.com/octo/example/pull/42\" --interval 0.2 --timeout 10" \
  C-m

if ! wait_for_text "$pane" '<watch type="pr"' 10; then
  echo "pr watch did not register" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_absence "$pane" 'watch-pr-marker-comment' 1; then
  echo "pr notification appeared before PR discussion changed" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 10 ))
while [[ ! -f "$polled_file" || ! -f "$snapshot_file" ]] || grep -Fq 'watch-pr-marker-comment' "$snapshot_file" 2>/dev/null; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr never completed its baseline snapshot" >&2
    tmux capture-pane -p -t "$pane" -S -200 >&2 || true
    exit 1
  fi
  sleep 0.05
done

deadline=$(( $(date +%s) + 10 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -ge 1 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr did not leave an active watcher registration" >&2
    exit 1
  fi
  sleep 0.1
done

touch "$trigger_file"

if ! wait_for_text "$pane" 'type="pr"' 15; then
  echo "watch --pr did not deliver a notification" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'octocat' 15; then
  echo "watch --pr notification missing author details" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'watch-pr-marker-comment' 15; then
  echo "watch --pr notification missing comment snippet" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

touch "$second_trigger_file"

if ! wait_for_text "$pane" 'watch-pr-second-comment' 15; then
  echo "watch --pr did not continue watching for later PR discussion" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

touch "$close_file"

deadline=$(( $(date +%s) + 15 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -eq 0 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr did not exit after PR merged" >&2
    exit 1
  fi
  sleep 0.1
done

if ! wait_for_text "$pane" 'pull request merged' 15; then
  echo "watch --pr missing merged notification" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: watch --pr keeps watching until PR merged"
