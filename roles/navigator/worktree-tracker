#!/usr/bin/env bash
# Follow-the-worktree tracker. Watches the driver's `git worktree add`
# hook file and re-arms `atmux git watch` to follow whichever worktree
# the driver actually creates.
#
# How the signal arrives:
#
#   The agent's PATH has an atmux-managed `git` shim ahead of the real
#   git. Any `git worktree add <path>` call routes through `atmux git`,
#   which forwards to real git AND, on success, writes the new
#   worktree's absolute path to
#     $ATMUX_HOME/agents/<repo>/<driver>/git-hooks/last-worktree-add
#
#   This tracker stats that file on a schedule and re-points the git
#   watcher when it sees a new path.
#
# Usage:
#   worktree-tracker <driver_name> <nav_session> <nav_pane> <state_dir> <log>
#
# Why this is robust beyond the cursor-agent case: anything that runs
# `git worktree add` through the shim emits the signal. Other adapters,
# user-issued git commands, scripts — all the same. Multi-team safe
# because each agent has its own hook file under its own state dir.
set -u

driver="${1:?usage: worktree-tracker <driver> <nav_session> <nav_pane> <state_dir> <log>}"
nav_session="${2:?usage: worktree-tracker <driver> <nav_session> <nav_pane> <state_dir> <log>}"
nav_pane="${3:?usage: worktree-tracker <driver> <nav_session> <nav_pane> <state_dir> <log>}"
state_dir="${4:?usage: worktree-tracker <driver> <nav_session> <nav_pane> <state_dir> <log>}"
log="${5:?usage: worktree-tracker <driver> <nav_session> <nav_pane> <state_dir> <log>}"

POLL_INTERVAL="${POLL_INTERVAL:-2}"   # seconds between hook-file stats
ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
ATMUX_REPO="${ATMUX_REPO:-}"

note() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >> "$log"; }

[[ -n "$ATMUX_REPO" ]] || { note "ATMUX_REPO unset — exiting"; exit 0; }

hook_file="$ATMUX_HOME/agents/$ATMUX_REPO/$driver/git-hooks/last-worktree-add"

note "worktree-tracker start: driver=$driver hook=$hook_file"

last_seen=""

# Self-terminate when the navigator session goes away (so the tmux
# window we run in dies cleanly even if the run-loop is mid-sleep).
nav_session_alive() {
  tmux has-session -t "$nav_session" 2>/dev/null
}

is_valid_worktree() {
  local path="$1"
  [[ -n "$path" && -d "$path" ]] || return 1
  git -C "$path" rev-parse --git-dir >/dev/null 2>&1
}

# Tear down the current `git-watch` window (if any) and spawn a fresh
# one rooted at $1. Each spawn gets a new unique --id so the persisted
# baseline state at $ATMUX_HOME/git/watch/<repo>/<id>/ never collides
# with the prior incarnation.
rearm_git_watch_at() {
  local target_path="$1"

  # Drop the prior git-watch state dir so the next watcher boots from
  # a clean baseline against the new path (the old --id's persisted
  # baseline tree won't match this worktree).
  local old_id=""
  if [[ -f "$state_dir/git-watch-id" ]]; then
    old_id="$(cat "$state_dir/git-watch-id" 2>/dev/null || true)"
  fi
  if [[ -n "$old_id" ]]; then
    rm -rf "$ATMUX_HOME/git/watch/$ATMUX_REPO/$old_id" 2>/dev/null || true
  fi

  # Kill the current git-watch window. Tmux will reap the watcher
  # process automatically; no pkill needed.
  tmux kill-window -t "$nav_session:git-watch" 2>/dev/null || true

  # New unique id for this spawn.
  local new_id
  new_id="$(printf '%s-rearm-%s-%04x' \
    "$driver" \
    "$(date +%s)" \
    "$(od -An -N2 -tx1 /dev/urandom 2>/dev/null | tr -d ' \n' || printf '%04x' $$)")"
  printf '%s\n' "$new_id" > "$state_dir/git-watch-id"

  # Spawn a fresh git-watch window with cwd at the driver's worktree.
  # `-c` sets the new window's working directory.
  tmux new-window -d -n git-watch -t "$nav_session" \
    -c "$target_path" \
    -e "ATMUX_NAVIGATOR_PANE=$nav_pane" \
    "atmux git watch \
       --id $(printf '%q' "$new_id") \
       --interval 10 \
       --coalesce 0 \
       --exec 'atmux notify --pane \"\$ATMUX_NAVIGATOR_PANE\" --xml \"\$(cat)\"' \
       >$(printf '%q' "$state_dir/git-watch.log") 2>&1" \
    2>/dev/null && note "rearmed git-watch at $target_path (id=$new_id)" \
    || note "tmux new-window failed for $target_path"
}

while sleep "$POLL_INTERVAL"; do
  nav_session_alive || { note "navigator session $nav_session gone — exiting"; exit 0; }

  [[ -f "$hook_file" ]] || continue

  current="$(cat "$hook_file" 2>/dev/null || true)"
  [[ -n "$current" ]] || continue
  [[ "$current" == "$last_seen" ]] && continue

  if ! is_valid_worktree "$current"; then
    note "hook reported $current but it isn't a valid worktree — ignoring"
    continue
  fi

  rearm_git_watch_at "$current"
  last_seen="$current"
done
