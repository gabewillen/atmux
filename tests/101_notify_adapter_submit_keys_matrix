#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

# Matrix sanity check: for every shipped adapter manifest, resolve_submit_keys
# returns the expected steer + interrupt key strings. Catches manifest schema
# regressions that would silently downgrade interrupt -> Enter.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}/atmux-keys-${RANDOM}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
mkdir -p "$ATMUX_HOME"
cleanup() { rm -rf "$ATMUX_HOME"; }
trap cleanup EXIT

source "$NOTIFY_SCRIPT"

normalize_keys() {
  # resolve_submit_keys may emit keys separated by newlines; normalise to
  # a single comma-joined string for stable comparison.
  tr '\n' ',' | sed 's/,$//'
}

check() {
  local label="$1" got="$2" want="$3"
  if [[ "$got" != "$want" ]]; then
    echo "FAIL: $label: want=$want got=$got" >&2
    exit 1
  fi
  printf '  ok: %-50s -> %s\n' "$label" "$got"
}

want_steer_for() {
  case "$1" in
    claude-code|codex|cursor-agent|gemini|opencode) printf 'Enter' ;;
    *) return 1 ;;
  esac
}

want_interrupt_for() {
  case "$1" in
    claude-code) printf 'Escape' ;;
    codex)       printf 'Escape' ;;
    cursor-agent) printf 'C-c' ;;
    gemini)      printf 'C-c' ;;
    opencode)    printf 'C-c' ;;
    *) return 1 ;;
  esac
}

echo "matrix: every adapter manifest resolves to expected submit_keys" >&2

for adapter in claude-code codex cursor-agent gemini opencode; do
  s="$(resolve_submit_keys "$adapter" steer | normalize_keys)"
  i="$(resolve_submit_keys "$adapter" interrupt | normalize_keys)"
  check "$adapter steer"     "$s" "$(want_steer_for "$adapter")"
  check "$adapter interrupt" "$i" "$(want_interrupt_for "$adapter")"
done

# Fallback: unknown adapter must fall back to Enter for both modes (this
# is what protects atmux from crashing when a user's session has a stale
# ATMUX_ADAPTER pointing at a deleted adapter).
unknown_s="$(resolve_submit_keys "this-adapter-does-not-exist" steer | normalize_keys)"
unknown_i="$(resolve_submit_keys "this-adapter-does-not-exist" interrupt | normalize_keys)"
check "unknown adapter steer"     "$unknown_s" "Enter"
check "unknown adapter interrupt" "$unknown_i" "Enter"

# Empty adapter name: same fallback. Otherwise an unset ATMUX_ADAPTER could
# crash the worker on an unbounded printf or empty manifest read.
empty_s="$(resolve_submit_keys "" steer | normalize_keys)"
empty_i="$(resolve_submit_keys "" interrupt | normalize_keys)"
check "empty adapter steer"     "$empty_s" "Enter"
check "empty adapter interrupt" "$empty_i" "Enter"

# Manifest with no submit_keys at all: must still fall back, never produce
# an empty string (an empty submit-keys list would skip submit entirely
# and leave the payload stuck in the input).
fake_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-fake-adapter.XXXXXX")"
mkdir -p "$fake_root/adapter/keysless"
cat > "$fake_root/adapter/keysless/manifest" <<'EOF'
NAME=keysless
VERSION=1
INPUT_START="?"
EOF
(
  ATMUX_SOURCE_ROOT="$fake_root"
  s="$(resolve_submit_keys "keysless" steer | normalize_keys)"
  i="$(resolve_submit_keys "keysless" interrupt | normalize_keys)"
  [[ "$s" == "Enter" ]] || { echo "FAIL: keysless steer: $s" >&2; exit 1; }
  [[ "$i" == "Enter" ]] || { echo "FAIL: keysless interrupt: $i" >&2; exit 1; }
  echo "  ok: keysless manifest                                -> Enter / Enter"
)
rm -rf "$fake_root"

fake_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-manifest-noexec.XXXXXX")"
mkdir -p "$fake_root/adapter/malicious"
marker="$fake_root/manifest-executed"
cat > "$fake_root/adapter/malicious/manifest" <<EOF
NAME=malicious
VERSION=1
SUBMIT_KEYS_STEER=(\$(touch "$marker") Enter)
INPUT_START=\$(touch "$marker")
EOF
(
  ATMUX_SOURCE_ROOT="$fake_root"
  s="$(resolve_submit_keys "malicious" steer | normalize_keys)"
  [[ "$s" == "Enter" ]] || { echo "FAIL: malicious steer keys: $s" >&2; exit 1; }
  prompt="$(resolve_input_prompt_for_adapter "malicious" "$fake_root" || true)"
  [[ -n "$prompt" ]] || true
  [[ ! -e "$marker" ]] || { echo "FAIL: adapter manifest metadata read executed shell code" >&2; exit 1; }
  echo "  ok: adapter manifest metadata reads do not execute shell"
)
rm -rf "$fake_root"

echo "ok: all adapter manifests resolve to expected submit_keys"

# resolve_submit_keys_strict must NOT fall back to Enter when a mode is
# missing — it returns empty + non-zero so --interrupt can detect the gap
# instead of silently sending Enter as the abort prefix.
echo "matrix: strict resolver returns empty for missing modes" >&2

fake_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-strict-resolver.XXXXXX")"
mkdir -p "$fake_root/adapter/steer-only"
cat > "$fake_root/adapter/steer-only/manifest" <<'EOF'
NAME=steer-only
VERSION=1
SUBMIT_KEYS_STEER=(Enter)
EOF
(
  ATMUX_SOURCE_ROOT="$fake_root"
  if resolve_submit_keys_strict "steer-only" interrupt > /dev/null 2>&1; then
    echo "FAIL: strict resolver should fail when mode is missing" >&2
    exit 1
  fi
  s_strict="$(resolve_submit_keys_strict "steer-only" steer | normalize_keys)"
  [[ "$s_strict" == "Enter" ]] || { echo "FAIL: strict steer: $s_strict" >&2; exit 1; }
  echo "  ok: strict resolver returns empty for missing mode  -> exit 1"
  echo "  ok: strict resolver returns keys when mode is present -> Enter"
)
rm -rf "$fake_root"

echo "ok: strict submit-keys resolver behaves correctly"
