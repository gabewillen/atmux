#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux exec [--detach | --shared] [--] <command> [args...]

Description:
  Execute a command with passthrough stdio and unchanged exit behavior.
  After the command exits or is interrupted, send an ATMUX notification back
  to the current agent pane with the exit code.

  --detach   Run the command in a new tmux window inside the current
             agent's session. Returns immediately. Tmux ties the window
             to the session — when the session is killed, the window
             (and the command) die with it. No nohup, no orphans.
  --shared   Run in a new tmux window inside the per-repo
             `atmux-<repo>-workers` session (lazy-created if missing).
             Use for long-running workers that aren't owned by any
             single agent (e.g. PR/issue feed watchers fanning events
             out to multiple subscribers). Implies --detach.

Examples:
  atmux exec sleep 30
  atmux exec -- make test
  atmux exec --detach -- make test
  atmux exec --shared -- atmux pr watch 123
USAGE
}

display_command_text() {
  local joined=""
  local part=""
  for part in "$@"; do
    if [[ -n "$joined" ]]; then
      joined+=" "
    fi
    joined+="$part"
  done
  printf '%s\n' "$joined"
}

exec_notifications_suppressed() {
  case "${ATMUX_EXEC_SUPPRESS_NOTIFY:-0}" in
    1|true|TRUE|yes|YES)
      return 0
      ;;
  esac
  return 1
}

record_exec_start() {
  local pid="$1"
  local repo_name="$2"
  local command_text="$3"
  local started_at="$4"
  local executor_pane="${5:-}"
  exec_dir="$(exec_dir_for_repo_pid "$repo_name" "$pid")"
  mkdir -p "$exec_dir"
  atmux_fs_write_field "$exec_dir/pid" "$pid"
  atmux_fs_write_field "$exec_dir/repo" "$repo_name"
  atmux_fs_write_field "$exec_dir/command" "$command_text"
  atmux_fs_write_field "$exec_dir/started_at" "$started_at"
  atmux_fs_write_field "$exec_dir/session_name" "${ATMUX_SESSION_NAME:-}"
  atmux_fs_write_field "$exec_dir/agent_name" "${ATMUX_AGENT_NAME:-}"
  atmux_fs_write_field "$exec_dir/executor_pane" "$executor_pane"
  atmux_fs_write_field "$exec_dir/state" "running"
}

record_exec_finish() {
  local finished_at="$1"
  local exit_code="$2"
  [[ -n "${exec_dir:-}" ]] || return 0
  atmux_fs_write_field "$exec_dir/finished_at" "$finished_at"
  atmux_fs_write_field "$exec_dir/exit_code" "$exit_code"
  atmux_fs_write_field "$exec_dir/state" "exited"
}

notify_exec_completion() {
  local exec_dir="$1"
  local notify_pane="$2"
  local notification_xml="$3"

  send_notification "$notify_pane" "$notification_xml" || true
  notify_exec_watchers "$exec_dir" "$notify_pane" "$notification_xml" || true
  atmux_fs_write_field "$exec_dir/notified" "$(timestamp_utc)"
}

notify_exec_completion_inline() {
  local exec_dir="$1"
  local notify_pane="$2"
  local notification_xml="$3"

  printf '%s\n' "$notification_xml"
  notify_exec_watchers "$exec_dir" "$notify_pane" "$notification_xml" || true
  atmux_fs_write_field "$exec_dir/notified" "$(timestamp_utc)"
}

terminate_child_with_signal() {
  local signal="$1"
  if [[ -n "${child_pid:-}" ]]; then
    kill "-$signal" "$child_pid" >/dev/null 2>&1 || true
  fi
}

finish_foreground_exec() {
  local exit_code="$1"

  foreground_finished=1
  atmux_fs_write_field "$exec_dir/finished_at" "$(timestamp_utc)"
  atmux_fs_write_field "$exec_dir/exit_code" "$exit_code"
  if ! exec_notifications_suppressed; then
    notification_xml="$(build_notification "exec" "$command_text" "atmux agent capture ${ATMUX_AGENT_NAME:-unknown}" "exit_code=$exit_code")"
    notify_exec_completion_inline "$exec_dir" "$notify_pane" "$notification_xml"
  fi
  signal_exec_watchers "$exec_dir" || true
  atmux_fs_write_field "$exec_dir/state" "exited"
  signal_exec_watchers "$exec_dir" || true
}

foreground_exit_trap() {
  local exit_code="$1"

  if [[ "${foreground_finished:-0}" -eq 0 && -n "${exec_dir:-}" ]]; then
    trap - INT TERM HUP QUIT EXIT
    terminate_child_with_signal TERM
    if [[ -n "${child_pid:-}" ]]; then
      wait "$child_pid" >/dev/null 2>&1 || true
    fi
    finish_foreground_exec "$exit_code"
  fi
}

handle_foreground_signal() {
  local signal="$1"
  local exit_code="$2"

  trap - INT TERM HUP QUIT
  terminate_child_with_signal "$signal"
  if [[ -n "${child_pid:-}" ]]; then
    wait "$child_pid" >/dev/null 2>&1 || true
  fi
  finish_foreground_exec "$exit_code"
  exit "$exit_code"
}

direct_foreground_exit_trap() {
  local exit_code="$1"

  if [[ "${foreground_finished:-0}" -eq 0 && -n "${exec_dir:-}" ]]; then
    trap - INT TERM HUP QUIT EXIT
    finish_foreground_exec "$exit_code"
  fi
}

handle_direct_foreground_signal() {
  local exit_code="$1"

  trap - INT TERM HUP QUIT EXIT
  finish_foreground_exec "$exit_code"
  exit "$exit_code"
}

exec_foreground() {
  child_pid=""

  if [[ -t 0 && -t 1 ]]; then
    exec_dir=""
    foreground_finished=0
    child_pid="$$"
    record_exec_start "$child_pid" "$repo_name" "$command_text" "$(timestamp_utc)" "$notify_pane"

    interrupted=0
    trap 'direct_foreground_exit_trap "$?"' EXIT
    trap 'interrupted=1' INT
    trap 'handle_direct_foreground_signal 143' TERM
    trap 'handle_direct_foreground_signal 129' HUP
    trap 'handle_direct_foreground_signal 131' QUIT
    set +e
    "${cmd[@]}"
    exit_code=$?
    set -e
    trap - INT TERM HUP QUIT
    if [[ "${interrupted:-0}" -eq 1 && "$exit_code" -eq 0 ]]; then
      exit_code=130
    fi

    finish_foreground_exec "$exit_code"
    trap - EXIT
    exit "$exit_code"
  fi

  foreground_finished=0
  trap 'foreground_exit_trap "$?"' EXIT
  trap 'handle_foreground_signal INT 130' INT
  trap 'handle_foreground_signal TERM 143' TERM
  trap 'handle_foreground_signal HUP 129' HUP
  trap 'handle_foreground_signal QUIT 131' QUIT

  "${cmd[@]}" &
  child_pid=$!
  exec_dir=""
  record_exec_start "$child_pid" "$repo_name" "$command_text" "$(timestamp_utc)" "$notify_pane"

  set +e
  wait "$child_pid"
  exit_code=$?
  set -e
  trap - INT TERM HUP QUIT

  finish_foreground_exec "$exit_code"
  trap - EXIT

  exit "$exit_code"
}

exec_detached() {
  # Target session for the new tmux window:
  #
  #   --shared   →  atmux-<repo>-workers (repo-shared bg session,
  #                 lazy-created if missing). Use for long-running
  #                 workers that aren't owned by any single agent —
  #                 e.g. PR/issue feed watchers fanning events out
  #                 across multiple subscribing agents.
  #   default    →  current agent's session (ATMUX_SESSION_NAME).
  #                 Used for tracked foreground-style execs that
  #                 should die when the agent does.
  local session=""
  if (( shared == 1 )); then
    if [[ -z "${repo_name:-}" ]]; then
      echo "--shared requires a repo context (no ATMUX_REPO and no git repo at cwd)" >&2
      exit 2
    fi
    session="atmux-${repo_name}-workers"
    if ! tmux has-session -t "$session" 2>/dev/null; then
      # Lazy-create. The placeholder window holds the session open
      # via `tail -f /dev/null` — portable across macOS BSD and Linux
      # GNU userlands (vs `sleep infinity`, which BSD sleep rejects;
      # the BSD shell would exit immediately and tmux would close
      # the empty session).
      tmux new-session -d -s "$session" -n holder \
        "exec tail -f /dev/null" 2>/dev/null || true
      if ! tmux has-session -t "$session" 2>/dev/null; then
        echo "--shared: failed to create session $session" >&2
        exit 2
      fi
    fi
  else
    session="${ATMUX_SESSION_NAME:-}"
    if [[ -z "$session" ]]; then
      echo "--detach requires an atmux session (ATMUX_SESSION_NAME not set; use --shared for a repo-scoped workers session)" >&2
      exit 2
    fi
    if ! tmux has-session -t "$session" 2>/dev/null; then
      echo "--detach: session not found: $session" >&2
      exit 2
    fi
  fi
  local window="exec-$$"

  # Store argv null-delimited to avoid quoting issues across tmux shells
  mkdir -p "${ATMUX_HOME}/tmp"
  local argv_file
  argv_file="$(mktemp "${ATMUX_HOME}/tmp/argv.XXXXXX")"
  printf '%s\0' "${cmd[@]}" > "$argv_file"
  local pid_fifo="$argv_file.pid"
  mkfifo "$pid_fifo"
  exec 8<>"$pid_fifo"

  # Pre-create exec_dir with a temp key; _run will update with real PID
  local detach_id="detach-$$-$RANDOM"
  exec_dir=""
  record_exec_start "$detach_id" "$repo_name" "$command_text" "$(timestamp_utc)" "$notify_pane"
  atmux_fs_write_field "$exec_dir/detached" "1"

  # Write a runner script to avoid quoting issues across tmux's default
  # shell. Forward every exported env var from the caller so the
  # spawned worker sees the same environment it would have under nohup
  # (ATMUX_HOME, ATMUX_GH_BIN, test-specific overrides, etc). A few
  # tmux-internal vars are skipped because tmux re-derives them in the
  # new window.
  local runner="$argv_file.run"
  local self="${BASH_SOURCE[0]}"
  {
    printf '#!/usr/bin/env bash\n'
    # Always forward ATMUX_HOME explicitly. The script-local
    # `ATMUX_HOME="${ATMUX_HOME:-...}"` assignment near the top of
    # `atmux exec` is *not* exported, so it doesn't appear in
    # `compgen -e` unless a parent process already exported it. Some
    # callers (e.g. test harnesses, ad-hoc shells) leave it unexported,
    # which would otherwise silently let the worker fall back to
    # `$HOME/.atmux` instead of the caller's intended ATMUX_HOME.
    printf 'export ATMUX_HOME=%q\n' "$ATMUX_HOME"
    while IFS= read -r __exec_env_name; do
      [[ -n "$__exec_env_name" ]] || continue
      case "$__exec_env_name" in
        TMUX|TMUX_PANE|_|ATMUX_HOME) continue ;;
      esac
      printf 'export %s=%q\n' "$__exec_env_name" "${!__exec_env_name-}"
    done < <(compgen -e)
    printf "exec %q _run %q %q %q %q %q\n" \
      "$self" "$argv_file" "$notify_pane" "$repo_name" "$exec_dir" "$pid_fifo"
  } > "$runner"
  chmod +x "$runner"

  # Launch in a new tmux window. `-a` appends after the current
  # window so we never collide with a session whose base-index is 0
  # and is already occupied by the adapter pane.
  local process_pane
  process_pane="$(tmux new-window -a -d -t "$session:" -n "$window" -P -F '#{pane_id}' "$runner")"

  atmux_fs_write_field "$exec_dir/executor_pane" "$process_pane"

  # Wait for _run to write its real PID
  local real_pid="" deadline
  deadline=$(( $(date +%s) + 5 ))
  if ! read -r -t 5 real_pid <&8; then
    real_pid="$(tr -d '\r\n' < "$exec_dir/pid" 2>/dev/null || true)"
  fi
  exec 8>&- 8<&- || true
  rm -f "$pid_fifo"
  if [[ -z "$real_pid" || "$real_pid" == "$detach_id" ]]; then
    echo "timeout waiting for detached process PID" >&2
    exit 1
  fi

  # Symlink from real PID so watch --pid <real_pid> resolves
  local real_dir
  real_dir="$(exec_dir_for_repo_pid "$repo_name" "$real_pid")"
  if [[ "$real_dir" != "$exec_dir" ]]; then
    ln -snf "$exec_dir" "$real_dir"
  fi

  printf '<exec pid="%s" pane="%s" detached="true" />\n' "$real_pid" "$process_pane"
}

# Runs inside the detached tmux window.
# Invoked as: exec _run <argv_file> <notify_pane> <repo_name> <exec_dir> [pid_fifo]
_run_detached() {
  local argv_file="$1"
  local notify_pane="$2"
  local repo_name="$3"
  exec_dir="$4"
  local pid_fifo="${5:-}"

  # Write our real PID (parent polls for this)
  atmux_fs_write_field "$exec_dir/pid" "$$"
  if [[ -n "$pid_fifo" && -p "$pid_fifo" ]]; then
    printf '%s\n' "$$" > "$pid_fifo" 2>/dev/null || true
  fi

  # Read command from null-delimited argv file
  local -a run_cmd=()
  while IFS= read -r -d '' arg; do
    run_cmd+=("$arg")
  done < "$argv_file"
  rm -f "$argv_file" "$argv_file.run"

  set +e
  "${run_cmd[@]}"
  local exit_code=$?
  set -e

  atmux_fs_write_field "$exec_dir/finished_at" "$(timestamp_utc)"
  atmux_fs_write_field "$exec_dir/exit_code" "$exit_code"

  local command_text
  command_text="$(read_state_field "$exec_dir/command")"
  local agent_name
  agent_name="$(read_state_field "$exec_dir/agent_name")"

  # Queue notifications BEFORE marking state=exited, so watchers polling
  # state haven't cleaned up their watcher files yet
  if ! exec_notifications_suppressed; then
    local notification_xml
    notification_xml="$(build_notification "exec" "$command_text" "atmux agent capture ${agent_name:-unknown}" "exit_code=$exit_code")"
    notify_exec_completion "$exec_dir" "$notify_pane" "$notification_xml"
  fi

  signal_exec_watchers "$exec_dir" || true
  atmux_fs_write_field "$exec_dir/state" "exited"
  signal_exec_watchers "$exec_dir" || true

  exit "$exit_code"
}

detach=0

if [[ $# -eq 0 ]]; then
  usage
  exit 2
fi

# Internal subcommand: _run is invoked inside a detached tmux window
if [[ "$1" == "_run" ]]; then
  shift
  _run_detached "$@"
  exit $?
fi

shared=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --detach)
      detach=1
      shift
      ;;
    --shared)
      shared=1
      detach=1
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  echo "missing command" >&2
  exit 2
fi

cmd=( "$@" )
command_text="$(display_command_text "${cmd[@]}")"
notify_pane="$(atmux_resolve_current_pane)"
repo_name="$(atmux_resolve_repo_name)"

if [[ "$detach" -eq 1 ]]; then
  exec_detached
else
  exec_foreground
fi
