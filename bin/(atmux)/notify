#!/usr/bin/env bash
# shellcheck shell=bash
# Shared helpers for exec, issue, watch --pid, watch --issue; also `atmux notify` CLI when executed.
# When sourced, only function definitions run (see bottom).

normalize_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

primary_pane_for_session() {
  local session="$1"
  tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }'
}

current_pane() {
  # Prefer TMUX_PANE (set by tmux per-pane) — display-message -p resolves
  # wrong without an attached client.
  if [[ -n "${TMUX_PANE:-}" ]]; then
    printf '%s\n' "$TMUX_PANE"
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return 0
  fi
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    primary_pane_for_session "$ATMUX_SESSION_NAME"
    return 0
  fi
  return 0
}

queue_self_notification() {
  local pane="$1"
  local payload="$2"
  shift 2
  local submit_key_str="${*:-Enter}"
  [[ -n "$pane" ]] || return 0

  nohup bash -lc '
    pane="$1"
    payload="$2"
    submit_key_str="$3"
    sleep 0.2
    settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"
    submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.3}"
    tmux send-keys -t "$pane" C-u >/dev/null 2>&1 || exit 0
    sleep "$settle"
    tmux send-keys -t "$pane" -l "$payload" >/dev/null 2>&1 || exit 0
    sleep "$settle"
    for _sk in $submit_key_str; do
      tmux send-keys -t "$pane" "$_sk" >/dev/null 2>&1 || exit 0
    done
    sleep "$submit_wait"
  ' _ "$pane" "$payload" "$submit_key_str" >/dev/null 2>&1 &
}

# Unified notification builder.
# Usage: build_notification <type> <from> <cmd> [key=value ...]
# Output: <notification type="..." from="..." cmd="..." key="value" ... />
build_notification() {
  local type="$1" from="$2" cmd="$3"
  shift 3
  local attrs=""
  local kv k v
  for kv in "$@"; do
    k="${kv%%=*}"
    v="${kv#*=}"
    attrs+=" ${k}=\"$(xml_escape "$v")\""
  done
  local cmd_attr=""
  if [[ -n "$cmd" ]]; then
    cmd_attr=" cmd=\"$(xml_escape "$cmd")\""
  fi
  printf '<notification type="%s" from="%s"%s%s />' \
    "$(xml_escape "$type")" \
    "$(xml_escape "$from")" \
    "$cmd_attr" \
    "$attrs"
}

get_session_env() {
  local session="$1" key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

session_short_name() {
  local session="$1" repo="$2"
  local prefix="atmux-${repo}-"
  if [[ -n "$repo" && "$session" == "$prefix"* ]]; then
    printf '%s\n' "${session#"$prefix"}"
  else
    printf '%s\n' "$session"
  fi
}

resolve_submit_keys() {
  local adapter="$1"
  local mode="${2:-queue}"
  local source_root manifest_path compact raw_keys

  source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"
  manifest_path="$source_root/adapter/$adapter/manifest.json"
  if [[ ! -f "$manifest_path" ]]; then
    manifest_path="$ATMUX_HOME/adapters/$adapter/manifest.json"
  fi
  if [[ ! -f "$manifest_path" ]]; then
    printf 'Enter\n'
    return 0
  fi

  compact="$(tr -d '\n\r\t ' < "$manifest_path")"
  raw_keys="$(printf '%s' "$compact" | sed -n "s/.*\"${mode}\":\[\([^]]*\)\].*/\1/p")"
  if [[ -z "$raw_keys" ]]; then
    printf 'Enter\n'
    return 0
  fi

  printf '%s' "$raw_keys" | sed 's/"//g; s/,/\n/g'
}

timestamp_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

repo_name_from_context() {
  local repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  normalize_name "$repo_name"
}

write_field() {
  local file="$1"
  local value="${2:-}"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" > "$file"
}

exec_root_for_repo() {
  local repo_name="$1"
  printf '%s/exec/%s\n' "$ATMUX_HOME" "$repo_name"
}

exec_dir_for_repo_pid() {
  local repo_name="$1"
  local pid="$2"
  printf '%s/%s\n' "$(exec_root_for_repo "$repo_name")" "$pid"
}

read_state_field() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    printf ''
    return 0
  fi
  tr -d '\r\n' <"$file" 2>/dev/null || printf ''
}

validate_exec_ownership() {
  local exec_dir="$1"
  local expect_pid="$2"
  local expect_repo="$3"
  local got_pid got_repo

  [[ -d "$exec_dir" ]] || return 1
  got_pid="$(read_state_field "$exec_dir/pid")"
  got_repo="$(read_state_field "$exec_dir/repo")"
  [[ -n "$got_pid" && "$got_pid" == "$expect_pid" ]] || return 1
  [[ -n "$got_repo" && "$got_repo" == "$expect_repo" ]] || return 1
  return 0
}

issue_root_for_repo() {
  local repo="$1"
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  printf '%s/issues/%s\n' "$atmux_home" "$repo"
}

issue_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

notify_exec_watchers() {
  local exec_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$exec_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    queue_self_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_issue_watchers() {
  local issue_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$issue_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    queue_self_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

send_payload_to_pane() {
  local target="$1"
  local payload="$2"
  shift 2
  local submit_keys=("$@")
  [[ ${#submit_keys[@]} -gt 0 ]] || submit_keys=("Enter")
  local settle submit_wait extra_enter confirm_polls confirm_interval
  local attempts retry_wait
  local before_count after_count confirmed poll attempt snap initial_before_count current_count _sk

  settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"
  submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.3}"
  extra_enter="${ATMUX_SEND_DOUBLE_ENTER:-0}"
  confirm_polls="${ATMUX_SEND_CONFIRM_POLLS:-20}"
  confirm_interval="${ATMUX_SEND_CONFIRM_INTERVAL_SECONDS:-0.05}"
  attempts="${ATMUX_SEND_ATTEMPTS:-8}"
  retry_wait="${ATMUX_SEND_RETRY_WAIT_SECONDS:-0.5}"

  marker_count() {
    tmux capture-pane -p -t "$target" -S -800 2>/dev/null | tr -d '\r\n' | grep -o '<notification ' | wc -l | tr -d ' '
  }

  initial_before_count="$(marker_count || true)"
  [[ -n "$initial_before_count" ]] || initial_before_count=0

  for ((attempt=1; attempt<=attempts; attempt++)); do
    current_count="$(marker_count || true)"
    [[ -n "$current_count" ]] || current_count=0
    if (( current_count > initial_before_count )); then
      return 0
    fi
    before_count="$current_count"
    [[ -n "$before_count" ]] || before_count=0

    tmux send-keys -t "$target" C-u
    sleep "$settle"
    tmux send-keys -t "$target" -l "$payload"
    sleep "$settle"
    for _sk in "${submit_keys[@]}"; do
      tmux send-keys -t "$target" "$_sk"
    done
    sleep "$submit_wait"

    confirmed=0
    for poll in $(seq 1 "$confirm_polls"); do
      snap="$(tmux capture-pane -p -t "$target" -S -800 2>/dev/null || true)"
      after_count="$(printf '%s' "$snap" | tr -d '\r\n' | grep -o '<notification ' | wc -l | tr -d ' ' || true)"
      [[ -n "$after_count" ]] || after_count=0
      if (( after_count > before_count )); then
        confirmed=1
        break
      fi
      sleep "$confirm_interval"
    done

    if [[ "$extra_enter" == "1" || "$confirmed" -eq 0 ]]; then
      for _sk in "${submit_keys[@]}"; do
        tmux send-keys -t "$target" "$_sk"
      done
      sleep "$submit_wait"
      after_count="$(marker_count || true)"
      [[ -n "$after_count" ]] || after_count=0
      if (( after_count > before_count )); then
        confirmed=1
      fi
    fi

    if [[ "$confirmed" -eq 1 ]]; then
      return 0
    fi

    current_count="$(marker_count || true)"
    [[ -n "$current_count" ]] || current_count=0
    if (( current_count > initial_before_count )); then
      return 0
    fi

    sleep "$retry_wait"
  done

  return 1
}

notify_cli_usage() {
  cat <<'USAGE'
Usage:
  atmux notify --pane <tmux-pane-id> --xml <payload> [--interrupt]

Description:
  Queue an ATMUX XML notification to a tmux pane (same mechanism as exec/issue fan-out).
  --interrupt  Use the adapter's interrupt submit key instead of the default queue
               key (Enter). Resolves the adapter from the pane's session, or from
               --session if provided.

Examples:
  atmux notify --pane %12 --xml '<notification type="test" from="manual" cmd="atmux message read abc" />'
  atmux notify --pane %12 --xml '<notification type="urgent" from="mgr" />' --interrupt
USAGE
}

notify_cli_main() {
  local pane=""
  local xml_payload=""
  local interrupt=0
  local session=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane)
        pane="${2:-}"
        shift 2
        ;;
      --xml)
        xml_payload="${2:-}"
        shift 2
        ;;
      --interrupt)
        interrupt=1
        shift
        ;;
      --session)
        session="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        notify_cli_usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        notify_cli_usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
  [[ -n "$xml_payload" ]] || { echo "missing --xml" >&2; exit 2; }

  local submit_keys=()
  if [[ "$interrupt" -eq 1 ]]; then
    local adapter="" resolve_session="$session"
    if [[ -z "$resolve_session" && -n "$pane" ]]; then
      resolve_session="$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null || true)"
    fi
    if [[ -n "$resolve_session" ]]; then
      adapter="$(get_session_env "$resolve_session" ATMUX_ADAPTER)"
      if [[ -n "$adapter" ]]; then
        mapfile -t submit_keys < <(resolve_submit_keys "$adapter" "interrupt")
      fi
    fi
  fi

  queue_self_notification "$pane" "$xml_payload" ${submit_keys[@]+"${submit_keys[@]}"}
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail
  ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
  case "${1:-}" in
    build)
      shift
      build_notification "$@"
      ;;
    queue)
      shift
      queue_self_notification "$@"
      ;;
    deliver)
      shift
      send_payload_to_pane "$@"
      ;;
    --pane|--xml|-h|--help|help|"")
      notify_cli_main "$@"
      ;;
    *)
      notify_cli_main "$@"
      ;;
  esac
fi
