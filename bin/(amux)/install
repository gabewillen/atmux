#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  amux install [--no-slash-commands]

Description:
  Install amux into ~/.amux and, by default, install harness-specific slash/custom
  commands for supported adapters.

Options:
  --no-slash-commands  Skip installing Claude/Gemini/Codex slash commands.

Examples:
  amux install
  amux install --no-slash-commands
USAGE
}

main() {
  local script_dir repo_root
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  repo_root="$(cd -- "$script_dir/../.." && pwd)"

  case "${1:-}" in
    -h|--help|help)
      usage
      exit 0
      ;;
  esac

  exec "$repo_root/install.sh" "$@"
}

main "$@"
