#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"

usage() {
  cat <<'USAGE'
Usage:
  atmux role list
  atmux role show <name>
  atmux role resolve [--kind agent|team] <name>
  atmux role kind <name>
  atmux role create <name> (--from-file <path> | --from-stdin | --description <text>)
                           [--kind agent|team]
                           [--parent-team <name>]
                           [--intelligence <0-100>] [--adapters <a,b,...>]
                           [--hooks <start,stop>] [--scope repo|global|auto]
                           [--force]

Description:
  Manage adapter-agnostic roles. A role is a directory containing any of:
    role.md           prompt body, appended under "# Role" in the control file
    manifest          optional, sourced bash: KIND, INTELLIGENCE, ADAPTERS=(name ...)
    start             runs before the adapter starts (agent_create time) or
                      after team state/worktree setup and member spawn
                      (team_create time)
    stop              runs after the adapter exits (agent kill time) or after
                      a team is killed (team kill time)

  KIND defaults to `agent`. KIND=team roles are consumed by
  `atmux team create --role <name>` and receive ATMUX_TEAM /
  ATMUX_ROLE_STATE_DIR / ATMUX_WORKTREE in their start hook.

Resolution precedence (first match wins):
    ATMUX_ROLE_SEARCH_PREPEND/<name>      (team member spawning only)
    <repo>/.atmux/roles/agents/<name>
    ~/.atmux/roles/agents/<name>
    <source_root>/roles/agents/<name>
    <repo>/.atmux/roles/teams/<name>
    ~/.atmux/roles/teams/<name>
    <source_root>/roles/teams/<name>

`create` writes agents under roles/agents/<name> and teams under
roles/teams/<name>. Use --parent-team <team> with --kind agent to create a
team-private member role under roles/teams/<team>/roles/<name>.
USAGE
}

create_usage() {
  cat <<'USAGE'
Usage:
  atmux role create <name> (--from-file <path> | --from-stdin | --description <text>)
                           [--kind agent|team]
                           [--parent-team <name>]
                           [--intelligence <0-100>] [--adapters <a,b,...>]
                           [--hooks <start,stop>] [--scope repo|global|auto]
                           [--force]

Description:
  Scaffold a new role directory. Exactly one body source is required:
    --from-file <path>    use the file's contents as role.md
    --from-stdin          read role.md body from stdin
    --description <text>  generate a minimal role.md stub from this text

  Optional manifest fields (omit any to leave it out):
    --kind <kind>         agent (default) or team
    --parent-team <name>  create an agent role private to a team
    --intelligence <n>    default agent intelligence (0-100; agent kind only)
    --adapters <list>     comma-separated allow-list of adapter names (agent kind only)

  Optional hooks (chmod +x written templates):
    --hooks <list>        comma-separated subset of start,stop (or "none")
                          Stub contents differ by --kind.

  --force overwrites an existing role directory.
USAGE
}

source_root() {
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -d "$ATMUX_SOURCE_ROOT" ]]; then
    printf '%s\n' "$ATMUX_SOURCE_ROOT"
    return 0
  fi
  local self_root
  self_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
  if [[ -d "$self_root/roles" || -d "$self_root/bin/(atmux)" ]]; then
    printf '%s\n' "$self_root"
    return 0
  fi
  if [[ -d "$ATMUX_HOME/src/atmux" ]]; then
    printf '%s\n' "$ATMUX_HOME/src/atmux"
    return 0
  fi
  printf '%s\n' "$self_root"
}

role_search_paths() {
  local repo_root="" sr
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  sr="$(source_root)"
  if [[ -n "$repo_root" ]]; then
    printf '%s\n' "$repo_root/.atmux/roles"
  fi
  printf '%s\n' "$ATMUX_HOME/roles"
  printf '%s\n' "$sr/roles"
}

role_search_prepend_paths() {
  local raw="${ATMUX_ROLE_SEARCH_PREPEND:-}" path
  [[ -n "$raw" ]] || return 0
  local old_ifs="$IFS"
  IFS=:
  for path in $raw; do
    [[ -n "$path" ]] && printf '%s\n' "$path"
  done
  IFS="$old_ifs"
}

role_name_valid() {
  # Role names live as single directory names — no slashes, no relative path
  # segments, no leading dot. This keeps `--role <name>` from escaping the
  # search roots via `..` traversal.
  local name="$1"
  [[ -n "$name" ]] || return 1
  case "$name" in
    .|..|.*|*/*) return 1 ;;
  esac
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || return 1
  case "$name" in
    *..*) return 1 ;;
  esac
  return 0
}

role_path_kind() {
  # Args: <role_dir> <fallback_kind>. Hierarchical paths encode kind.
  local dir="$1" fallback="${2:-}"
  case "$dir" in
    */roles/agents/*) printf '%s\n' "agent"; return 0 ;;
    */roles/teams/*/roles/*) printf '%s\n' "agent"; return 0 ;;
    */roles/teams/*) printf '%s\n' "team"; return 0 ;;
  esac
  if [[ -n "$fallback" ]]; then
    printf '%s\n' "$fallback"
  else
    read_manifest_kind "$dir"
  fi
}

resolve_role_dir() {
  local name="$1"
  local want_kind="${2:-}"
  role_name_valid "$name" || return 1
  case "$want_kind" in
    ""|agent|team) ;;
    *) return 1 ;;
  esac
  local base dir kind
  if [[ "$want_kind" != "team" ]]; then
    while IFS= read -r base; do
      [[ -n "$base" ]] || continue
      dir="$base/$name"
      [[ -d "$dir" ]] || continue
      kind="$(role_path_kind "$dir" "agent")"
      [[ -z "$want_kind" || "$kind" == "$want_kind" ]] || continue
      printf '%s\n' "$dir"
      return 0
    done < <(role_search_prepend_paths)
  fi
  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    if [[ "$want_kind" != "team" && -d "$base/agents/$name" ]]; then
      printf '%s\n' "$base/agents/$name"
      return 0
    fi
  done < <(role_search_paths)
  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    if [[ "$want_kind" != "agent" && -d "$base/teams/$name" ]]; then
      printf '%s\n' "$base/teams/$name"
      return 0
    fi
  done < <(role_search_paths)
  return 1
}

resolve_private_agent_role_dir() {
  local name="$1"
  role_name_valid "$name" || return 1
  local base dir
  while IFS= read -r base; do
    [[ -n "$base" ]] || continue
    while IFS= read -r dir; do
      [[ -d "$dir" ]] || continue
      printf '%s\n' "$dir"
      return 0
    done < <(find "$base/teams" -mindepth 3 -maxdepth 3 -type d -path "*/roles/$name" 2>/dev/null | sort)
  done < <(role_search_paths)
  return 1
}

read_manifest_kind() {
  # Args: <role_dir>. Echoes KIND (defaults to "agent" if manifest missing or
  # KIND unset). Sourcing happens in a subshell so manifest side-effects can't
  # leak into the caller.
  local dir="$1"
  local manifest="$dir/manifest"
  if [[ ! -f "$manifest" ]]; then
    printf '%s\n' "agent"
    return 0
  fi
  local kind
  kind="$(
    KIND=""
    # shellcheck source=/dev/null
    source "$manifest" 2>/dev/null || true
    printf '%s' "$KIND"
  )"
  case "$kind" in
    agent|team) printf '%s\n' "$kind" ;;
    "")         printf '%s\n' "agent" ;;
    *)          printf '%s\n' "agent" ;;
  esac
}

list_roles() {
  local base name dir seen="" kind
  while IFS= read -r base; do
    [[ -d "$base" ]] || continue
    while IFS= read -r dir; do
      name="$(basename "$dir")"
      kind="$(role_path_kind "$dir" "agent")"
      case "$seen" in *"|$kind:$name|"*) continue ;; esac
      seen="$seen|$kind:$name|"
      printf '%s\t%s\t%s\n' "$name" "$kind" "$dir"
    done < <(find "$base/agents" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort)
    while IFS= read -r dir; do
      name="$(basename "$dir")"
      kind="$(role_path_kind "$dir" "team")"
      case "$seen" in *"|$kind:$name|"*) continue ;; esac
      seen="$seen|$kind:$name|"
      printf '%s\t%s\t%s\n' "$name" "$kind" "$dir"
    done < <(find "$base/teams" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort)
  done < <(role_search_paths)
}

resolve_create_dest() {
  # Prints the absolute destination directory for `role create` based on scope.
  # Args: <name> <scope> <kind> <parent_team>
  local name="$1" scope="$2" kind="$3" parent_team="${4:-}" rr="" rel=""
  if [[ -n "$parent_team" ]]; then
    rel="teams/$parent_team/roles/$name"
  elif [[ "$kind" == "team" ]]; then
    rel="teams/$name"
  else
    rel="agents/$name"
  fi
  case "$scope" in
    global)
      printf '%s\n' "$ATMUX_HOME/roles/$rel"
      ;;
    repo)
      rr="$(git rev-parse --show-toplevel 2>/dev/null || true)"
      if [[ -z "$rr" ]]; then
        echo "atmux role create: --scope repo requires being inside a git repo" >&2
        return 1
      fi
      printf '%s\n' "$rr/.atmux/roles/$rel"
      ;;
    auto)
      rr="$(git rev-parse --show-toplevel 2>/dev/null || true)"
      if [[ -n "$rr" && -d "$rr/.atmux" ]]; then
        printf '%s\n' "$rr/.atmux/roles/$rel"
      else
        printf '%s\n' "$ATMUX_HOME/roles/$rel"
      fi
      ;;
    *)
      echo "atmux role create: invalid --scope: $scope (want repo|global|auto)" >&2
      return 1
      ;;
  esac
}

write_role_manifest() {
  # Args: <dest_dir> <name> <kind> <intelligence> <adapters_csv>
  # Always writes a manifest when kind=team (so KIND is recorded). For kind=agent
  # only writes when there's something to record.
  local dest="$1" name="$2" kind="$3" intel="$4" adapters="$5"
  if [[ "$kind" != "team" && -z "$intel" && -z "$adapters" ]]; then
    return 0
  fi
  {
    if [[ "$kind" == "team" ]]; then
      printf '# Sourced by atmux when a team is created with --role %s.\n' "$name"
    else
      printf '# Sourced by atmux when an agent is created with --role %s.\n' "$name"
    fi
    printf '# Anything exported here is visible during creation.\n\n'
    printf '# Role kind: agent (default) or team. Team-kind roles are spawned\n'
    printf '# by `atmux team create --role %s`.\n' "$name"
    printf 'KIND=%s\n' "$kind"
    if [[ -n "$intel" ]]; then
      printf '\n# Default intelligence (caller'\''s --intelligence flag still wins)\n'
      printf 'INTELLIGENCE=%s\n' "$intel"
    fi
    if [[ -n "$adapters" ]]; then
      printf '\n# Adapter allow-list. Comment out to allow any adapter.\n'
      printf 'ADAPTERS=(%s)\n' "${adapters//,/ }"
    fi
  } > "$dest/manifest"
}

write_role_start_hook() {
  # Args: <dest_dir> <name> <kind>
  local dest="$1" name="$2" kind="${3:-agent}"
  if [[ "$kind" == "team" ]]; then
    cat > "$dest/start" <<EOF
#!/usr/bin/env bash
# Team role start hook for $name. Runs after team state/worktree setup and
# member spawn. Env provided by atmux:
#   ATMUX_TEAM            - this team's short name
#   ATMUX_REPO            - normalized repo name
#   ATMUX_WORKTREE        - the team worktree path
#   ATMUX_ROLE_DIR        - this role's directory
#   ATMUX_ROLE_STATE_DIR  - private state dir for this (team, role) pair
set -euo pipefail

state="\$ATMUX_ROLE_STATE_DIR"
mkdir -p "\$state"

# TODO: spawn members and register cross-member watchers. Record agent
# names and watcher ids under "\$state/" so 'stop' can tear them down.
#
# Example:
#   atmux agent create driver --role driver --intelligence 20 \\
#     --team "\$ATMUX_TEAM" --shared-worktree
#   echo driver >> "\$state/members"
EOF
  else
    cat > "$dest/start" <<EOF
#!/usr/bin/env bash
# Role start hook for $name. Runs after the control file is rendered, before
# the AI CLI execs. Env provided by atmux:
#   ATMUX_ROLE_STATE_DIR  - private state dir for this (agent, role) pair
#   ATMUX_ROLE_DIR        - this role's directory
#   ATMUX_AGENT_NAME      - the agent's short name
#   ATMUX_REPO            - normalized repo name
set -euo pipefail

state="\$ATMUX_ROLE_STATE_DIR"
mkdir -p "\$state"

# TODO: register watchers, warm caches, etc. Record any ids in
# "\$state/" so 'stop' can tear them down.
EOF
  fi
  chmod +x "$dest/start"
}

write_role_stop_hook() {
  # Args: <dest_dir> <name> <kind>
  local dest="$1" name="$2" kind="${3:-agent}"
  if [[ "$kind" == "team" ]]; then
    cat > "$dest/stop" <<EOF
#!/usr/bin/env bash
# Team role stop hook for $name. Tears down whatever start registered:
# typically the spawned members and any cross-member watchers.
set -euo pipefail

state="\${ATMUX_ROLE_STATE_DIR:-}"
[[ -n "\$state" && -d "\$state" ]] || exit 0

# TODO: kill members and watchers recorded by start.
#
# Example:
#   if [[ -f "\$state/members" ]]; then
#     while IFS= read -r member; do
#       [[ -n "\$member" ]] && atmux agent kill "\$member" >/dev/null 2>&1 || true
#     done < "\$state/members"
#   fi

rm -rf "\$state"
EOF
  else
    cat > "$dest/stop" <<EOF
#!/usr/bin/env bash
# Role stop hook for $name. Tears down whatever start registered.
set -euo pipefail

state="\${ATMUX_ROLE_STATE_DIR:-}"
[[ -n "\$state" && -d "\$state" ]] || exit 0

# TODO: undo registrations made by start (e.g. atmux watcher kill <id>).

rm -rf "\$state"
EOF
  fi
  chmod +x "$dest/stop"
}

write_role_md_stub() {
  # Args: <dest_dir> <name> <description>
  local dest="$1" name="$2" desc="$3"
  cat > "$dest/role.md" <<EOF
# $name

You are $desc.

## Workflow

1. <fill in step one>
2. <fill in step two>

## Tools available

- \`atmux\` — coordinate with peer agents.
- \`git\` — when the role touches code.
EOF
}

create_role() {
  local name=""
  local description="" body_file="" body_stdin=0
  local kind="agent"
  local parent_team=""
  local intelligence="" adapters="" hooks=""
  local scope="auto" force=0

  # First positional is the role name.
  if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
    name="$1"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --description)        description="$2"; shift 2 ;;
      --description=*)      description="${1#--description=}"; shift ;;
      --from-file)          body_file="$2"; shift 2 ;;
      --from-file=*)        body_file="${1#--from-file=}"; shift ;;
      --from-stdin)         body_stdin=1; shift ;;
      --kind)               kind="$2"; shift 2 ;;
      --kind=*)             kind="${1#--kind=}"; shift ;;
      --parent-team)        parent_team="$2"; shift 2 ;;
      --parent-team=*)      parent_team="${1#--parent-team=}"; shift ;;
      --intelligence)       intelligence="$2"; shift 2 ;;
      --intelligence=*)     intelligence="${1#--intelligence=}"; shift ;;
      --adapters)           adapters="$2"; shift 2 ;;
      --adapters=*)         adapters="${1#--adapters=}"; shift ;;
      --hooks)              hooks="$2"; shift 2 ;;
      --hooks=*)            hooks="${1#--hooks=}"; shift ;;
      --scope)              scope="$2"; shift 2 ;;
      --scope=*)            scope="${1#--scope=}"; shift ;;
      --force)              force=1; shift ;;
      -h|--help)            create_usage; return 0 ;;
      --)                   shift; break ;;
      *)
        echo "atmux role create: unknown arg: $1" >&2
        create_usage >&2
        return 2
        ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "atmux role create: <name> is required" >&2
    create_usage >&2
    return 2
  fi

  if ! role_name_valid "$name"; then
    echo "atmux role create: invalid role name: $name (want ^[A-Za-z0-9._-]+\$, no .. or /)" >&2
    return 2
  fi
  if [[ -n "$parent_team" ]] && ! role_name_valid "$parent_team"; then
    echo "atmux role create: invalid --parent-team: $parent_team (want ^[A-Za-z0-9._-]+\$, no .. or /)" >&2
    return 2
  fi

  # Exactly one body source.
  local sources=0
  [[ -n "$body_file" ]] && sources=$((sources + 1))
  [[ "$body_stdin" -eq 1 ]] && sources=$((sources + 1))
  [[ -n "$description" ]] && sources=$((sources + 1))
  if [[ "$sources" -ne 1 ]]; then
    echo "atmux role create: supply exactly one of --from-file, --from-stdin, --description" >&2
    return 2
  fi

  if [[ -n "$body_file" && ! -f "$body_file" ]]; then
    echo "atmux role create: --from-file not found: $body_file" >&2
    return 1
  fi

  case "$kind" in
    agent|team) ;;
    *)
      echo "atmux role create: --kind must be agent or team, got: $kind" >&2
      return 2
      ;;
  esac

  if [[ "$kind" == "team" ]]; then
    if [[ -n "$parent_team" ]]; then
      echo "atmux role create: --parent-team is only valid for --kind agent" >&2
      return 2
    fi
    if [[ -n "$intelligence" ]]; then
      echo "atmux role create: --intelligence is not valid for --kind team" >&2
      return 2
    fi
    if [[ -n "$adapters" ]]; then
      echo "atmux role create: --adapters is not valid for --kind team" >&2
      return 2
    fi
  fi

  if [[ -n "$intelligence" ]]; then
    if ! [[ "$intelligence" =~ ^[0-9]+$ ]] || [[ "$intelligence" -lt 0 ]] || [[ "$intelligence" -gt 100 ]]; then
      echo "atmux role create: --intelligence must be 0-100, got: $intelligence" >&2
      return 2
    fi
  fi

  # Validate hooks up front so a bad value can't leave a partial role on disk.
  if [[ -n "$hooks" && "$hooks" != "none" ]]; then
    local hooks_csv_check=",${hooks// /},"
    local rest_check="${hooks_csv_check//,start,/,}"
    rest_check="${rest_check//,stop,/,}"
    rest_check="${rest_check//,/}"
    if [[ -n "$rest_check" ]]; then
      echo "atmux role create: unknown hook(s) in --hooks: $hooks (valid: start, stop, none)" >&2
      return 2
    fi
  fi

  local dest
  if ! dest="$(resolve_create_dest "$name" "$scope" "$kind" "$parent_team")"; then
    return 2
  fi

  if [[ -e "$dest" ]]; then
    if [[ "$force" -eq 1 ]]; then
      rm -rf "$dest"
    else
      echo "atmux role create: role already exists at $dest (use --force to overwrite)" >&2
      return 1
    fi
  fi

  mkdir -p "$dest"

  # Author role.md. Strip any literal <atmux>/</atmux> fence lines from
  # supplied bodies — those are reserved in the rendered control file.
  if [[ -n "$body_file" ]]; then
    sed -E '/^[[:space:]]*<\/?atmux([[:space:]>]|$)/d' < "$body_file" > "$dest/role.md"
  elif [[ "$body_stdin" -eq 1 ]]; then
    sed -E '/^[[:space:]]*<\/?atmux([[:space:]>]|$)/d' > "$dest/role.md"
  else
    write_role_md_stub "$dest" "$name" "$description"
  fi

  write_role_manifest "$dest" "$name" "$kind" "$intelligence" "$adapters"

  if [[ -n "$hooks" && "$hooks" != "none" ]]; then
    local hooks_csv=",${hooks// /},"
    case "$hooks_csv" in
      *,start,*) write_role_start_hook "$dest" "$name" "$kind" ;;
    esac
    case "$hooks_csv" in
      *,stop,*) write_role_stop_hook "$dest" "$name" "$kind" ;;
    esac
  fi

  printf 'created role: %s\n' "$dest"
  ( cd "$dest" && find . -mindepth 1 -maxdepth 1 -printf '  %P\n' 2>/dev/null \
      || ls -1 "$dest" | sed 's/^/  /' )
}

sub="${1:-}"
shift || true

case "$sub" in
  list)
    list_roles
    ;;
  show)
    name="${1:-}"
    [[ -n "$name" ]] || { echo "usage: atmux role show <name>" >&2; exit 2; }
    if dir="$(resolve_role_dir "$name")"; then
      if [[ -f "$dir/role.md" ]]; then
        cat "$dir/role.md"
      fi
      exit 0
    fi
    echo "role not found: $name" >&2
    exit 1
    ;;
  resolve)
    want_kind=""
    case "${1:-}" in
      --kind)
        want_kind="${2:-}"
        shift 2 || true
        ;;
      --kind=*)
        want_kind="${1#--kind=}"
        shift
        ;;
    esac
    case "$want_kind" in
      ""|agent|team) ;;
      *) echo "usage: atmux role resolve [--kind agent|team] <name>" >&2; exit 2 ;;
    esac
    name="${1:-}"
    [[ -n "$name" ]] || { echo "usage: atmux role resolve [--kind agent|team] <name>" >&2; exit 2; }
    if dir="$(resolve_role_dir "$name" "$want_kind")"; then
      printf '%s\n' "$dir"
      exit 0
    fi
    exit 1
    ;;
  private-agent)
    name="${1:-}"
    [[ -n "$name" ]] || { echo "usage: atmux role private-agent <name>" >&2; exit 2; }
    if dir="$(resolve_private_agent_role_dir "$name")"; then
      printf '%s\n' "$dir"
      exit 0
    fi
    exit 1
    ;;
  kind)
    name="${1:-}"
    [[ -n "$name" ]] || { echo "usage: atmux role kind <name>" >&2; exit 2; }
    if dir="$(resolve_role_dir "$name")"; then
      role_path_kind "$dir"
      exit 0
    fi
    echo "role not found: $name" >&2
    exit 1
    ;;
  create)
    create_role "$@"
    exit $?
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown role command: $sub" >&2
    usage >&2
    exit 2
    ;;
esac
