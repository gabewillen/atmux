#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-pr-shared.XXXXXX")"
atmux_home="$tmp_root/.atmux"
repo_name="prshared$RANDOM"
session_a="atmux-${repo_name}-watcher-a"
session_b="atmux-${repo_name}-watcher-b"
trigger_file="$tmp_root/trigger-1"
second_trigger_file="$tmp_root/trigger-2"
close_file="$tmp_root/close"
count_file="$tmp_root/count"
stub_dir="$tmp_root/bin"
snapshot_file="$atmux_home/watch-pr/octo_example_pr_42/snapshot"

cleanup() {
  tmux kill-session -t "$session_a" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_b" >/dev/null 2>&1 || true
  rm -rf "$tmp_root"
}
trap cleanup EXIT

mkdir -p "$stub_dir"
cat > "$stub_dir/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

count_file="${ATMUX_TEST_PR_COUNT_FILE:?}"
current=0
if [[ -f "$count_file" ]]; then
  current="$(cat "$count_file")"
fi
current=$((current + 1))
printf '%s\n' "$current" > "$count_file"

if [[ -f "${ATMUX_TEST_PR_CLOSE_FILE:-}" ]]; then
  printf '%s\n' 'STATE|closed'
  printf '%s\n' '2026-04-23T00:00:00Z|issue_comment|IC_kw_shared|octocat||shared-pr-comment'
  printf '%s\n' '2026-04-23T00:00:02Z|review_comment|RC_kw_shared|hubot||shared-pr-second-comment'
elif [[ -f "${ATMUX_TEST_PR_SECOND_TRIGGER:-}" ]]; then
  printf '%s\n' 'STATE|open'
  printf '%s\n' '2026-04-23T00:00:00Z|issue_comment|IC_kw_shared|octocat||shared-pr-comment'
  printf '%s\n' '2026-04-23T00:00:02Z|review_comment|RC_kw_shared|hubot||shared-pr-second-comment'
elif [[ -f "${ATMUX_TEST_PR_TRIGGER:-}" ]]; then
  printf '%s\n' 'STATE|open'
  printf '%s\n' '2026-04-23T00:00:00Z|issue_comment|IC_kw_shared|octocat||shared-pr-comment'
else
  printf '%s\n' 'STATE|open'
fi
EOF
chmod +x "$stub_dir/gh"

tmux new-session -d -s "$session_a" -n "$session_a" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux new-session -d -s "$session_b" -n "$session_b" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

for session in "$session_a" "$session_b"; do
  tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
  tmux set-environment -t "$session" ATMUX_AGENT_NAME "$(basename "$session")"
  tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"
done

pane_a="$(tmux list-panes -t "$session_a" -F '#{pane_id}' 2>/dev/null | head -n1)"
pane_b="$(tmux list-panes -t "$session_b" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_a" && -n "$pane_b" ]] || { echo "missing watcher panes" >&2; exit 1; }

watchers_dir="$atmux_home/watch-pr/octo_example_pr_42/watchers"

watch_cmd="ATMUX_HOME=\"$atmux_home\" ATMUX_GH_BIN=\"$stub_dir/gh\" ATMUX_TEST_PR_TRIGGER=\"$trigger_file\" ATMUX_TEST_PR_SECOND_TRIGGER=\"$second_trigger_file\" ATMUX_TEST_PR_CLOSE_FILE=\"$close_file\" ATMUX_TEST_PR_COUNT_FILE=\"$count_file\" \"$ATMUX_BIN\" watch --pr \"https://github.com/octo/example/pull/42\" --interval 0.2 --timeout 10"
tmux send-keys -t "$pane_a" "$watch_cmd" C-m
tmux send-keys -t "$pane_b" "$watch_cmd" C-m

if ! wait_for_text "$pane_a" '<watch type="pr"' 10; then
  echo "watcher A did not register" >&2
  tmux capture-pane -p -t "$pane_a" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane_b" '<watch type="pr"' 10; then
  echo "watcher B did not register" >&2
  tmux capture-pane -p -t "$pane_b" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 10 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -ge 2 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "shared watch --pr did not leave both watcher registrations active" >&2
    exit 1
  fi
  sleep 0.1
done

deadline=$(( $(date +%s) + 10 ))
while [[ ! -f "$count_file" || ! -f "$snapshot_file" ]] || grep -Fq 'shared-pr-comment' "$snapshot_file" 2>/dev/null; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "shared pr watcher never completed its baseline snapshot" >&2
    exit 1
  fi
  sleep 0.05
done

sleep 1
poll_count="$(cat "$count_file")"
if (( poll_count >= 10 )); then
  echo "expected shared polling worker, got excessive gh polls: $poll_count" >&2
  exit 1
fi

touch "$trigger_file"

if ! wait_for_text "$pane_a" 'shared-pr-comment' 15; then
  echo "watcher A missing shared PR notification" >&2
  tmux capture-pane -p -t "$pane_a" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane_b" 'shared-pr-comment' 15; then
  echo "watcher B missing shared PR notification" >&2
  tmux capture-pane -p -t "$pane_b" -S -200 >&2 || true
  exit 1
fi

touch "$second_trigger_file"

if ! wait_for_text "$pane_a" 'shared-pr-second-comment' 15; then
  echo "watcher A missing second shared PR notification" >&2
  tmux capture-pane -p -t "$pane_a" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane_b" 'shared-pr-second-comment' 15; then
  echo "watcher B missing second shared PR notification" >&2
  tmux capture-pane -p -t "$pane_b" -S -200 >&2 || true
  exit 1
fi

touch "$close_file"

deadline=$(( $(date +%s) + 15 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -eq 0 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "shared watch --pr did not exit after PR closed" >&2
    exit 1
  fi
  sleep 0.1
done

echo "ok: watch --pr shares one polling worker across local watchers until PR closes"
