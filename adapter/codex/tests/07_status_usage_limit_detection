#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"

setup_out="$("$SCRIPTS_DIR/setup")"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-codex-test-home.XXXXXX")"

cleanup() {
  "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$atmux_home"
}
trap cleanup EXIT

if ! "$REPO_ROOT/bin/(atmux)/watch" --target "$pane_id" --scope pane --text "OpenAI Codex" --timeout 20 --interval 0.2 --lines 600; then
  tmux capture-pane -p -t "$pane_id" -S -220 >&2 || true
  echo "timed out waiting for codex banner" >&2
  exit 1
fi
status_out=""
for _ in $(seq 1 15); do
  status_out="$(
    ATMUX_HOME="$atmux_home" \
    ATMUX_TARGET_PANE="$pane_id" \
    ATMUX_SOURCE_ROOT="$REPO_ROOT" \
    "$ADAPTER_DIR/scripts/status"
  )"
  if printf '%s\n' "$status_out" | grep -Eq 'model="[^"]+"'; then
    break
  fi
  sleep 0.3
done

extract_attr() {
  local attr="$1"
  printf '%s\n' "$status_out" | sed -n "s/.*$attr=\"\\([^\"]*\\)\".*/\\1/p" | tail -n 1
}

echo "$status_out" | grep -F '<status ' >/dev/null
echo "$status_out" | grep -F 'adapter="codex"' >/dev/null
echo "$status_out" | grep -F 'owner="agent"' >/dev/null
echo "$status_out" | grep -F 'control_file="AGENTS.md"' >/dev/null

state="$(extract_attr state)"
model="$(extract_attr model)"
reasoning="$(extract_attr reasoning_level)"

case "$state" in
  idle|busy|errored|usage-limit) ;;
  *)
    echo "unexpected state: $state" >&2
    exit 1
    ;;
esac
[[ -n "$model" ]] || { echo "model is empty" >&2; exit 1; }
case "$reasoning" in
  low|medium|high|extra-high) ;;
  *)
    echo "unexpected reasoning_level: $reasoning" >&2
    exit 1
    ;;
esac

echo "PASS 07_status_usage_limit_detection"
