#!/usr/bin/env bash
set -euo pipefail

# Tests invoke atmux from the host shell (not a tmux pane); allow without TMUX.
export ATMUX_ALLOW_OUTSIDE_TMUX="${ATMUX_ALLOW_OUTSIDE_TMUX:-1}"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CLEANUP_ORPHANS="$TESTS_DIR/scripts/cleanup-orphans"

usage() {
  cat <<'USAGE'
Usage: tests/runner [--parallel N] [--shard N/TOTAL]

  --parallel N    Run up to N tests concurrently. Each parallel test gets
                  its own ATMUX_HOME and its own tmux server (via a
                  per-test TMUX_TMPDIR), so tests with hardcoded session
                  names don't collide across workers.
                  Default: 1 (serial).

  --shard N/TOTAL Run only the Nth slice of TOTAL using round-robin
                  assignment. Useful for matrix-style CI sharding when
                  --parallel isn't enough on a single runner.
                  Default: 1/1 (entire suite).

Live tests (suffix "_live") are skipped unless
ATMUX_RUN_LIVE_ADAPTER_TESTS=1 is exported.
USAGE
}

PARALLEL=1
SHARD_INDEX=1
SHARD_TOTAL=1

parse_shard() {
  local spec="$1"
  if [[ ! "$spec" =~ ^([0-9]+)/([0-9]+)$ ]]; then
    echo "error: --shard expects N/TOTAL (e.g. 3/8), got '$spec'" >&2
    exit 2
  fi
  SHARD_INDEX="${BASH_REMATCH[1]}"
  SHARD_TOTAL="${BASH_REMATCH[2]}"
  if (( SHARD_INDEX < 1 || SHARD_INDEX > SHARD_TOTAL || SHARD_TOTAL < 1 )); then
    echo "error: --shard $spec is out of range" >&2
    exit 2
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --parallel)
      PARALLEL="${2:-}"
      [[ "$PARALLEL" =~ ^[0-9]+$ ]] || { echo "error: --parallel expects an integer" >&2; exit 2; }
      shift 2
      ;;
    --parallel=*)
      PARALLEL="${1#--parallel=}"
      [[ "$PARALLEL" =~ ^[0-9]+$ ]] || { echo "error: --parallel expects an integer" >&2; exit 2; }
      shift
      ;;
    --shard)
      parse_shard "${2:-}"
      shift 2
      ;;
    --shard=*)
      parse_shard "${1#--shard=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done
(( PARALLEL >= 1 )) || PARALLEL=1

log() {
  printf '[atmux-tests] %s\n' "$*"
}

should_skip_test() {
  local test_name="$1"
  case "${ATMUX_RUN_LIVE_ADAPTER_TESTS:-0}" in
    1|true|TRUE|yes|YES) return 1 ;;
  esac
  case "$test_name" in
    *_live) return 0 ;;
  esac
  return 1
}

# Run a single test in a fully isolated sandbox: own ATMUX_HOME and own
# TMUX_TMPDIR. The test's own `lib/isolate-tmux.sh` will pick up the
# unset ATMUX_TESTS_TMUX_TMPDIR (because we unset it below) and create
# its own private tmux server inside the sandbox. Stdout/stderr are
# captured to a per-test log; on success the log is dropped, on failure
# it's emitted in full so CI logs show the cause.
run_one() {
  local test_script="$1"
  local name
  name="$(basename "$test_script")"
  [[ -x "$test_script" ]] || chmod +x "$test_script"

  if should_skip_test "$name"; then
    log "skipping $name (set ATMUX_RUN_LIVE_ADAPTER_TESTS=1 to include live adapter tests)"
    return 0
  fi

  local sandbox log_file
  sandbox="$(mktemp -d "${TMPDIR:-/tmp}/atmux-test-sandbox.XXXXXX")"
  log_file="$sandbox/run.log"
  mkdir -p "$sandbox/atmux"

  log "running $name"
  local rc=0
  (
    # Each parallel worker gets its own ATMUX_HOME.
    export ATMUX_HOME="$sandbox/atmux"
    # Force the test's isolate-tmux lib to provision a fresh tmux
    # server in the sandbox instead of reusing a runner-wide socket.
    unset ATMUX_TESTS_TMUX_TMPDIR
    exec "$test_script"
  ) >"$log_file" 2>&1 || rc=$?

  if (( rc == 0 )); then
    log "ok $name"
  else
    log "FAIL $name (rc=$rc)"
    sed 's/^/    | /' "$log_file" >&2
  fi
  rm -rf "$sandbox"
  return $rc
}

# Build the test list, applying shard filter.
collect_tests() {
  local i=0 owner test_script
  for test_script in "$TESTS_DIR"/[0-9]*_*; do
    [[ -f "$test_script" ]] || continue
    owner=$(( i % SHARD_TOTAL + 1 ))
    i=$(( i + 1 ))
    if (( owner == SHARD_INDEX )); then
      printf '%s\n' "$test_script"
    fi
  done
}

main() {
  local tests=()
  while IFS= read -r line; do
    tests+=("$line")
  done < <(collect_tests)

  local total="${#tests[@]}"
  if (( total == 0 )); then
    log "no tests selected"
    return 0
  fi

  if (( PARALLEL == 1 )); then
    local t
    for t in "${tests[@]}"; do
      run_one "$t" || return 1
    done
  else
    # Bounded-parallel runner. Spawn up to PARALLEL workers; track each
    # worker's PID and its associated test name so failures are
    # attributable in the log.
    export -f run_one log should_skip_test
    export TESTS_DIR ATMUX_RUN_LIVE_ADAPTER_TESTS ATMUX_ALLOW_OUTSIDE_TMUX
    local fail=0
    printf '%s\n' "${tests[@]}" \
      | xargs -n 1 -P "$PARALLEL" -I {} bash -c 'run_one "$@"' _ {} \
      || fail=$?
    if (( fail != 0 )); then
      return 1
    fi
  fi

  if (( SHARD_TOTAL > 1 )); then
    log "shard $SHARD_INDEX/$SHARD_TOTAL complete ($total tests)"
  else
    log "suite complete ($total tests)"
  fi
}

# Final cleanup: nuke any stragglers from `atmux schedule --detach` and
# the like that the per-test sandboxing didn't catch. (Per-sandbox tmux
# servers and ATMUX_HOMEs already get torn down inside run_one.)
[[ ! -x "$CLEANUP_ORPHANS" ]] || "$CLEANUP_ORPHANS" || true

main "$@"
