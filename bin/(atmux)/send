#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux send --to <agent|team> [--reply-required] [--interrupt] "message"

Description:
  Send XML messages to a single agent or every agent in a team. Without
  --interrupt, the message is queued and delivered when the receiving agent
  is at its idle prompt.
  Resolution order for --to:
    1) Team name
    2) Agent name
  --interrupt  Hard interrupt: send the adapter's abort key sequence
               (`SUBMIT_KEYS_INTERRUPT` in the manifest) to stop the current
               operation, then submit the message. Use sparingly — this aborts
               whatever the agent is doing.

Examples:
  atmux send --to planner "run tests"
  atmux send --to platform --reply-required "status check-in"
  atmux send --to worker --interrupt "stop, that's wrong"
USAGE
}

sender_session() {
  local from="${ATMUX_SESSION_NAME:-}"
  if [[ -z "$from" ]]; then
    local from_repo
    from_repo="$(repo_name_from_context)"
    if [[ -n "$from_repo" ]]; then
      from="atmux-${from_repo}-${ATMUX_AGENT_NAME:-unknown}"
    else
      from="atmux-unknown-${ATMUX_AGENT_NAME:-unknown}"
    fi
  fi
  printf '%s\n' "$from"
}

sender_pane() {
  local pane=""
  pane="$(current_pane)"
  if [[ -n "$pane" ]]; then
    printf '%s\n' "$pane"
    return 0
  fi
  if [[ -n "${from_session:-}" ]]; then
    pane="$(primary_pane_for_session "$from_session")"
    if [[ -n "$pane" ]]; then
      printf '%s\n' "$pane"
      return 0
    fi
  fi
  return 1
}

notify_sender_failed_send() {
  local target="$1"
  local reason="$2"
  local pane="" payload=""

  pane="$(sender_pane 2>/dev/null || true)"
  [[ -n "$pane" ]] || return 0

  payload="$(build_notification "send_failed" "send" "" \
    "target=$target" \
    "reason=$reason")"
  send_payload_to_pane "$pane" "$payload" || true
}

self_send_error() {
  echo "cannot send to yourself; for self reminders/ticks use: atmux schedule --once <duration> --notification \"<text>\"" >&2
}

store_message() {
  local repo="$1" from="$2" to="$3" body="$4" reply_required="$5"
  local root id dir ts
  root="$ATMUX_HOME/messages/$repo"
  mkdir -p "$root"
  id="$(id)"
  dir="$root/$id"
  mkdir -p "$dir"
  ts="$(timestamp_utc)"
  write_field "$dir/from" "$from"
  write_field "$dir/to" "$to"
  write_field "$dir/body" "$body"
  write_field "$dir/reply_required" "$reply_required"
  write_field "$dir/timestamp" "$ts"
  printf '%s\n' "$id"
}

store_team_message() {
  local repo="$1" from="$2" team="$3" body="$4" reply_required="$5"
  local root id dir ts
  root="$(team_message_root_for_team "$repo" "$team")"
  mkdir -p "$root"
  id="$(id)"
  dir="$root/$id"
  mkdir -p "$dir"
  ts="$(timestamp_utc)"
  write_field "$dir/from" "$from"
  write_field "$dir/team" "$team"
  write_field "$dir/body" "$body"
  write_field "$dir/reply_required" "$reply_required"
  write_field "$dir/timestamp" "$ts"
  printf '%s\n' "$id"
}

resolve_steer_keys() {
  local session="$1"
  local adapter=""
  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  if [[ -n "$adapter" ]]; then
    resolve_submit_keys "$adapter" "steer"
  else
    printf 'Enter\n'
  fi
}

resolve_abort_keys() {
  local session="$1"
  local adapter=""
  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  if [[ -z "$adapter" ]]; then
    return 0
  fi
  resolve_submit_keys_strict "$adapter" "interrupt" || true
}

build_message_payload_for_session() {
  local _target_session="$1"
  local from_session="$2"
  local read_cmd="$3"
  local reply_required_value="$4"

  # build_notification renders the read_cmd as `hint="run \`<cmd>\`"`,
  # so callers no longer need to pass a separate hint kvarg.
  build_notification "message" "$from_session" "$read_cmd" \
    "reply_required=$reply_required_value"
}

build_team_message_payload() {
  local from_session="$1"
  local team_name="$2"
  local read_cmd="$3"
  local reply_required_value="$4"

  build_notification "team_message" "$from_session" "$read_cmd" \
    "team=$team_name" \
    "reply_required=$reply_required_value"
}

text_has_line() {
  local text="$1" needle="$2"
  [[ -n "$needle" ]] || return 1
  grep -Fxq "$needle" <<< "$text"
}

send_to_session() {
  local target_session="$1"
  local payload="$2"
  shift 2
  local submit_keys=("$@")
  local target_pane=""

  if ! tmux has-session -t "$target_session" 2>/dev/null; then
    debug_notify "send:target_session_missing session=$(printf '%q' "$target_session")"
    return 1
  fi
  target_pane="$(primary_pane_for_session "$target_session")"
  if [[ -z "$target_pane" ]]; then
    debug_notify "send:target_pane_missing session=$(printf '%q' "$target_session")"
    return 1
  fi
  debug_notify "send:target_resolved session=$(printf '%q' "$target_session") pane=$(printf '%q' "$target_pane") submit_keys=$(printf '%q' "${submit_keys[*]:-Enter}") $(payload_debug_summary "$payload")"
  send_payload_to_pane "$target_pane" "$payload" ${submit_keys[@]+"${submit_keys[@]}"}
}

send_to_pane() {
  local target_pane="$1"
  local payload="$2"

  if [[ -z "$target_pane" ]] || ! pane_exists "$target_pane"; then
    debug_notify "send:target_pane_missing pane=$(printf '%q' "$target_pane")"
    return 1
  fi
  debug_notify "send:target_pane_resolved pane=$(printf '%q' "$target_pane") $(payload_debug_summary "$payload")"
  send_payload_to_pane "$target_pane" "$payload"
}

target_name=""
reply_required=0
interrupt=0
message=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --to)
      target_name="${2:-}"
      shift 2
      ;;
    --reply-required)
      reply_required=1
      shift
      ;;
    --interrupt)
      interrupt=1
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    --)
      shift
      message="$*"
      break
      ;;
    *)
      if [[ -z "$message" ]]; then
        message="$1"
      else
        message+=" $1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$target_name" ]]; then
  echo "missing required flag: --to <agent|team>" >&2
  exit 2
fi
if [[ -z "$message" ]]; then
  echo "missing message" >&2
  exit 2
fi

reply_required_value="false"
if [[ "$reply_required" -eq 1 ]]; then
  reply_required_value="true"
fi

repo_name="$(repo_name_from_context)"
from_session="$(sender_session)"
debug_notify "send:start from=$(printf '%q' "$from_session") to=$(printf '%q' "$target_name") repo=$(printf '%q' "$repo_name") interrupt=$interrupt reply_required=$reply_required"

team_session=""
if team_name="$(resolve_team_name "$target_name" "$repo_name")"; then
  team_session="atmux-${repo_name}-team-${team_name}"
fi

if [[ -n "$team_session" ]]; then
  debug_notify "send:team_resolved target=$(printf '%q' "$target_name") team=$(printf '%q' "$team_name") session=$(printf '%q' "$team_session")"
  members=()
  while IFS= read -r s; do
    [[ -n "$s" ]] || continue
    members+=("$s")
  done < <(team_member_sessions_from_state "$repo_name" "$team_name" | sort -u)

  msg_id="$(store_team_message "$repo_name" "$from_session" "$team_name" "$message" "$reply_required_value")"
  printf -v read_cmd 'atmux message read %q --team %q --repo %q' "$msg_id" "$team_name" "$repo_name"

  attempted=0
  delivered=0
  failed=0
  results=""
  notified_sessions=""
  notified_panes=""
  for s in "${members[@]+"${members[@]}"}"; do
    attempted=$((attempted + 1))
    payload="$(build_team_message_payload "$from_session" "$team_name" "$read_cmd" "$reply_required_value")"
    member_keys=()
    member_pre_keys=""
    member_bypass=""
    if (( interrupt == 1 )); then
      while IFS= read -r __mk_line; do
        member_keys+=("$__mk_line")
      done < <(resolve_steer_keys "$s")
      member_bypass=1
      while IFS= read -r __pk_line; do
        [[ -n "$__pk_line" ]] || continue
        if [[ -n "$member_pre_keys" ]]; then
          member_pre_keys+=" "
        fi
        member_pre_keys+="$__pk_line"
      done < <(resolve_abort_keys "$s")
    fi
    if ATMUX_NOTIFY_PRE_KEYS="$member_pre_keys" \
       ATMUX_NOTIFY_BYPASS_IDLE="$member_bypass" \
       send_to_session "$s" "$payload" ${member_keys[@]+"${member_keys[@]}"}; then
      delivered=$((delivered + 1))
      notified_sessions+="$s"$'\n'
      member_pane="$(primary_pane_for_session "$s")"
      [[ -n "$member_pane" ]] && notified_panes+="$member_pane"$'\n'
      results+="  <target kind=\"member\" session=\"$(xml_escape "$s")\" queued=\"true\" />"$'\n'
    else
      failed=$((failed + 1))
      results+="  <target kind=\"member\" session=\"$(xml_escape "$s")\" queued=\"false\" />"$'\n'
    fi
  done

  subscribers_dir="$(team_message_watchers_dir "$repo_name" "$team_name")"
  if [[ -d "$subscribers_dir" ]]; then
    while IFS= read -r subscriber; do
      [[ -e "$subscriber" ]] || continue
      subscriber_name="$(basename "$subscriber")"
      subscriber_pane="$(cat "$subscriber/pane" 2>/dev/null || cat "$subscriber" 2>/dev/null || true)"
      subscriber_session="$(cat "$subscriber/session" 2>/dev/null || true)"
      subscriber_repo="$(cat "$subscriber/repo" 2>/dev/null || true)"
      subscriber_team="$(cat "$subscriber/team" 2>/dev/null || true)"
      [[ -n "$subscriber_pane" ]] || continue
      [[ "$subscriber_repo" == "$repo_name" && "$subscriber_team" == "$team_name" ]] || continue
      if text_has_line "$notified_sessions" "$subscriber_session" || text_has_line "$notified_panes" "$subscriber_pane"; then
        continue
      fi

      attempted=$((attempted + 1))
      payload="$(build_team_message_payload "$from_session" "$team_name" "$read_cmd" "$reply_required_value")"
      if send_to_pane "$subscriber_pane" "$payload"; then
        delivered=$((delivered + 1))
        notified_panes+="$subscriber_pane"$'\n'
        [[ -n "$subscriber_session" ]] && notified_sessions+="$subscriber_session"$'\n'
        results+="  <target kind=\"subscriber\" watcher=\"$(xml_escape "$subscriber_name")\" pane=\"$(xml_escape "$subscriber_pane")\" queued=\"true\" />"$'\n'
      else
        failed=$((failed + 1))
        results+="  <target kind=\"subscriber\" watcher=\"$(xml_escape "$subscriber_name")\" pane=\"$(xml_escape "$subscriber_pane")\" queued=\"false\" />"$'\n'
      fi
    done < <(find "$subscribers_dir" -mindepth 1 -maxdepth 1 \( -type f -o -type d \) 2>/dev/null | sort)
  fi

  printf '<send to="team" name="%s" session="%s" message_id="%s" queued="%s" attempted="%s" failed="%s">\n%s</send>\n' \
    "$(xml_escape "$team_name")" \
    "$(xml_escape "$team_session")" \
    "$(xml_escape "$msg_id")" \
    "$(xml_escape "$delivered")" \
    "$(xml_escape "$attempted")" \
    "$(xml_escape "$failed")" \
    "$results"

  if (( failed > 0 )); then
    notify_sender_failed_send "$team_name" "failed to queue for ${failed} team target(s)"
    exit 1
  fi
  exit 0
fi

target_session="$("$HERE/agent" resolve "$target_name" "$repo_name" || true)"
if [[ -z "$target_session" ]]; then
  notify_sender_failed_send "$target_name" "target not found"
  debug_notify "send:agent_resolve_failed target=$(printf '%q' "$target_name") repo=$(printf '%q' "$repo_name")"
  echo "target not found as team or agent: $target_name" >&2
  exit 1
fi
debug_notify "send:agent_resolved target=$(printf '%q' "$target_name") session=$(printf '%q' "$target_session")"
if [[ "$target_session" == "$from_session" ]]; then
  self_send_error
  exit 2
fi
msg_id="$(store_message "$repo_name" "$from_session" "$target_name" "$message" "$reply_required_value")"
printf -v read_cmd 'atmux message read %q --repo %q' "$msg_id" "$repo_name"
payload="$(build_message_payload_for_session "$target_session" "$from_session" "$read_cmd" "$reply_required_value")"
submit_keys=()
target_pre_keys=""
target_bypass=""
if (( interrupt == 1 )); then
  while IFS= read -r __sk_line; do
    submit_keys+=("$__sk_line")
  done < <(resolve_steer_keys "$target_session")
  target_bypass=1
  while IFS= read -r __pk_line; do
    [[ -n "$__pk_line" ]] || continue
    if [[ -n "$target_pre_keys" ]]; then
      target_pre_keys+=" "
    fi
    target_pre_keys+="$__pk_line"
  done < <(resolve_abort_keys "$target_session")
fi
if ! ATMUX_NOTIFY_PRE_KEYS="$target_pre_keys" \
     ATMUX_NOTIFY_BYPASS_IDLE="$target_bypass" \
     send_to_session "$target_session" "$payload" ${submit_keys[@]+"${submit_keys[@]}"}; then
  notify_sender_failed_send "$target_session" "failed to queue notification"
  echo "failed to queue for session: $target_session" >&2
  exit 1
fi
printf '<send to="agent" name="%s" session="%s" message_id="%s" queued="1" attempted="1" failed="0" />\n' \
  "$(xml_escape "$target_name")" \
  "$(xml_escape "$target_session")" \
  "$(xml_escape "$msg_id")"
