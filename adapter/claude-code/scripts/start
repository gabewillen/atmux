#!/usr/bin/env bash
set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
  echo "claude command not found in PATH" >&2
  exit 127
fi

manifest_lib="${ATMUX_SOURCE_ROOT:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)}/bin/(atmux)/(lib)/manifest"
# shellcheck source=bin/(atmux)/(lib)/manifest
source "$manifest_lib"

set_bootstrap_state() {
  local state="$1"
  local session=""
  if [[ -n "${TMUX:-}" ]]; then
    session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  [[ -n "$session" ]] || return 0
  tmux set-environment -t "$session" ATMUX_BOOTSTRAP_STATE "$state" >/dev/null 2>&1 || true
}

state_dir="${ATMUX_HOME:-$HOME/.atmux}/adapters/claude-code"
state_file="$state_dir/state.env"
mkdir -p "$state_dir"
[[ -f "$state_file" ]] || printf 'MODEL=%s\nREASONING_LEVEL=%s\n' 'sonnet' 'medium' > "$state_file"
# shellcheck disable=SC1090
source "$state_file"

arg_present() {
  local needle="$1"
  shift || true
  local arg
  for arg in "$@"; do
    [[ "$arg" == "$needle" ]] && return 0
  done
  return 1
}

normalize_model() {
  case "${1:-}" in
    sonnet|opus) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

normalize_effort() {
  case "${1:-}" in
    low|medium|high) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

if [[ -n "${ATMUX_INTELLIGENCE:-}" && "${ATMUX_INTELLIGENCE}" =~ ^[0-9]+$ ]] \
  && (( ATMUX_INTELLIGENCE >= 0 && ATMUX_INTELLIGENCE <= 100 )); then
  manifest_path="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/manifest"
  profile="$(resolve_profile_from_manifest "$ATMUX_INTELLIGENCE" "$manifest_path" || true)"
  if [[ -n "$profile" ]]; then
    prof_model="${profile%% *}"
    prof_reasoning="${profile#* }"
    MODEL="$(normalize_model "$prof_model" || printf '%s\n' "$MODEL")"
    REASONING_LEVEL="$(normalize_effort "$prof_reasoning" || printf '%s\n' "$REASONING_LEVEL")"
  fi
fi

if [[ -n "${ATMUX_CLAUDE_MODEL:-}" ]]; then
  MODEL="$(normalize_model "$ATMUX_CLAUDE_MODEL" || { echo "invalid ATMUX_CLAUDE_MODEL: $ATMUX_CLAUDE_MODEL" >&2; exit 2; })"
fi
if [[ -n "${ATMUX_CLAUDE_EFFORT:-}" ]]; then
  REASONING_LEVEL="$(normalize_effort "$ATMUX_CLAUDE_EFFORT" || { echo "invalid ATMUX_CLAUDE_EFFORT: $ATMUX_CLAUDE_EFFORT" >&2; exit 2; })"
fi

# Generic per-field overrides win over intelligence_map and adapter-specific
# legacy envvars. Unknown values pass through unchanged so the adapter can
# emit its own error if the model id isn't valid for the underlying CLI.
if [[ -n "${ATMUX_MODEL:-}" ]]; then
  MODEL="$ATMUX_MODEL"
fi
if [[ -n "${ATMUX_REASONING_LEVEL:-}" ]]; then
  REASONING_LEVEL="$ATMUX_REASONING_LEVEL"
fi

printf 'MODEL=%s\nREASONING_LEVEL=%s\n' "$MODEL" "$REASONING_LEVEL" > "$state_file"

if ! arg_present --model "$@"; then
  set -- --model "$MODEL" "$@"
fi
if ! arg_present --effort "$@"; then
  set -- --effort "$REASONING_LEVEL" "$@"
fi
if ! arg_present --dangerously-skip-permissions "$@"; then
  set -- --dangerously-skip-permissions "$@"
fi

set_bootstrap_state ready
echo "starting claude in $(pwd)"
exec claude "$@"
