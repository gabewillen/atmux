#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

wait_for_count() {
  local target="$1"
  local needle="$2"
  local expected_count="$3"
  local timeout="${4:-8}"
  local deadline now snap compact count
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -600 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    count="$(printf '%s' "$compact" | grep -F -o "$needle" | wc -l | tr -d ' ')"
    if [[ -n "$count" ]] && (( count >= expected_count )); then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

eval "$("$SCRIPTS_DIR/setup")"

# Track the interval scheduler PID so we can kill it on EXIT — without
# this it keeps firing 'ping' notifications into the sender session
# (which gets recreated by setup in every later test under the same
# name) and floods their notify queue, which causes time-sensitive
# tests like 71_send_failure_notifies_sender to time out waiting for
# their own notifications.
schedule_pid=""
cleanup() {
  if [[ -n "$schedule_pid" ]]; then
    kill -TERM "$schedule_pid" 2>/dev/null || true
    pkill -TERM -P "$schedule_pid" 2>/dev/null || true
  fi
  "$SCRIPTS_DIR/teardown" --team-session "$TEAM_SESSION" --agent1-session "$AGENT1_SESSION" --agent2-session "$AGENT2_SESSION"
}
trap cleanup EXIT

sender_pane="$(tmux list-panes -t "$AGENT1_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$sender_pane" ]] || { echo "sender pane missing" >&2; exit 1; }

# Schedule returns immediately (detached by default)
out="$(ATMUX_REPO="$REPO_NAME" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="$AGENT1_SESSION" "$ATMUX_BIN" schedule --interval 1s --notification "ping")"
printf '%s\n' "$out" | grep -Fq '<schedule'
printf '%s\n' "$out" | grep -Fq 'kind="notification"'
printf '%s\n' "$out" | grep -Fq 'mode="interval"'
schedule_pid="$(printf '%s\n' "$out" | sed -n 's/.*pid="\([^"]*\)".*/\1/p' | head -n1)"

if ! wait_for_count "$sender_pane" 'type="scheduled"' 2 12; then
  echo "scheduled notifications not repeated in sender pane" >&2
  tmux capture-pane -p -t "$sender_pane" -S -160 >&2 || true
  exit 1
fi

echo "ok: schedule --interval notification repeatedly delivered to self"
