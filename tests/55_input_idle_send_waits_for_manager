#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

# Test that send to root manager saves user input, delivers notification,
# and restores the input — even while the user is typing.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

repo_name="idle${RANDOM}"
session_mgr="atmux-${repo_name}-mgr"
session_agent="atmux-${repo_name}-worker"

cleanup() {
  tmux kill-session -t "$session_mgr" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_agent" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session_mgr" >/dev/null 2>&1 || true
tmux kill-session -t "$session_agent" >/dev/null 2>&1 || true

# Root manager: cat process, adapter set, no ATMUX_MANAGER
tmux new-session -d -s "$session_mgr" -n "$session_mgr" -x 160 -y 40 "cat"
tmux set-environment -t "$session_mgr" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_mgr" ATMUX_AGENT_NAME "mgr"
tmux set-environment -t "$session_mgr" ATMUX_SESSION_NAME "$session_mgr"
tmux set-environment -t "$session_mgr" ATMUX_ADAPTER "claude-code"

# Child agent: bash shell, has ATMUX_MANAGER
tmux new-session -d -s "$session_agent" -n "$session_agent" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux set-environment -t "$session_agent" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_agent" ATMUX_AGENT_NAME "worker"
tmux set-environment -t "$session_agent" ATMUX_SESSION_NAME "$session_agent"
tmux set-environment -t "$session_agent" ATMUX_MANAGER "mgr"

pane_mgr="$(tmux list-panes -t "$session_mgr" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_mgr" ]] || { echo "mgr pane missing" >&2; exit 1; }

# Simulate user typing on prompt
sleep 0.3
tmux send-keys -t "$pane_mgr" -l "❯ "
tmux send-keys -t "$pane_mgr" Enter
sleep 0.3
user_text="reviewing the architecture docs"
tmux send-keys -t "$pane_mgr" -l "❯ ${user_text}"
# Wait for the typed input to land in the pane buffer before firing the
# notification — otherwise on slower hosts (notably Linux CI without an
# attached client) the worker can save_input/C-u/restore while the
# original send-keys is still draining, clipping the tail.
if ! wait_for_text "$pane_mgr" "$user_text" 5; then
  echo "user_text never landed in pane before notify" >&2
  tmux capture-pane -p -t "$pane_mgr" -S -40 >&2 || true
  exit 1
fi

# Agent sends to manager
ATMUX_REPO="$repo_name" ATMUX_AGENT_NAME="worker" ATMUX_SESSION_NAME="$session_agent" \
  "$ATMUX_BIN" send --to mgr "task complete" >/dev/null

# Notification should be delivered
if ! wait_for_text "$pane_mgr" '<notification' 15; then
  echo "notification not delivered to manager" >&2
  tmux capture-pane -p -t "$pane_mgr" -S -200 >&2 || true
  exit 1
fi

# User's input should be restored
sleep 2
if ! wait_for_text "$pane_mgr" "$user_text" 10; then
  echo "user input not restored after notification" >&2
  tmux capture-pane -p -t "$pane_mgr" -S -20 >&2 || true
  exit 1
fi

echo "ok: send to manager delivers notification and restores user input"
