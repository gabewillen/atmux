#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"
# shellcheck source=bin/(atmux)/(internal)/reporter
source "$HERE/(internal)/reporter"

TEMPLATE_DIR="$(cd -- "$HERE/../.." && pwd)/templates"

render_issue_template() {
  local given="$1" when="$2" then_="$3" todos="$4"
  local tpl
  tpl="$(cat "$TEMPLATE_DIR/issue.md")"
  tpl="${tpl//%%GIVEN%%/$given}"
  tpl="${tpl//%%WHEN%%/$when}"
  tpl="${tpl//%%THEN%%/$then_}"
  tpl="${tpl//%%TODOS%%/$todos}"
  printf '%s\n' "$tpl"
}

usage() {
  cat <<'USAGE'
Usage:
  atmux issue create --title <title> [--description <description>]
                     [--given <context>] [--when <action>] [--then <outcome>]
                     [--todo <todo>]... [--repo <repo>]
                     [--assign-to <agent|session>]
  atmux issue list [--repo <repo>]
  atmux issue ls [--repo <repo>]
  atmux issue get <id> [--repo <repo>]
  atmux issue show <id> [--repo <repo>]
  atmux issue assign <id> --to <agent|session> [--repo <repo>]
  atmux issue claim <id> [--by <agent|session>] [--repo <repo>]
  atmux issue comment <id> "message" [--repo <repo>]
  atmux issue watch <id> [--repo <repo>] [--timeout <s>] [--interval <s>]
  atmux issue watch --feed <repo|url> [--timeout <s>] [--interval <s>]

Description:
  Repo-scoped issue tickets on filesystem.
  Issues are stored at: ~/.atmux/issues/<repo>/<id>/

  `create --assign-to` creates the issue and immediately assigns it.
  `watch <id>` waits for the next update on a single issue.
  `watch --feed <repo>` watches a GitHub repo for newly-filed issues.
USAGE
}

resolve_repo_name() {
  local explicit_repo="${1:-}"
  local repo=""
  if [[ -n "$explicit_repo" ]]; then
    repo="$explicit_repo"
  elif [[ -n "${ATMUX_REPO:-}" ]]; then
    repo="${ATMUX_REPO}"
  elif [[ -n "${TMUX:-}" ]]; then
    repo="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo="$(basename "$repo_root")"
    fi
  fi
  if [[ -z "$repo" ]]; then
    echo "unable to resolve repo; pass --repo <repo> or run inside a git repo" >&2
    exit 2
  fi
  normalize_name "$repo"
}

current_actor_name() {
  local repo="${1:-}"
  local actor="${ATMUX_AGENT_NAME:-}"
  if [[ -z "$actor" && -n "${TMUX:-}" ]]; then
    actor="$(tmux show-environment ATMUX_AGENT_NAME 2>/dev/null | sed -n 's/^ATMUX_AGENT_NAME=//p' || true)"
  fi
  if [[ -n "$actor" ]]; then
    printf '%s\n' "$actor"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    local session=""
    session="$(tmux display-message -p '#S' 2>/dev/null || true)"
    if [[ -n "$session" ]]; then
      session_short_name "$session" "$repo"
      return
    fi
  fi
  printf '%s\n' "external"
}

now_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

read_field() {
  local file="$1"
  cat "$file" 2>/dev/null || true
}

identity_matches() {
  local left="$1"
  local right="$2"
  local repo="$3"
  local left_short="$left"
  local right_short="$right"

  [[ -n "$left" && -n "$right" ]] || return 1
  [[ "$left" == "$right" ]] && return 0

  if [[ -n "$repo" ]]; then
    left_short="$(session_short_name "$left" "$repo")"
    right_short="$(session_short_name "$right" "$repo")"
    [[ "$left_short" == "$right_short" ]] && return 0
    [[ "atmux-${repo}-${left_short}" == "$right" ]] && return 0
    [[ "atmux-${repo}-${right_short}" == "$left" ]] && return 0
  fi

  return 1
}

ensure_can_assign() {
  local manager="${ATMUX_MANAGER:-}"
  if [[ -z "$manager" && -n "${TMUX:-}" ]]; then
    manager="$(tmux show-environment ATMUX_MANAGER 2>/dev/null | sed -n 's/^ATMUX_MANAGER=//p' || true)"
  fi
  if [[ -n "$manager" ]]; then
    echo "managed agents cannot assign issues; use 'atmux issue claim' instead" >&2
    exit 1
  fi
}

create_issue() {
  local title=""
  local description=""
  local given=""
  local when=""
  local then_=""
  local explicit_repo=""
  local todos=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)
        title="${2:-}"
        shift 2
        ;;
      --description)
        description="${2:-}"
        shift 2
        ;;
      --given)
        given="${2:-}"
        shift 2
        ;;
      --when)
        when="${2:-}"
        shift 2
        ;;
      --then)
        then_="${2:-}"
        shift 2
        ;;
      --todo|--todos)
        todos+=("${2:-}")
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$title" ]]; then
    echo "missing required flag: --title" >&2
    exit 2
  fi

  # Build description from template if structured flags were provided
  local has_todos=0
  (( ${#todos[@]} > 0 )) && has_todos=1
  if [[ -n "$given" || -n "$when" || -n "$then_" || "$has_todos" -eq 1 ]]; then
    local todos_text=""
    local t
    if [[ "$has_todos" -eq 1 ]]; then
      for t in "${todos[@]}"; do
        [[ -n "$t" ]] || continue
        todos_text+="- $t"$'\n'
      done
    fi
    todos_text="${todos_text%$'\n'}"

    if [[ -f "$TEMPLATE_DIR/issue.md" ]]; then
      description="$(render_issue_template "$given" "$when" "$then_" "$todos_text")"
    else
      # Inline fallback if template file is missing
      description="**Given** ${given}"$'\n'"**When** ${when}"$'\n'"**Then** ${then_}"
      [[ -z "$todos_text" ]] || description+=$'\n\n'"## Tasks"$'\n'"$todos_text"
    fi
  fi

  local repo root id dir created_at
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  mkdir -p "$root"

  id="$(id)"
  dir="$(issue_dir_for_id "$root" "$id")"
  created_at="$(now_utc)"

  mkdir -p "$dir"
  write_field "$dir/title" "$title"
  write_field "$dir/description" "$description"
  write_field "$dir/state" "open"
  write_field "$dir/created_at" "$created_at"
  write_field "$dir/updated_at" "$created_at"
  write_field "$dir/assigned_to" ""
  write_field "$dir/assigned_by" ""
  write_field "$dir/assigned_at" ""
  write_field "$dir/claimed_by" ""
  write_field "$dir/claimed_at" ""

  printf '<issue id="%s" repo="%s" state="open" path="%s" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$dir")"
}

list_issues() {
  local explicit_repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir id title state created_at updated_at assigned_to claimed_by
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"

  report_open issues repo="$repo"
  if [[ -d "$root" ]]; then
    while IFS= read -r dir; do
      [[ -d "$dir" ]] || continue
      id="$(basename "$dir")"
      title="$(read_field "$dir/title")"
      state="$(read_field "$dir/state")"
      created_at="$(read_field "$dir/created_at")"
      updated_at="$(read_field "$dir/updated_at")"
      assigned_to="$(read_field "$dir/assigned_to")"
      claimed_by="$(read_field "$dir/claimed_by")"
      report_record issue \
        id="$id" \
        state="$state" \
        created_at="$created_at" \
        updated_at="$updated_at" \
        assigned_to="$assigned_to" \
        claimed_by="$claimed_by" \
        title="$title"
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d | sort)
  fi
  report_close issues
}

get_issue() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux issue get <id> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir title description state created_at updated_at
  local assigned_to assigned_by assigned_at claimed_by claimed_at
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  dir="$(issue_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "issue not found: $id" >&2
    exit 1
  fi

  title="$(read_field "$dir/title")"
  description="$(read_field "$dir/description")"
  state="$(read_field "$dir/state")"
  created_at="$(read_field "$dir/created_at")"
  updated_at="$(read_field "$dir/updated_at")"
  assigned_to="$(read_field "$dir/assigned_to")"
  assigned_by="$(read_field "$dir/assigned_by")"
  assigned_at="$(read_field "$dir/assigned_at")"
  claimed_by="$(read_field "$dir/claimed_by")"
  claimed_at="$(read_field "$dir/claimed_at")"

  printf '<issue id="%s" repo="%s" state="%s" created_at="%s" updated_at="%s">\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$state")" \
    "$(xml_escape "$created_at")" \
    "$(xml_escape "$updated_at")"
  printf '  <title>%s</title>\n' "$title"
  printf '  <description>%s</description>\n' "$description"
  printf '  <assignment to="%s" by="%s" at="%s" />\n' \
    "$(xml_escape "$assigned_to")" \
    "$(xml_escape "$assigned_by")" \
    "$(xml_escape "$assigned_at")"
  printf '  <claim by="%s" at="%s" />\n' \
    "$(xml_escape "$claimed_by")" \
    "$(xml_escape "$claimed_at")"
  printf '</issue>\n'
}

assign_issue() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""
  local to=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux issue assign <id> --to <agent|session> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)
        to="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$to" ]]; then
    echo "missing required flag: --to" >&2
    exit 2
  fi

  ensure_can_assign

  local repo root dir now assigned_by
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  dir="$(issue_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "issue not found: $id" >&2
    exit 1
  fi

  now="$(now_utc)"
  assigned_by="$(current_actor_name "$repo")"

  write_field "$dir/assigned_to" "$to"
  write_field "$dir/assigned_by" "$assigned_by"
  write_field "$dir/assigned_at" "$now"
  write_field "$dir/claimed_by" ""
  write_field "$dir/claimed_at" ""
  write_field "$dir/state" "assigned"
  write_field "$dir/updated_at" "$now"

  printf '<issue id="%s" repo="%s" state="assigned" assigned_to="%s" assigned_by="%s" assigned_at="%s" claimed_by="" claimed_at="" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$to")" \
    "$(xml_escape "$assigned_by")" \
    "$(xml_escape "$now")"

  local actor_pane assignee_session assignee_pane notification_xml
  actor_pane="$(current_pane)"
  assignee_session="$("$HERE/agent" resolve "$to" "$repo" 2>/dev/null || true)"
  if [[ -n "$assignee_session" ]]; then
    assignee_pane="$(primary_pane_for_session "$assignee_session")"
  fi
  notification_xml="$(build_notification "issue" "assign" "atmux issue get $id" "state=assigned")"
  if [[ -n "$assignee_pane" && "$assignee_pane" != "$actor_pane" ]]; then
    send_notification "$assignee_pane" "$notification_xml"
  fi
  notify_issue_watchers "$dir" "$actor_pane" "$notification_xml"
}

claim_issue() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""
  local by=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux issue claim <id> [--by <agent|session>] [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --by)
        by="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir assigned_to claimed_by now
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  dir="$(issue_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "issue not found: $id" >&2
    exit 1
  fi

  if [[ -z "$by" ]]; then
    by="$(current_actor_name "$repo")"
  fi

  if [[ -z "$by" || "$by" == "external" ]]; then
    echo "unable to infer claimer; pass --by <agent|session>" >&2
    exit 2
  fi

  assigned_to="$(read_field "$dir/assigned_to")"
  if [[ -n "$assigned_to" ]] && ! identity_matches "$assigned_to" "$by" "$repo"; then
    echo "issue is assigned to '$assigned_to'; '$by' cannot claim it" >&2
    exit 1
  fi

  claimed_by="$(read_field "$dir/claimed_by")"
  if [[ -n "$claimed_by" ]] && ! identity_matches "$claimed_by" "$by" "$repo"; then
    echo "issue already claimed by '$claimed_by'" >&2
    exit 1
  fi

  now="$(now_utc)"
  if [[ -z "$assigned_to" ]]; then
    write_field "$dir/assigned_to" "$by"
    write_field "$dir/assigned_by" "self-claim"
    write_field "$dir/assigned_at" "$now"
    assigned_to="$by"
  fi
  write_field "$dir/claimed_by" "$by"
  write_field "$dir/claimed_at" "$now"
  write_field "$dir/state" "in_progress"
  write_field "$dir/updated_at" "$now"

  printf '<issue id="%s" repo="%s" state="in_progress" assigned_to="%s" claimed_by="%s" claimed_at="%s" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$assigned_to")" \
    "$(xml_escape "$by")" \
    "$(xml_escape "$now")"

  local actor_pane notification_xml
  actor_pane="$(current_pane)"
  notification_xml="$(build_notification "issue" "claim" "atmux issue get $id" "state=in_progress")"
  notify_issue_watchers "$dir" "$actor_pane" "$notification_xml"
}

sub="${1:-}"
shift || true

case "$sub" in
  create)
    # Extract --assign-to <name> so we can run a follow-up assign step.
    assign_to=""
    create_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --assign-to)   assign_to="${2:-}"; shift 2 ;;
        --assign-to=*) assign_to="${1#--assign-to=}"; shift ;;
        *)             create_args+=("$1"); shift ;;
      esac
    done
    create_xml="$(create_issue "${create_args[@]}")"
    printf '%s\n' "$create_xml"
    if [[ -n "$assign_to" ]]; then
      new_id="$(printf '%s' "$create_xml" | sed -n 's/.*<issue id="\([^"]*\)".*/\1/p' | head -n 1)"
      new_repo="$(printf '%s' "$create_xml" | sed -n 's/.*repo="\([^"]*\)".*/\1/p' | head -n 1)"
      if [[ -z "$new_id" ]]; then
        echo "atmux issue create: created issue but could not parse id for --assign-to" >&2
        exit 1
      fi
      if [[ -n "$new_repo" ]]; then
        assign_issue "$new_id" --to "$assign_to" --repo "$new_repo"
      else
        assign_issue "$new_id" --to "$assign_to"
      fi
    fi
    ;;
  list|ls)
    list_issues "$@"
    ;;
  get|show)
    get_issue "$@"
    ;;
  assign)
    assign_issue "$@"
    ;;
  claim)
    claim_issue "$@"
    ;;
  comment)
    here_issue="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ $# -lt 2 ]]; then
      echo "usage: atmux issue comment <id> \"message\" [--repo R]" >&2
      exit 2
    fi
    issue_id="$1"; shift
    comment_msg="$1"; shift
    exec "$here_issue/(internal)/comment" "$comment_msg" --issue "$issue_id" "$@"
    ;;
  watch)
    here_issue="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    # --feed <repo> selects the new-issues stream watcher; otherwise first
    # positional is an issue id.
    feed_repo=""
    forward_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --feed)   feed_repo="${2:-}"; shift 2 ;;
        --feed=*) feed_repo="${1#--feed=}"; shift ;;
        *)        forward_args+=("$1"); shift ;;
      esac
    done
    if [[ -n "$feed_repo" ]]; then
      exec "$here_issue/[watch]/issues" --issues "$feed_repo" ${forward_args[@]+"${forward_args[@]}"}
    fi
    if [[ ${#forward_args[@]} -eq 0 || "${forward_args[0]:0:1}" == "-" ]]; then
      echo "usage: atmux issue watch <id> [--repo R]   |   atmux issue watch --feed <repo>" >&2
      exit 2
    fi
    issue_id="${forward_args[0]}"
    rest=("${forward_args[@]:1}")
    exec "$here_issue/[watch]/issue" --issue "$issue_id" ${rest[@]+"${rest[@]}"}
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown issue command: $sub" >&2
    exit 2
    ;;
esac
