#!/usr/bin/env bash
# shellcheck shell=bash
# Shared helpers for exec, issue, watch --pid, watch --issue; also `amux notify` CLI when executed.
# When sourced, only function definitions run (see bottom).

normalize_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

primary_pane_for_session() {
  local session="$1"
  tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }'
}

current_pane() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return 0
  fi
  if [[ -n "${AMUX_SESSION_NAME:-}" ]]; then
    primary_pane_for_session "$AMUX_SESSION_NAME"
    return 0
  fi
  return 0
}

queue_self_notification() {
  local pane="$1"
  local payload="$2"
  [[ -n "$pane" ]] || return 0

  nohup bash -lc '
    pane="$1"
    payload="$2"
    sleep 0.2
    settle="${AMUX_SEND_SETTLE_SECONDS:-0.2}"
    submit_wait="${AMUX_SEND_SUBMIT_WAIT_SECONDS:-0.15}"
    tmux send-keys -t "$pane" C-u >/dev/null 2>&1 || exit 0
    sleep "$settle"
    tmux send-keys -t "$pane" -l "$payload" >/dev/null 2>&1 || exit 0
    sleep "$settle"
    tmux send-keys -t "$pane" Enter >/dev/null 2>&1 || exit 0
    sleep "$submit_wait"
  ' _ "$pane" "$payload" >/dev/null 2>&1 &
}

build_notification_xml() {
  local command_text="$1"
  local timestamp="$2"
  local exit_code="$3"

  printf '<amux><notification from="exec %s" timestamp="%s" exitcode="%s" /></amux>' \
    "$(xml_escape "$command_text")" \
    "$(xml_escape "$timestamp")" \
    "$(xml_escape "$exit_code")"
}

build_issue_notification_xml() {
  local action="$1"
  local issue_id="$2"
  local state="$3"
  local timestamp="$4"

  printf '<amux><notification from="issue %s" issue_id="%s" state="%s" timestamp="%s" /></amux>' \
    "$(xml_escape "$action")" \
    "$(xml_escape "$issue_id")" \
    "$(xml_escape "$state")" \
    "$(xml_escape "$timestamp")"
}

timestamp_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

repo_name_from_context() {
  local repo_name="${AMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment AMUX_REPO 2>/dev/null | sed -n 's/^AMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  normalize_name "$repo_name"
}

write_field() {
  local file="$1"
  local value="${2:-}"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" > "$file"
}

exec_root_for_repo() {
  local repo_name="$1"
  printf '%s/exec/%s\n' "$AMUX_HOME" "$repo_name"
}

exec_dir_for_repo_pid() {
  local repo_name="$1"
  local pid="$2"
  printf '%s/%s\n' "$(exec_root_for_repo "$repo_name")" "$pid"
}

issue_root_for_repo() {
  local repo="$1"
  local amux_home="${AMUX_HOME:-$HOME/.amux}"
  printf '%s/issues/%s\n' "$amux_home" "$repo"
}

issue_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

notify_exec_watchers() {
  local exec_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$exec_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    queue_self_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_issue_watchers() {
  local issue_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$issue_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    queue_self_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_cli_usage() {
  cat <<'USAGE'
Usage:
  amux notify --pane <tmux-pane-id> --xml <payload>

Description:
  Queue an AMUX XML notification to a tmux pane (same mechanism as exec/issue fan-out).

Examples:
  amux notify --pane %12 --xml '<amux><notification from="test" /></amux>'
USAGE
}

notify_cli_main() {
  local pane=""
  local xml_payload=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane)
        pane="${2:-}"
        shift 2
        ;;
      --xml)
        xml_payload="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        notify_cli_usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        notify_cli_usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
  [[ -n "$xml_payload" ]] || { echo "missing --xml" >&2; exit 2; }

  queue_self_notification "$pane" "$xml_payload"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail
  AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"
  notify_cli_main "$@"
fi
