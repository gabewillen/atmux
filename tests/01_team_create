#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

eval "$("$SCRIPTS_DIR/setup")"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"" EXIT

team_state="${ATMUX_HOME:-$HOME/.atmux}/teams/$REPO_NAME/$TEAM_NAME"
if [[ ! -d "$team_state" ]]; then
  echo "team state missing: $team_state" >&2
  exit 1
fi

repo="$(cat "$team_state/repo" 2>/dev/null || true)"
team="$(cat "$team_state/name" 2>/dev/null || true)"
session="$(cat "$team_state/session_name" 2>/dev/null || true)"

[[ "$repo" == "$REPO_NAME" ]] || { echo "expected ATMUX_REPO=$REPO_NAME, got: ${repo:-<empty>}" >&2; exit 1; }
[[ "$team" == "$TEAM_NAME" ]] || { echo "expected ATMUX_TEAM=$TEAM_NAME, got: ${team:-<empty>}" >&2; exit 1; }
[[ "$session" == "$TEAM_SESSION" ]] || { echo "expected session marker $TEAM_SESSION, got: ${session:-<empty>}" >&2; exit 1; }
if tmux has-session -t "$TEAM_SESSION" 2>/dev/null; then
  echo "team create should not create default tmux view session" >&2
  exit 1
fi

echo "ok: team created in state without default dashboard ($TEAM_SESSION)"
