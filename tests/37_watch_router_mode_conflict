#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

# Combining --pid and --issue should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --pid 1234 --issue abc >/dev/null 2>&1
rc=$?
set -e
[[ "$rc" -eq 2 ]] || { echo "expected exit 2 for --pid + --issue, got $rc" >&2; exit 1; }

# Combining --pid and --agent should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --pid 1234 --agent foo >/dev/null 2>&1
rc2=$?
set -e
[[ "$rc2" -eq 2 ]] || { echo "expected exit 2 for --pid + --agent, got $rc2" >&2; exit 1; }

# Combining --issue and --agent should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --issue abc --agent foo >/dev/null 2>&1
rc3=$?
set -e
[[ "$rc3" -eq 2 ]] || { echo "expected exit 2 for --issue + --agent, got $rc3" >&2; exit 1; }

# Combining --issue and --pr should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --issue abc --pr https://github.com/o/r/pull/1 >/dev/null 2>&1
rc4=$?
set -e
[[ "$rc4" -eq 2 ]] || { echo "expected exit 2 for --issue + --pr, got $rc4" >&2; exit 1; }

# Combining --issues and --pr should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --issues o/r --pr https://github.com/o/r/pull/1 >/dev/null 2>&1
rc5=$?
set -e
[[ "$rc5" -eq 2 ]] || { echo "expected exit 2 for --issues + --pr, got $rc5" >&2; exit 1; }

# Combining --issues and --agent should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --issues o/r --agent foo >/dev/null 2>&1
rc6=$?
set -e
[[ "$rc6" -eq 2 ]] || { echo "expected exit 2 for --issues + --agent, got $rc6" >&2; exit 1; }

# Combining --pull-request and --pr should fail because --pull-request is only
# a compatibility alias for local PRs.
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --pull-request abc --pr https://github.com/o/r/pull/1 >/dev/null 2>&1
rc_pr_file=$?
set -e
[[ "$rc_pr_file" -eq 2 ]] || { echo "expected exit 2 for --pull-request + --pr, got $rc_pr_file" >&2; exit 1; }

# Combining --path and --agent should fail
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch --path '*.txt' --agent foo >/dev/null 2>&1
rc_path=$?
set -e
[[ "$rc_path" -eq 2 ]] || { echo "expected exit 2 for --path + --agent, got $rc_path" >&2; exit 1; }

# No arguments at all
set +e
ATMUX_REPO="test" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" watch >/dev/null 2>&1
rc7=$?
set -e
[[ "$rc7" -eq 2 ]] || { echo "expected exit 2 for no args, got $rc7" >&2; exit 1; }

echo "ok: watch rejects conflicting mode flags and missing args"
