#!/usr/bin/env bash
# Edge-triggered idle watcher: a thin loop around `atmux agent watch`.
# Each loop iteration waits for the driver to be idle for IDLE_INTERVAL
# seconds, fires one `<watch type="agent" reason="idle"/>` notification
# on the navigator's pane, then waits for the next active→idle cycle.
#
# `atmux agent watch` is the canonical "wait until agent is idle"
# primitive — when the adapter has a status script it uses
# adapter-reported state (robust to TUI animations); otherwise it
# falls back to pane-output stability. Keeping the navigator's idle
# detection in lock-step with that primitive avoids two competing
# definitions of "idle".
#
# Usage: idle-watch <driver_name> <nav_pane_id> <state_log_path>
set -u

driver="${1:?usage: idle-watch <driver> <pane> <log>}"
nav_pane="${2:?usage: idle-watch <driver> <pane> <log>}"
log="${3:?usage: idle-watch <driver> <pane> <log>}"

IDLE_SECONDS="${IDLE_SECONDS:-30}"   # how long idle before firing
WATCH_TIMEOUT="${WATCH_TIMEOUT:-3600}"  # outer call cap (re-armed each loop)
POLL_INTERVAL="${POLL_INTERVAL:-2}"

note() { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >> "$log"; }

note "idle-watch start: driver=$driver pane=$nav_pane idle=${IDLE_SECONDS}s timeout=${WATCH_TIMEOUT}s"

nav_session_active() {
  tmux display-message -p -t "$nav_pane" '#{session_name}' >/dev/null 2>&1
}

while true; do
  if ! nav_session_active; then
    note "navigator pane $nav_pane no longer resolvable — exiting"
    exit 0
  fi

  # Block until the driver is idle for IDLE_SECONDS or WATCH_TIMEOUT
  # elapses. rc=0 → idle observed; rc=124 → timeout (try again next
  # loop); other → error (also try again, with backoff).
  rc=0
  atmux agent watch "$driver" \
    --idle "$IDLE_SECONDS" \
    --timeout "$WATCH_TIMEOUT" \
    --interval "$POLL_INTERVAL" \
    >/dev/null 2>&1 || rc=$?

  case "$rc" in
    0)
      xml="<watch type=\"agent\" id=\"${driver}\" reason=\"idle\" stable_seconds=\"${IDLE_SECONDS}\"/>"
      if atmux notify --pane "$nav_pane" --xml "$xml" >/dev/null 2>&1; then
        note "idle notification fired (driver=$driver stable_seconds=${IDLE_SECONDS})"
      else
        note "atmux notify FAILED (pane=$nav_pane)"
      fi
      # Wait for the driver to leave idle before re-arming, otherwise
      # we'd fire repeatedly on a persistently-idle driver. `atmux
      # agent watch` returns 0 immediately when already idle, so loop
      # back into it would reuse the same idleness.
      while nav_session_active; do
        sleep "$POLL_INTERVAL"
        # Check the adapter status — if not idle, break and re-arm.
        if ! atmux agent watch "$driver" --idle 1 --timeout 1 --interval 1 >/dev/null 2>&1; then
          break
        fi
      done
      ;;
    124)
      # Timeout — driver was active the whole window. Loop again.
      :
      ;;
    *)
      note "atmux agent watch failed (rc=$rc) — backing off"
      sleep "$POLL_INTERVAL"
      ;;
  esac
done
