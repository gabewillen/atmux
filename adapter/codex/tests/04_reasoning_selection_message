#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-codex-test-home.XXXXXX")"
trap 'rm -rf "$atmux_home"' EXIT

ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" set high >/dev/null
current_reasoning="$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" get)"
[[ "$current_reasoning" == "high" ]] || {
  echo "unexpected reasoning-level get value after set high: $current_reasoning" >&2
  exit 1
}

ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" set xhigh >/dev/null
current_reasoning="$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" get)"
[[ "$current_reasoning" == "extra-high" ]] || {
  echo "unexpected reasoning-level get value after set xhigh: $current_reasoning" >&2
  exit 1
}

if ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" set invalid >/dev/null 2>&1; then
  echo "invalid reasoning-level unexpectedly succeeded" >&2
  exit 1
fi

echo "PASS 04_reasoning_selection_message"
