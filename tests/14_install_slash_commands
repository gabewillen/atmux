#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-install-test-home.XXXXXX")"
tmp_home_no_slash="$(mktemp -d "${TMPDIR:-/tmp}/atmux-install-test-home-noslash.XXXXXX")"

cleanup() {
  rm -rf "$tmp_home" "$tmp_home_no_slash"
}
trap cleanup EXIT

HOME="$tmp_home" "$ATMUX_BIN" install >/dev/null

[[ -x "$tmp_home/.atmux/bin/atmux" ]] || { echo "launcher missing after atmux install" >&2; exit 1; }
[[ -f "$tmp_home/.claude/skills/atmux-send/SKILL.md" ]] || { echo "claude atmux-send skill missing" >&2; exit 1; }
[[ -f "$tmp_home/.gemini/commands/atmux-send.toml" ]] || { echo "gemini atmux-send command missing" >&2; exit 1; }
[[ -f "$tmp_home/.codex/prompts/atmux-send.md" ]] || { echo "codex atmux-send prompt missing" >&2; exit 1; }

HOME="$tmp_home_no_slash" "$ATMUX_BIN" install --no-slash-commands >/dev/null

[[ -x "$tmp_home_no_slash/.atmux/bin/atmux" ]] || { echo "launcher missing after atmux install --no-slash-commands" >&2; exit 1; }
[[ ! -e "$tmp_home_no_slash/.claude/skills/atmux-send/SKILL.md" ]] || { echo "claude slash commands should be skipped" >&2; exit 1; }
[[ ! -e "$tmp_home_no_slash/.gemini/commands/atmux-send.toml" ]] || { echo "gemini slash commands should be skipped" >&2; exit 1; }
[[ ! -e "$tmp_home_no_slash/.codex/prompts/atmux-send.md" ]] || { echo "codex slash commands should be skipped" >&2; exit 1; }

echo "ok: install manages harness-specific slash commands"
