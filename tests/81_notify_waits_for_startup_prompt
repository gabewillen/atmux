#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_absence() {
  local target="$1"
  local needle="$2"
  local duration="${3:-1}"
  local end now
  end=$(( $(date +%s) + duration ))
  while true; do
    if wait_for_text "$target" "$needle" 1; then
      return 1
    fi
    now="$(date +%s)"
    if (( now >= end )); then
      return 0
    fi
  done
}

ATMUX_HOME="${TMPDIR:-/tmp}/atmux-notify-startup-${RANDOM}"
ATMUX_SOURCE_ROOT="$ATMUX_HOME/src/atmux"
export ATMUX_SEND_READY_TIMEOUT_SECONDS=2
# shellcheck source=bin/(atmux)/notify
source "$NOTIFY_SCRIPT"

repo_name="startup${RANDOM}"
session="atmux-${repo_name}-worker"
prompt_prefix="READY>"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$ATMUX_HOME"
}
trap cleanup EXIT

mkdir -p "$ATMUX_SOURCE_ROOT/adapter/mock"
cat > "$ATMUX_SOURCE_ROOT/adapter/mock/manifest" <<EOF
NAME=mock
SUBMIT_KEYS_STEER=(Enter)
INPUT_START="$prompt_prefix"
EOF

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 "cat"
tmux set-environment -t "$session" ATMUX_ADAPTER "mock"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

marker="startup-wait-${RANDOM}"
payload="$(build_notification "test" "$marker" "")"
send_notification "$pane" "$payload"

if ! wait_for_absence "$pane" "$marker" 1; then
  echo "notification delivered before startup prompt was ready" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

tmux send-keys -t "$pane" -l "$prompt_prefix "
tmux send-keys -t "$pane" Enter

if ! wait_for_text "$pane" "$marker" 10; then
  echo "notification not delivered after startup prompt became ready" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: notification worker waits for startup prompt before delivery"
