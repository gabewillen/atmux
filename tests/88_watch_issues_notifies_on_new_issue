#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_absence() {
  local target="$1"
  local needle="$2"
  local duration="${3:-1}"
  local end now
  end=$(( $(date +%s) + duration ))
  while true; do
    if wait_for_text "$target" "$needle" 1; then
      return 1
    fi
    now="$(date +%s)"
    if (( now >= end )); then
      return 0
    fi
  done
}

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-issues.XXXXXX")"
atmux_home="$tmp_root/.atmux"
repo_name="issues$RANDOM"
session="atmux-${repo_name}-watcher"
trigger_file="$tmp_root/trigger-1"
second_trigger_file="$tmp_root/trigger-2"
stub_dir="$tmp_root/bin"
snapshot_file="$atmux_home/watch-issues/octo_example_issues/snapshot"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  # Detached watcher subprocesses may still be unwinding their
  # `atmux exec` state dir at trap-fire time, which races the rm and
  # leaves a `detach-<pid>-<n>` subdir busy. Best-effort delete with
  # a short retry so a slow teardown on CI doesn't fail the whole
  # test after the assertions already passed.
  for _ in 1 2 3 4 5; do
    rm -rf "$tmp_root" 2>/dev/null && return 0
    sleep 0.2
  done
  rm -rf "$tmp_root" 2>/dev/null || true
}
trap cleanup EXIT

mkdir -p "$stub_dir"
cat > "$stub_dir/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" != "api" || "${2:-}" != "graphql" ]]; then
  echo "unexpected gh invocation: $*" >&2
  exit 1
fi

if [[ -f "${ATMUX_TEST_ISSUES_SECOND_TRIGGER:-}" ]]; then
  printf '%s\n' '2026-04-24T00:00:00Z|I_kw_1|101|octocat|OPEN|watch-issues-first|https://github.com/octo/example/issues/101'
  printf '%s\n' '2026-04-24T00:00:03Z|I_kw_2|102|hubot|OPEN|watch-issues-second|https://github.com/octo/example/issues/102'
elif [[ -f "${ATMUX_TEST_ISSUES_TRIGGER:-}" ]]; then
  printf '%s\n' '2026-04-24T00:00:00Z|I_kw_1|101|octocat|OPEN|watch-issues-first|https://github.com/octo/example/issues/101'
else
  printf ''
fi
EOF
chmod +x "$stub_dir/gh"

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session" ATMUX_AGENT_NAME "watcher"
tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "missing watcher pane" >&2; exit 1; }

watchers_dir="$atmux_home/watch-issues/octo_example_issues/watchers"

tmux send-keys -t "$pane" \
  "ATMUX_HOME=\"$atmux_home\" ATMUX_GH_BIN=\"$stub_dir/gh\" ATMUX_TEST_ISSUES_TRIGGER=\"$trigger_file\" ATMUX_TEST_ISSUES_SECOND_TRIGGER=\"$second_trigger_file\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watcher\" ATMUX_SESSION_NAME=\"$session\" \"$ATMUX_BIN\" issue watch --feed \"https://github.com/octo/example/issues\" --interval 0.2 --timeout 12" \
  C-m

if ! wait_for_text "$pane" '<watch type="issues"' 10; then
  echo "issue watch --feed did not register" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_absence "$pane" 'watch-issues-first' 1; then
  echo "issue notification appeared before repo issues changed" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 10 ))
while [[ ! -f "$snapshot_file" ]] || grep -Fq 'watch-issues-first' "$snapshot_file" 2>/dev/null; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --issues never completed its baseline snapshot" >&2
    tmux capture-pane -p -t "$pane" -S -200 >&2 || true
    exit 1
  fi
  sleep 0.05
done

deadline=$(( $(date +%s) + 10 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -ge 1 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --issues did not leave an active watcher registration" >&2
    exit 1
  fi
  sleep 0.1
done

touch "$trigger_file"

if ! wait_for_text "$pane" 'type="issue"' 15; then
  echo "watch --issues did not deliver a notification" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'octocat' 15; then
  echo "watch --issues notification missing author details" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'watch-issues-first' 15; then
  echo "watch --issues notification missing issue title snippet" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

touch "$second_trigger_file"

if ! wait_for_text "$pane" 'watch-issues-second' 15; then
  echo "watch --issues did not continue watching for later issues" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 12 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -eq 0 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --issues did not expire after timeout" >&2
    exit 1
  fi
  sleep 0.1
done

echo "ok: watch --issues notifies on new GitHub issues"
