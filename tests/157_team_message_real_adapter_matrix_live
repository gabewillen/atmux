#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"
CONTROL_FILES=(CLAUDE.md GEMINI.md)
CONTROL_SNAPSHOT=""

snapshot_control_files() {
  local file
  CONTROL_SNAPSHOT="$(mktemp -d "${TMPDIR:-/tmp}/atmux-control-files.XXXXXX")"
  for file in "${CONTROL_FILES[@]}"; do
    if [[ -e "$REPO_ROOT/$file" ]]; then
      cp "$REPO_ROOT/$file" "$CONTROL_SNAPSHOT/$file"
    else
      touch "$CONTROL_SNAPSHOT/$file.missing"
    fi
  done
}

restore_control_files() {
  local file
  [[ -n "$CONTROL_SNAPSHOT" ]] || return 0
  for file in "${CONTROL_FILES[@]}"; do
    if [[ -f "$CONTROL_SNAPSHOT/$file.missing" ]]; then
      rm -f "$REPO_ROOT/$file"
    elif [[ -f "$CONTROL_SNAPSHOT/$file" ]]; then
      cp "$CONTROL_SNAPSHOT/$file" "$REPO_ROOT/$file"
    fi
  done
  rm -rf "$CONTROL_SNAPSHOT"
}

require_adapter_command() {
  local adapter="$1"
  case "$adapter" in
    codex) command -v codex >/dev/null 2>&1 ;;
    claude-code) command -v claude >/dev/null 2>&1 ;;
    gemini) command -v gemini >/dev/null 2>&1 ;;
    cursor-agent) command -v agent >/dev/null 2>&1 || command -v cursor-agent >/dev/null 2>&1 ;;
    *) return 1 ;;
  esac
}

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-30}"
  local deadline now snap
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -2200 2>/dev/null | tr -d '\r' || true)"
    if printf '%s' "$snap" | grep -Fq -- "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

wait_for_adapter_ready() {
  local pane="$1"
  local adapter="$2"
  case "$adapter" in
    codex)
      wait_for_text "$pane" 'OpenAI Codex' 90
      ;;
    claude-code)
      wait_for_text "$pane" 'Claude Code v' 90
      ;;
    gemini)
      wait_for_text "$pane" 'Type your message' 120
      ;;
    cursor-agent)
      wait_for_text "$pane" 'Cursor Agent' 120
      ;;
    *)
      echo "unknown adapter: $adapter" >&2
      exit 2
      ;;
  esac
}

session_pane() {
  local session="$1"
  tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1
}

extract_xml_attr() {
  local attr="$1"
  sed -n "s/.*${attr}=\"\\([^\"]*\\)\".*/\\1/p" | head -n1
}

run_adapter_case() {
  local adapter="$1"
  local label="${adapter//[^A-Za-z0-9]/-}"
  local repo="teammsg-live-${label}-${RANDOM}"
  local team="teammsg${RANDOM}"
  local atmux_home team_session member_session member_pane send_out message_id

  echo "--- $adapter ---" >&2

  if ! require_adapter_command "$adapter"; then
    echo "missing real adapter command for $adapter" >&2
    exit 1
  fi

  atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-team-message-live-${label}.XXXXXX")"
  TMP_DIRS+=("$atmux_home")

  team_session="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
    "$ATMUX_BIN" team create "$team" --shared-worktree)"
  [[ -n "$team_session" ]] || { echo "failed to create team for $adapter" >&2; exit 1; }
  SESSIONS+=("$team_session")

  member_session="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
    ATMUX_AGENT_NAME="manager" ATMUX_SESSION_NAME="atmux-${repo}-manager" \
    "$ATMUX_BIN" agent create member --team "$team" --role implementer --adapter "$adapter" --intelligence 50 --shared-worktree)"
  member_session="$(printf '%s\n' "$member_session" | extract_xml_attr session)"
  [[ -n "$member_session" ]] || { echo "failed to parse member session for $adapter" >&2; exit 1; }
  SESSIONS+=("$member_session")

  member_pane="$(session_pane "$member_session")"
  [[ -n "$member_pane" ]] || { echo "missing member pane for $adapter" >&2; exit 1; }
  if ! wait_for_adapter_ready "$member_pane" "$adapter"; then
    echo "member did not become ready for $adapter" >&2
    tmux capture-pane -p -t "$member_pane" -S -240 >&2 || true
    exit 1
  fi

  send_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
    ATMUX_AGENT_NAME="manager" ATMUX_SESSION_NAME="atmux-${repo}-manager" \
    "$ATMUX_BIN" send --to "$team" "live team message ${adapter} ${RANDOM}")"
  message_id="$(printf '%s\n' "$send_out" | extract_xml_attr message_id)"
  [[ -n "$message_id" ]] || {
    echo "failed to parse team message id for $adapter" >&2
    printf '%s\n' "$send_out" >&2
    exit 1
  }

  if ! wait_for_text "$member_pane" '<notification type="team_message"' 45; then
    echo "member did not receive team_message notification for $adapter" >&2
    tmux capture-pane -p -t "$member_pane" -S -260 >&2 || true
    exit 1
  fi
  if ! wait_for_text "$member_pane" "$message_id" 10 \
     || ! wait_for_text "$member_pane" "--team $team" 10 \
     || ! wait_for_text "$member_pane" "--repo $repo" 10; then
    echo "team_message notification missing team-scoped read hint for $adapter" >&2
    tmux capture-pane -p -t "$member_pane" -S -260 >&2 || true
    exit 1
  fi

  ATMUX_ALLOW_OUTSIDE_TMUX=1 ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" ATMUX_REPO="$repo" \
    "$ATMUX_BIN" team kill "$team" >/dev/null 2>&1 || true
}

TMP_DIRS=()
SESSIONS=()

cleanup() {
  local session tmp_dir
  for session in "${SESSIONS[@]:-}"; do
    [[ -n "$session" ]] || continue
    tmux kill-session -t "$session" >/dev/null 2>&1 || true
  done
  for tmp_dir in "${TMP_DIRS[@]:-}"; do
    [[ -n "$tmp_dir" ]] || continue
    rm -rf "$tmp_dir"
  done
  rm -rf "$REPO_ROOT/.gemini"
  restore_control_files
}
trap cleanup EXIT

snapshot_control_files

for adapter in ${ATMUX_TEST_ADAPTERS:-codex claude-code gemini cursor-agent}; do
  run_adapter_case "$adapter"
done

echo "ok: live adapters receive team_message notifications with team read hints"
