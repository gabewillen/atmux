#!/usr/bin/env bash
set -euo pipefail

# Verifies the `prepare-prompt` adapter contract introduced in 0.11.0:
#   - claude-code  → adds null-separated --append-system-prompt <text> args.
#   - codex        → adds --config developer_instructions=<TOML-quoted-text>.
#   - gemini       → writes sidecar under $ATMUX_HOME, emits GEMINI_SYSTEM_MD env.
#   - cursor-agent → writes <worktree>/.cursor/rules/atmux.mdc, no args/env.
#   - opencode     → sidecar JSON under $ATMUX_HOME + OPENCODE_CONFIG env.
#   - none of them touch <worktree>/{AGENTS,CLAUDE,GEMINI}.md.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-prep-test.XXXXXX")"
cleanup() { rm -rf "$tmp_root"; }
trap cleanup EXIT

# Sample atmux content with characters that exercise TOML escaping
# (backslash, double quote, newlines).
read -r -d '' SAMPLE <<'EOF' || true
<atmux>
# Role
- ROLE: tester
- raw "quoted" text and a backslash\here
multi
line
content
</atmux>
EOF

assert_no_pollution() {
  local worktree="$1"
  for f in AGENTS.md CLAUDE.md GEMINI.md; do
    if [[ -e "$worktree/$f" ]]; then
      echo "fail: prepare-prompt should not touch $worktree/$f" >&2
      exit 1
    fi
  done
}

# Bash 3.2 (macOS default) lacks `declare -g`, so each test section reads
# the null-separated args inline into a local array.

# === claude-code ============================================================
worktree="$tmp_root/cc-wt"
mkdir -p "$worktree"
args="$tmp_root/cc.args"; envf="$tmp_root/cc.env"
: > "$args"; : > "$envf"
printf '%s' "$SAMPLE" \
  | ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$args" ATMUX_PREP_ENV_FILE="$envf" \
    "$REPO_ROOT/adapter/claude-code/scripts/prepare-prompt"

cc_args=()
while IFS= read -r -d '' a; do cc_args+=("$a"); done < "$args"
[[ "${#cc_args[@]}" -eq 2 ]] \
  || { echo "fail: claude args count=${#cc_args[@]} (want 2)" >&2; exit 1; }
[[ "${cc_args[0]}" == "--append-system-prompt" ]] \
  || { echo "fail: claude arg[0]='${cc_args[0]}' (want --append-system-prompt)" >&2; exit 1; }
[[ "${cc_args[1]}" == *'"quoted"'* && "${cc_args[1]}" == *'backslash\here'* ]] \
  || { echo "fail: claude arg[1] missing literal text; got: ${cc_args[1]}" >&2; exit 1; }
[[ ! -s "$envf" ]] \
  || { echo "fail: claude should not emit env directives, got: $(cat "$envf")" >&2; exit 1; }
assert_no_pollution "$worktree"

# === codex ==================================================================
worktree="$tmp_root/cx-wt"
mkdir -p "$worktree"
args="$tmp_root/cx.args"; envf="$tmp_root/cx.env"
: > "$args"; : > "$envf"
printf '%s' "$SAMPLE" \
  | ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$args" ATMUX_PREP_ENV_FILE="$envf" \
    "$REPO_ROOT/adapter/codex/scripts/prepare-prompt"

cx_args=()
while IFS= read -r -d '' a; do cx_args+=("$a"); done < "$args"
[[ "${#cx_args[@]}" -eq 2 ]] \
  || { echo "fail: codex args count=${#cx_args[@]} (want 2)" >&2; exit 1; }
[[ "${cx_args[0]}" == "--config" ]] \
  || { echo "fail: codex arg[0]='${cx_args[0]}' (want --config)" >&2; exit 1; }
[[ "${cx_args[1]}" == 'developer_instructions="'*'"' ]] \
  || { echo "fail: codex arg[1] not TOML-quoted developer_instructions=...; got: ${cx_args[1]}" >&2; exit 1; }
# TOML escapes: backslash -> \\, quote -> \", newline -> \n
[[ "${cx_args[1]}" == *'\\here'* ]] \
  || { echo "fail: codex arg[1] missing escaped backslash; got: ${cx_args[1]}" >&2; exit 1; }
[[ "${cx_args[1]}" == *'\"quoted\"'* ]] \
  || { echo "fail: codex arg[1] missing escaped double-quote; got: ${cx_args[1]}" >&2; exit 1; }
[[ "${cx_args[1]}" == *'\n'* ]] \
  || { echo "fail: codex arg[1] missing escaped newline; got: ${cx_args[1]}" >&2; exit 1; }
[[ ! -s "$envf" ]] \
  || { echo "fail: codex should not emit env directives, got: $(cat "$envf")" >&2; exit 1; }
assert_no_pollution "$worktree"

# === gemini =================================================================
worktree="$tmp_root/gm-wt"
mkdir -p "$worktree"
gm_home="$tmp_root/gm-home"
args="$tmp_root/gm.args"; envf="$tmp_root/gm.env"
: > "$args"; : > "$envf"
printf '%s' "$SAMPLE" \
  | ATMUX_HOME="$gm_home" ATMUX_REPO=demo ATMUX_AGENT_NAME=worker \
    ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$args" ATMUX_PREP_ENV_FILE="$envf" \
    "$REPO_ROOT/adapter/gemini/scripts/prepare-prompt"

[[ ! -s "$args" ]] \
  || { echo "fail: gemini should not emit args; got: $(xxd "$args")" >&2; exit 1; }
expected_path="$gm_home/state/agents/demo/worker/gemini-system.md"
grep -Fxq "GEMINI_SYSTEM_MD=$expected_path" "$envf" \
  || { echo "fail: gemini env missing GEMINI_SYSTEM_MD=$expected_path; got: $(cat "$envf")" >&2; exit 1; }
[[ -f "$expected_path" ]] \
  || { echo "fail: gemini sidecar not written at $expected_path" >&2; exit 1; }
grep -Fq 'ROLE: tester' "$expected_path" \
  || { echo "fail: gemini sidecar missing role content" >&2; exit 1; }
assert_no_pollution "$worktree"

# === cursor-agent ===========================================================
worktree="$tmp_root/cu-wt"
mkdir -p "$worktree"
args="$tmp_root/cu.args"; envf="$tmp_root/cu.env"
: > "$args"; : > "$envf"
printf '%s' "$SAMPLE" \
  | ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$args" ATMUX_PREP_ENV_FILE="$envf" \
    "$REPO_ROOT/adapter/cursor-agent/scripts/prepare-prompt"

[[ ! -s "$args" ]] \
  || { echo "fail: cursor should not emit args; got: $(xxd "$args")" >&2; exit 1; }
[[ ! -s "$envf" ]] \
  || { echo "fail: cursor should not emit env directives; got: $(cat "$envf")" >&2; exit 1; }
sidecar="$worktree/.cursor/rules/atmux.mdc"
[[ -f "$sidecar" ]] \
  || { echo "fail: cursor sidecar not written at $sidecar" >&2; exit 1; }
grep -Fq 'alwaysApply: true' "$sidecar" \
  || { echo "fail: cursor sidecar missing alwaysApply frontmatter" >&2; exit 1; }
grep -Fq 'ROLE: tester' "$sidecar" \
  || { echo "fail: cursor sidecar missing role content" >&2; exit 1; }
assert_no_pollution "$worktree"

# === opencode ===============================================================
worktree="$tmp_root/oc-wt"
mkdir -p "$worktree"
oc_home="$tmp_root/oc-home"
args="$tmp_root/oc.args"; envf="$tmp_root/oc.env"
: > "$args"; : > "$envf"
printf '%s' "$SAMPLE" \
  | ATMUX_HOME="$oc_home" ATMUX_REPO=demo ATMUX_AGENT_NAME=worker \
    ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$args" ATMUX_PREP_ENV_FILE="$envf" \
    "$REPO_ROOT/adapter/opencode/scripts/prepare-prompt"

[[ ! -s "$args" ]] \
  || { echo "fail: opencode should not emit argv pairs; got: $(xxd "$args")" >&2; exit 1; }
line="$(grep '^OPENCODE_CONFIG=' "$envf" | tail -n 1)"
[[ -n "$line" ]] || { echo "fail: opencode env missing OPENCODE_CONFIG; got: $(cat "$envf")" >&2; exit 1; }
cfg="${line#OPENCODE_CONFIG=}"
[[ -f "$cfg" ]] || { echo "fail: opencode config missing at $cfg" >&2; exit 1; }
inst_dir="$oc_home/state/agents/demo/worker"
expected_md="$(cd "$inst_dir" && pwd)/opencode-atmux-instructions.md"
python3 -c "import json,sys; c=json.load(open(sys.argv[1])); assert c.get('instructions')==[sys.argv[2]]" "$cfg" "$expected_md" \
  || { echo "fail: opencode config instructions path mismatch" >&2; exit 1; }
[[ -f "$expected_md" ]] || { echo "fail: opencode instructions sidecar missing" >&2; exit 1; }
grep -Fq 'ROLE: tester' "$expected_md" \
  || { echo "fail: opencode sidecar missing role content" >&2; exit 1; }
assert_no_pollution "$worktree"

# === opencode JSON via shell fallback when python3 is missing/unusable =====
worktree="$tmp_root/oc-shell-wt"
mkdir -p "$worktree"
oc_home="$tmp_root/oc-shell-home"
fake_py_bin="$tmp_root/oc-shell-fake-bin"
mkdir -p "$fake_py_bin"
printf '%s\n' '#!/bin/sh' 'exit 1' > "$fake_py_bin/python3"
chmod +x "$fake_py_bin/python3"
args="$tmp_root/oc-shell.args"
envf="$tmp_root/oc-shell.env"
: > "$args"
: > "$envf"
printf '%s' "$SAMPLE" \
  | PATH="$fake_py_bin:/bin:/usr/bin:/usr/local/bin" \
    ATMUX_HOME="$oc_home" ATMUX_REPO=demo ATMUX_AGENT_NAME=worker \
    ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$args" ATMUX_PREP_ENV_FILE="$envf" \
    "$REPO_ROOT/adapter/opencode/scripts/prepare-prompt"

[[ ! -s "$args" ]] \
  || { echo "fail: opencode shell-fallback should not emit argv pairs; got: $(xxd "$args")" >&2; exit 1; }
line="$(grep '^OPENCODE_CONFIG=' "$envf" | tail -n 1)"
[[ -n "$line" ]] || { echo "fail: opencode shell-fallback env missing OPENCODE_CONFIG; got: $(cat "$envf")" >&2; exit 1; }
cfg="${line#OPENCODE_CONFIG=}"
[[ -f "$cfg" ]] || { echo "fail: opencode shell-fallback config missing at $cfg" >&2; exit 1; }
inst_dir="$oc_home/state/agents/demo/worker"
expected_md="$(cd "$inst_dir" && pwd)/opencode-atmux-instructions.md"
PATH="/usr/bin:/bin:/usr/local/bin:${PATH:-}" python3 -c "import json,sys; c=json.load(open(sys.argv[1])); assert c.get('instructions')==[sys.argv[2]]" "$cfg" "$expected_md" \
  || { echo "fail: opencode shell-fallback config instructions path mismatch" >&2; exit 1; }
[[ -f "$expected_md" ]] || { echo "fail: opencode shell-fallback instructions sidecar missing" >&2; exit 1; }
grep -Fq 'ROLE: tester' "$expected_md" \
  || { echo "fail: opencode shell-fallback sidecar missing role content" >&2; exit 1; }
assert_no_pollution "$worktree"

# === empty stdin: no-op for every adapter ===================================
for adapter in claude-code codex gemini cursor-agent opencode; do
  noop_args="$tmp_root/${adapter}.noop.args"
  noop_env="$tmp_root/${adapter}.noop.env"
  : > "$noop_args"; : > "$noop_env"
  : | ATMUX_HOME="$tmp_root/noop-home" ATMUX_REPO=r ATMUX_AGENT_NAME=a \
        ATMUX_WORKTREE="$tmp_root/noop-${adapter}-wt" \
        ATMUX_PREP_ARGS_FILE="$noop_args" ATMUX_PREP_ENV_FILE="$noop_env" \
        "$REPO_ROOT/adapter/$adapter/scripts/prepare-prompt"
  [[ ! -s "$noop_args" && ! -s "$noop_env" ]] \
    || { echo "fail: $adapter wrote prep output for empty stdin" >&2; exit 1; }
done

# === auto adapter delegates to ATMUX_ADAPTER_SELECTED =======================
# Verifies the auto/scripts/prepare-prompt path actually execs the selected
# adapter's prepare-prompt with the same env. We pick claude-code because
# its output (a single null-separated --append-system-prompt arg pair) is
# the easiest to assert byte-for-byte.
worktree="$tmp_root/auto-wt"
mkdir -p "$worktree"
auto_args="$tmp_root/auto.args"; auto_env="$tmp_root/auto.env"
direct_args="$tmp_root/auto.direct.args"; direct_env="$tmp_root/auto.direct.env"
: > "$auto_args"; : > "$auto_env"
: > "$direct_args"; : > "$direct_env"

printf '%s' "$SAMPLE" \
  | ATMUX_ADAPTER_SELECTED=claude-code \
    ATMUX_SOURCE_ROOT="$REPO_ROOT" \
    ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$auto_args" ATMUX_PREP_ENV_FILE="$auto_env" \
    "$REPO_ROOT/adapter/auto/scripts/prepare-prompt"

printf '%s' "$SAMPLE" \
  | ATMUX_WORKTREE="$worktree" \
    ATMUX_PREP_ARGS_FILE="$direct_args" ATMUX_PREP_ENV_FILE="$direct_env" \
    "$REPO_ROOT/adapter/claude-code/scripts/prepare-prompt"

cmp "$auto_args" "$direct_args" \
  || { echo "fail: auto delegation produced different args than direct claude-code" >&2; xxd "$auto_args" >&2; echo "---" >&2; xxd "$direct_args" >&2; exit 1; }
cmp "$auto_env" "$direct_env" \
  || { echo "fail: auto delegation produced different env than direct claude-code" >&2; cat "$auto_env" >&2; echo "---" >&2; cat "$direct_env" >&2; exit 1; }
assert_no_pollution "$worktree"

# When no adapter is selected and select fails (no ATMUX_ADAPTER_SELECTED,
# no tmux sessions), auto's prepare-prompt should silently no-op (exit 0
# with no output) rather than erroring.
no_sel_args="$tmp_root/auto.nosel.args"
no_sel_env="$tmp_root/auto.nosel.env"
: > "$no_sel_args"; : > "$no_sel_env"
printf '%s' "$SAMPLE" \
  | ATMUX_HOME="$tmp_root/auto-empty-home" \
    ATMUX_SOURCE_ROOT="$tmp_root/no-such-source-root" \
    ATMUX_PREP_ARGS_FILE="$no_sel_args" ATMUX_PREP_ENV_FILE="$no_sel_env" \
    "$REPO_ROOT/adapter/auto/scripts/prepare-prompt" || true
[[ ! -s "$no_sel_args" && ! -s "$no_sel_env" ]] \
  || { echo "fail: auto with no resolvable adapter should produce no prep output" >&2; exit 1; }

echo "ok: prepare-prompt contract holds for all five first-party adapters (and auto delegates correctly) and never touches AGENTS.md/CLAUDE.md/GEMINI.md"
