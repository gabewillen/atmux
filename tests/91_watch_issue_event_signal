#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-issue-event.XXXXXX")"
repo_name="ie${RANDOM}"
atmux_home="$tmp_home/.atmux"
rc_file="$tmp_home/watch.rc"

cleanup() {
  if [[ -n "${watch_pid:-}" ]] && kill -0 "$watch_pid" >/dev/null 2>&1; then
    kill "$watch_pid" >/dev/null 2>&1 || true
    wait "$watch_pid" >/dev/null 2>&1 || true
  fi
  rm -rf "$tmp_home"
}
trap cleanup EXIT

create_out="$(ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" issue create --title "event-test" --repo "$repo_name")"
issue_id="$(printf '%s\n' "$create_out" | sed -n 's/.*id="\([^"]*\)".*/\1/p')"
[[ -n "$issue_id" ]] || { echo "failed to parse issue id" >&2; exit 1; }

(
  set +e
  ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
    "$ATMUX_BIN" watch --issue "$issue_id" --repo "$repo_name" --interval 999 --timeout 30
  printf '%s\n' "$?" > "$rc_file"
) &
watch_pid=$!

sleep 0.2
ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
  "$ATMUX_BIN" issue claim "$issue_id" --repo "$repo_name" --by worker >/dev/null

deadline=$(( $(date +%s) + 5 ))
while kill -0 "$watch_pid" >/dev/null 2>&1; do
  if (( $(date +%s) >= deadline )); then
    echo "watch --issue did not wake from issue event" >&2
    exit 1
  fi
  sleep 0.1
done
wait "$watch_pid" || true

watch_rc="$(tr -d '\r\n' < "$rc_file" 2>/dev/null || true)"
[[ "$watch_rc" == "0" ]] || { echo "expected watch rc 0, got ${watch_rc:-missing}" >&2; exit 1; }

echo "ok: watch --issue wakes from issue event without polling interval"
