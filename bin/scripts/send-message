#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  send-message --to agent:<name> --type <type> --text "..."
USAGE
}

to=""
msg_type="status"
text=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --to)
      to="${2:-}"
      shift 2
      ;;
    --type)
      msg_type="${2:-}"
      shift 2
      ;;
    --text)
      text="${2:-}"
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown flag: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "$to" || -z "$text" ]]; then
  usage >&2
  exit 2
fi

repo="${AMUX_REPO:-}"
if [[ -z "$repo" ]]; then
  echo "AMUX_REPO is required" >&2
  exit 1
fi

session="amux-${repo}"
ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

case "$to" in
  agent:*)
    name="${to#agent:}"
    target_window="amux-${repo}-agent-${name}"
    target="${session}:${target_window}"
    ;;
  *)
    echo "invalid --to: $to" >&2
    exit 2
    ;;
esac

msg="[MSG][type:${msg_type}][ts:${ts}] ${text}"
tmux send-keys -t "$target" "echo '$msg'" C-m
