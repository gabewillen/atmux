#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

eval "$("$SCRIPTS_DIR/setup")"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"" EXIT

marker1="team-capture-a-$RANDOM"
marker2="team-capture-b-$RANDOM"

tmux send-keys -t "${AGENT1_SESSION}:0.0" "$marker1" C-m
tmux send-keys -t "${AGENT2_SESSION}:0.0" "$marker2" C-m
sleep 0.2

out="$(ATMUX_REPO="$REPO_NAME" "$ATMUX_BIN" team capture "$TEAM_NAME" --lines 120)"

printf '%s\n' "$out" | grep -Fq "<captures scope=\"team\" team=\"$TEAM_NAME\" session=\"$TEAM_SESSION\">"
printf '%s\n' "$out" | grep -Fq "$marker1"
printf '%s\n' "$out" | grep -Fq "$marker2"

capture_count="$(printf '%s\n' "$out" | grep -c "<capture ")"
if ! [[ "$capture_count" =~ ^[0-9]+$ ]] || (( capture_count < 2 )); then
  echo "expected at least 2 capture nodes for team, got: ${capture_count:-0}" >&2
  printf '%s\n' "$out" >&2
  exit 1
fi

tiled="$(ATMUX_REPO="$REPO_NAME" "$ATMUX_BIN" team capture "$TEAM_NAME" --tiled --lines 120)"

printf '%s\n' "$tiled" | grep -Fq "<captures scope=\"team-view\" team=\"$TEAM_NAME\" session=\"$TEAM_SESSION\" layout=\"tiled\">"
printf '%s\n' "$tiled" | grep -Fq "$marker1"
printf '%s\n' "$tiled" | grep -Fq "$marker2"

tiled_capture_count="$(printf '%s\n' "$tiled" | grep -c "<capture ")"
if [[ "$tiled_capture_count" != "1" ]]; then
  echo "expected one tiled capture node, got: ${tiled_capture_count:-0}" >&2
  printf '%s\n' "$tiled" >&2
  exit 1
fi
if printf '%s\n' "$tiled" | grep -Fq 'lines="120"'; then
  echo "expected tiled capture lines to describe visible view height, not requested scrollback" >&2
  printf '%s\n' "$tiled" >&2
  exit 1
fi

if ! tmux has-session -t "$TEAM_SESSION" 2>/dev/null; then
  echo "expected tiled capture to create team view session: $TEAM_SESSION" >&2
  printf '%s\n' "$tiled" >&2
  exit 1
fi

echo "ok: team capture includes both members; tiled capture composes both markers"
