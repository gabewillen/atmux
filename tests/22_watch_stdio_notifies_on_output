#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-stdio.XXXXXX")"
repo_name="s${RANDOM}"
session_exec="atmux-${repo_name}-executor"
session_watch="atmux-${repo_name}-watcher"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"

cleanup() {
  tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true
  # Notify-queue workers run as separate processes and can keep writing
  # to $atmux_home/notify-queue/*/payloads after the tmux sessions die,
  # which races `rm -rf` and trips "Directory not empty". Kill them first.
  if [[ -d "$atmux_home/notify-queue" ]]; then
    while IFS= read -r -d '' pid_file; do
      local pid
      pid="$(tr -d '\r\n' < "$pid_file" 2>/dev/null || true)"
      [[ -n "$pid" ]] && kill "$pid" 2>/dev/null || true
    done < <(find "$atmux_home/notify-queue" -name worker.pid -print0 2>/dev/null)
    local deadline alive
    deadline=$(( $(date +%s) + 3 ))
    while (( $(date +%s) < deadline )); do
      alive=0
      while IFS= read -r -d '' pid_file; do
        local pid
        pid="$(tr -d '\r\n' < "$pid_file" 2>/dev/null || true)"
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
          alive=1
          break
        fi
      done < <(find "$atmux_home/notify-queue" -name worker.pid -print0 2>/dev/null)
      (( alive == 0 )) && break
      sleep 0.1
    done
  fi
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true

tmux new-session -d -s "$session_exec" -n "$session_exec" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux new-session -d -s "$session_watch" -n "$session_watch" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

pane_exec="$(tmux list-panes -t "$session_exec" -F '#{pane_id}' 2>/dev/null | head -n1)"
pane_watch="$(tmux list-panes -t "$session_watch" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_exec" && -n "$pane_watch" ]] || { echo "missing panes" >&2; exit 1; }

# Start a detached exec that produces output in waves (delay gives watcher time to start)
marker1="wave1-$RANDOM"
marker2="wave2-$RANDOM"
tmux send-keys -t "$pane_exec" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"executor\" ATMUX_SESSION_NAME=\"$session_exec\" \"$ATMUX_BIN\" exec --detach -- bash -lc 'sleep 4; echo $marker1; sleep 4; echo $marker2; sleep 1'" C-m

# Wait for exec metadata — read the real PID from the pid file (not the dir name)
deadline=$(( $(date +%s) + 10 ))
pid=""
exec_entry=""
while [[ -z "$pid" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    for ep_dir in "$exec_root"/detach-*; do
      if [[ -d "$ep_dir" && -f "$ep_dir/pid" ]]; then
        candidate="$(tr -d '\r\n' <"$ep_dir/pid")"
        # Wait for _run to write the real PID (not the detach placeholder)
        if [[ -n "$candidate" && "$candidate" != detach-* ]]; then
          pid="$candidate"
          exec_entry="$ep_dir"
          break
        fi
      fi
    done
  fi
  sleep 0.05
done

# Start stdio watcher on watcher session
tmux send-keys -t "$pane_watch" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watcher\" ATMUX_SESSION_NAME=\"$session_watch\" \"$ATMUX_BIN\" process watch \"$pid\" --stdio --duration 30 --timeout 15 --interval 1" C-m

# Wait for watcher to register
deadline=$(( $(date +%s) + 10 ))
while true; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for watcher registration" >&2
    tmux capture-pane -p -t "$pane_watch" -S -80 >&2 || true
    exit 1
  fi
  wdir="$exec_root/$pid/watchers"
  wn=0
  if [[ -d "$wdir" ]]; then
    wn="$(find "$wdir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wn:-0}" -ge 1 ]]; then
    break
  fi
  sleep 0.05
done

# Wait for first output notification at watcher pane
if ! wait_for_text "$pane_watch" 'type="exec_output"' 20; then
  echo "watcher did not receive exec_output notification" >&2
  tmux capture-pane -p -t "$pane_watch" -S -200 >&2 || true
  exit 1
fi

# Verify the notification includes pid and pane attributes
snap="$(tmux capture-pane -p -t "$pane_watch" -S -400 2>/dev/null || true)"
compact="$(printf '%s' "$snap" | tr -d '\r\n')"

if ! printf '%s' "$compact" | grep -Fq "pid=\"$pid\""; then
  echo "exec_output notification missing pid attribute" >&2
  exit 1
fi

if ! printf '%s' "$compact" | grep -Fq 'pane="'; then
  echo "exec_output notification missing pane attribute" >&2
  exit 1
fi

# Wait for process to exit and watcher to clean up
deadline=$(( $(date +%s) + 30 ))
while true; do
  st="$(tr -d '\r\n' < "$exec_entry/state" 2>/dev/null || true)"
  [[ "$st" != "exited" ]] || break
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for process to exit" >&2
    exit 1
  fi
  sleep 0.5
done

# Watcher should have cleaned up after process exited
sleep 1
wcount="$(find "$exec_entry/watchers" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
[[ "${wcount:-0}" -eq 0 ]] || { echo "expected no watcher files left, found $wcount" >&2; exit 1; }

echo "ok: watch --stdio sends exec_output notifications and cleans up"
