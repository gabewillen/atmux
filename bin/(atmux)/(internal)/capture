#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify  # accessed via $HERE/../notify
source "$HERE/../notify"

usage() {
  cat <<'USAGE'
Internal capture backend. Invoked by the noun-first front-ends:

  atmux agent capture <name|session> [--lines <n>]
  atmux agent capture --all [--lines <n>]
  atmux team capture <name|session> [--tiled] [--lines <n>]

Direct invocation (--agent, --team, --all) is for internal callers only and
is not part of the user-facing CLI surface.
USAGE
}

capture_session_panes() {
  local session="$1"
  local lines="$2"
  local extra_attrs="${3:-}"
  local pane snapshot
  while IFS= read -r pane; do
    [[ -z "$pane" ]] && continue
    snapshot="$(tmux capture-pane -p -t "$pane" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    printf '  <capture session="%s" pane="%s" lines="%s"%s>%s</capture>\n' \
      "$(xml_escape "$session")" \
      "$(xml_escape "$pane")" \
      "$(xml_escape "$lines")" \
      "$extra_attrs" \
      "$snapshot"
  done < <(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null || true)
}

capture_team_view_render() {
  local session="$1"
  local target="${2:-${session}:0}"
  local pane left top width height agent_session agent_name format
  format=$'#{pane_id}\t#{pane_left}\t#{pane_top}\t#{pane_width}\t#{pane_height}\t#{@atmux_agent_session}\t#{@atmux_agent_name}'
  {
    while IFS=$'\t' read -r pane left top width height agent_session agent_name; do
      [[ -z "$pane" ]] && continue
      printf '\034%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$pane" "$left" "$top" "$width" "$height" "$agent_session" "$agent_name"
      tmux capture-pane -p -t "$pane" 2>/dev/null | tr -d '\r' || true
    done < <(tmux list-panes -t "$target" -F "$format" 2>/dev/null || true)
  } | awk -v sep="$(printf '\034')" '
    function blank(n, out) {
      out = ""
      while (length(out) < n) out = out " "
      return out
    }
    function fit(s, n) {
      s = substr(s, 1, n)
      return s blank(n - length(s))
    }
    function flush_pane(    r, y, src, row, line) {
      if (!active) return
      if (left + width > canvas_width) canvas_width = left + width
      if (top + height > canvas_height) canvas_height = top + height
      pane_count++
      pane_left[pane_count] = left
      pane_top[pane_count] = top
      pane_width[pane_count] = width
      pane_height[pane_count] = height
      pane_lines[pane_count] = line_count
      for (r = 1; r <= line_count; r++) {
        pane_text[pane_count, r] = line_buf[r]
      }
      line_count = 0
    }
    substr($0, 1, 1) == sep {
      flush_pane()
      split(substr($0, 2), f, "\t")
      left = f[2] + 0
      top = f[3] + 0
      width = f[4] + 0
      height = f[5] + 0
      active = 1
      next
    }
    {
      if (active) {
        line_count++
        line_buf[line_count] = $0
      }
    }
    END {
      flush_pane()
      for (y = 1; y <= canvas_height; y++) {
        canvas[y] = blank(canvas_width)
      }
      for (p = 1; p <= pane_count; p++) {
        left = pane_left[p]
        top = pane_top[p]
        width = pane_width[p]
        height = pane_height[p]
        line_count = pane_lines[p]
        for (r = 1; r <= height; r++) {
          src = line_count - height + r
          line = (src >= 1 ? pane_text[p, src] : "")
          line = fit(line, width)
          y = top + r
          row = canvas[y]
          canvas[y] = substr(row, 1, left) line substr(row, left + width + 1)
        }
      }
      for (y = 1; y <= canvas_height; y++) print canvas[y]
    }
  '
}

capture_team_view_render_all() {
  local session="$1"
  local window_id window_index window_name rendered first=1
  while IFS=$'\t' read -r window_id window_index window_name; do
    [[ -n "$window_id" ]] || continue
    rendered="$(capture_team_view_render "$session" "$window_id")"
    if (( first == 0 )); then
      printf '\n'
    fi
    printf '[window %s: %s]\n' "$window_index" "$window_name"
    printf '%s\n' "$rendered"
    first=0
  done < <(tmux list-windows -t "$session" -F $'#{window_id}\t#{window_index}\t#{window_name}' 2>/dev/null || true)
}

wait_team_view_render_ready() {
  local session="$1"
  local repo_name="$2"
  local team_name="$3"
  local expected_count pane_count attempts ready pane agent_session source_nonblank view_nonblank
  expected_count="$(team_member_sessions_from_state "$repo_name" "$team_name" | sed '/^$/d' | wc -l | tr -d '[:space:]')"
  [[ "$expected_count" =~ ^[0-9]+$ ]] || expected_count=0
  (( expected_count > 0 )) || return 0

  attempts=0
  while (( attempts < 40 )); do
    ready=1
    pane_count=0
    while IFS=$'\t' read -r pane agent_session; do
      [[ -n "$pane" ]] || continue
      if [[ -z "$agent_session" ]]; then
        ready=0
        continue
      fi
      pane_count=$((pane_count + 1))
      source_nonblank="$(tmux capture-pane -p -t "$agent_session" 2>/dev/null | tr -d '\r' | sed '/^[[:space:]]*$/d' | head -n1 || true)"
      if [[ -n "$source_nonblank" ]]; then
        view_nonblank="$(tmux capture-pane -p -t "$pane" 2>/dev/null | tr -d '\r' | sed '/^[[:space:]]*$/d' | head -n1 || true)"
        [[ -n "$view_nonblank" ]] || ready=0
      fi
    done < <(tmux list-panes -a -F $'#{session_name}\t#{pane_id}\t#{@atmux_agent_session}' 2>/dev/null \
      | awk -F '\t' -v s="$session" '$1 == s { print $2 "\t" $3 }')
    if (( pane_count >= expected_count && ready == 1 )); then
      return 0
    fi
    sleep 0.05
    attempts=$((attempts + 1))
  done
}

agent_target=""
team_target=""
capture_all=0
team_tiled=0
lines="200"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent)
      agent_target="${2:-}"
      shift 2
      ;;
    --team)
      team_target="${2:-}"
      shift 2
      ;;
    --tiled)
      team_tiled=1
      shift
      ;;
    --all)
      capture_all=1
      shift
      ;;
    --lines)
      lines="${2:-}"
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if ! [[ "$lines" =~ ^[0-9]+$ ]] || (( lines < 1 )); then
  echo "invalid --lines value: $lines" >&2
  exit 2
fi

selectors=0
[[ -n "$agent_target" ]] && selectors=$((selectors + 1))
[[ -n "$team_target" ]] && selectors=$((selectors + 1))
[[ "$capture_all" -eq 1 ]] && selectors=$((selectors + 1))
if (( selectors != 1 )); then
  echo "exactly one selector is required: --agent, --team, or --all" >&2
  exit 2
fi
if [[ "$team_tiled" -eq 1 && -z "$team_target" ]]; then
  echo "--tiled is only valid with --team" >&2
  exit 2
fi

repo_name="$(repo_name_from_context)"

if [[ "$capture_all" -eq 1 ]]; then
  current_pane=""
  if [[ -n "${TMUX:-}" ]]; then
    current_pane="$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)"
  fi

  printf '<captures scope="all" repo="%s">\n' "$(xml_escape "$repo_name")"
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    s="${line%% *}"
    p="${line##* }"
    [[ "$s" == atmux-* ]] || continue
    if [[ -n "$repo_name" && "$s" != "atmux-${repo_name}-"* ]]; then
      continue
    fi
    if [[ -n "$current_pane" && "$p" == "$current_pane" ]]; then
      continue
    fi
    snapshot="$(tmux capture-pane -p -t "$p" -S "-$lines" 2>/dev/null | tr -d '\r' || true)"
    printf '  <capture session="%s" pane="%s" lines="%s">%s</capture>\n' \
      "$(xml_escape "$s")" \
      "$(xml_escape "$p")" \
      "$(xml_escape "$lines")" \
      "$snapshot"
  done < <(tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null || true)
  printf '</captures>\n'
  exit 0
fi

if [[ -n "$agent_target" ]]; then
  session="$("$HERE/../agent" resolve "$agent_target" "$repo_name" || true)"
  if [[ -z "$session" ]]; then
    echo "agent session not found: $agent_target" >&2
    echo "pass absolute (atmux-<repo>-<agent>) or shorthand (<agent>)" >&2
    exit 1
  fi
  if [[ "$session" == "atmux-${repo_name}-team-"* ]]; then
    echo "target is a team/view name; use --team instead" >&2
    exit 2
  fi
  if [[ "$(get_session_env "$session" ATMUX_SESSION_KIND)" == "team" ]]; then
    echo "target is a team/view name; use --team instead" >&2
    exit 2
  fi

  agent_name="$(get_session_env "$session" ATMUX_AGENT_NAME)"
  if [[ -z "$agent_name" ]]; then
    agent_name="$(session_short_name "$session" "$repo_name")"
  fi
  printf '<captures scope="agent" agent="%s" session="%s">\n' \
    "$(xml_escape "$agent_name")" \
    "$(xml_escape "$session")"
  capture_session_panes "$session" "$lines" " agent=\"$(xml_escape "$agent_name")\""
  printf '</captures>\n'
  exit 0
fi

if ! team_name="$(resolve_team_name "$team_target" "$repo_name")"; then
  echo "team not found: $team_target" >&2
  echo "pass absolute (atmux-<repo>-team-<name>) or shorthand (<name>)" >&2
  exit 1
fi

session="atmux-${repo_name}-team-${team_name}"

if [[ "$team_tiled" -eq 1 ]]; then
  "$HERE/../team" view --no-attach "$team_name" >/dev/null
  wait_team_view_render_ready "$session" "$repo_name" "$team_name"
  printf '<captures scope="team-view" team="%s" session="%s" layout="tiled">\n' \
    "$(xml_escape "$team_name")" \
    "$(xml_escape "$session")"
  snapshot="$(capture_team_view_render_all "$session")"
  visible_lines="$(printf '%s\n' "$snapshot" | wc -l | tr -d '[:space:]')"
  printf '  <capture session="%s" lines="%s" team="%s" layout="tiled">%s</capture>\n' \
    "$(xml_escape "$session")" \
    "$(xml_escape "$visible_lines")" \
    "$(xml_escape "$team_name")" \
    "$snapshot"
  printf '</captures>\n'
  exit 0
fi

printf '<captures scope="team" team="%s" session="%s">\n' \
  "$(xml_escape "$team_name")" \
  "$(xml_escape "$session")"
while IFS= read -r member_session; do
  [[ -n "$member_session" ]] || continue
  capture_session_panes "$member_session" "$lines" " team=\"$(xml_escape "$team_name")\""
done < <(team_member_sessions_from_state "$repo_name" "$team_name")
printf '</captures>\n'
