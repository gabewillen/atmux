#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="idle${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 "cat"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

# Simulate a user mid-typing: "> some partial input" (not submitted)
sleep 0.3
tmux send-keys -t "$pane" -l "> some partial input"

# Schedule the input to be cleared after 2 seconds (simulates user finishing)
(
  sleep 2
  tmux send-keys -t "$pane" C-u
  sleep 0.1
  tmux send-keys -t "$pane" -l "> "
  tmux send-keys -t "$pane" Enter
) &
clearer_pid=$!

# wait_for_input_idle should block until the clearer runs
ATMUX_INPUT_IDLE_INTERVAL=0.2 start_ts="$(date +%s)"
if ! wait_for_input_idle "$pane" '^> *$' 10; then
  echo "idle not detected after clearing" >&2
  tmux capture-pane -p -t "$pane" -S -10 >&2 || true
  kill "$clearer_pid" 2>/dev/null || true
  exit 1
fi
elapsed=$(( $(date +%s) - start_ts ))

wait "$clearer_pid" 2>/dev/null || true

# Should have waited at least 1 second (the clearer runs at 2s)
[[ "$elapsed" -ge 1 ]] || { echo "didn't wait for typing to clear: ${elapsed}s" >&2; exit 1; }

echo "ok: wait_for_input_idle blocks while user is typing, resumes when idle"
