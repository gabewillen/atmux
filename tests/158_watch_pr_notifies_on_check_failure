#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-pr-checks.XXXXXX")"
atmux_home="$tmp_root/.atmux"
repo_name="prchk$RANDOM"
session="atmux-${repo_name}-watcher"
trigger_file="$tmp_root/trigger-fail"
stub_dir="$tmp_root/bin"
snapshot_file="$atmux_home/watch-pr/octo_example_pr_77/snapshot"
watchers_dir="$atmux_home/watch-pr/octo_example_pr_77/watchers"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$tmp_root"
}
trap cleanup EXIT

mkdir -p "$stub_dir"
cat > "$stub_dir/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" != "api" || "${2:-}" != "graphql" ]]; then
  echo "unexpected gh invocation: $*" >&2
  exit 1
fi

if [[ -f "${ATMUX_TEST_PR_FAIL_TRIGGER:-}" ]]; then
  printf '%s\n' 'STATE|open'
  printf '%s\n' '2026-04-23T00:00:09Z|check_run|99001|github-actions|FAILURE|build-and-test failure'
else
  printf '%s\n' 'STATE|open'
fi
EOF
chmod +x "$stub_dir/gh"

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session" ATMUX_AGENT_NAME "watcher"
tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "missing watcher pane" >&2; exit 1; }

tmux send-keys -t "$pane" \
  "ATMUX_HOME=\"$atmux_home\" ATMUX_GH_BIN=\"$stub_dir/gh\" ATMUX_TEST_PR_FAIL_TRIGGER=\"$trigger_file\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watcher\" ATMUX_SESSION_NAME=\"$session\" \"$ATMUX_BIN\" pr watch \"https://github.com/octo/example/pull/77\" --interval 0.2 --timeout 10" \
  C-m

if ! wait_for_text "$pane" '<watch type="pr"' 10; then
  echo "pr watch did not register" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 10 ))
while [[ ! -f "$snapshot_file" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr never produced a baseline snapshot" >&2
    tmux capture-pane -p -t "$pane" -S -200 >&2 || true
    exit 1
  fi
  sleep 0.05
done

deadline=$(( $(date +%s) + 10 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -ge 1 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr did not leave an active watcher registration" >&2
    exit 1
  fi
  sleep 0.1
done

touch "$trigger_file"

if ! wait_for_text "$pane" 'kind="check_run"' 15; then
  echo "watch --pr did not deliver a check_run notification" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'state="FAILURE"' 15; then
  echo "watch --pr check_run notification missing FAILURE state" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'build-and-test' 15; then
  echo "watch --pr check_run notification missing check name" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'gh pr checks 77' 15; then
  echo "watch --pr check_run notification missing gh pr checks hint" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: watch --pr emits notification on failing CI check"
