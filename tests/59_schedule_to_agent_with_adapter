#!/usr/bin/env bash
set -euo pipefail

# Test: manager (root, has ATMUX_ADAPTER) sets a schedule for a child agent
# (has ATMUX_MANAGER + ATMUX_ADAPTER). Verifies the agent receives at least 2
# scheduled notifications — the exact production flow reported broken.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_count() {
  local target="$1"
  local needle="$2"
  local expected_count="$3"
  local timeout="${4:-20}"
  local deadline now snap compact count
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -600 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    count="$(printf '%s' "$compact" | { grep -F -o "$needle" || true; } | wc -l | tr -d ' ')"
    if [[ -n "$count" ]] && (( count >= expected_count )); then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      echo "  got $count of $expected_count after ${timeout}s" >&2
      return 1
    fi
    sleep 0.2
  done
}

repo_name="sched${RANDOM}"
session_mgr="atmux-${repo_name}-mgr"
session_agent="atmux-${repo_name}-worker"
tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-schedule-adapter.XXXXXX")"
atmux_home="$tmp_home/.atmux"

cleanup() {
  tmux kill-session -t "$session_mgr" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_agent" >/dev/null 2>&1 || true
  "$TESTS_DIR/scripts/cleanup-orphans" >/dev/null 2>&1 || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session_mgr" >/dev/null 2>&1 || true
tmux kill-session -t "$session_agent" >/dev/null 2>&1 || true

# Root manager: running cat (simulates adapter CLI), has ATMUX_ADAPTER, no ATMUX_MANAGER
tmux new-session -d -s "$session_mgr" -n "$session_mgr" -x 160 -y 40 -c "$REPO_ROOT" "cat"
tmux set-environment -t "$session_mgr" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_mgr" ATMUX_AGENT_NAME "mgr"
tmux set-environment -t "$session_mgr" ATMUX_SESSION_NAME "$session_mgr"
tmux set-environment -t "$session_mgr" ATMUX_ADAPTER "claude-code"
tmux set-environment -t "$session_mgr" ATMUX_HOME "$atmux_home"
tmux set-environment -t "$session_mgr" ATMUX_SOURCE_ROOT "$REPO_ROOT"

# Child agent: running cat (simulates adapter CLI), has ATMUX_MANAGER + ATMUX_ADAPTER
tmux new-session -d -s "$session_agent" -n "$session_agent" -x 160 -y 40 -c "$REPO_ROOT" "cat"
tmux set-environment -t "$session_agent" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_agent" ATMUX_AGENT_NAME "worker"
tmux set-environment -t "$session_agent" ATMUX_SESSION_NAME "$session_agent"
tmux set-environment -t "$session_agent" ATMUX_MANAGER "mgr"
tmux set-environment -t "$session_agent" ATMUX_ADAPTER "claude-code"
tmux set-environment -t "$session_agent" ATMUX_HOME "$atmux_home"
tmux set-environment -t "$session_agent" ATMUX_SOURCE_ROOT "$REPO_ROOT"

pane_agent="$(tmux list-panes -t "$session_agent" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_agent" ]] || { echo "agent pane missing" >&2; exit 1; }

sleep 0.5
tmux send-keys -t "$pane_agent" -l "❯ "
tmux send-keys -t "$pane_agent" Enter

# Manager schedules a delayed send command to the agent.
echo "--- scheduling from manager context ---" >&2
sched_out="$(ATMUX_REPO="$repo_name" ATMUX_AGENT_NAME="mgr" ATMUX_SESSION_NAME="$session_mgr" \
  ATMUX_HOME="$atmux_home" ATMUX_SOURCE_ROOT="$REPO_ROOT" \
  "$ATMUX_BIN" schedule --interval 2s -- "$ATMUX_BIN" send --to worker "check in" 2>&1)" || {
    echo "schedule command failed: $sched_out" >&2
    exit 1
  }
echo "schedule output: $sched_out" >&2

# Verify schedule returned expected XML
printf '%s\n' "$sched_out" | grep -Fq '<schedule' || { echo "no <schedule in output" >&2; exit 1; }
printf '%s\n' "$sched_out" | grep -Fq 'kind="command"' || { echo "schedule output missing command kind" >&2; exit 1; }

# Wait for at least 2 message notifications to arrive at the agent from the scheduled sends.
echo "--- waiting for notifications on agent pane $pane_agent ---" >&2
if ! wait_for_count "$pane_agent" 'type="message"' 2 20; then
  echo "agent did not receive 2+ scheduled message notifications" >&2
  echo "--- agent pane contents ---" >&2
  tmux capture-pane -p -t "$pane_agent" -S -200 >&2 || true
  echo "--- manager pane contents ---" >&2
  tmux capture-pane -p -t "$session_mgr" -S -200 >&2 || true
  # Check for stale notify queue
  echo "--- notify queue state ---" >&2
  pane_hash="${pane_agent//%/_}"
  ls -la "$HOME/.atmux/notify-queue/$pane_hash/payloads/" 2>&1 >&2 || echo "(no queue dir)" >&2
  ls -la "$HOME/.atmux/notify-queue/$pane_hash/" 2>&1 >&2 || true
  exit 1
fi

echo "ok: manager schedule command delivers repeated messages to child agent"
