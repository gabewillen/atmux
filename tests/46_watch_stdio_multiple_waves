#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

count_notifications() {
  local target="$1"
  local type="$2"
  tmux capture-pane -p -t "$target" -S -800 2>/dev/null | tr -d '\r\n' | { grep -o "type=\"${type}\"" || true; } | wc -l | tr -d ' '
}

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-stdio-waves.XXXXXX")"
repo_name="sw${RANDOM}"
session_exec="atmux-${repo_name}-exec"
session_watch="atmux-${repo_name}-watch"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"

cleanup() {
  tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true

tmux new-session -d -s "$session_exec" -n "$session_exec" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux new-session -d -s "$session_watch" -n "$session_watch" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

pane_exec="$(tmux list-panes -t "$session_exec" -F '#{pane_id}' 2>/dev/null | head -n1)"
pane_watch="$(tmux list-panes -t "$session_watch" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_exec" && -n "$pane_watch" ]] || { echo "missing panes" >&2; exit 1; }

# Start detached exec that produces output in 3 distinct waves
tmux send-keys -t "$pane_exec" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"exec\" ATMUX_SESSION_NAME=\"$session_exec\" \"$ATMUX_BIN\" exec --detach -- bash -lc 'sleep 3; echo wave1; sleep 3; echo wave2; sleep 3; echo wave3; sleep 1'" C-m

# Wait for exec metadata
deadline=$(( $(date +%s) + 10 ))
pid=""
exec_entry=""
while [[ -z "$pid" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    for ep_dir in "$exec_root"/detach-*; do
      if [[ -d "$ep_dir" && -f "$ep_dir/pid" ]]; then
        candidate="$(tr -d '\r\n' <"$ep_dir/pid")"
        if [[ -n "$candidate" && "$candidate" != detach-* ]]; then
          pid="$candidate"
          exec_entry="$ep_dir"
          break
        fi
      fi
    done
  fi
  sleep 0.05
done

# Start stdio watcher with fast polling
tmux send-keys -t "$pane_watch" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watch\" ATMUX_SESSION_NAME=\"$session_watch\" \"$ATMUX_BIN\" watch --pid \"$pid\" --stdio --duration 30 --timeout 15 --interval 1" C-m

# Wait for watcher registration
deadline=$(( $(date +%s) + 10 ))
while true; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "timeout waiting for watcher registration" >&2
    exit 1
  fi
  wdir="$exec_root/$pid/watchers"
  wn=0
  if [[ -d "$wdir" ]]; then
    wn="$(find "$wdir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wn:-0}" -ge 1 ]]; then
    break
  fi
  sleep 0.05
done

# Wait for at least two exec_output notifications to arrive
deadline=$(( $(date +%s) + 30 ))
while true; do
  count="$(count_notifications "$pane_watch" "exec_output")"
  if [[ "${count:-0}" -ge 2 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "expected >=2 exec_output notifications, got ${count:-0}" >&2
    tmux capture-pane -p -t "$pane_watch" -S -200 >&2 || true
    exit 1
  fi
  sleep 1
done

echo "ok: watch --stdio sends multiple exec_output notifications for distinct output waves"
