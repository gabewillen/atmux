#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
AMUX_BIN="$REPO_ROOT/bin/amux.sh"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-8}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

repo_name="e$RANDOM"
session="amux-${repo_name}-sender"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux set-environment -t "$session" AMUX_REPO "$repo_name"
tmux set-environment -t "$session" AMUX_AGENT_NAME "sender"
tmux set-environment -t "$session" AMUX_SESSION_NAME "$session"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "exec test pane missing" >&2; exit 1; }

marker="exec-exit-$RANDOM-$(date +%s)"
tmux send-keys -t "$pane" "AMUX_REPO=\"$repo_name\" AMUX_AGENT_NAME=\"sender\" AMUX_SESSION_NAME=\"$session\" \"$AMUX_BIN\" exec -- bash -lc 'echo $marker'" C-m

if ! wait_for_text "$pane" "$marker" 10; then
  echo "wrapped command output not found in exec pane: $marker" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" "<notification from=\"exec" 10; then
  echo "exec notification not found in exec pane" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" "exitcode=\"0\"" 10; then
  echo "successful exec exit code notification missing" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: exec preserves output and sends exit notification"
