#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
repo_name="$(basename "$repo_root")"
adapter="${AMUX_ADAPTER:-codex}"
agent_name="${AMUX_AGENT_NAME:-agent}"
worktree_dir="$HOME/.amux/agents/${repo_name}-${agent_name}"
branch_name="amux-${repo_name}-${agent_name}"

mkdir -p "$HOME/.amux/agents"

if ! git -C "$repo_root" rev-parse --verify HEAD >/dev/null 2>&1; then
  echo "repository has no commits; create an initial commit before running amux start" >&2
  exit 1
fi

if [[ ! -d "$worktree_dir" ]]; then
  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch_name"; then
    git -C "$repo_root" worktree add "$worktree_dir" "$branch_name" >/dev/null
  else
    git -C "$repo_root" worktree add -b "$branch_name" "$worktree_dir" HEAD >/dev/null
  fi
  git -C "$worktree_dir" submodule update --init --recursive >/dev/null 2>&1 || true
fi

ensure_local_excludes() {
  local wt="$1"
  local adapter_name="$2"
  local exclude_file
  exclude_file="$(git -C "$wt" rev-parse --git-path info/exclude)"

  mkdir -p "$(dirname "$exclude_file")"
  touch "$exclude_file"

  local adapter_cmd="$wt/adapter/$adapter_name/cmd"
  if [[ ! -x "$adapter_cmd" ]]; then
    echo "adapter command not found: $adapter_cmd" >&2
    exit 1
  fi

  local pattern
  pattern="$("$adapter_cmd" control-file)"
  if [[ -z "$pattern" ]]; then
    echo "adapter setup returned empty control file for adapter: $adapter_name" >&2
    exit 1
  fi

  if ! grep -Fxq "$pattern" "$exclude_file"; then
    printf '%s\n' "$pattern" >> "$exclude_file"
  fi
}

ensure_local_excludes "$worktree_dir" "$adapter"

export AMUX_WORKTREE="$worktree_dir"

runner="$worktree_dir/bin/scripts/start"
if [[ ! -f "$runner" ]]; then
  echo "start runner not found: $runner" >&2
  exit 1
fi

cd "$worktree_dir"
exec bash "$runner" "$@"
