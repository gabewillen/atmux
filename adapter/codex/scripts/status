#!/usr/bin/env bash
set -euo pipefail

roles_dir="${AMUX_HOME:-$HOME/.amux}/roles"
MODEL=''
REASONING_LEVEL=''

sanitize_reasoning() {
  local raw="$1"
  raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"
  case "$raw" in
    "extra high"|"extra-high"|"extra_high"|"extrahigh") printf '%s\n' 'extra-high' ;;
    low|medium|high) printf '%s\n' "$raw" ;;
    *) printf '%s\n' "$raw" ;;
  esac
}

xml_escape() {
  local s="${1:-}"
  s="${s//&/&amp;}"
  s="${s//</&lt;}"
  s="${s//>/&gt;}"
  s="${s//\"/&quot;}"
  s="${s//\'/&apos;}"
  printf '%s\n' "$s"
}

resolve_target() {
  if [[ -n "${AMUX_TARGET_PANE:-}" ]]; then
    printf '%s\n' "$AMUX_TARGET_PANE"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return
  fi
  if [[ -n "${AMUX_SESSION_NAME:-}" ]]; then
    tmux list-panes -t "$AMUX_SESSION_NAME" -F '#{pane_id}' 2>/dev/null | head -n 1
    return
  fi
  if [[ -n "${AMUX_REPO:-}" && -n "${AMUX_AGENT_NAME:-}" ]]; then
    sess="amux-${AMUX_REPO}-${AMUX_AGENT_NAME}"
    tmux list-panes -t "$sess" -F '#{pane_id}' 2>/dev/null | head -n 1
    return
  fi
}

capture_status_snapshot() {
  local target="$1"
  local watch_cmd="${AMUX_SOURCE_ROOT:-${AMUX_HOME:-$HOME/.amux}/src/amux}/bin/amux/watch"

  tmux send-keys -t "$target" C-u
  sleep 0.2
  tmux send-keys -t "$target" -l "/status"
  sleep 0.2
  tmux send-keys -t "$target" ENTER

  if [[ -x "$watch_cmd" ]]; then
    "$watch_cmd" --target "$target" --scope pane --text "OpenAI Codex" --timeout 6 --interval 0.2 --lines 400 >/dev/null 2>&1 || true
  else
    sleep 0.8
  fi

  tmux capture-pane -p -t "$target" -S -500 2>/dev/null || true
}

extract_latest_status_block() {
  local snapshot="$1"
  printf '%s\n' "$snapshot" | awk '
    { lines[NR]=$0 }
    /OpenAI Codex/ { start=NR }
    END {
      if (!start) exit
      from=start-3
      to=start+80
      if (from < 1) from=1
      if (to > NR) to=NR
      for (i=from; i<=to; i++) print lines[i]
    }
  '
}

extract_percent_left() {
  local snapshot="$1"
  local key="$2"
  local line
  line="$(printf '%s\n' "$snapshot" | awk -v k="$key" 'index($0,k){l=$0} END{print l}')"
  [[ -n "$line" ]] || return 1
  printf '%s\n' "$line" | sed -nE 's/.*[^0-9]([0-9]{1,3})% left.*/\1/p' | tail -n 1
}

parse_model_and_reasoning() {
  local snapshot="$1"
  local line parsed_model parsed_reasoning parsed

  parsed=0
  line="$(printf '%s\n' "$snapshot" | awk '/Model:[[:space:]]/{l=$0} END{print l}')"
  [[ -n "$line" ]] || return 1

  parsed_model="$(printf '%s\n' "$line" | sed -nE 's/.*Model:[[:space:]]*([^[:space:]]+).*/\1/p')"
  parsed_reasoning="$(printf '%s\n' "$line" | sed -nE 's/.*\(reasoning ([^,\)]+).*/\1/p')"

  if [[ -n "$parsed_model" ]]; then
    MODEL="$parsed_model"
    parsed=1
  fi
  if [[ -n "$parsed_reasoning" ]]; then
    REASONING_LEVEL="$(sanitize_reasoning "$parsed_reasoning")"
    parsed=1
  fi
  if (( parsed == 1 )); then
    return 0
  fi
  return 1
}

infer_state() {
  local snapshot="$1"
  local status_block="$2"
  local five_left weekly_left credits

  if printf '%s\n' "$snapshot" | grep -Fq "disabled while a task is in progress"; then
    printf '%s\n' 'busy'
    return
  fi

  if printf '%s\n' "$status_block" | grep -Fq "OpenAI Codex" && printf '%s\n' "$status_block" | grep -Fq "Model:"; then
    five_left="$(extract_percent_left "$status_block" "5h limit:" || true)"
    weekly_left="$(extract_percent_left "$status_block" "Weekly limit:" || true)"
    credits="$(printf '%s\n' "$status_block" | sed -nE 's/.*Credits:[[:space:]]*([0-9]+).*/\1/p' | tail -n 1)"

    if [[ "$five_left" == "0" || "$weekly_left" == "0" || "$credits" == "0" ]]; then
      printf '%s\n' 'usage-limit'
    else
      printf '%s\n' 'idle'
    fi
    return
  fi

  case "${AMUX_STATE:-idle}" in
    idle|busy|errored|usage-limit) printf '%s\n' "${AMUX_STATE:-idle}" ;;
    *) printf '%s\n' 'errored' ;;
  esac
}

owner="agent"
if [[ -n "${AMUX_MANAGER:-}" || -f "$roles_dir/agent.manager" ]]; then
  owner="manager"
fi

snapshot=""
status_block=""
output_model="$MODEL"
output_reasoning="$REASONING_LEVEL"
target="$(resolve_target)"
if [[ -n "$target" ]]; then
  parsed_ok=0
  if [[ "${AMUX_STATUS_PASSIVE:-0}" == "1" ]]; then
    snapshot="$(tmux capture-pane -p -t "$target" -S -500 2>/dev/null || true)"
  else
    snapshot="$(capture_status_snapshot "$target")"
  fi
  status_block="$(extract_latest_status_block "$snapshot" || true)"
  if [[ -n "$status_block" ]]; then
    if parse_model_and_reasoning "$status_block"; then
      parsed_ok=1
    fi
  else
    if parse_model_and_reasoning "$snapshot"; then
      parsed_ok=1
    fi
  fi

  if (( parsed_ok == 1 )); then
    output_model="$MODEL"
    output_reasoning="$REASONING_LEVEL"
  else
    # Avoid leaking stale model/reasoning from another pane when target parsing fails.
    output_model=""
    output_reasoning=""
  fi
fi

state="$(infer_state "$snapshot" "$status_block")"
printf '<status adapter="%s" owner="%s" state="%s" model="%s" reasoning_level="%s" control_file="AGENTS.md" />\n' \
  "codex" "$(xml_escape "$owner")" "$(xml_escape "$state")" "$(xml_escape "$output_model")" "$(xml_escape "$output_reasoning")"
