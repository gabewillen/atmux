#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"
# shellcheck source=bin/(atmux)/(lib)/tmux
source "$HERE/(lib)/tmux"
# shellcheck source=bin/(atmux)/(internal)/reporter
source "$HERE/(internal)/reporter"

usage() {
  cat <<'USAGE'
Usage:
  atmux team create <name> [--role <role>] [--start <cmd>] [--stop <cmd>]
                           [--worktree <path>] [--shared-worktree]
                           [--time-limit <duration>]
                           [--adapter <adapter>] [--intelligence <0-100>]
                           [--model <id>] [--reasoning <level>]
                           [--set <key>=<value>]...
                           [--set <member>.<key>=<value>]...
  atmux team list
  atmux team ls
  atmux team status [<name>]
  atmux team capture <name> [--tiled] [--lines <n>]
  atmux team kill <name|pattern> [...]
  atmux team resolve <name> [<repo_name>]

Description:
  Manage repo-scoped teams of agents.

  Every team is recorded in filesystem state under ATMUX_HOME. Teams do
  not create a tmux dashboard session by default, and membership is not
  constrained by pane layout.

  Every team gets its own fresh git worktree by default — members spawned
  with `--shared-worktree` inherit it via ATMUX_WORKTREE, so agents can
  share that team worktree without stomping the user's checkout. `team
  kill` removes the worktree and branch when atmux owns it.

  --role <name>       Apply a KIND=team role: creates the team, spawns
                      each MEMBERS entry from the role manifest, then
                      runs the role's optional `start` hook for any
                      cross-cutting wiring. `team kill` auto-kills the
                      spawned members and runs the matching `stop` hook.

  --worktree <path>   Override the worktree location. Default is
                      $ATMUX_HOME/teams/<repo>/<team>/worktree on a new
                      branch atmux-<repo>-team-<team>.

  --shared-worktree   Opt out of the fresh-worktree default. Use the
                      caller's pwd (or repo root) instead. Useful for
                      coordination teams that just talk and never edit.

  --time-limit <dur>  Store session deadline metadata and expose it to
                      member role prompts/hooks as ATMUX_TEAM_TIME_LIMIT,
                      ATMUX_TEAM_DEADLINE_AT, and
                      ATMUX_TEAM_DEADLINE_EPOCH.

  --adapter / --intelligence / --model / --reasoning
                      Apply to every member spawned from MEMBERS=(...).
                      Per-member overrides via `--set <member>.<field>=
                      <value>` take precedence (member name matches the
                      last `-`-segment of the member's first token, e.g.
                      `${ATMUX_TEAM}-driver` matches on `driver`).

  --set <key>=<value> Known agent fields apply to every member. Unknown
                      undotted keys are role-level configuration exposed to
                      team manifests as ATMUX_TEAM_SET_<KEY>; repeated keys
                      are newline-joined. Use dotted keys for per-member
                      overrides, e.g. `--set recorder.model=composer-2-fast`.
USAGE
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "atmux team must be run from a git repository" >&2
    exit 1
  fi

  repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

resolve_role_runner() {
  # Mirrors agent:resolve_role_runner so team create can locate the `role`
  # subcommand in the same install layouts.
  local here_role
  here_role="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -x "$here_role/role" ]]; then
    printf '%s\n' "$here_role/role"
    return 0
  fi
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/(atmux)/role" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/bin/(atmux)/role"
    return 0
  fi
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  if [[ -x "$atmux_home/src/atmux/bin/(atmux)/role" ]]; then
    printf '%s\n' "$atmux_home/src/atmux/bin/(atmux)/role"
    return 0
  fi
  return 1
}

read_team_role_manifest() {
  # Echoes manifest fields for a team-kind role. Output lines:
  #   KIND=<agent|team>
  #   MEMBER=<args>     (one line per MEMBERS entry, in declared order)
  # Sources in a subshell so manifest side-effects can't leak into the
  # caller. Caller pre-exports ATMUX_TEAM and ATMUX_REPO so manifests can
  # parameterize MEMBERS — e.g. `${ATMUX_TEAM}-driver` to get
  # team-unique session names without templating support.
  local manifest_path="$1"
  if [[ ! -f "$manifest_path" ]]; then
    printf 'KIND=agent\n'
    return 0
  fi
  (
    KIND=""
    MEMBERS=()
    # shellcheck source=/dev/null
    source "$manifest_path" 2>/dev/null || true
    case "$KIND" in
      agent|team) printf 'KIND=%s\n' "$KIND" ;;
      *)          printf 'KIND=agent\n' ;;
    esac
    if [[ "${#MEMBERS[@]}" -gt 0 ]]; then
      local entry
      for entry in "${MEMBERS[@]}"; do
        # One MEMBER per line; entry text is the tail of `atmux agent create`.
        # Strip embedded newlines defensively so the line protocol stays sound.
        printf 'MEMBER=%s\n' "${entry//$'\n'/ }"
      done
    fi
  )
}

resolve_atmux_runner_for_team() {
  # Locate the `atmux` front-end so the team can spawn members. Mirrors the
  # path search used inside agent create.
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/atmux" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/bin/atmux"
    return 0
  fi
  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/bin/atmux" ]]; then
      printf '%s\n' "$repo_root/bin/atmux"
      return 0
    fi
  fi
  if command -v atmux >/dev/null 2>&1; then
    printf '%s\n' atmux
    return 0
  fi
  return 1
}

resolve_source_root_for_team() {
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -d "$ATMUX_SOURCE_ROOT" ]]; then
    printf '%s\n' "$ATMUX_SOURCE_ROOT"
    return 0
  fi
  local source_root
  source_root="$(cd -- "$HERE/../.." 2>/dev/null && pwd || true)"
  if [[ -n "$source_root" && -x "$source_root/bin/atmux" ]]; then
    printf '%s\n' "$source_root"
    return 0
  fi
  printf '%s/src/atmux\n' "${ATMUX_HOME:-$HOME/.atmux}"
}

parse_duration_seconds() {
  local raw="${1:-}"
  local value unit multiplier

  if [[ ! "$raw" =~ ^([0-9]+)(ms|s|m|h|d)?$ ]]; then
    echo "invalid duration: $raw" >&2
    exit 2
  fi

  value="${BASH_REMATCH[1]}"
  unit="${BASH_REMATCH[2]:-s}"
  case "$unit" in
    ms) multiplier="0.001" ;;
    s) multiplier="1" ;;
    m) multiplier="60" ;;
    h) multiplier="3600" ;;
    d) multiplier="86400" ;;
    *) echo "invalid duration unit: $unit" >&2; exit 2 ;;
  esac

  awk -v value="$value" -v multiplier="$multiplier" '
    BEGIN {
      seconds = value * multiplier
      if (seconds > 0 && seconds != int(seconds)) {
        seconds = int(seconds) + 1
      }
      printf "%d\n", seconds
    }
  '
}

epoch_to_utc() {
  local epoch="$1"
  date -u -r "$epoch" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || date -u -d "@$epoch" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null \
    || printf '%s\n' "$epoch"
}

teardown_team() {
  # Best-effort cleanup when team create fails partway through. Kills any
  # already-spawned members via `atmux agent kill` (so their worktrees and
  # branches get cleaned up too), then removes any optional team view,
  # the role state dir, and the team's owned worktree (if create_team made one).
  # Args: <repo_name> <team_name> <session> <role_state_dir> [<owned_worktree>]
  local repo="$1" team="$2" session="$3" state_dir="${4:-}" owned_wt="${5:-}"
  local prefix="atmux-${repo}-"
  local atmux_bin member_session member_team member_short
  atmux_bin="$(resolve_atmux_runner_for_team || true)"
  local -a member_shorts=()
  while IFS= read -r member_session; do
    [[ -z "$member_session" ]] && continue
    [[ "$member_session" == "$session" ]] && continue
    member_team="$(get_session_env "$member_session" ATMUX_TEAM)"
    [[ "$member_team" == "$team" ]] || continue
    member_short="${member_session#"$prefix"}"
    member_shorts+=("$member_short")
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null \
            | awk -v p="$prefix" 'index($0,p)==1 { print }')
  if [[ "${#member_shorts[@]}" -gt 0 && -n "$atmux_bin" ]]; then
    "$atmux_bin" agent kill "${member_shorts[@]}" >/dev/null 2>&1 || true
  fi
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  if [[ -n "$state_dir" && -d "$state_dir" ]]; then
    rm -rf -- "$state_dir" 2>/dev/null || true
  fi
  if [[ -n "$owned_wt" && -d "$owned_wt" ]]; then
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]] \
       && git -C "$repo_root" worktree list --porcelain 2>/dev/null \
            | grep -Fqx "worktree $owned_wt"; then
      git -C "$repo_root" worktree remove -f "$owned_wt" >/dev/null 2>&1 || true
    fi
    rm -rf -- "$owned_wt" 2>/dev/null || true
    local owner_meta
    owner_meta="$(dirname -- "$owned_wt")/owned-worktree"
    [[ -f "$owner_meta" ]] && rm -f -- "$owner_meta" 2>/dev/null || true
  fi
}

member_short_name() {
  # Map a member entry's first token to the short name used by `--set
  # <member>.<field>=...`. Per the spec the match is on the last
  # `-`-segment, so `${ATMUX_TEAM}-driver` (already expanded by the
  # manifest source) becomes `driver`.
  local first_tok="$1"
  printf '%s\n' "${first_tok##*-}"
}

team_role_set_env_name() {
  local key="$1" var
  var="$(printf '%s' "$key" | tr '[:lower:]' '[:upper:]' | sed -E 's/[^A-Z0-9_]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  printf 'ATMUX_TEAM_SET_%s\n' "$var"
}

team_set_is_agent_field() {
  case "$1" in
    model|reasoning|reasoning_level|adapter|adapters|intelligence|name|team|start|start_command|stop|stop_command)
      return 0
      ;;
  esac
  return 1
}

write_team_session_manifest() {
  local out="$1" repo="$2" team="$3" session="$4" role_name="$5" role_path="$6" worktree="$7" doc_path="$8"
  local time_limit_value="$9" deadline_at_value="${10}" deadline_epoch_value="${11}" member_text="${12:-}"
  shift 12
  local entry role_set
  {
    printf 'VERSION=1\n'
    printf 'KIND=team-session\n'
    printf 'REPO=%q\n' "$repo"
    printf 'TEAM=%q\n' "$team"
    printf 'SESSION=%q\n' "$session"
    printf 'ROLE=%q\n' "$role_name"
    printf 'ROLE_DIR=%q\n' "$role_path"
    printf 'WORKTREE=%q\n' "$worktree"
    printf 'DOC_DIR=%q\n' "$doc_path"
    printf 'TIME_LIMIT=%q\n' "$time_limit_value"
    printf 'DEADLINE_AT=%q\n' "$deadline_at_value"
    printf 'DEADLINE_EPOCH=%q\n' "$deadline_epoch_value"
    printf 'ROLE_SETS=(\n'
    for role_set in "$@"; do
      printf '  %q\n' "$role_set"
    done
    printf ')\n'
    printf 'MEMBERS=(\n'
    while IFS= read -r entry; do
      [[ -n "$entry" ]] || continue
      printf '  %q\n' "$entry"
    done <<< "$member_text"
    printf ')\n'
  } > "$out"
}

spawn_team_members() {
  # Spawns each MEMBER from the manifest via `atmux agent create <args>
  # --team <team>`. Returns non-zero on the first spawn failure so the caller
  # can tear down the partially-built team.
  # Args: <repo_name> <team_name> <member_lines> [<team_work_dir>]
  #
  # Reads the following caller-scope variables (set by create_team) for
  # per-spawn overrides:
  #   team_adapter, team_intelligence, team_model, team_reasoning
  #   team_sets[]         — known undotted agent --set key=val (apply to every member)
  #   team_dotted_sets[]  — `<member>.<key>=<val>` (apply only to that member)
  local _repo="$1" team="$2" lines="$3" team_work_dir="${4:-}"
  [[ -n "$lines" ]] || return 0

  local atmux_bin
  atmux_bin="$(resolve_atmux_runner_for_team || true)"
  if [[ -z "$atmux_bin" ]]; then
    echo "atmux team create: cannot locate the atmux binary to spawn members" >&2
    return 127
  fi

  # Build the team-wide override arg list once. Overrides are appended to
  # each `agent create` so they win over the role's MEMBERS=(...) defaults
  # (later flag wins in agent's parser).
  local -a team_overrides=()
  [[ -n "${team_adapter:-}"      ]] && team_overrides+=(--adapter "$team_adapter")
  [[ -n "${team_intelligence:-}" ]] && team_overrides+=(--intelligence "$team_intelligence")
  [[ -n "${team_model:-}"        ]] && team_overrides+=(--model "$team_model")
  [[ -n "${team_reasoning:-}"    ]] && team_overrides+=(--reasoning "$team_reasoning")
  local set_kv
  for set_kv in "${team_sets[@]+"${team_sets[@]}"}"; do
    [[ -n "$set_kv" ]] && team_overrides+=(--set "$set_kv")
  done

  local entry
  while IFS= read -r entry; do
    [[ -z "$entry" ]] && continue
    # Tokenize via `eval set --` so quoted args survive (e.g. a member
    # entry with `--description "multi word"`). The manifest is already
    # sourced bash — anyone who can write MEMBERS can also run arbitrary
    # code at source time — so this `eval` adds no new attack surface.
    local -a tokens=()
    if ! eval "set -- $entry" 2>/dev/null; then
      echo "atmux team create: malformed MEMBERS entry: $entry" >&2
      return 1
    fi
    tokens=("$@")
    if [[ "${#tokens[@]}" -eq 0 ]]; then
      continue
    fi

    # Per-member overrides (--set <member>.<field>=<value>). Match on the
    # last `-`-segment of the first token (e.g. `${ATMUX_TEAM}-driver` →
    # `driver`). Appended after team-level overrides so they win.
    local member_short
    member_short="$(member_short_name "${tokens[0]}")"
    local -a member_overrides=()
    local dotted_kv member_part field_part
    for dotted_kv in "${team_dotted_sets[@]+"${team_dotted_sets[@]}"}"; do
      [[ -n "$dotted_kv" ]] || continue
      member_part="${dotted_kv%%.*}"
      field_part="${dotted_kv#*.}"
      [[ "$member_part" == "$member_short" ]] || continue
      # field_part is `<key>=<value>` — pass through as `--set <key>=<value>`.
      member_overrides+=(--set "$field_part")
    done

    # Export ATMUX_WORKTREE so `agent create --shared-worktree` picks it up
    # — that's how members spawned by a `team create --worktree` end up
    # sharing the team's worktree instead of the repo root.
    local -a env_prefix=()
    if [[ -n "$team_work_dir" ]]; then
      env_prefix=(env "ATMUX_WORKTREE=$team_work_dir" "ATMUX_TEAM=$team")
    fi
    if [[ -n "${team_time_limit:-}${team_deadline_at:-}${team_deadline_epoch:-}${team_doc_dir:-}" ]]; then
      if [[ "${#env_prefix[@]}" -eq 0 ]]; then
        env_prefix=(env)
      fi
      [[ -n "${team_time_limit:-}" ]] && env_prefix+=("ATMUX_TEAM_TIME_LIMIT=$team_time_limit")
      [[ -n "${team_deadline_at:-}" ]] && env_prefix+=("ATMUX_TEAM_DEADLINE_AT=$team_deadline_at")
      [[ -n "${team_deadline_epoch:-}" ]] && env_prefix+=("ATMUX_TEAM_DEADLINE_EPOCH=$team_deadline_epoch")
      [[ -n "${team_doc_dir:-}" ]] && env_prefix+=("ATMUX_TEAM_DOC_DIR=$team_doc_dir")
    fi
    if [[ -n "${ATMUX_ROLE_SEARCH_PREPEND:-}" ]]; then
      if [[ "${#env_prefix[@]}" -eq 0 ]]; then
        env_prefix=(env)
      fi
      env_prefix+=("ATMUX_ROLE_SEARCH_PREPEND=$ATMUX_ROLE_SEARCH_PREPEND")
    fi
    if ! "${env_prefix[@]+"${env_prefix[@]}"}" "$atmux_bin" agent create \
           "${tokens[@]}" --team "$team" \
           "${team_overrides[@]+"${team_overrides[@]}"}" \
           "${member_overrides[@]+"${member_overrides[@]}"}" >/dev/null; then
      echo "atmux team create: spawning member failed: agent create $entry" >&2
      return 1
    fi
  done <<< "$lines"
  return 0
}

run_team_role_hook() {
  local cmd="$1"
  [[ -n "$cmd" ]] || return 0
  if [[ -x "$cmd" && -f "$cmd" ]]; then
    "$cmd"
  else
    bash -c "$cmd"
  fi
}

run_team_role_hook_bounded() {
  # Caps wall-clock so a misbehaving start hook can't wedge `team create`.
  local cmd="$1"
  local budget_secs="${2:-60}"
  local pid deadline now
  [[ -n "$cmd" ]] || return 0
  ( run_team_role_hook "$cmd" ) &
  pid=$!
  deadline=$(( $(date +%s) + budget_secs ))
  while kill -0 "$pid" 2>/dev/null; do
    now="$(date +%s)"
    if (( now >= deadline )); then
      kill -TERM "$pid" 2>/dev/null || true
      sleep 0.5
      kill -KILL "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
      return 124
    fi
    sleep 0.2
  done
  wait "$pid"
}

team_idle_status_script_for_session() {
  local session="$1" adapter candidate
  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  [[ -n "$adapter" ]] || return 1
  for candidate in \
    "${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}/adapter/$adapter/scripts/status" \
    "$ATMUX_HOME/adapters/$adapter/scripts/status"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

team_idle_member_state() {
  local session="$1" pane status_script status_xml state agent_name session_name selected_adapter status_source_root
  tmux has-session -t "$session" 2>/dev/null || { printf 'missing\n'; return 0; }
  pane="$(primary_pane_for_session "$session")"
  [[ -n "$pane" ]] || { printf 'missing\n'; return 0; }
  status_script="$(team_idle_status_script_for_session "$session" || true)"
  if [[ -n "$status_script" ]]; then
    agent_name="$(get_session_env "$session" ATMUX_AGENT_NAME)"
    session_name="$(get_session_env "$session" ATMUX_SESSION_NAME)"
    selected_adapter="$(get_session_env "$session" ATMUX_ADAPTER_SELECTED)"
    status_source_root="${ATMUX_SOURCE_ROOT:-$ATMUX_HOME/src/atmux}"
    status_xml="$(ATMUX_HOME="$ATMUX_HOME" \
      ATMUX_SOURCE_ROOT="$status_source_root" \
      ATMUX_STATUS_PASSIVE=1 \
      ATMUX_TARGET_PANE="$pane" \
      ATMUX_AGENT_NAME="$agent_name" \
      ATMUX_SESSION_NAME="${session_name:-$session}" \
      ATMUX_ADAPTER_SELECTED="$selected_adapter" \
      "$status_script" 2>/dev/null || true)"
    state="$(printf '%s' "$status_xml" | sed -n 's/.*state="\([^"]*\)".*/\1/p' | head -n1)"
    case "$state" in
      idle|errored|usage-limit) printf 'idle\n' ;;
      *) printf 'busy\n' ;;
    esac
    return 0
  fi
  # Without an adapter status hook, a live pane is conservatively treated as
  # busy. Team-idle notifications are only meaningful when every member can
  # report its own runtime state.
  printf 'busy\n'
}

team_idle_all_members_idle() {
  local repo="$1" team="$2"
  local member state count=0
  while IFS= read -r member; do
    [[ -n "$member" ]] || continue
    count=$((count + 1))
    state="$(team_idle_member_state "$member")"
    [[ "$state" == "idle" ]] || return 1
  done < <(team_member_sessions_from_state "$repo" "$team" | sort -u)
  (( count > 0 ))
}

team_idle_any_member_active() {
  local repo="$1" team="$2"
  local member state
  while IFS= read -r member; do
    [[ -n "$member" ]] || continue
    state="$(team_idle_member_state "$member")"
    [[ "$state" != "idle" ]] && return 0
  done < <(team_member_sessions_from_state "$repo" "$team" | sort -u)
  return 1
}

team_idle_notification_xml() {
  local repo="$1" team="$2" stable_seconds="$3"
  local member count=0 member_names=""
  while IFS= read -r member; do
    [[ -n "$member" ]] || continue
    count=$((count + 1))
    if [[ -n "$member_names" ]]; then
      member_names+=","
    fi
    member_names+="${member#atmux-"${repo}"-}"
  done < <(team_member_sessions_from_state "$repo" "$team" | sort -u)
  printf '<notification type="team-idle" team="%s" reason="all_idle" members="%s" stable_seconds="%s" member_names="%s"/>' \
    "$(xml_escape "$team")" \
    "$(xml_escape "$count")" \
    "$(xml_escape "$stable_seconds")" \
    "$(xml_escape "$member_names")"
}

run_team_idle_watch() {
  local explicit_repo="" team_name="" watcher_name="" idle_seconds="${ATMUX_TEAM_IDLE_SECONDS:-30}" interval="${ATMUX_TEAM_IDLE_INTERVAL:-2}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo) explicit_repo="$(normalize_name "${2:-}")"; shift 2 ;;
      --team) team_name="$(normalize_name "${2:-}")"; shift 2 ;;
      --watcher) watcher_name="${2:-}"; shift 2 ;;
      --idle) idle_seconds="${2:-}"; shift 2 ;;
      --interval) interval="${2:-}"; shift 2 ;;
      *) echo "atmux team _idle-watch: unknown flag: $1" >&2; exit 2 ;;
    esac
  done
  [[ -n "$explicit_repo" && -n "$team_name" && -n "$watcher_name" ]] || {
    echo "atmux team _idle-watch requires --repo, --team, and --watcher" >&2
    exit 2
  }

  local watcher_dir first_idle_ts=0 fired=0 now pane xml
  watcher_dir="$(team_idle_watcher_dir "$explicit_repo" "$team_name" "$watcher_name")"
  while [[ -d "$watcher_dir" ]] && team_state_exists "$explicit_repo" "$team_name"; do
    now="$(date +%s)"
    if team_idle_all_members_idle "$explicit_repo" "$team_name"; then
      if (( first_idle_ts == 0 )); then
        first_idle_ts="$now"
      fi
      if (( fired == 0 && now - first_idle_ts >= idle_seconds )); then
        pane="$(cat "$watcher_dir/pane" 2>/dev/null || true)"
        if [[ -n "$pane" ]]; then
          xml="$(team_idle_notification_xml "$explicit_repo" "$team_name" "$idle_seconds")"
          send_notification "$pane" "$xml" || true
        fi
        fired=1
      fi
    else
      first_idle_ts=0
      if team_idle_any_member_active "$explicit_repo" "$team_name"; then
        fired=0
      fi
    fi
    sleep "$interval"
  done
}

subscribe_caller_to_team_idle() {
  local repo="$1" team="$2"
  local pane="" session="" agent="" watcher_name="" watcher_dir="" atmux_bin="" source_root="" log_file=""
  pane="$(current_pane)"
  [[ -n "$pane" ]] || return 0
  if ! tmux display-message -t "$pane" -p '#{pane_id}' >/dev/null 2>&1; then
    return 0
  fi
  session="$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null || true)"
  agent="${ATMUX_AGENT_NAME:-}"
  if [[ -z "$agent" && -n "$session" ]]; then
    agent="$(get_session_env "$session" ATMUX_AGENT_NAME)"
  fi
  [[ -n "$agent" || "$(get_session_env "$session" ATMUX_SESSION_KIND)" == "agent" ]] || return 0

  watcher_name="$(pane_queue_key "$pane")"
  watcher_dir="$(team_idle_watcher_dir "$repo" "$team" "$watcher_name")"
  mkdir -p "$watcher_dir"
  write_field "$watcher_dir/pane" "$pane"
  write_field "$watcher_dir/session" "$session"
  write_field "$watcher_dir/agent" "$agent"
  write_field "$watcher_dir/repo" "$repo"
  write_field "$watcher_dir/team" "$team"
  write_field "$watcher_dir/subscribed_at" "$(timestamp_utc)"

  atmux_bin="$(resolve_atmux_runner_for_team || true)"
  [[ -n "$atmux_bin" ]] || return 0
  source_root="$(resolve_source_root_for_team)"
  log_file="$watcher_dir/worker.log"
  (
    ATMUX_HOME="$ATMUX_HOME" \
    ATMUX_SOURCE_ROOT="$source_root" \
    ATMUX_REPO="$repo" \
      "$atmux_bin" team _idle-watch \
        --repo "$repo" --team "$team" --watcher "$watcher_name" \
        --idle "${ATMUX_TEAM_IDLE_SECONDS:-30}" \
        --interval "${ATMUX_TEAM_IDLE_INTERVAL:-2}"
  ) >>"$log_file" 2>&1 &
  write_field "$watcher_dir/worker.pid" "$!"
  team_idle_watcher_id "$repo" "$team" "$watcher_name"
}

create_team() {
  local raw_name=""
  local role=""
  local start_cmd=""
  local stop_cmd=""
  # Default: every team gets its own fresh worktree. Members spawned with
  # --shared-worktree inherit it via env. `--worktree <path>` overrides
  # the location; `--shared-worktree` opts out (use the caller's pwd /
  # repo root instead, useful for coordination teams that just talk and
  # never touch files).
  local shared_worktree=0
  local worktree_path=""
  local worktree_explicit=0
  local time_limit=""
  # Team-wide member overrides: applied to every spawned MEMBER. Per-member
  # `--set <member>.<field>=<value>` overrides win, since spawn_team_members
  # appends per-member overrides after these.
  local team_adapter=""
  local team_intelligence=""
  local team_model=""
  local team_reasoning=""
  local set_key=""
  local -a team_sets=()
  local -a team_dotted_sets=()
  local -a team_role_sets=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --role)    role="${2:-}"; shift 2 ;;
      --role=*)  role="${1#--role=}"; shift ;;
      --start)   start_cmd="${2:-}"; shift 2 ;;
      --start=*) start_cmd="${1#--start=}"; shift ;;
      --stop)    stop_cmd="${2:-}"; shift 2 ;;
      --stop=*)  stop_cmd="${1#--stop=}"; shift ;;
      --adapter)        team_adapter="${2:-}"; shift 2 ;;
      --adapter=*)      team_adapter="${1#--adapter=}"; shift ;;
      --intelligence)   team_intelligence="${2:-}"; shift 2 ;;
      --intelligence=*) team_intelligence="${1#--intelligence=}"; shift ;;
      --model)          team_model="${2:-}"; shift 2 ;;
      --model=*)        team_model="${1#--model=}"; shift ;;
      --reasoning)      team_reasoning="${2:-}"; shift 2 ;;
      --reasoning=*)    team_reasoning="${1#--reasoning=}"; shift ;;
      --set)
        local set_kv="${2:-}"
        if [[ "$set_kv" != *=* ]]; then
          echo "atmux team create: --set requires key=value: $set_kv" >&2
          exit 2
        fi
        set_key="${set_kv%%=*}"
        if [[ "$set_key" == team.* ]]; then
          team_role_sets+=("${set_kv#team.}")
        elif [[ "$set_key" == *.* ]]; then
          team_dotted_sets+=("$set_kv")
        elif team_set_is_agent_field "$set_key"; then
          team_sets+=("$set_kv")
        else
          team_role_sets+=("$set_kv")
        fi
        shift 2
        ;;
      --set=*)
        local set_kv="${1#--set=}"
        if [[ "$set_kv" != *=* ]]; then
          echo "atmux team create: --set requires key=value: $set_kv" >&2
          exit 2
        fi
        set_key="${set_kv%%=*}"
        if [[ "$set_key" == team.* ]]; then
          team_role_sets+=("${set_kv#team.}")
        elif [[ "$set_key" == *.* ]]; then
          team_dotted_sets+=("$set_kv")
        elif team_set_is_agent_field "$set_key"; then
          team_sets+=("$set_kv")
        else
          team_role_sets+=("$set_kv")
        fi
        shift
        ;;
      --worktree)
        worktree_explicit=1
        # Path-only override; presence with no path is a no-op (default
        # path is already used).
        if [[ $# -ge 2 && "${2:0:1}" != "-" ]]; then
          worktree_path="$2"
          shift 2
        else
          shift
        fi
        ;;
      --worktree=*) worktree_path="${1#--worktree=}"; worktree_explicit=1; shift ;;
      --shared-worktree) shared_worktree=1; shift ;;
      --time-limit) time_limit="${2:-}"; shift 2 ;;
      --time-limit=*) time_limit="${1#--time-limit=}"; shift ;;
      -h|--help)
        echo "usage: atmux team create <name> [--role <role>] [--time-limit <duration>] [--start <cmd>] [--stop <cmd>] [--worktree <path>] [--shared-worktree] [--adapter ...] [--intelligence ...] [--model ...] [--reasoning ...] [--set <key>=<val>]..."
        return 0
        ;;
      --) shift ;;
      -*)
        echo "atmux team create: unknown flag: $1" >&2
        exit 2
        ;;
      *)
        if [[ -z "$raw_name" ]]; then
          raw_name="$1"
          shift
        else
          echo "atmux team create: unexpected argument: $1" >&2
          exit 2
        fi
        ;;
    esac
  done

  if [[ -z "$raw_name" ]]; then
    echo "usage: atmux team create <name> [--role <role>]" >&2
    exit 2
  fi

  case "$start_cmd" in
    *$'\n'*) echo "atmux team create: --start must be a single line; use a script file for multi-line commands" >&2; exit 2 ;;
  esac
  case "$stop_cmd" in
    *$'\n'*) echo "atmux team create: --stop must be a single line; use a script file for multi-line commands" >&2; exit 2 ;;
  esac

  local repo_root repo_name team_name session state_dir doc_dir
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  team_name="$(normalize_name "$raw_name")"
  session="atmux-${repo_name}-team-${team_name}"
  state_dir="$(team_state_dir "$repo_name" "$team_name")"
  doc_dir="$repo_root/docs/atmux/$team_name"
  local team_exists=0
  if [[ -f "$state_dir/name" || -d "$state_dir/members" ]]; then
    team_exists=1
  fi

  # Resolve role first so we can fail before opening the session if the role
  # is missing or wrong-kind.
  local role_dir=""
  if [[ -n "$role" ]]; then
    if role_runner="$(resolve_role_runner || true)" && [[ -x "$role_runner" ]]; then
      role_dir="$("$role_runner" resolve --kind team "$role" 2>/dev/null || true)"
      if [[ -z "$role_dir" ]] && "$role_runner" resolve --kind agent "$role" >/dev/null 2>&1; then
        echo "atmux team create: role '$role' is KIND=agent; use 'atmux agent create --role $role' instead" >&2
        exit 2
      fi
    fi
    if [[ -z "$role_dir" ]]; then
      echo "atmux team create: role not found: $role" >&2
      exit 1
    fi
    manifest_out="$(
      export ATMUX_TEAM="$team_name" ATMUX_REPO="$repo_name"
      role_set_kv=""
      for role_set_kv in "${team_role_sets[@]+"${team_role_sets[@]}"}"; do
        [[ -n "$role_set_kv" ]] || continue
        role_set_key="${role_set_kv%%=*}"
        role_set_value="${role_set_kv#*=}"
        role_set_env="$(team_role_set_env_name "$role_set_key")"
        if [[ -n "${!role_set_env:-}" ]]; then
          export "$role_set_env=${!role_set_env}"$'\n'"$role_set_value"
        else
          export "$role_set_env=$role_set_value"
        fi
      done
      read_team_role_manifest "$role_dir/manifest" || true
    )"
    member_lines="$(printf '%s\n' "$manifest_out" | sed -n 's/^MEMBER=//p')"
    if [[ -z "$start_cmd" && -x "$role_dir/start" ]]; then
      start_cmd="$role_dir/start"
    fi
    if [[ -z "$stop_cmd" && -x "$role_dir/stop" ]]; then
      stop_cmd="$role_dir/stop"
    fi
  fi

  if [[ "$team_exists" -eq 1 ]]; then
    if [[ -n "$role" || -n "$start_cmd" || -n "$stop_cmd" \
          || "$worktree_explicit" -eq 1 || "$shared_worktree" -eq 1 || -n "$time_limit" ]]; then
      echo "atmux team create: team '$team_name' already exists; --role/--start/--stop/--worktree/--shared-worktree/--time-limit only apply to fresh teams" >&2
      exit 1
    fi
    local existing_session existing_doc_dir existing_role existing_deadline
    existing_session="$(cat "$state_dir/session_name" 2>/dev/null || printf 'atmux-%s-team-%s' "$repo_name" "$team_name")"
    existing_doc_dir="$(cat "$state_dir/doc_dir" 2>/dev/null || true)"
    existing_role="$(cat "$state_dir/role" 2>/dev/null || true)"
    existing_deadline="$(cat "$state_dir/deadline_at" 2>/dev/null || true)"
    printf '<team name="%s" repo="%s" session="%s" state_dir="%s" doc_dir="%s"%s%s />\n' \
      "$(xml_escape "$team_name")" \
      "$(xml_escape "$repo_name")" \
      "$(xml_escape "$existing_session")" \
      "$(xml_escape "$state_dir")" \
      "$(xml_escape "$existing_doc_dir")" \
      "$([[ -n "$existing_role" ]] && printf ' role="%s"' "$(xml_escape "$existing_role")")" \
      "$([[ -n "$existing_deadline" ]] && printf ' deadline_at="%s"' "$(xml_escape "$existing_deadline")")"
    return 0
  fi

  # Worktree: by default every team gets its own fresh worktree so members
  # don't stomp the user's actual checkout. `--shared-worktree` opts out
  # (use the caller's pwd / repo root). `--worktree <path>` overrides
  # only the location. Spawned members with --shared-worktree inherit
  # whichever path the team ended up with via ATMUX_WORKTREE in the
  # member environment. Tracked with a marker so `team kill` can remove the
  # worktree on teardown when atmux owns it.
  local team_work_dir="$repo_root"
  local team_worktree_owned=0
  local team_worktree_branch=""
  if [[ "$shared_worktree" -eq 0 ]]; then
    local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
    if [[ -z "$worktree_path" ]]; then
      worktree_path="$atmux_home/teams/$repo_name/$team_name/worktree"
    fi
    local team_branch="atmux-${repo_name}-team-${team_name}"
    if [[ -e "$worktree_path" ]]; then
      if ! git -C "$worktree_path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "atmux team create: --worktree path exists and is not a git worktree: $worktree_path" >&2
        exit 1
      fi
      # Reuse: don't re-add, don't claim ownership for teardown.
    else
      mkdir -p "$(dirname -- "$worktree_path")"
      local worktree_err=""
      if ! worktree_err="$(git -C "$repo_root" worktree add -B "$team_branch" "$worktree_path" HEAD 2>&1)"; then
        if printf '%s\n' "$worktree_err" | grep -Eq 'cannot lock ref|Operation not permitted|Permission denied'; then
          echo "atmux team create: branch creation failed; retrying detached worktree at $worktree_path" >&2
          if ! git -C "$repo_root" worktree add "$worktree_path" HEAD >/dev/null 2>&1; then
            echo "atmux team create: failed to create worktree at $worktree_path" >&2
            exit 1
          fi
        else
          printf '%s\n' "$worktree_err" >&2
          exit 1
        fi
      else
        team_worktree_branch="$team_branch"
      fi
      team_worktree_owned=1
    fi
    team_work_dir="$worktree_path"
  fi

  mkdir -p "$state_dir/members"

  local started_epoch duration_seconds deadline_epoch="" deadline_at=""
  started_epoch="$(date +%s)"
  if [[ -n "$time_limit" ]]; then
    duration_seconds="$(parse_duration_seconds "$time_limit")"
    deadline_epoch=$(( started_epoch + duration_seconds ))
    deadline_at="$(epoch_to_utc "$deadline_epoch")"
  fi
  write_field "$state_dir/name" "$team_name"
  write_field "$state_dir/repo" "$repo_name"
  write_field "$state_dir/session_name" "$session"
  write_field "$state_dir/worktree_path" "$team_work_dir"
  write_field "$state_dir/doc_dir" "$doc_dir"
  write_field "$state_dir/created_at" "$(timestamp_utc)"
  write_field "$state_dir/started_epoch" "$started_epoch"
  [[ -n "$role" ]] && write_field "$state_dir/role" "$role"
  [[ -n "$role_dir" ]] && write_field "$state_dir/role_dir" "$role_dir"
  [[ -n "$start_cmd" ]] && write_field "$state_dir/role_start" "$start_cmd"
  [[ -n "$stop_cmd" ]] && write_field "$state_dir/role_stop" "$stop_cmd"
  [[ -n "$time_limit" ]] && write_field "$state_dir/time_limit" "$time_limit"
  [[ -n "$deadline_epoch" ]] && write_field "$state_dir/deadline_epoch" "$deadline_epoch"
  [[ -n "$deadline_at" ]] && write_field "$state_dir/deadline_at" "$deadline_at"
  if [[ "$team_worktree_owned" -eq 1 ]]; then
    write_field "$state_dir/owned-worktree" "$team_work_dir"
    [[ -n "$team_worktree_branch" ]] && write_field "$state_dir/owned-worktree-branch" "$team_worktree_branch"
  fi
  write_team_session_manifest "$state_dir/manifest" "$repo_name" "$team_name" "$session" \
    "$role" "$role_dir" "$team_work_dir" "$doc_dir" \
    "$time_limit" "$deadline_at" "$deadline_epoch" "${member_lines:-}" \
    "${team_role_sets[@]+"${team_role_sets[@]}"}"
  team_time_limit="$time_limit"
  team_deadline_at="$deadline_at"
  team_deadline_epoch="$deadline_epoch"
  team_doc_dir="$doc_dir"

  if [[ -n "$role" || -n "$start_cmd" || -n "$stop_cmd" ]]; then
    local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
    local role_state_dir="$atmux_home/teams/$repo_name/$team_name/role-state"
    mkdir -p "$role_state_dir"

    # 1) Spawn declared MEMBERS first. Atmux owns these — `team kill` will
    #    auto-kill any agent whose ATMUX_TEAM matches this team's name.
    if [[ -n "${member_lines:-}" ]]; then
      if ! ATMUX_ROLE_SEARCH_PREPEND="$role_dir/roles${ATMUX_ROLE_SEARCH_PREPEND:+:$ATMUX_ROLE_SEARCH_PREPEND}" \
           spawn_team_members "$repo_name" "$team_name" "$member_lines" "$team_work_dir"; then
        echo "atmux team create: tearing down team after member spawn failure" >&2
        teardown_team "$repo_name" "$team_name" "$session" "$role_state_dir" \
          "$([[ "$team_worktree_owned" -eq 1 ]] && printf '%s' "$team_work_dir")"
        rm -rf -- "$state_dir" 2>/dev/null || true
        exit 1
      fi
    fi

    # 2) Run optional start hook (cross-cutting wiring; most team roles won't
    #    need this — reactive logic typically lives in the member roles).
    if [[ -n "$start_cmd" ]]; then
      local role_start_rc=0
      ATMUX_ROLE="$role" \
      ATMUX_ROLE_DIR="$role_dir" \
      ATMUX_ROLE_STATE_DIR="$role_state_dir" \
      ATMUX_TEAM="$team_name" \
      ATMUX_REPO="$repo_name" \
      ATMUX_WORKTREE="$team_work_dir" \
      ATMUX_TEAM_TIME_LIMIT="$team_time_limit" \
      ATMUX_TEAM_DEADLINE_AT="$team_deadline_at" \
      ATMUX_TEAM_DEADLINE_EPOCH="$team_deadline_epoch" \
      ATMUX_TEAM_DOC_DIR="$team_doc_dir" \
        run_team_role_hook_bounded "$start_cmd" "${ATMUX_ROLE_START_TIMEOUT:-60}" || role_start_rc=$?
      if [[ "$role_start_rc" -ne 0 ]]; then
        if [[ "$role_start_rc" -eq 124 ]]; then
          echo "atmux team create: role start timed out after ${ATMUX_ROLE_START_TIMEOUT:-60}s; tearing down team" >&2
        else
          echo "atmux team create: role start failed (rc=$role_start_rc); tearing down team" >&2
        fi
        teardown_team "$repo_name" "$team_name" "$session" "$role_state_dir" \
          "$([[ "$team_worktree_owned" -eq 1 ]] && printf '%s' "$team_work_dir")"
        rm -rf -- "$state_dir" 2>/dev/null || true
        exit 1
      fi
    fi
  fi

  # When invoked from within a repo agent session, remember this as the
  # default team for subsequent `atmux agent create ...` calls.
  #
  # Stamp `ATMUX_DEFAULT_TEAM` rather than `ATMUX_TEAM`. The latter is
  # the kill predicate `atmux team kill` uses to enumerate members
  # (membership signal); if we stamp it on the caller too, team kill
  # treats the caller as a member and kills it. `ATMUX_DEFAULT_TEAM`
  # is read by `agent create` purely as a fallback for `--team` when
  # the user doesn't pass one explicitly.
  local idle_subscription_attr=""
  if [[ -n "${TMUX:-}" ]]; then
    local caller_session caller_repo
    caller_session="$(tmux display-message -p '#S' 2>/dev/null || true)"
    if [[ -n "$caller_session" ]] && tmux has-session -t "$caller_session" 2>/dev/null; then
      caller_repo="$(tmux show-environment -t "$caller_session" ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
      if [[ -z "$caller_repo" || "$caller_repo" == "$repo_name" ]]; then
        tmux set-environment -t "$caller_session" ATMUX_DEFAULT_TEAM "$team_name" >/dev/null 2>&1 || true
        idle_watcher_id="$(subscribe_caller_to_team_idle "$repo_name" "$team_name" || true)"
        if [[ -n "$idle_watcher_id" ]]; then
          idle_subscription_attr=" idle_subscription=\"team-idle\" idle_watcher_id=\"$(xml_escape "$idle_watcher_id")\""
        fi
      fi
    fi
  fi

  printf '<team name="%s" repo="%s" session="%s" state_dir="%s" doc_dir="%s"%s%s%s />\n' \
    "$(xml_escape "$team_name")" \
    "$(xml_escape "$repo_name")" \
    "$(xml_escape "$session")" \
    "$(xml_escape "$state_dir")" \
    "$(xml_escape "$doc_dir")" \
    "$([[ -n "$role" ]] && printf ' role="%s"' "$(xml_escape "$role")")" \
    "$([[ -n "${team_deadline_at:-}" ]] && printf ' deadline_at="%s"' "$(xml_escape "$team_deadline_at")")" \
    "$idle_subscription_attr"
}

list_teams() {
  local repo_name
  {
    IFS= read -r _
    IFS= read -r repo_name
  } < <(repo_context)

  report_open teams repo="$repo_name"
  local base dir name session doc_dir deadline_at role
  base="${ATMUX_HOME:-$HOME/.atmux}/teams/$repo_name"
  if [[ -d "$base" ]]; then
    while IFS= read -r dir; do
      [[ -d "$dir" ]] || continue
      name="$(cat "$dir/name" 2>/dev/null || basename "$dir")"
      session="$(cat "$dir/session_name" 2>/dev/null || printf 'atmux-%s-team-%s' "$repo_name" "$name")"
      doc_dir="$(cat "$dir/doc_dir" 2>/dev/null || true)"
      deadline_at="$(cat "$dir/deadline_at" 2>/dev/null || true)"
      role="$(cat "$dir/role" 2>/dev/null || true)"
      report_record team name="$name" repo="$repo_name" session="$session" state_dir="$dir" doc_dir="$doc_dir" role="$role" deadline_at="$deadline_at"
    done < <(find "$base" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  fi
  report_close teams
}

is_team_session() {
  local session="$1"
  local repo_name="${2:-}"
  if [[ -n "$repo_name" && "$session" == "atmux-${repo_name}-team-"* ]]; then
    local team_name="${session#atmux-${repo_name}-team-}"
    team_state_exists "$repo_name" "$team_name" && return 0
  fi
  return 1
}

run_team_stop_hook_from_state() {
  local repo="$1" team="$2" state_dir="$3"
  local stop_cmd role role_dir role_state_dir worktree doc_dir deadline_at deadline_epoch time_limit
  stop_cmd="$(cat "$state_dir/role_stop" 2>/dev/null || true)"
  [[ -n "$stop_cmd" ]] || return 0
  role="$(cat "$state_dir/role" 2>/dev/null || true)"
  role_dir="$(cat "$state_dir/role_dir" 2>/dev/null || true)"
  role_state_dir="$state_dir/role-state"
  worktree="$(cat "$state_dir/worktree_path" 2>/dev/null || true)"
  doc_dir="$(cat "$state_dir/doc_dir" 2>/dev/null || true)"
  deadline_at="$(cat "$state_dir/deadline_at" 2>/dev/null || true)"
  deadline_epoch="$(cat "$state_dir/deadline_epoch" 2>/dev/null || true)"
  time_limit="$(cat "$state_dir/time_limit" 2>/dev/null || true)"
  ATMUX_ROLE="$role" \
  ATMUX_ROLE_DIR="$role_dir" \
  ATMUX_ROLE_STATE_DIR="$role_state_dir" \
  ATMUX_TEAM="$team" \
  ATMUX_REPO="$repo" \
  ATMUX_WORKTREE="$worktree" \
  ATMUX_TEAM_TIME_LIMIT="$time_limit" \
  ATMUX_TEAM_DEADLINE_AT="$deadline_at" \
  ATMUX_TEAM_DEADLINE_EPOCH="$deadline_epoch" \
  ATMUX_TEAM_DOC_DIR="$doc_dir" \
    run_team_role_hook_bounded "$stop_cmd" "${ATMUX_ROLE_STOP_TIMEOUT:-30}" || true
}

remove_team_owned_worktree() {
  local repo_root="$1" state_dir="$2" owned_wt branch
  owned_wt="$(cat "$state_dir/owned-worktree" 2>/dev/null || true)"
  [[ -n "$owned_wt" ]] || return 0
  branch="$(cat "$state_dir/owned-worktree-branch" 2>/dev/null || true)"
  if [[ -z "$branch" && -d "$owned_wt" ]]; then
    branch="$(git -C "$owned_wt" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  fi
  if [[ -n "$owned_wt" && -d "$owned_wt" ]]; then
    if git -C "$repo_root" worktree list --porcelain 2>/dev/null | grep -Fqx "worktree $owned_wt"; then
      git -C "$repo_root" worktree remove -f "$owned_wt" >/dev/null 2>&1 || true
    fi
    rm -rf -- "$owned_wt" 2>/dev/null || true
    git -C "$repo_root" worktree prune >/dev/null 2>&1 || true
  fi
  if [[ -n "$branch" ]]; then
    git -C "$repo_root" branch -D "$branch" >/dev/null 2>&1 || true
  fi
}

remove_team_idle_watchers() {
  local repo="$1" team="$2" root watcher_dir worker_pid
  root="$(team_idle_watchers_dir "$repo" "$team")"
  [[ -d "$root" ]] || return 0
  while IFS= read -r watcher_dir; do
    [[ -d "$watcher_dir" ]] || continue
    worker_pid="$(cat "$watcher_dir/worker.pid" 2>/dev/null | tr -d '\r\n' || true)"
    if [[ -n "$worker_pid" ]] && kill -0 "$worker_pid" 2>/dev/null; then
      kill -TERM "$worker_pid" 2>/dev/null || true
    fi
  done < <(find "$root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  rm -rf -- "$(team_idle_watch_dir "$repo" "$team")" 2>/dev/null || true
}

kill_teams() {
  local repo_root repo_name atmux_bin target team_name state_dir view_session member member_short
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  atmux_bin="$(resolve_atmux_runner_for_team || true)"
  [[ -n "$atmux_bin" ]] || { echo "atmux team kill: cannot locate atmux binary" >&2; exit 127; }

  for target in "$@"; do
    if ! team_name="$(resolve_team_name "$target" "$repo_name")"; then
      echo "team not found: $target" >&2
      exit 1
    fi
    state_dir="$(team_state_dir "$repo_name" "$team_name")"
    view_session="$(cat "$state_dir/session_name" 2>/dev/null || printf 'atmux-%s-team-%s' "$repo_name" "$team_name")"
    while IFS= read -r member; do
      [[ -n "$member" ]] || continue
      member_short="${member#atmux-${repo_name}-}"
      "$atmux_bin" agent kill "$member_short" >/dev/null 2>&1 || true
    done < <(team_member_sessions_from_state "$repo_name" "$team_name")
    run_team_stop_hook_from_state "$repo_name" "$team_name" "$state_dir"
    tmux kill-session -t "$view_session" >/dev/null 2>&1 || true
    remove_team_idle_watchers "$repo_name" "$team_name"
    remove_team_owned_worktree "$repo_root" "$state_dir"
    rm -rf -- "$state_dir"
  done
}

view_team() {
  local target="${1:-}" attach_view=1 repo_root repo_name team_name member team_session attach_cmd pane pane_count window_index pane_slot window_target current_window_id pane_window real_tmux socket
  [[ -n "$target" ]] || { echo "usage: atmux team view <name>" >&2; exit 2; }
  if [[ "$target" == "--no-attach" ]]; then
    attach_view=0
    target="${2:-}"
    [[ -n "$target" ]] || { echo "usage: atmux team view [--no-attach] <name>" >&2; exit 2; }
  fi
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  team_name="$(resolve_team_name "$target" "$repo_name")" || { echo "team not found: $target" >&2; exit 1; }
  team_session="atmux-${repo_name}-team-${team_name}"
  attach_cmd="$(atmux_tmux_attach_command)" || exit 1
  if tmux has-session -t "$team_session" 2>/dev/null; then
    tmux kill-session -t "$team_session" >/dev/null 2>&1 || true
  fi
  pane_count=0
  current_window_id=""
  while IFS= read -r member; do
    [[ -n "$member" ]] || continue
    window_index=$((pane_count / 2))
    pane_slot=$((pane_count % 2))
    if (( pane_count == 0 )); then
      tmux new-session -d -s "$team_session" -n "$team_session" -c "$repo_root" "TMUX= $attach_cmd attach-session -r -t \"$member\""
      atmux_configure_tmux_pane_defaults "$team_session"
      tmux set-environment -t "$team_session" ATMUX_REPO "$repo_name" >/dev/null 2>&1 || true
      tmux set-environment -t "$team_session" ATMUX_TEAM "$team_name" >/dev/null 2>&1 || true
      tmux set-environment -t "$team_session" ATMUX_SESSION_NAME "$team_session" >/dev/null 2>&1 || true
      tmux set-environment -t "$team_session" ATMUX_SESSION_KIND "team-view" >/dev/null 2>&1 || true
      pane="$(tmux list-panes -t "$team_session" -F '#{pane_id}' 2>/dev/null | head -n1 || true)"
    elif (( pane_slot == 0 )); then
      pane="$(tmux new-window -d -t "$team_session:" -n "${team_name}-$((window_index + 1))" -c "$repo_root" -P -F '#{pane_id}' "TMUX= $attach_cmd attach-session -r -t \"$member\"" 2>/dev/null || true)"
    else
      window_target="${current_window_id:-$team_session}"
      pane="$(tmux split-window -h -d -t "$window_target" -c "$repo_root" -P -F '#{pane_id}' "TMUX= $attach_cmd attach-session -r -t \"$member\"" 2>/dev/null || true)"
    fi
    if [[ -n "$pane" ]]; then
      pane_window="$(tmux display-message -p -t "$pane" '#{window_id}' 2>/dev/null || true)"
      [[ -n "$pane_window" ]] && current_window_id="$pane_window"
      tmux select-pane -t "$pane" -T "${member#atmux-${repo_name}-}" >/dev/null 2>&1 || true
      tmux set-option -p -t "$pane" @atmux_agent_session "$member" >/dev/null 2>&1 || true
      tmux set-option -p -t "$pane" @atmux_agent_name "${member#atmux-${repo_name}-}" >/dev/null 2>&1 || true
      pane_count=$((pane_count + 1))
      [[ -n "$pane_window" ]] && tmux select-layout -t "$pane_window" even-horizontal >/dev/null 2>&1 || true
    fi
  done < <(team_member_sessions_from_state "$repo_name" "$team_name")
  if (( pane_count == 0 )); then
    tmux new-session -d -s "$team_session" -n "$team_session" -c "$repo_root" "cat"
    tmux set-window-option -t "${team_session}:0" remain-on-exit on >/dev/null 2>&1 || true
    atmux_configure_tmux_pane_defaults "$team_session"
    tmux set-environment -t "$team_session" ATMUX_REPO "$repo_name" >/dev/null 2>&1 || true
    tmux set-environment -t "$team_session" ATMUX_TEAM "$team_name" >/dev/null 2>&1 || true
    tmux set-environment -t "$team_session" ATMUX_SESSION_NAME "$team_session" >/dev/null 2>&1 || true
    tmux set-environment -t "$team_session" ATMUX_SESSION_KIND "team-view" >/dev/null 2>&1 || true
  fi
  if [[ "$attach_view" -eq 1 ]]; then
    if atmux_tmux_current_client_is_project_server; then
      tmux switch-client -t "$team_session"
      return 0
    fi
    real_tmux="$(atmux_real_tmux_bin)" || exit 1
    socket="$(atmux_tmux_socket)"
    exec "$real_tmux" -S "$socket" attach-session -t "$team_session"
  fi
  printf '<team-view name="%s" repo="%s" session="%s" />\n' \
    "$(xml_escape "$team_name")" \
    "$(xml_escape "$repo_name")" \
    "$(xml_escape "atmux-${repo_name}-team-${team_name}")"
}

sub="${1:-}"
shift || true

case "$sub" in
  create|_create)
    create_team "$@"
    ;;
  _idle-watch)
    run_team_idle_watch "$@"
    ;;
  list|ls)
    list_teams
    ;;
  status)
    here_team="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    exec "$here_team/(list)/team-status" "$@"
    ;;
  capture)
    here_team="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux team capture <name> [--tiled] [--lines N]" >&2
      exit 2
    fi
    target_name="$1"; shift
    exec "$here_team/(internal)/capture" --team "$target_name" "$@"
    ;;
  kill)
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux team kill <name|pattern> [...]" >&2
      exit 2
    fi
    kill_teams "$@"
    ;;
  view)
    view_team "$@"
    ;;
  resolve)
    target="${1:-}"
    if [[ -z "$target" ]]; then
      echo "usage: atmux team resolve <name> [<repo_name>]" >&2
      exit 2
    fi
    r_repo="${2:-}"
    if [[ -z "$r_repo" ]]; then
      r_repo="$(repo_name_from_context)"
    fi

    if team_name="$(resolve_team_name "$target" "$r_repo")"; then
      printf 'atmux-%s-team-%s\n' "$r_repo" "$team_name"
      exit 0
    fi
    exit 1
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown team command: $sub" >&2
    exit 2
    ;;
esac
