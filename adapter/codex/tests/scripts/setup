#!/usr/bin/env bash
set -euo pipefail

SCRIPTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$(cd -- "$SCRIPTS_DIR/.." && pwd)"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"

SESSION_PREFIX="${ATMUX_CODEX_TEST_SESSION_PREFIX:-atmux-codex-test}"
WORKDIR="${ATMUX_CODEX_TEST_WORKDIR:-$REPO_ROOT}"
TIMEOUT="${ATMUX_CODEX_TEST_TIMEOUT:-60}"

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "missing required command: $1" >&2
    exit 1
  }
}

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="$3"
  local interval="0.5"
  local lines="500"

  local deadline now snapshot
  deadline=$(( $(date +%s) + timeout ))

  while true; do
    snapshot="$(tmux capture-pane -p -t "$target" -S "-$lines" 2>/dev/null || true)"
    if printf '%s\n' "$snapshot" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep "$interval"
  done
}

require_cmd tmux
require_cmd codex

session_name="${ATMUX_CODEX_TEST_SESSION_NAME:-${SESSION_PREFIX}-$(date +%s)-$$}"
if tmux has-session -t "$session_name" 2>/dev/null; then
  tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
fi

codex_cmd="codex --dangerously-bypass-approvals-and-sandbox --search"
tmux new-session -d -s "$session_name" -n "$session_name" -c "$WORKDIR" "$codex_cmd"

pane_id="$(tmux list-panes -t "$session_name" -F '#{pane_id}' 2>/dev/null | head -n 1)"
[[ -n "$pane_id" ]] || { echo "unable to resolve pane id" >&2; exit 1; }

if ! wait_for_text "$pane_id" "OpenAI Codex" "$TIMEOUT"; then
  tmux capture-pane -p -t "$pane_id" -S -120 >&2 || true
  echo "timed out waiting for OpenAI Codex" >&2
  exit 1
fi

printf 'SESSION_NAME=%s\n' "$session_name"
printf 'PANE_ID=%s\n' "$pane_id"
