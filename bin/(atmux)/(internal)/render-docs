#!/usr/bin/env bash
# Render README.md from the same sources of truth: command `usage()`
# heredocs, executable command layout, roles, and adapter manifests.
#
#   render-docs readme        # write README.md
#   render-docs all           # all generated docs (currently README.md)
#   render-docs all --check   # render to a tmpdir and diff vs on-disk
#
# Pure bash + python3 (used only for adapter manifest parsing). Pure
# runtime atmux still has no python3 dependency — this is a dev tool.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$ROOT" ]]; then
  ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)"
fi

CMD_DIR="$ROOT/bin/(atmux)"
ADAPTER_DIR="$ROOT/adapter"
TEMPLATE_DIR="$ROOT/templates"

# shellcheck source=bin/(atmux)/(lib)/command-docs
source "$ROOT/bin/(atmux)/(lib)/command-docs"

require_python3() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "render-docs: python3 is required for adapter manifest parsing" >&2
    exit 2
  fi
}

command_files() {
  atmux_command_files "$CMD_DIR" public
}

# Extract the first heredoc inside a `usage()`-like function. Matches
# `cat <<'<DELIM>'` where the body's first non-empty line begins with
# `Usage:`. Captures lines up to the closing `<DELIM>`. Trims trailing
# blank lines.
extract_usage_block() {
  atmux_extract_usage_block "$1"
}

# Split a usage block on its top-level section labels (Usage:, Description:,
# Examples:, Options:, Notes:, Durations:). Emits a stream of records:
#   <SECTION_LABEL>
#   <body line>
#   <body line>
#   ...
#   <SECTION_LABEL>
#   ...
# Body lines are de-indented by stripping the leading two spaces that the
# heredocs use.
render_command_section() {
  local name="$1" file="$2" heading="$3"
  if [[ ! -f "$file" ]]; then
    return 0
  fi

  # Per-command markdown override. When templates/cli/<name>.md exists,
  # use it verbatim under the section heading. The heredoc in the script
  # is the source of truth for terminal `--help`; this file is the source
  # of truth for the rendered markdown. Either can be edited independently.
  local override="$TEMPLATE_DIR/cli/$name.md"
  if [[ -f "$override" ]]; then
    # `$(...)` strips trailing newlines, normalising whatever the override
    # ends with. We then re-add exactly one blank line so consecutive
    # sections are separated cleanly.
    local body
    body="$(cat "$override")"
    printf '%s `%s`\n\n%s\n\n' "$heading" "$name" "$body"
    return 0
  fi

  local block
  block="$(extract_usage_block "$file")"
  if [[ -z "$block" ]]; then
    return 0
  fi

  printf '%s `%s`\n\n' "$heading" "$name"

  # Buffer the body of each section so trailing blank lines can be stripped
  # before the closing code fence. Without this, every section ends with a
  # blank line inside the fence, which reads sloppily.
  local current=""
  local body=""
  flush() {
    if [[ -z "$current" ]]; then return 0; fi
    # Strip trailing blank lines from $body.
    while [[ "$body" == *$'\n' ]]; do body="${body%$'\n'}"; done
    case "$current" in
      Usage|Examples)
        printf '```sh\n%s\n```\n\n' "$body"
        ;;
      Description|Notes)
        printf '%s\n\n' "$body"
        ;;
      Options|Durations)
        printf '**%s**\n\n```\n%s\n```\n\n' "$current" "$body"
        ;;
    esac
    body=""
    current=""
  }
  while IFS= read -r line; do
    if [[ "$line" == "##SECTION##"* ]]; then
      flush
      current="${line#"##SECTION##"}"
      continue
    fi
    if [[ -n "$current" ]]; then
      body+="$line"$'\n'
    fi
  done < <(printf '%s\n' "$block" | atmux_split_usage_sections)
  flush
}

extract_description_summary() {
  atmux_extract_description_summary
}

extract_primary_usage() {
  atmux_extract_primary_usage
}

command_summary_row() {
  local name="$1" file="$2" block sections usage desc
  [[ -f "$file" ]] || return 0
  block="$(extract_usage_block "$file")"
  [[ -n "$block" ]] || return 0
  sections="$(printf '%s\n' "$block" | atmux_split_usage_sections)"
  usage="$(printf '%s\n' "$sections" | extract_primary_usage)"
  desc="$(printf '%s\n' "$sections" | extract_description_summary)"
  [[ -n "$usage" ]] || usage="atmux $name"
  [[ -n "$desc" ]] || desc="Run \`atmux $name --help\` for details."
  usage="${usage//|/\\|}"
  desc="${desc//|/\\|}"
  printf '| `%s` | %s |\n' "$usage" "$desc"
}

render_command_index() {
  printf '| Command | Purpose |\n'
  printf '|---------|---------|\n'
  local file
  while IFS= read -r file; do
    command_summary_row "$(basename "$file")" "$file"
  done < <(command_files)
}

render_top_level_usage() {
  local tmp_home block
  tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-render-help.XXXXXX")"
  block="$(env -u ATMUX_AGENT_NAME -u ATMUX_TEAM -u ATMUX_SESSION_NAME \
    ATMUX_HOME="$tmp_home" ATMUX_SOURCE_ROOT="$ROOT" ATMUX_NO_WRAP=1 "$ROOT/bin/atmux" --help)"
  rm -rf "$tmp_home"
  printf '```text\n%s\n```\n' "$block"
}

render_intelligence_scale() {
  require_python3
  python3 - "$ADAPTER_DIR" <<'PY'
import os, re, shlex, sys
adapter_dir = sys.argv[1]
def parse_manifest(path):
    data = {"name": None, "rows": []}
    text = open(path).read()
    m = re.search(r'^NAME=(.+)$', text, re.M)
    if m:
        parts = shlex.split(m.group(1))
        data["name"] = parts[0] if parts else None
    block = re.search(r'INTELLIGENCE_MAP=\(\n(.*?)\n\)', text, re.S)
    if block:
        for raw in re.findall(r'^\s*"([^"]+)"', block.group(1), re.M):
            parts = raw.split()
            if len(parts) >= 4:
                data["rows"].append({"min": parts[0], "max": parts[1], "model": parts[2], "reasoning_level": parts[3]})
    return data
print("| Adapter | Intelligence | Model | Reasoning level |")
print("|---------|--------------|-------|-----------------|")
for name in sorted(os.listdir(adapter_dir)):
    manifest = os.path.join(adapter_dir, name, "manifest")
    if not os.path.isfile(manifest):
        continue
    data = parse_manifest(manifest)
    for row in data.get("rows", []):
        rng = f"{row['min']}–{row['max']}"
        print(f"| `{data['name']}` | {rng} | `{row['model']}` | `{row['reasoning_level']}` |")
PY
}

render_adapter_list() {
  require_python3
  python3 - "$ADAPTER_DIR" <<'PY'
import os, re, shlex, sys
adapter_dir = sys.argv[1]
print("| Adapter | CLI |")
print("|---------|-----|")
for name in sorted(os.listdir(adapter_dir)):
    manifest = os.path.join(adapter_dir, name, "manifest")
    if not os.path.isfile(manifest):
        continue
    text = open(manifest).read()
    m = re.search(r'^NAME=(.+)$', text, re.M)
    parts = shlex.split(m.group(1)) if m else []
    adapter_name = parts[0] if parts else name
    display_path = os.path.join(adapter_dir, name, "display.txt")
    if os.path.isfile(display_path):
        with open(display_path) as f:
            display = f.read().strip()
    else:
        display = adapter_name
    print(f"| `{adapter_name}` | {display} |")
PY
}

render_env_vars_table() {
  printf '| Variable | Description |\n'
  printf '|----------|-------------|\n'
  while IFS=$'\t' read -r var desc; do
    [[ -z "$var" ]] && continue
    printf '| `%s` | %s |\n' "$var" "$desc"
  done < "$TEMPLATE_DIR/env-vars.tsv"
}

extract_first_markdown_paragraph() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  awk '
    /^[[:space:]]*$/ {
      if (started) exit
      next
    }
    /^[[:space:]]*#/ { next }
    {
      line=$0
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      if (started) out = out " " line
      else { out = line; started = 1 }
    }
    END { print out }
  ' "$file"
}

render_builtin_team_member_list() {
  local team_dir="$1"
  local roles_dir="$team_dir/roles"
  [[ -d "$roles_dir" ]] || return 0

  local member_dir name readme role_md link_target desc sep
  sep=""
  set -- "$roles_dir"/*
  for member_dir in "$@"; do
    [[ -d "$member_dir" ]] || continue
    name="$(basename "$member_dir")"

    readme="$member_dir/README.md"
    role_md="$member_dir/role.md"
    if [[ -f "$readme" ]]; then
      link_target="${member_dir#"$ROOT/"}"/README.md
      desc="$(extract_first_markdown_paragraph "$readme")"
    else
      link_target="${member_dir#"$ROOT/"}"/role.md
      desc="$(extract_first_markdown_paragraph "$role_md")"
    fi
    if [[ -z "$desc" && -f "$role_md" ]]; then
      desc="$(extract_first_markdown_paragraph "$role_md")"
    fi
    desc="${desc//|/\\|}"

    printf '%s[`%s`](%s)' "$sep" "$name" "$link_target"
    if [[ -n "$desc" ]]; then
      printf ': %s' "$desc"
    fi
    sep="<br>"
  done
}

render_builtin_role_rows() {
  local target_kind="$1"
  [[ -d "$ROOT/roles" ]] || return 0

  local role_dir name readme role_md link_target desc demo members
  case "$target_kind" in
    agent)
      set -- "$ROOT"/roles/agents/*
      ;;
    team)
      set -- "$ROOT"/roles/teams/*
      ;;
    *)
      return 0
      ;;
  esac
  for role_dir in "$@"; do
    [[ -d "$role_dir" ]] || continue
    name="$(basename "$role_dir")"

    readme="$role_dir/README.md"
    role_md="$role_dir/role.md"
    if [[ -f "$readme" ]]; then
      link_target="${role_dir#"$ROOT/"}"/README.md
      desc="$(extract_first_markdown_paragraph "$readme")"
    else
      link_target="${role_dir#"$ROOT/"}"/role.md
      desc="$(extract_first_markdown_paragraph "$role_md")"
    fi
    if [[ -z "$desc" && -f "$role_md" ]]; then
      desc="$(extract_first_markdown_paragraph "$role_md")"
    fi
    desc="${desc//|/\\|}"

    demo=""
    if [[ -f "$role_dir/demo.gif" ]]; then
      demo="[demo](${role_dir#"$ROOT/"}/demo.gif)"
    fi

    if [[ "$target_kind" == "team" ]]; then
      members="$(render_builtin_team_member_list "$role_dir")"
      printf '| [`%s`](%s) | %s | %s | %s |\n' "$name" "$link_target" "$desc" "$members" "$demo"
    else
      printf '| [`%s`](%s) | %s | %s |\n' "$name" "$link_target" "$desc" "$demo"
    fi
  done
}

render_builtin_role_table() {
  local title="$1" kind="$2" rows
  rows="$(render_builtin_role_rows "$kind")"
  [[ -n "$rows" ]] || return 0

  printf '#### %s\n\n' "$title"
  if [[ "$kind" == "team" ]]; then
    printf '| Role | Description | Members | Demo |\n'
    printf '|------|-------------|---------|------|\n'
  else
    printf '| Role | Description | Demo |\n'
    printf '|------|-------------|------|\n'
  fi
  printf '%s\n\n' "$rows"
}

render_builtin_roles() {
  render_builtin_role_table "Built-in agent roles" "agent"
  render_builtin_role_table "Built-in team roles" "team"
}

render_version() {
  cat "$ROOT/VERSION"
}

# Read the template and substitute every {{TOKEN}} by piping the token's
# rendered value through a placeholder line. Done in a single awk pass so
# tokens can appear anywhere on a line.
render_template() {
  local template_file="$1"
  local tmpdir
  tmpdir="$(mktemp -d)"
  trap "rm -rf $tmpdir" RETURN

  render_top_level_usage          > "$tmpdir/TOP_LEVEL_USAGE"
  render_intelligence_scale       > "$tmpdir/INTELLIGENCE_SCALE"
  render_adapter_list             > "$tmpdir/ADAPTER_LIST"
  render_command_index            > "$tmpdir/COMMAND_INDEX"
  render_env_vars_table           > "$tmpdir/ENV_VARS_TABLE"
  render_builtin_roles            > "$tmpdir/BUILT_IN_ROLES"
  render_version                  > "$tmpdir/VERSION"

  awk -v tdir="$tmpdir" '
    function read_token(name,    file, l, content, first) {
      file = tdir "/" name
      content = ""
      first = 1
      while ((getline l < file) > 0) {
        if (first) { content = l; first = 0 }
        else       { content = content "\n" l }
      }
      close(file)
      return content
    }
    {
      line=$0
      out=""
      emitted_block=0
      while (match(line, /\{\{[A-Z_]+\}\}/)) {
        before=substr(line, 1, RSTART-1)
        token=substr(line, RSTART+2, RLENGTH-4)
        after=substr(line, RSTART+RLENGTH)
        value=read_token(token)
        # Single-line token: splice inline. Multi-line: emit the prefix on
        # its own line, then the multi-line block, then continue with the
        # suffix on the next iteration so any further tokens are still
        # processed.
        if (index(value, "\n") == 0) {
          out = out before value
        } else {
          if (out before != "") print out before
          # Trim trailing blank lines from multi-line tokens. Without this,
          # a token whose contents end with `\n\n` plus the templates own
          # trailing blank line accumulate into 2+ blank lines.
          sub(/\n+$/, "", value)
          print value
          out = ""
          emitted_block = 1
        }
        line = after
      }
      # When a block-emitting token consumed the whole template line, dont
      # also emit the line itself — that would inject an extra blank.
      if (emitted_block && out == "" && line == "") next
      print out line
    }
  ' "$template_file"
}

render_readme() {
  render_template "$TEMPLATE_DIR/README.md.tmpl"
}

write_or_check() {
  local target="$1"
  local content="$2"
  if (( CHECK )); then
    if ! diff -u "$target" <(printf '%s' "$content"); then
      echo
      echo "render-docs: $target is out of sync." >&2
      echo "Run: bin/(atmux)/(internal)/render-docs readme" >&2
      DRIFT=1
    fi
  else
    printf '%s' "$content" > "$target"
    echo "wrote $target"
  fi
}

cmd_readme() {
  local out
  out="$(render_readme)"
  write_or_check "$ROOT/README.md" "$out"
}

cmd_all() {
  cmd_readme
}

main() {
  CHECK=0
  DRIFT=0
  local cmd=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --check) CHECK=1; shift ;;
      readme|all) cmd="$1"; shift ;;
      -h|--help)
        sed -n '2,12p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
        exit 0
        ;;
      *)
        echo "render-docs: unknown argument: $1" >&2
        exit 64
        ;;
    esac
  done
  if [[ -z "$cmd" ]]; then
    echo "render-docs: usage: render-docs {readme|all} [--check]" >&2
    exit 64
  fi
  case "$cmd" in
    readme)       cmd_readme ;;
    all)          cmd_all ;;
  esac
  if (( CHECK && DRIFT )); then
    exit 1
  fi
}

main "$@"
