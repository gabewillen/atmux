#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_absence() {
  local target="$1"
  local needle="$2"
  local duration="${3:-1}"
  local deadline snap compact now
  deadline=$(( $(date +%s) + duration ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 1
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 0
    fi
    sleep 0.1
  done
}

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-issue.XXXXXX")"
repo_name="is$RANDOM"
session_a="atmux-${repo_name}-boss"
session_b="atmux-${repo_name}-watcher"
atmux_home="$tmp_home/.atmux"
issues_root="$atmux_home/issues/$repo_name"

cleanup() {
  tmux kill-session -t "$session_a" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_b" >/dev/null 2>&1 || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session_a" >/dev/null 2>&1 || true
tmux kill-session -t "$session_b" >/dev/null 2>&1 || true

tmux new-session -d -s "$session_a" -n "$session_a" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux new-session -d -s "$session_b" -n "$session_b" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

tmux set-environment -t "$session_a" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_a" ATMUX_AGENT_NAME "boss"
tmux set-environment -t "$session_a" ATMUX_SESSION_NAME "$session_a"
tmux set-environment -t "$session_b" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_b" ATMUX_AGENT_NAME "watcher"
tmux set-environment -t "$session_b" ATMUX_SESSION_NAME "$session_b"

pane_a="$(tmux list-panes -t "$session_a" -F '#{pane_id}' 2>/dev/null | head -n1)"
pane_b="$(tmux list-panes -t "$session_b" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_a" && -n "$pane_b" ]] || { echo "missing panes" >&2; exit 1; }

set +e
out_rej="$(ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" "$ATMUX_BIN" watch --issue 00000000-0000-0000-0000-000000000001 2>&1)"
rc_rej=$?
set -e
[[ "$rc_rej" -eq 2 ]] || { echo "expected reject exit 2, got $rc_rej: $out_rej" >&2; exit 1; }

create_out="$(ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" "$ATMUX_BIN" issue create --title "watch-issue" --repo "$repo_name")"
issue_id="$(printf '%s\n' "$create_out" | sed -n 's/.*id="\([^"]*\)".*/\1/p' | head -n1)"
[[ -n "$issue_id" ]] || { echo "failed to parse issue id" >&2; exit 1; }

tmux send-keys -t "$pane_b" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watcher\" ATMUX_SESSION_NAME=\"$session_b\" \"$ATMUX_BIN\" watch --issue \"$issue_id\"" C-m

# Wait for the watcher file to appear before assigning, to avoid a race where
# issue assign fans out before the watcher has registered itself.
watcher_dir="$issues_root/$issue_id/watchers"
watcher_deadline=$(( $(date +%s) + 10 ))
while true; do
  wcount=0
  if [[ -d "$watcher_dir" ]]; then
    wcount="$(find "$watcher_dir" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  [[ "${wcount:-0}" -gt 0 ]] && break
  now="$(date +%s)"
  if (( now >= watcher_deadline )); then
    echo "watcher file never appeared in $watcher_dir" >&2
    exit 1
  fi
  sleep 0.05
done

tmux send-keys -t "$pane_a" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"boss\" ATMUX_SESSION_NAME=\"$session_a\" \"$ATMUX_BIN\" issue assign \"$issue_id\" --to watcher" C-m

if ! wait_for_absence "$pane_a" '<notification type="issue"' 2; then
  echo "assigner pane unexpectedly received issue notification" >&2
  tmux capture-pane -p -t "$pane_a" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane_b" 'type="issue"' 35; then
  echo "watcher pane missing issue notification" >&2
  tmux capture-pane -p -t "$pane_b" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 15 ))
while true; do
  wdir="$issues_root/$issue_id/watchers"
  wcount=0
  if [[ -d "$wdir" ]]; then
    wcount="$(find "$wdir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -eq 0 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "expected no watcher files, got $wcount" >&2
    exit 1
  fi
  sleep 0.1
done

echo "ok: watch --issue validates, issue assign fans out to watcher without notifying assigner, watchers cleaned up"
