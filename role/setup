#!/usr/bin/env bash
set -euo pipefail

adapter=""
role="agent"
description="${AMUX_ROLE_DESCRIPTION:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --adapter)
      adapter="${2:-}"
      shift 2
      ;;
    --role)
      role="${2:-}"
      shift 2
      ;;
    --description)
      description="${2:-}"
      shift 2
      ;;
    *)
      echo "unknown flag: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "$adapter" ]]; then
  echo "missing --adapter" >&2
  exit 2
fi

role_setup="$(pwd)/role/${role}/setup"
if [[ ! -x "$role_setup" ]]; then
  echo "role setup not found: $role_setup" >&2
  exit 1
fi

if [[ -n "$description" ]]; then
  exec "$role_setup" --adapter "$adapter" --description "$description"
fi

exec "$role_setup" --adapter "$adapter"
