#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-gemini-test-home.XXXXXX")"
cleanup() {
  [[ -n "${session_name:-}" ]] && "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$atmux_home"
}
trap cleanup EXIT

start_cmd="ATMUX_HOME='$atmux_home' '$ADAPTER_DIR/scripts/start'"
setup_out="$("$SCRIPTS_DIR/setup" --command "$start_cmd" --wait-text 'Type your message')"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

model_list="$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" list)"
[[ "$model_list" == $'gemini-3.1-pro-preview\ngemini-3-flash-preview\ngemini-3.1-flash-lite-preview' ]] || { echo "unexpected model list: $model_list" >&2; exit 1; }

ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" set gemini-3.1-pro-preview high >/dev/null
[[ "$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" get)" == "gemini-3.1-pro-preview" ]] || { echo "unexpected model get" >&2; exit 1; }
[[ "$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" get)" == "high" ]] || { echo "unexpected reasoning get after model set" >&2; exit 1; }

ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" set medium >/dev/null
[[ "$(ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" get)" == "medium" ]] || { echo "unexpected reasoning-level get" >&2; exit 1; }

if ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/model" set invalid >/dev/null 2>&1; then
  echo "invalid model unexpectedly succeeded" >&2
  exit 1
fi
if ATMUX_HOME="$atmux_home" "$ADAPTER_DIR/scripts/reasoning-level" set invalid >/dev/null 2>&1; then
  echo "invalid reasoning-level unexpectedly succeeded" >&2
  exit 1
fi

echo "PASS 03_model_reasoning_contract"
