#!/usr/bin/env bash
# shellcheck shell=bash
# Shared helpers for exec, issue, watch --pid, watch --issue; also `atmux notify` CLI when executed.
# When sourced, only function definitions run (see bottom).

ATMUX_NOTIFY_SCRIPT_PATH="${BASH_SOURCE[0]}"

normalize_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

primary_pane_for_session() {
  local session="$1"
  tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }'
}

current_pane() {
  # Prefer TMUX_PANE (set by tmux per-pane) — display-message -p resolves
  # wrong without an attached client.
  if [[ -n "${TMUX_PANE:-}" ]]; then
    printf '%s\n' "$TMUX_PANE"
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux display-message -p '#{pane_id}' 2>/dev/null || true
    return 0
  fi
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    primary_pane_for_session "$ATMUX_SESSION_NAME"
    return 0
  fi
  return 0
}

pane_queue_key() {
  local pane="$1"
  local pane_pid=""
  pane_pid="$(tmux display-message -t "$pane" -p "#{pane_pid}" 2>/dev/null || true)"
  if [[ -n "$pane_pid" ]]; then
    pane="${pane}-${pane_pid}"
  fi
  printf '%s\n' "${pane//[^A-Za-z0-9_.-]/_}"
}

notify_queue_dir() {
  local pane="$1"
  printf '%s/notify-queue/%s\n' "$ATMUX_HOME" "$(pane_queue_key "$pane")"
}

resolve_notify_script_path() {
  local source_root="$1"
  local notify_script="$source_root/bin/(atmux)/notify"
  if [[ -x "$notify_script" ]]; then
    printf '%s\n' "$notify_script"
  else
    printf '%s\n' "$ATMUX_NOTIFY_SCRIPT_PATH"
  fi
}

resolve_input_prompt_for_adapter() {
  local adapter="$1"
  local source_root="$2"
  local manifest_path compact

  local ATMUX_SOURCE_ROOT="$source_root"
  if ! manifest_path="$(resolve_manifest_path "$adapter")"; then
    return 1
  fi

  compact="$(tr -d '\n\r\t' < "$manifest_path")"
  printf '%s' "$compact" | sed -n 's/.*"input_idle"[[:space:]]*:[[:space:]]*{[^}]*"prompt"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

normalize_prompt_text() {
  local text="${1:-}"
  local nbsp=$'\u00a0'
  text="${text//$nbsp/ }"
  printf '%s' "$text"
}

pane_cursor_position() {
  local pane="$1"
  local cursor_x cursor_y

  cursor_x="$(tmux display-message -t "$pane" -p "#{cursor_x}" 2>/dev/null || true)"
  cursor_y="$(tmux display-message -t "$pane" -p "#{cursor_y}" 2>/dev/null || true)"

  [[ "$cursor_x" =~ ^[0-9]+$ ]] || return 1
  [[ "$cursor_y" =~ ^[0-9]+$ ]] || return 1

  printf '%s %s\n' "$cursor_x" "$cursor_y"
}

truncate_line_to_cursor() {
  local line="${1:-}"
  local cursor_x="${2:-}"

  [[ "$cursor_x" =~ ^[0-9]+$ ]] || {
    printf '%s' "$line"
    return 0
  }

  if (( cursor_x <= 0 )); then
    printf ''
    return 0
  fi

  if command -v perl >/dev/null 2>&1; then
    printf '%s' "$line" | PERL_BADLANG=0 perl -CS -e '
      use utf8;
      my $limit = shift @ARGV;
      my $text = do { local $/; <STDIN> };
      print substr($text, 0, $limit);
    ' "$cursor_x"
    return 0
  fi

  printf '%s' "$line" | cut -c "1-${cursor_x}"
}

split_prompt_line() {
  local line normalized_line prompt normalized_prompt leading_trimmed rest

  line="$(normalize_prompt_text "${1:-}")"
  prompt="$(normalize_prompt_text "${2:-}")"
  prompt="${prompt%"${prompt##*[![:space:]]}"}"
  prompt="${prompt#"${prompt%%[![:space:]]*}"}"
  [[ -n "$prompt" ]] || return 1

  leading_trimmed="${line#"${line%%[![:space:]]*}"}"
  [[ "$leading_trimmed" == "$prompt"* ]] || return 1

  rest="${leading_trimmed#"$prompt"}"
  rest="${rest#"${rest%%[![:space:]]*}"}"
  printf '%s' "$rest"
}

resolve_prompt_prefix_for_pane() {
  local pane="$1"
  local source_root="$2"
  local sess adapter

  sess="$(tmux display-message -t "$pane" -p "#{session_name}" 2>/dev/null || true)"
  [[ -n "$sess" ]] || return 1

  adapter="$(get_session_env "$sess" ATMUX_ADAPTER)"
  [[ -n "$adapter" ]] || return 1

  resolve_input_prompt_for_adapter "$adapter" "$source_root"
}

resolve_adapter_for_pane() {
  local pane="$1"
  local sess

  sess="$(tmux display-message -t "$pane" -p "#{session_name}" 2>/dev/null || true)"
  [[ -n "$sess" ]] || return 1

  get_session_env "$sess" ATMUX_ADAPTER
}

resolve_status_script_for_adapter() {
  local adapter="$1"
  local source_root="$2"
  local status_script="$source_root/adapter/$adapter/scripts/status"

  if [[ -x "$status_script" ]]; then
    printf '%s\n' "$status_script"
    return 0
  fi

  status_script="$ATMUX_HOME/adapters/$adapter/scripts/status"
  if [[ -x "$status_script" ]]; then
    printf '%s\n' "$status_script"
    return 0
  fi

  return 1
}

status_state_from_xml() {
  local xml="${1:-}"
  printf '%s\n' "$xml" | sed -n 's/.*state="\([^"]*\)".*/\1/p' | tail -n 1
}

extract_prompt_input() {
  local pane="$1"
  local prompt_prefix="$2"
  local snap line cursor_x cursor_y cursor_info
  local -a lines=()
  local end_idx
  local start_idx=-1
  local idx saved_input=""

  [[ -n "$prompt_prefix" ]] || return 0

  snap="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
  while IFS= read -r line; do
    lines+=("$line")
  done <<< "$snap"
  [[ ${#lines[@]} -gt 0 ]] || return 0

  cursor_info="$(pane_cursor_position "$pane" 2>/dev/null || true)"
  if [[ -n "$cursor_info" ]]; then
    cursor_x="${cursor_info%% *}"
    cursor_y="${cursor_info##* }"
    if (( cursor_y >= ${#lines[@]} )); then
      cursor_y=$((${#lines[@]} - 1))
    fi
    lines[cursor_y]="$(truncate_line_to_cursor "${lines[cursor_y]}" "$cursor_x")"
    end_idx=$cursor_y
  else
    end_idx=$((${#lines[@]} - 1))
  fi

  for (( idx=end_idx; idx>=0; idx-- )); do
    if split_prompt_line "${lines[idx]}" "$prompt_prefix" >/dev/null; then
      start_idx=$idx
      break
    fi
  done
  (( start_idx >= 0 )) || return 0

  saved_input="$(split_prompt_line "${lines[start_idx]}" "$prompt_prefix" || true)"
  for (( idx=start_idx + 1; idx<=end_idx; idx++ )); do
    saved_input+="${lines[idx]}"
  done
  printf '%s' "$saved_input"
}

pane_has_prompt_line() {
  local pane="$1"
  local prompt_prefix="$2"
  local snap line cursor_y cursor_info
  local -a lines=()
  local idx

  [[ -n "$prompt_prefix" ]] || return 1

  snap="$(tmux capture-pane -p -t "$pane" 2>/dev/null || true)"
  while IFS= read -r line; do
    lines+=("$line")
  done <<< "$snap"
  [[ ${#lines[@]} -gt 0 ]] || return 1

  cursor_info="$(pane_cursor_position "$pane" 2>/dev/null || true)"
  if [[ -n "$cursor_info" ]]; then
    cursor_y="${cursor_info##* }"
    if (( cursor_y >= ${#lines[@]} )); then
      cursor_y=$((${#lines[@]} - 1))
    fi
  else
    cursor_y=$((${#lines[@]} - 1))
  fi

  for (( idx=cursor_y; idx>=0; idx-- )); do
    if split_prompt_line "${lines[idx]}" "$prompt_prefix" >/dev/null; then
      return 0
    fi
  done

  return 1
}

restore_prompt_input() {
  local pane="$1"
  local prompt_prefix="$2"
  local saved_input="$3"
  local settle submit_wait
  local attempt

  [[ -n "$saved_input" ]] || return 0

  settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"
  submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.3}"

  if [[ -n "$prompt_prefix" ]]; then
    for (( attempt=0; attempt<20; attempt++ )); do
      if pane_has_prompt_line "$pane" "$prompt_prefix"; then
        break
      fi
      sleep 0.1
    done
  fi

  sleep "$settle"
  tmux send-keys -t "$pane" -l "$saved_input" >/dev/null 2>&1 || true
  sleep "$submit_wait"
}

wait_for_pane_ready() {
  local pane="$1"
  local source_root="$2"
  local prompt_prefix="${3:-}"
  local timeout="${4:-45}"
  local deadline now adapter status_script status_xml state

  deadline=$(( $(date +%s) + timeout ))
  adapter="$(resolve_adapter_for_pane "$pane" 2>/dev/null || true)"
  status_script=""
  if [[ -n "$adapter" ]]; then
    status_script="$(resolve_status_script_for_adapter "$adapter" "$source_root" 2>/dev/null || true)"
  fi

  while true; do
    if [[ -n "$prompt_prefix" ]] && ! pane_has_prompt_line "$pane" "$prompt_prefix"; then
      :
    else
      if [[ -n "$status_script" ]]; then
        status_xml="$(ATMUX_HOME="$ATMUX_HOME" ATMUX_SOURCE_ROOT="$source_root" ATMUX_STATUS_PASSIVE=1 \
          ATMUX_TARGET_PANE="$pane" "$status_script" 2>/dev/null || true)"
        state="$(status_state_from_xml "$status_xml")"
        case "$state" in
          idle|errored|usage-limit) return 0 ;;
        esac
      else
        return 0
      fi
    fi

    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

deliver_notification_to_pane() {
  local pane="$1"
  local payload="$2"
  local submit_keys="$3"
  local settle submit_wait
  local sk

  settle="${ATMUX_SEND_SETTLE_SECONDS:-0.4}"
  submit_wait="${ATMUX_SEND_SUBMIT_WAIT_SECONDS:-0.3}"

  tmux send-keys -t "$pane" C-u >/dev/null 2>&1 || return 0
  sleep "$settle"
  tmux send-keys -t "$pane" -l "$payload" >/dev/null 2>&1 || return 0
  sleep "$settle"
  for sk in $submit_keys; do
    tmux send-keys -t "$pane" "$sk" >/dev/null 2>&1 || return 0
  done
  sleep "$submit_wait"
}

next_notification_queue_id() {
  local qdir="$1"
  local lock_dir="$qdir/seq.lock"
  local current="0"
  local next=1

  mkdir -p "$qdir"
  while ! mkdir "$lock_dir" 2>/dev/null; do
    sleep 0.01
  done

  if [[ -f "$qdir/next_id" ]]; then
    current="$(tr -d '\r\n' < "$qdir/next_id" 2>/dev/null || printf '0')"
    [[ "$current" =~ ^[0-9]+$ ]] || current="0"
    next="$(( 10#$current + 1 ))"
  fi
  printf '%s\n' "$next" > "$qdir/next_id"
  rmdir "$lock_dir" >/dev/null 2>&1 || true

  printf '%010d\n' "$next"
}

queue_notification_payload() {
  local pane="$1"
  local payload="$2"
  local submit_key_str="$3"
  local qdir payload_dir queue_id item_dir

  qdir="$(notify_queue_dir "$pane")"
  payload_dir="$qdir/payloads"
  mkdir -p "$payload_dir"

  queue_id="$(next_notification_queue_id "$qdir")"
  item_dir="$payload_dir/$queue_id"
  mkdir -p "$item_dir"
  write_field "$item_dir/payload" "$payload"
  write_field "$item_dir/submit_keys" "$submit_key_str"
}

acquire_notification_worker_lock() {
  local qdir="$1"
  local lock_dir="$qdir/lock"
  local pid_file="$qdir/worker.pid"
  local pid=""

  if mkdir "$lock_dir" 2>/dev/null; then
    printf '%s\n' "$$" > "$pid_file"
    return 0
  fi

  if [[ -f "$pid_file" ]]; then
    pid="$(tr -d '\r\n' < "$pid_file" 2>/dev/null || true)"
  fi
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    return 1
  fi

  rm -rf "$lock_dir" "$pid_file"
  if mkdir "$lock_dir" 2>/dev/null; then
    printf '%s\n' "$$" > "$pid_file"
    return 0
  fi
  return 1
}

drain_notification_queue() {
  local pane="$1"
  local source_root="$2"
  local qdir payload_dir item_dir payload submit_keys
  local prompt_prefix="" saved_input=""
  local idle_polls=0
  local max_idle_polls=5
  local -a items=()

  qdir="$(notify_queue_dir "$pane")"
  payload_dir="$qdir/payloads"

  [[ -d "$payload_dir" ]] || return 0
  acquire_notification_worker_lock "$qdir" || return 0

  trap 'rm -rf "$qdir/lock" "$qdir/worker.pid"' EXIT

  prompt_prefix="$(resolve_prompt_prefix_for_pane "$pane" "$source_root" 2>/dev/null || true)"
  if [[ -n "$prompt_prefix" ]]; then
    saved_input="$(extract_prompt_input "$pane" "$prompt_prefix")"
  fi

  while true; do
    items=()
    while IFS= read -r item_dir; do
      [[ -n "$item_dir" ]] || continue
      items+=("$item_dir")
    done < <(find "$payload_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
    if [[ ${#items[@]} -eq 0 ]]; then
      idle_polls=$((idle_polls + 1))
      if (( idle_polls >= max_idle_polls )); then
        break
      fi
      sleep 0.05
      continue
    fi
    idle_polls=0

    for item_dir in "${items[@]}"; do
      [[ -d "$item_dir" ]] || continue
      payload="$(cat "$item_dir/payload" 2>/dev/null || true)"
      submit_keys="$(cat "$item_dir/submit_keys" 2>/dev/null || printf 'Enter')"
      deliver_notification_to_pane "$pane" "$payload" "$submit_keys"
      rm -rf "$item_dir"
    done
  done

  restore_prompt_input "$pane" "$prompt_prefix" "$saved_input"

  rm -rf "$qdir/lock" "$qdir/worker.pid"
  trap - EXIT
  rmdir "$payload_dir" >/dev/null 2>&1 || true
  rm -f "$qdir/next_id"
  rmdir "$qdir" >/dev/null 2>&1 || true
}

# Send a notification to a pane in the background. Delivery is serialized per
# pane so rapid sends cannot interleave or clobber restored input.
send_notification() {
  local pane="$1"
  local payload="$2"
  shift 2
  local submit_key_str="${*:-Enter}"
  [[ -n "$pane" ]] || return 0

  local source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME:-$HOME/.atmux}/src/atmux}"
  local notify_script
  notify_script="$(resolve_notify_script_path "$source_root")"

  queue_notification_payload "$pane" "$payload" "$submit_key_str"

  nohup env \
    ATMUX_HOME="$ATMUX_HOME" \
    ATMUX_SOURCE_ROOT="$source_root" \
    "$notify_script" __drain-queue --pane "$pane" --source-root "$source_root" >/dev/null 2>&1 &
}

# Unified notification builder.
# Usage: build_notification <type> <from> <cmd> [key=value ...]
# Output: <notification type="..." from="..." cmd="..." key="value" ... />
build_notification() {
  local type="$1" from="$2" cmd="$3"
  shift 3
  local attrs=""
  local kv k v
  for kv in "$@"; do
    k="${kv%%=*}"
    v="${kv#*=}"
    attrs+=" ${k}=\"$(xml_escape "$v")\""
  done
  local cmd_attr=""
  if [[ -n "$cmd" ]]; then
    cmd_attr=" cmd=\"$(xml_escape "$cmd")\""
  fi
  printf '<notification type="%s" from="%s"%s%s />' \
    "$(xml_escape "$type")" \
    "$(xml_escape "$from")" \
    "$cmd_attr" \
    "$attrs"
}

get_session_env() {
  local session="$1" key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

session_short_name() {
  local session="$1" repo="$2"
  local prefix="atmux-${repo}-"
  if [[ -n "$repo" && "$session" == "$prefix"* ]]; then
    printf '%s\n' "${session#"$prefix"}"
  else
    printf '%s\n' "$session"
  fi
}

resolve_manifest_path() {
  local adapter="$1"
  local source_root manifest_path

  source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"
  manifest_path="$source_root/adapter/$adapter/manifest.json"
  if [[ -f "$manifest_path" ]]; then
    printf '%s\n' "$manifest_path"
    return 0
  fi
  manifest_path="$ATMUX_HOME/adapters/$adapter/manifest.json"
  if [[ -f "$manifest_path" ]]; then
    printf '%s\n' "$manifest_path"
    return 0
  fi
  return 1
}

resolve_submit_keys() {
  local adapter="$1"
  local mode="${2:-queue}"
  local manifest_path compact raw_keys

  if ! manifest_path="$(resolve_manifest_path "$adapter")"; then
    printf 'Enter\n'
    return 0
  fi

  compact="$(tr -d '\n\r\t ' < "$manifest_path")"
  raw_keys="$(printf '%s' "$compact" | sed -n "s/.*\"${mode}\":\[\([^]]*\)\].*/\1/p")"
  if [[ -z "$raw_keys" ]]; then
    printf 'Enter\n'
    return 0
  fi

  printf '%s' "$raw_keys" | sed 's/"//g; s/,/\n/g'
}

timestamp_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

repo_name_from_context() {
  local repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo_name="$(basename "$repo_root")"
    fi
  fi
  normalize_name "$repo_name"
}

write_field() {
  local file="$1"
  local value="${2:-}"
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$value" > "$file"
}

exec_root_for_repo() {
  local repo_name="$1"
  printf '%s/exec/%s\n' "$ATMUX_HOME" "$repo_name"
}

exec_dir_for_repo_pid() {
  local repo_name="$1"
  local pid="$2"
  printf '%s/%s\n' "$(exec_root_for_repo "$repo_name")" "$pid"
}

read_state_field() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    printf ''
    return 0
  fi
  tr -d '\r\n' <"$file" 2>/dev/null || printf ''
}

validate_exec_ownership() {
  local exec_dir="$1"
  local expect_pid="$2"
  local expect_repo="$3"
  local got_pid got_repo

  [[ -d "$exec_dir" ]] || return 1
  got_pid="$(read_state_field "$exec_dir/pid")"
  got_repo="$(read_state_field "$exec_dir/repo")"
  [[ -n "$got_pid" && "$got_pid" == "$expect_pid" ]] || return 1
  [[ -n "$got_repo" && "$got_repo" == "$expect_repo" ]] || return 1
  return 0
}

issue_root_for_repo() {
  local repo="$1"
  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  printf '%s/issues/%s\n' "$atmux_home" "$repo"
}

issue_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

notify_exec_watchers() {
  local exec_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$exec_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    send_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

notify_issue_watchers() {
  local issue_dir="$1"
  local skip_pane="$2"
  local payload="$3"
  local wdir="$issue_dir/watchers"
  [[ -d "$wdir" ]] || return 0
  local f pane
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    [[ -f "$f" ]] || continue
    pane="$(tr -d '\r\n' <"$f" 2>/dev/null || true)"
    [[ -n "$pane" ]] || continue
    [[ "$pane" == "$skip_pane" ]] && continue
    send_notification "$pane" "$payload"
  done < <(find "$wdir" -maxdepth 1 -type f 2>/dev/null)
}

# Convenience wrapper — callers pass submit_keys as an array.
send_payload_to_pane() {
  local target="$1"
  local payload="$2"
  shift 2
  local submit_keys=("$@")
  [[ ${#submit_keys[@]} -gt 0 ]] || submit_keys=("Enter")
  send_notification "$target" "$payload" "${submit_keys[@]}"
}

notify_cli_usage() {
  cat <<'USAGE'
Usage:
  atmux notify --pane <tmux-pane-id> --xml <payload> [--interrupt]

Description:
  Send an ATMUX XML notification to a tmux pane.
  --interrupt  Use the adapter's interrupt submit key instead of the default
               key (Enter). Resolves the adapter from the pane's session, or from
               --session if provided.

Examples:
  atmux notify --pane %12 --xml '<notification type="test" from="manual" cmd="atmux message read abc" />'
  atmux notify --pane %12 --xml '<notification type="urgent" from="mgr" />' --interrupt
USAGE
}

notify_cli_main() {
  local pane=""
  local xml_payload=""
  local interrupt=0
  local session=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane)
        pane="${2:-}"
        shift 2
        ;;
      --xml)
        xml_payload="${2:-}"
        shift 2
        ;;
      --interrupt)
        interrupt=1
        shift
        ;;
      --session)
        session="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        notify_cli_usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        notify_cli_usage >&2
        exit 2
        ;;
    esac
  done

  [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
  [[ -n "$xml_payload" ]] || { echo "missing --xml" >&2; exit 2; }

  local submit_keys=()
  if [[ "$interrupt" -eq 1 ]]; then
    local adapter="" resolve_session="$session"
    if [[ -z "$resolve_session" && -n "$pane" ]]; then
      resolve_session="$(tmux display-message -t "$pane" -p '#{session_name}' 2>/dev/null || true)"
    fi
    if [[ -n "$resolve_session" ]]; then
      adapter="$(get_session_env "$resolve_session" ATMUX_ADAPTER)"
      if [[ -n "$adapter" ]]; then
        mapfile -t submit_keys < <(resolve_submit_keys "$adapter" "interrupt")
      fi
    fi
  fi

  send_notification "$pane" "$xml_payload" ${submit_keys[@]+"${submit_keys[@]}"}
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  set -euo pipefail
  ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
  case "${1:-}" in
    __drain-queue)
      shift
      pane=""
      source_root="${ATMUX_SOURCE_ROOT:-${ATMUX_HOME}/src/atmux}"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --pane)
            pane="${2:-}"
            shift 2
            ;;
          --source-root)
            source_root="${2:-}"
            shift 2
            ;;
          *)
            echo "unknown flag: $1" >&2
            exit 2
            ;;
        esac
      done
      [[ -n "$pane" ]] || { echo "missing --pane" >&2; exit 2; }
      drain_notification_queue "$pane" "$source_root"
      ;;
    build)
      shift
      build_notification "$@"
      ;;
    --pane|--xml|-h|--help|help|"")
      notify_cli_main "$@"
      ;;
    *)
      notify_cli_main "$@"
      ;;
  esac
fi
