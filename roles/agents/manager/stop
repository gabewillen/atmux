#!/usr/bin/env bash
# Role stop hook for manager. Tears down feed watcher registrations.
set -euo pipefail

state="${ATMUX_ROLE_STATE_DIR:-}"
[[ -n "$state" && -d "$state" ]] || exit 0

if [[ -f "$state/watcher-ids" ]]; then
  while IFS= read -r watcher_id; do
    [[ -n "$watcher_id" ]] || continue
    atmux watcher kill "$watcher_id" >/dev/null 2>&1 || true
  done < "$state/watcher-ids"
fi

rm -rf "$state"
