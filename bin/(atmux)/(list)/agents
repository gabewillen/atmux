#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/../notify"
# shellcheck source=bin/(atmux)/(internal)/reporter
source "$HERE/../(internal)/reporter"

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "atmux agent list must be run from a git repository" >&2
    exit 1
  fi

  repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

resolve_adapter_cmd_for_session() {
  local session="$1"
  local adapter source_root
  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  source_root="$(get_session_env "$session" ATMUX_SOURCE_ROOT)"
  [[ -n "$adapter" ]] || adapter="codex"

  if [[ -n "$source_root" && -x "$source_root/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "$source_root/adapter/$adapter/cmd"
    return 0
  fi
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/adapter/$adapter/cmd"
    return 0
  fi

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/adapter/$adapter/cmd" ]]; then
      printf '%s\n' "$repo_root/adapter/$adapter/cmd"
      return 0
    fi
  fi

  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  if [[ -x "$atmux_home/adapters/$adapter/cmd" ]]; then
    printf '%s\n' "$atmux_home/adapters/$adapter/cmd"
    return 0
  fi

  return 1
}

status_node_for_session() {
  local session="$1"
  local passive_status="${2:-0}"
  local pane adapter adapter_cmd source_root status_out node

  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  source_root="$(get_session_env "$session" ATMUX_SOURCE_ROOT)"
  pane="$(primary_pane_for_session "$session")"
  [[ -n "$adapter" ]] || adapter="codex"

  if ! adapter_cmd="$(resolve_adapter_cmd_for_session "$session")"; then
    printf '<status adapter="%s" owner="agent" state="errored" model="" reasoning_level="" control_file="" />\n' "$(xml_escape "$adapter")"
    return 0
  fi

  status_out="$(
    ATMUX_SOURCE_ROOT="$source_root" \
    ATMUX_TARGET_PANE="$pane" \
    ATMUX_STATUS_PASSIVE="$passive_status" \
    "$adapter_cmd" status 2>/dev/null || true
  )"

  node="$(printf '%s\n' "$status_out" | awk '/<status[[:space:]].*\/>/ { sub(/^[[:space:]]*/, ""); print; exit }')"
  if [[ -n "$node" ]]; then
    printf '%s\n' "$node"
  else
    printf '<status adapter="%s" owner="agent" state="errored" model="" reasoning_level="" control_file="" />\n' "$(xml_escape "$adapter")"
  fi
}

is_team_session() {
  local repo_name="$1"
  local session="$2"
  [[ "$session" == "atmux-${repo_name}-team-"* ]]
}

agent_local_name() {
  local repo_name="$1"
  local session="$2"
  printf '%s\n' "${session#atmux-${repo_name}-}"
}

main() {
  local all=0 status=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -a|--all)
        all=1
        shift
        ;;
      --status)
        status=1
        shift
        ;;
      *)
        echo "unknown argument: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ "$all" -ne 1 ]]; then
    echo "usage: atmux agent list --all [--status]" >&2
    exit 2
  fi

  local repo_root repo_name prefix
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  prefix="atmux-${repo_name}-"
  local mode
  mode="$(reporter_mode)"

  if [[ "$mode" == "xml" ]]; then
    # XML mode: keep the existing nested format byte-for-byte.
    printf '<agents repo="%s">\n' "$(xml_escape "$repo_name")"
    while IFS= read -r session; do
      [[ -z "$session" ]] && continue
      [[ "$session" == "$prefix"* ]] || continue
      if is_team_session "$repo_name" "$session"; then
        continue
      fi
      local aname
      aname="$(agent_local_name "$repo_name" "$session")"
      if [[ "$status" -eq 1 ]]; then
        printf '  <agent name="%s" session="%s">\n' "$(xml_escape "$aname")" "$(xml_escape "$session")"
        printf '    %s\n' "$(status_node_for_session "$session" 1)"
        printf '  </agent>\n'
      else
        printf '  <agent name="%s" session="%s" />\n' "$(xml_escape "$aname")" "$(xml_escape "$session")"
      fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | sort -u || true)
    printf '</agents>\n'
    return
  fi

  # CLI mode: flat table via reporter. With --status, status attrs become
  # extra columns on the agent row.
  report_open agents repo="$repo_name"
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    [[ "$session" == "$prefix"* ]] || continue
    if is_team_session "$repo_name" "$session"; then
      continue
    fi
    local aname
    aname="$(agent_local_name "$repo_name" "$session")"
    if [[ "$status" -eq 1 ]]; then
      local snode state model reasoning
      snode="$(status_node_for_session "$session" 1)"
      state="$(printf '%s' "$snode"  | sed -n 's/.*state="\([^"]*\)".*/\1/p')"
      model="$(printf '%s' "$snode"  | sed -n 's/.*model="\([^"]*\)".*/\1/p')"
      reasoning="$(printf '%s' "$snode" | sed -n 's/.*reasoning_level="\([^"]*\)".*/\1/p')"
      report_record agent \
        name="$aname" \
        session="$session" \
        state="$state" \
        model="$model" \
        reasoning="$reasoning"
    else
      report_record agent name="$aname" session="$session"
    fi
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | sort -u || true)
  report_close agents
}

main "$@"
