#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"
if [[ -z "${AMUX_SOURCE_ROOT:-}" ]]; then
  if [[ -d "$AMUX_HOME/src/amux" ]]; then
    AMUX_SOURCE_ROOT="$AMUX_HOME/src/amux"
  else
    AMUX_SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../../.." && pwd)"
  fi
fi

root_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
select_script="$root_dir/scripts/select"

resolve_adapter_cmd_path() {
  local adapter="$1"
  local repo_root=""

  if [[ -x "$AMUX_SOURCE_ROOT/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "$AMUX_SOURCE_ROOT/adapter/$adapter/cmd"
    return 0
  fi

  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/adapter/$adapter/cmd" ]]; then
      printf '%s\n' "$repo_root/adapter/$adapter/cmd"
      return 0
    fi
  fi

  if [[ -x "$AMUX_HOME/adapters/$adapter/cmd" ]]; then
    printf '%s\n' "$AMUX_HOME/adapters/$adapter/cmd"
    return 0
  fi

  return 1
}

current_session=""
if [[ -n "${TMUX:-}" ]]; then
  current_session="$(tmux display-message -p '#S' 2>/dev/null || true)"
fi

ordered="$(AMUX_HOME="$AMUX_HOME" AMUX_SOURCE_ROOT="$AMUX_SOURCE_ROOT" "$select_script" --all 2>/dev/null || true)"
[[ -n "$ordered" ]] || { echo "no available adapters" >&2; exit 127; }

last_rc=127
while IFS= read -r adapter; do
  [[ -z "$adapter" ]] && continue
  adapter_cmd="$(resolve_adapter_cmd_path "$adapter" || true)"
  [[ -x "$adapter_cmd" ]] || continue

  export AMUX_ADAPTER="$adapter"
  export AMUX_ADAPTER_REQUESTED="${AMUX_ADAPTER_REQUESTED:-auto}"
  if [[ -n "$current_session" ]]; then
    tmux set-environment -t "$current_session" AMUX_ADAPTER "$adapter"
    tmux set-environment -t "$current_session" AMUX_ADAPTER_REQUESTED "${AMUX_ADAPTER_REQUESTED:-auto}"
  fi

  if "$adapter_cmd" start "$@"; then
    exit 0
  fi

  last_rc=$?
  if [[ "$last_rc" -eq 127 ]]; then
    continue
  fi
  exit "$last_rc"
done <<< "$ordered"

exit "$last_rc"
