#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux send --to <name|session> [--reply-required] [--interrupt] "message"

Description:
  Send XML messages to a single agent or every agent in a team.
  Resolution order for --to:
    1) Team session/name
    2) Agent session/name
  --interrupt  Submit using the adapter's interrupt key (processed after current
               tool) instead of the default queue key (processed when idle).

Examples:
  atmux send --to planner "run tests"
  atmux send --to platform --reply-required "status check-in"
  atmux send --to worker --interrupt "stop and check this"
USAGE
}

sender_session() {
  local from="${ATMUX_SESSION_NAME:-}"
  if [[ -z "$from" ]]; then
    local from_repo
    from_repo="$(repo_name_from_context)"
    if [[ -n "$from_repo" ]]; then
      from="atmux-${from_repo}-${ATMUX_AGENT_NAME:-unknown}"
    else
      from="atmux-unknown-${ATMUX_AGENT_NAME:-unknown}"
    fi
  fi
  printf '%s\n' "$from"
}

store_message() {
  local repo="$1" from="$2" to="$3" body="$4" reply_required="$5"
  local root id dir ts
  root="$ATMUX_HOME/messages/$repo"
  mkdir -p "$root"
  id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
  dir="$root/$id"
  mkdir -p "$dir"
  ts="$(timestamp_utc)"
  write_field "$dir/from" "$from"
  write_field "$dir/to" "$to"
  write_field "$dir/body" "$body"
  write_field "$dir/reply_required" "$reply_required"
  write_field "$dir/timestamp" "$ts"
  printf '%s\n' "$id"
}

resolve_interrupt_keys() {
  local session="$1"
  local adapter=""
  adapter="$(get_session_env "$session" ATMUX_ADAPTER)"
  if [[ -n "$adapter" ]]; then
    resolve_submit_keys "$adapter" "interrupt"
  else
    printf 'Enter\n'
  fi
}

send_to_session() {
  local target_session="$1"
  local payload="$2"
  shift 2
  local submit_keys=("$@")
  local target_pane=""

  if ! tmux has-session -t "$target_session" 2>/dev/null; then
    return 1
  fi
  target_pane="$(primary_pane_for_session "$target_session")"
  [[ -n "$target_pane" ]] || return 1
  send_payload_to_pane "$target_pane" "$payload" ${submit_keys[@]+"${submit_keys[@]}"}
}

send_to_type=""
target_name=""
reply_required=0
interrupt=0
message=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --to)
      target_name="${2:-}"
      shift 2
      ;;
    --reply-required)
      reply_required=1
      shift
      ;;
    --interrupt)
      interrupt=1
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    --)
      shift
      message="$*"
      break
      ;;
    *)
      if [[ -z "$message" ]]; then
        message="$1"
      else
        message+=" $1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$target_name" ]]; then
  echo "missing required flag: --to <name|session>" >&2
  exit 2
fi
if [[ -z "$message" ]]; then
  echo "missing message" >&2
  exit 2
fi

reply_required_value="false"
if [[ "$reply_required" -eq 1 ]]; then
  reply_required_value="true"
fi

repo_name="$(repo_name_from_context)"
from_session="$(sender_session)"

# Store message and build notification
msg_id="$(store_message "$repo_name" "$from_session" "$target_name" "$message" "$reply_required_value")"
payload="$(build_notification "message" "$from_session" "atmux message read $msg_id" \
  "reply_required=$reply_required_value")"

team_session="$("$HERE/team" resolve "$target_name" "$repo_name" || true)"

if [[ -n "$team_session" ]]; then
  members=()
  while IFS= read -r s; do
    [[ -n "$s" ]] || continue
    members+=("$s")
  done < <(tmux list-panes -t "${team_session}:0" -F '#{@atmux_agent_session}' 2>/dev/null | awk 'NF' | sort -u)

  if [[ "${#members[@]}" -eq 0 ]]; then
    echo "no team members found in session: $team_session" >&2
    exit 1
  fi

  attempted=0
  delivered=0
  failed=0
  results=""
  for s in "${members[@]}"; do
    attempted=$((attempted + 1))
    member_keys=()
    if [[ "$interrupt" -eq 1 ]]; then
      mapfile -t member_keys < <(resolve_interrupt_keys "$s")
    fi
    if send_to_session "$s" "$payload" ${member_keys[@]+"${member_keys[@]}"}; then
      delivered=$((delivered + 1))
      results+="  <target session=\"$(xml_escape "$s")\" queued=\"true\" />"$'\n'
    else
      failed=$((failed + 1))
      results+="  <target session=\"$(xml_escape "$s")\" queued=\"false\" />"$'\n'
    fi
  done

  printf '<send to="team" name="%s" session="%s" message_id="%s" queued="%s" attempted="%s" failed="%s">\n%s</send>\n' \
    "$(xml_escape "$target_name")" \
    "$(xml_escape "$team_session")" \
    "$(xml_escape "$msg_id")" \
    "$(xml_escape "$delivered")" \
    "$(xml_escape "$attempted")" \
    "$(xml_escape "$failed")" \
    "$results"

  if (( failed > 0 )); then
    exit 1
  fi
  exit 0
fi

target_session="$("$HERE/agent" resolve "$target_name" "$repo_name" || true)"
if [[ -z "$target_session" ]]; then
  echo "target not found as team or agent: $target_name" >&2
  exit 1
fi
submit_keys=()
if [[ "$interrupt" -eq 1 ]]; then
  mapfile -t submit_keys < <(resolve_interrupt_keys "$target_session")
fi
if ! send_to_session "$target_session" "$payload" ${submit_keys[@]+"${submit_keys[@]}"}; then
  echo "failed to queue for session: $target_session" >&2
  exit 1
fi
printf '<send to="agent" name="%s" session="%s" message_id="%s" queued="1" attempted="1" failed="0" />\n' \
  "$(xml_escape "$target_name")" \
  "$(xml_escape "$target_session")" \
  "$(xml_escape "$msg_id")"
