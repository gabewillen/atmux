#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="idle${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

# No ATMUX_MANAGER — this IS the root manager
tmux set-environment -t "$session" ATMUX_ADAPTER "claude-code"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

# resolve_idle_context_for_pane should return the pattern and timeout
ctx="$(resolve_idle_context_for_pane "$pane" 2>/dev/null || true)"
[[ -n "$ctx" ]] || { echo "expected idle context for root manager" >&2; exit 1; }

pat="$(printf '%s\n' "$ctx" | head -1)"
timeout_val="$(printf '%s\n' "$ctx" | tail -1)"

[[ "$pat" == '^> *$' ]] || { echo "pattern mismatch: $pat" >&2; exit 1; }
[[ "$timeout_val" == "30" ]] || { echo "timeout mismatch: $timeout_val" >&2; exit 1; }

echo "ok: root manager pane resolves idle context with correct pattern and timeout"
