#!/usr/bin/env bash
set -euo pipefail

# Verifies that the rendered atmux prompt block (the content prepare-prompt
# hands to each adapter) never echoes inherited tmux/session env vars and no
# longer injects global delegation behavior. Coordination policy belongs in
# explicit roles, not the atmux-wide prompt.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
AGENT_SCRIPT="$REPO_ROOT/bin/(atmux)/agent"

tmp_repo="$(mktemp -d)"
cleanup() { rm -rf "$tmp_repo"; }
trap cleanup EXIT

(
  cd "$tmp_repo"
  git init -q
)

control_text="$(
  ATMUX_ADAPTER="codex" \
  ATMUX_REPO="prompt-envless-${RANDOM}" \
  ATMUX_WORKTREE="$tmp_repo" \
  ATMUX_SOURCE_ROOT="$REPO_ROOT" \
  ATMUX_ALLOW_OUTSIDE_TMUX=1 \
    "$AGENT_SCRIPT" _render-prompt "$tmp_repo"
)"

printf '%s\n' "$control_text" | grep -Fq '# atmux Rules'
printf '%s\n' "$control_text" | grep -Fq 'Use plain `atmux ...` commands; do not prefix them with inherited session environment.'
if printf '%s\n' "$control_text" | grep -Fq '# Delegation Rules'; then
  echo "prompt block still injects delegation rules" >&2
  exit 1
fi

if printf '%s\n' "$control_text" | grep -Fq '# Agent TMUX env'; then
  echo "prompt block still prints inherited env heading" >&2
  exit 1
fi
if printf '%s\n' "$control_text" | grep -Fq 'ATMUX_REPO='; then
  echo "prompt block still prints ATMUX_REPO" >&2
  exit 1
fi

# After 0.11.0: the prompt block must NOT be written to the project's
# AGENTS.md/CLAUDE.md/GEMINI.md anywhere along the prompt-prep path.
for f in AGENTS.md CLAUDE.md GEMINI.md; do
  if [[ -e "$tmp_repo/$f" ]]; then
    echo "fail: _render-prompt should not touch $tmp_repo/$f" >&2
    exit 1
  fi
done

echo "ok: prompt block omits inherited env vars and global delegation policy"
