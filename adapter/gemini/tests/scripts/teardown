#!/usr/bin/env bash
set -euo pipefail

session_name="${AMUX_GEMINI_TEST_SESSION_NAME:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session)
      session_name="${2:-}"
      shift 2
      ;;
    *)
      echo "unknown flag: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "$session_name" ]]; then
  echo "missing session name (use --session or AMUX_GEMINI_TEST_SESSION_NAME)" >&2
  exit 2
fi

if tmux has-session -t "$session_name" 2>/dev/null; then
  tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
fi
