#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"

usage() {
  cat <<'USAGE'
Usage:
  amux session list
  amux session ls
  amux session start [--name <name>] [--adapter <adapter>] [-- <adapter-args...>]
  amux session attach <name|session>

Description:
  List amux sessions, start a session, or attach to an existing one.

Examples:
  amux session list
  amux session start
  amux session start --name planner
  amux session attach planner
  amux session start --adapter claude-code -- --dangerously-skip-permissions
USAGE
}

normalize_repo_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

primary_pane_for_session() {
  local session="$1"
  tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }'
}

send_payload_to_pane() {
  local target="$1"
  local payload="$2"
  local settle submit_wait extra_enter confirm_polls confirm_interval
  local attempts retry_wait
  local before_count after_count confirmed poll attempt snap initial_before_count current_count

  # Use a paced key sequence for interactive TUIs:
  # clear line -> type payload -> submit.
  settle="${AMUX_SEND_SETTLE_SECONDS:-0.2}"
  submit_wait="${AMUX_SEND_SUBMIT_WAIT_SECONDS:-0.15}"
  extra_enter="${AMUX_SEND_DOUBLE_ENTER:-0}"
  confirm_polls="${AMUX_SEND_CONFIRM_POLLS:-20}"
  confirm_interval="${AMUX_SEND_CONFIRM_INTERVAL_SECONDS:-0.05}"
  attempts="${AMUX_SEND_ATTEMPTS:-8}"
  retry_wait="${AMUX_SEND_RETRY_WAIT_SECONDS:-0.5}"

  marker_count() {
    tmux capture-pane -p -t "$target" -S -800 2>/dev/null | tr -d '\r\n' | grep -o '</amux>' | wc -l | tr -d ' '
  }

  initial_before_count="$(marker_count || true)"
  [[ -n "$initial_before_count" ]] || initial_before_count=0

  for ((attempt=1; attempt<=attempts; attempt++)); do
    current_count="$(marker_count || true)"
    [[ -n "$current_count" ]] || current_count=0
    if (( current_count > initial_before_count )); then
      return 0
    fi
    before_count="$current_count"
    [[ -n "$before_count" ]] || before_count=0

    tmux send-keys -t "$target" C-u
    sleep "$settle"
    tmux send-keys -t "$target" -l "$payload"
    sleep "$settle"
    tmux send-keys -t "$target" Enter
    sleep "$submit_wait"

    confirmed=0
    for poll in $(seq 1 "$confirm_polls"); do
      snap="$(tmux capture-pane -p -t "$target" -S -800 2>/dev/null || true)"
      after_count="$(printf '%s' "$snap" | tr -d '\r\n' | grep -o '</amux>' | wc -l | tr -d ' ' || true)"
      [[ -n "$after_count" ]] || after_count=0
      if (( after_count > before_count )); then
        confirmed=1
        break
      fi
      sleep "$confirm_interval"
    done

    # Retry submit when marker did not advance, or when explicitly requested.
    if [[ "$extra_enter" == "1" || "$confirmed" -eq 0 ]]; then
      tmux send-keys -t "$target" Enter
      sleep "$submit_wait"
      after_count="$(marker_count || true)"
      [[ -n "$after_count" ]] || after_count=0
      if (( after_count > before_count )); then
        confirmed=1
      fi
    fi

    if [[ "$confirmed" -eq 1 ]]; then
      return 0
    fi

    current_count="$(marker_count || true)"
    [[ -n "$current_count" ]] || current_count=0
    if (( current_count > initial_before_count )); then
      return 0
    fi

    sleep "$retry_wait"
  done

  return 1
}

attach_or_switch() {
  local session="$1"
  local readonly="${AMUX_ATTACH_READONLY:-auto}"
  local bootstrap_state=""
  if [[ ! -t 0 || ! -t 1 ]]; then
    printf '%s\n' "$session"
    return
  fi

  case "$readonly" in
    auto|AUTO|"")
      local manager=""
      manager="$(tmux show-environment -t "$session" AMUX_MANAGER 2>/dev/null | sed -n 's/^AMUX_MANAGER=//p' || true)"
      if [[ -n "$manager" ]]; then
        readonly="1"
      else
        readonly="0"
      fi
      ;;
  esac

  bootstrap_state="$(get_session_env "$session" AMUX_BOOTSTRAP_STATE)"
  if [[ "$bootstrap_state" == "pending" ]]; then
    readonly="1"
  fi

  case "$readonly" in
    0|false|FALSE|no|NO)
      if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$session"
      else
        tmux attach-session -t "$session"
      fi
      return
      ;;
  esac

  start_bootstrap_unlock_if_needed "$session"

  if [[ -n "${TMUX:-}" ]]; then
    tmux refresh-client -f read-only >/dev/null 2>&1 || true
    tmux switch-client -r -t "$session" 2>/dev/null || tmux switch-client -t "$session"
  else
    tmux attach-session -r -t "$session"
  fi
}

ensure_tmux_scroll_enabled() {
  local history_limit
  history_limit="${AMUX_TMUX_HISTORY_LIMIT:-200000}"

  tmux set-option -g mouse on >/dev/null 2>&1 || true
  tmux set-window-option -g history-limit "$history_limit" >/dev/null 2>&1 || true

  while IFS= read -r window_id; do
    [[ -z "$window_id" ]] && continue
    tmux set-window-option -t "$window_id" history-limit "$history_limit" >/dev/null 2>&1 || true
  done < <(tmux list-windows -a -F '#{window_id}' 2>/dev/null || true)
}

get_session_env() {
  local session="$1"
  local key="$2"
  tmux show-environment -t "$session" "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

bootstrap_unlock_pid_matches_session() {
  local pid="$1"
  local session="$2"
  local cmd=""

  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1 || return 1
  cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  [[ -n "$cmd" ]] || return 1
  [[ "$cmd" == *"bin/(amux)/session"*"_bootstrap-unlock ${session}"* ]] || return 1
  return 0
}

unlock_session_clients() {
  local session="$1"
  local client readonly
  while read -r client readonly; do
    [[ -n "$client" ]] || continue
    if [[ "$readonly" == "1" ]]; then
      # read-only is reliably cleared by toggling client flags via switch-client -r.
      tmux switch-client -c "$client" -t "$session" -r >/dev/null 2>&1 || true
    fi
    tmux refresh-client -t "$client" -f '!ignore-size' >/dev/null 2>&1 || true
    tmux display-message -t "$client" "amux bootstrap complete; input unlocked" >/dev/null 2>&1 || true
  done < <(tmux list-clients -t "$session" -F '#{client_tty} #{client_readonly}' 2>/dev/null || true)
}

bootstrap_unlock_worker() {
  local session="$1"
  local interval timeout start_ts now state elapsed

  interval="${AMUX_BOOTSTRAP_UNLOCK_INTERVAL_SECONDS:-0.2}"
  timeout="${AMUX_BOOTSTRAP_UNLOCK_TIMEOUT_SECONDS:-120}"
  start_ts="$(date +%s)"

  while tmux has-session -t "$session" 2>/dev/null; do
    state="$(get_session_env "$session" AMUX_BOOTSTRAP_STATE)"
    if [[ "$state" != "pending" && -n "$state" ]]; then
      break
    fi

    now="$(date +%s)"
    elapsed=$((now - start_ts))
    if (( elapsed >= timeout )); then
      tmux set-environment -t "$session" AMUX_BOOTSTRAP_STATE failed >/dev/null 2>&1 || true
      state="failed"
      break
    fi

    sleep "$interval"
  done

  if tmux has-session -t "$session" 2>/dev/null; then
    unlock_session_clients "$session"
    tmux set-environment -t "$session" -u AMUX_BOOTSTRAP_UNLOCK_PID >/dev/null 2>&1 || true
  fi
}

start_bootstrap_unlock_if_needed() {
  local session="$1"
  local state pid log_file new_pid

  state="$(get_session_env "$session" AMUX_BOOTSTRAP_STATE)"
  [[ "$state" == "pending" ]] || return 0

  pid="$(get_session_env "$session" AMUX_BOOTSTRAP_UNLOCK_PID)"
  if [[ -n "$pid" ]] && bootstrap_unlock_pid_matches_session "$pid" "$session"; then
    return 0
  fi
  if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
  fi
  tmux set-environment -t "$session" -u AMUX_BOOTSTRAP_UNLOCK_PID >/dev/null 2>&1 || true

  log_file="${TMPDIR:-/tmp}/amux-bootstrap-${session}.log"
  nohup "$0" _bootstrap-unlock "$session" >>"$log_file" 2>&1 </dev/null &
  new_pid="$!"
  sleep 0.05
  if bootstrap_unlock_pid_matches_session "$new_pid" "$session"; then
    tmux set-environment -t "$session" AMUX_BOOTSTRAP_UNLOCK_PID "$new_pid"
  fi
}

monitor_pid_matches_session() {
  local pid="$1"
  local session="$2"
  local cmd=""

  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1 || return 1
  cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  [[ -n "$cmd" ]] || return 1
  [[ "$cmd" == *"bin/(amux)/session"*"_monitor-supervisor ${session}"* ]] || return 1
  return 0
}

child_monitor_pid_matches_manager() {
  local pid="$1"
  local session="$2"
  local cmd=""

  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" >/dev/null 2>&1 || return 1
  cmd="$(ps -p "$pid" -o command= 2>/dev/null || true)"
  [[ -n "$cmd" ]] || return 1
  [[ "$cmd" == *"bin/(amux)/session"*"_children-monitor-supervisor ${session}"* ]] || return 1
  return 0
}

monitor_heartbeat_is_fresh() {
  local session="$1"
  local max_age="${2:-30}"
  local hb now

  hb="$(get_session_env "$session" AMUX_MONITOR_HEARTBEAT_TS)"
  [[ "$hb" =~ ^[0-9]+$ ]] || return 1
  now="$(date +%s)"
  (( now - hb <= max_age ))
}

start_children_monitor_if_needed() {
  local session="$1"
  local manager repo source_root runner pid log_file new_pid

  manager="$(get_session_env "$session" AMUX_MANAGER)"
  [[ -z "$manager" ]] || return 0

  repo="$(get_session_env "$session" AMUX_REPO)"
  manager="$(get_session_env "$session" AMUX_AGENT_NAME)"
  [[ -n "$repo" && -n "$manager" ]] || return 0

  pid="$(get_session_env "$session" AMUX_CHILD_MONITOR_PID)"
  if [[ -n "$pid" ]] && child_monitor_pid_matches_manager "$pid" "$session"; then
    return 0
  fi
  if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
  fi
  tmux set-environment -t "$session" -u AMUX_CHILD_MONITOR_PID >/dev/null 2>&1 || true

  source_root="$(get_session_env "$session" AMUX_SOURCE_ROOT)"
  if [[ -z "$source_root" || ! -x "$source_root/bin/(amux)/session" ]]; then
    source_root="${AMUX_SOURCE_ROOT:-}"
  fi
  if [[ -z "$source_root" || ! -x "$source_root/bin/(amux)/session" ]]; then
    source_root="${AMUX_HOME:-$HOME/.amux}/src/amux"
  fi
  runner="$source_root/bin/(amux)/session"
  [[ -x "$runner" ]] || return 0

  log_file="${TMPDIR:-/tmp}/amux-children-monitor-${session}.log"
  nohup "$runner" _children-monitor-supervisor "$session" >>"$log_file" 2>&1 </dev/null &
  new_pid="$!"
  sleep 0.05
  if child_monitor_pid_matches_manager "$new_pid" "$session"; then
    tmux set-environment -t "$session" AMUX_CHILD_MONITOR_PID "$new_pid"
  elif kill -0 "$new_pid" >/dev/null 2>&1; then
    tmux set-environment -t "$session" AMUX_CHILD_MONITOR_PID "$new_pid"
  fi
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

resolve_manager_session_for_agent() {
  local session="$1"
  local repo manager canonical discovered_session s s_repo s_agent

  repo="$(get_session_env "$session" AMUX_REPO)"
  manager="$(get_session_env "$session" AMUX_MANAGER)"
  [[ -n "$repo" && -n "$manager" ]] || return 1

  if tmux has-session -t "$manager" 2>/dev/null; then
    printf '%s\n' "$manager"
    return 0
  fi

  canonical="amux-${repo}-${manager}"
  if tmux has-session -t "$canonical" 2>/dev/null; then
    printf '%s\n' "$canonical"
    return 0
  fi

  if [[ "$manager" == amux-* ]] && tmux has-session -t "$manager" 2>/dev/null; then
    printf '%s\n' "$manager"
    return 0
  fi

  discovered_session=""
  while IFS= read -r s; do
    [[ -z "$s" ]] && continue
    s_repo="$(get_session_env "$s" AMUX_REPO)"
    s_agent="$(get_session_env "$s" AMUX_AGENT_NAME)"
    if [[ "$s_repo" == "$repo" && "$s_agent" == "$manager" ]]; then
      discovered_session="$s"
      break
    fi
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

  [[ -n "$discovered_session" ]] || return 1
  printf '%s\n' "$discovered_session"
}

notify_manager_monitor_error() {
  local session="$1"
  local message="$2"
  local manager_session manager_pane now cooldown last_notified payload

  manager_session="$(resolve_manager_session_for_agent "$session" || true)"
  [[ -n "$manager_session" ]] || return 0
  manager_pane="$(primary_pane_for_session "$manager_session")"
  [[ -n "$manager_pane" ]] || return 0

  cooldown="${AMUX_MONITOR_ERROR_NOTIFY_COOLDOWN_SECONDS:-30}"
  now="$(date +%s)"
  last_notified="$(get_session_env "$session" AMUX_MONITOR_LAST_ERROR_NOTIFY_TS)"
  if [[ "$last_notified" =~ ^[0-9]+$ ]] && (( now - last_notified < cooldown )); then
    return 0
  fi
  tmux set-environment -t "$session" AMUX_MONITOR_LAST_ERROR_NOTIFY_TS "$now" >/dev/null 2>&1 || true

  payload="<amux><notification type=\"error\">$(xml_escape "$message")</notification></amux>"
  AMUX_SEND_ATTEMPTS=1 AMUX_SEND_DOUBLE_ENTER=0 send_payload_to_pane "$manager_pane" "$payload" >/dev/null 2>&1 || true
}

start_monitor_if_needed() {
  local source_root="$1"
  local session="$2"
  local stale_seconds restart_reason
  stale_seconds="${AMUX_MONITOR_STALE_SECONDS:-30}"
  restart_reason=""

  local pid
  pid="$(get_session_env "$session" AMUX_MONITOR_PID)"
  if [[ -n "$pid" ]] && monitor_pid_matches_session "$pid" "$session" && monitor_heartbeat_is_fresh "$session" "$stale_seconds"; then
    return 0
  fi
  if [[ -n "$pid" ]] && monitor_pid_matches_session "$pid" "$session"; then
    restart_reason="stale-monitor-heartbeat"
    kill "$pid" >/dev/null 2>&1 || true
  elif [[ -n "$pid" ]]; then
    restart_reason="missing-monitor-process"
  fi
  tmux set-environment -t "$session" -u AMUX_MONITOR_PID >/dev/null 2>&1 || true
  tmux set-environment -t "$session" -u AMUX_MONITOR_HEARTBEAT_TS >/dev/null 2>&1 || true

  local log_file
  log_file="${TMPDIR:-/tmp}/amux-monitor-${session}.log"
  nohup "$source_root/bin/(amux)/session" _monitor-supervisor "$session" >>"$log_file" 2>&1 </dev/null &
  local new_pid=$!
  sleep 0.05
  if monitor_pid_matches_session "$new_pid" "$session"; then
    tmux set-environment -t "$session" AMUX_MONITOR_PID "$new_pid"
    if [[ -n "$restart_reason" ]]; then
      notify_manager_monitor_error "$session" "idle monitor restarted for ${session} (${restart_reason})"
    fi
  else
    tmux set-environment -t "$session" -u AMUX_MONITOR_PID >/dev/null 2>&1 || true
    notify_manager_monitor_error "$session" "idle monitor failed to start for ${session}"
  fi
}

ensure_monitor_for_session() {
  local session="$1"
  local source_root
  [[ -n "$session" ]] || return 2
  source_root="$(get_session_env "$session" AMUX_SOURCE_ROOT)"
  if [[ -z "$source_root" || ! -x "$source_root/bin/(amux)/session" ]]; then
    source_root="${AMUX_SOURCE_ROOT:-}"
  fi
  if [[ -z "$source_root" || ! -x "$source_root/bin/(amux)/session" ]]; then
    source_root="${AMUX_HOME:-$HOME/.amux}/src/amux"
  fi
  start_monitor_if_needed "$source_root" "$session"
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "amux session start must be run from a git repository" >&2
    exit 1
  fi
  repo_name="${AMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment AMUX_REPO 2>/dev/null | sed -n 's/^AMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_repo_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

collect_agent_help() {
  local runner="$1"
  local runner_cwd="${2:-}"
  local out=""
  local cmd
  for cmd in create list send assign capture env; do
    local cmd_out=""
    if [[ -n "$runner_cwd" ]]; then
      cmd_out="$(cd "$runner_cwd" && AMUX_NO_WRAP=1 "$runner" "$cmd" --help 2>/dev/null || true)"
    else
      cmd_out="$(AMUX_NO_WRAP=1 "$runner" "$cmd" --help 2>/dev/null || true)"
    fi
    if [[ -n "$cmd_out" ]] && printf '%s\n' "$cmd_out" | grep -Eq "^  amux ${cmd}( |$)"; then
      out+=$'## '"$cmd"$'\n'
      out+="$cmd_out"$'\n\n'
    fi
  done
  printf '%s' "$out"
}

render_managed_block() {
  local repo_root="$1"
  local role_name="${AMUX_ROLE:-}"
  local repo_value="${AMUX_REPO:-}"
  local manager_value="${AMUX_MANAGER:-}"
  local amux_runner=""
  local amux_help=""
  local source_root="${AMUX_SOURCE_ROOT:-}"

  if [[ -n "$source_root" && -x "$source_root/bin/amux" ]]; then
    amux_runner="$source_root/bin/amux"
  elif [[ -x "$repo_root/bin/amux" ]]; then
    amux_runner="$repo_root/bin/amux"
  elif command -v amux >/dev/null 2>&1; then
    amux_runner="amux"
  fi

  if [[ -n "$amux_runner" ]]; then
    if [[ -n "$source_root" && -d "$source_root" ]]; then
      amux_help="$(collect_agent_help "$amux_runner" "$source_root")"
    else
      amux_help="$(collect_agent_help "$amux_runner")"
    fi
  fi

  {
    echo "<amux>"
    if [[ -n "$role_name" ]]; then
      echo "# Role"
      echo "- ROLE: $role_name"
      echo
    fi
    echo "# Amux Env"
    echo "AMUX_REPO=${repo_value}"
    echo "AMUX_MANAGER=${manager_value}"
    echo
    if [[ -z "$manager_value" ]]; then
      echo "# Delegation Rules"
      echo "- ALWAYS check \`amux list agents --all --status\` first."
      echo "- ALWAYS assign to an existing idle capable agent before creating a new one."
      echo "- ONLY create a new agent when no idle agent matches the required capability/intelligence."
      echo "- ALWAYS include clear task scope via \`--description\` and \`--todos\`."
      echo "- ALWAYS use \`--reply-required\` for decisions/blockers."
      echo "- NEVER poll agent panes unless absolutely necessary."
      echo "- NEVER do tasks yourself unless explicitly instructed."
      echo
    else
      echo "# Managed Agent Rules"
      echo "- ALWAYS acknowledge manager messages quickly with a short plan."
      echo "- ALWAYS send a message to your manager when stuck or after completing any task."
      echo "- ALWAYS message your manager with \`amux send --to \"\$AMUX_MANAGER\" \"...\"\`."
      echo "- ALWAYS coordinate with peer agents using \`amux send --to <agent> \"...\"\`."
      echo "- ALWAYS check \`amux list agents --all --status\` before creating new agents."
      echo "- ALWAYS reuse idle capable agents before creating new ones."
      echo "- ALWAYS spawn agents to decompose your todos if necessary."
      echo "- ALWAYS use \`--reply-required\` when a manager decision is needed."
      echo "- NEVER poll agent panes unless absolutely necessary."
      echo "- NEVER silently change scope; ask your manager first."
      echo "- NEVER report task completion without validation evidence."
      echo "- NEVER leave blockers unreported; escalate immediately."
      echo
    fi
    echo "# Amux Help"
    if [[ -n "$amux_help" ]]; then
      printf '%s\n' "$amux_help"
    fi
    echo "</amux>"
  }
}

inject_control_file() {
  local repo_root="$1"
  local adapter="${AMUX_ADAPTER:-codex}"
  local adapter_cmd=""

  adapter_cmd="$(resolve_adapter_cmd_path "$adapter" || true)"
  [[ -x "$adapter_cmd" ]] || return 0

  local control_file
  control_file="$("$adapter_cmd" control-file 2>/dev/null || true)"
  [[ -n "$control_file" ]] || return 0

  local target_file="$repo_root/$control_file"
  [[ -f "$target_file" ]] || : > "$target_file"

  local tmp_base managed_file stripped_file
  tmp_base="${TMPDIR:-/tmp}/amux-control-$RANDOM-$$"
  managed_file="${tmp_base}.managed"
  stripped_file="${tmp_base}.stripped"

  render_managed_block "$repo_root" > "$managed_file"

  if grep -Eq '^(<!-- AMUX:BEGIN -->|<amux>)$' "$target_file" 2>/dev/null; then
    awk '
      BEGIN { in_block=0 }
      /<!-- AMUX:BEGIN -->/ { in_block=1; next }
      /<!-- AMUX:END -->/ { in_block=0; next }
      /^<amux>$/ { in_block=1; next }
      /^<\/amux>$/ { in_block=0; next }
      in_block==0 { print }
    ' "$target_file" > "$stripped_file"
  else
    awk '
      /^# Default Rules$/ { exit }
      /^# Amux Help$/ { exit }
      { print }
    ' "$target_file" > "$stripped_file"
  fi

  {
    cat "$stripped_file"
    if [[ -s "$stripped_file" ]]; then
      echo
    fi
    cat "$managed_file"
    echo
  } > "$target_file"

  rm -f "$managed_file" "$stripped_file"
}

resolve_adapter_cmd_path() {
  local adapter="$1"
  local source_root="${AMUX_SOURCE_ROOT:-${AMUX_HOME}/src/amux}"
  local repo_root=""

  if [[ -n "$source_root" && -x "$source_root/adapter/$adapter/cmd" ]]; then
    printf '%s\n' "$source_root/adapter/$adapter/cmd"
    return 0
  fi

  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "$repo_root/adapter/$adapter/cmd" ]]; then
      printf '%s\n' "$repo_root/adapter/$adapter/cmd"
      return 0
    fi
  fi

  if [[ -x "$AMUX_HOME/adapters/$adapter/cmd" ]]; then
    printf '%s\n' "$AMUX_HOME/adapters/$adapter/cmd"
    return 0
  fi

  return 1
}

resolve_auto_candidates() {
  local auto_cmd=""
  auto_cmd="$(resolve_adapter_cmd_path "auto" || true)"
  [[ -x "$auto_cmd" ]] || return 1

  AMUX_HOME="$AMUX_HOME" AMUX_SOURCE_ROOT="${AMUX_SOURCE_ROOT:-${AMUX_HOME}/src/amux}" "$auto_cmd" select --all 2>/dev/null
}

run_adapter() {
  local adapter="codex"
  local requested_adapter=""
  local -a adapter_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --adapter)
        adapter="${2:-}"
        shift 2
        ;;
      --)
        shift
        adapter_args=("$@")
        break
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  requested_adapter="$adapter"
  export AMUX_ADAPTER_REQUESTED="$requested_adapter"

  # Ensure source-root amux commands win over stale worktree copies.
  if [[ -z "${AMUX_SOURCE_ROOT:-}" ]]; then
    if [[ -d "${AMUX_HOME}/src/amux" ]]; then
      AMUX_SOURCE_ROOT="${AMUX_HOME}/src/amux"
    else
      AMUX_SOURCE_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)"
    fi
    export AMUX_SOURCE_ROOT
  fi
  if [[ -d "$AMUX_SOURCE_ROOT/bin" ]]; then
    export PATH="$AMUX_SOURCE_ROOT/bin:$(pwd)/bin:$PATH"
  else
    export PATH="$(pwd)/bin:$PATH"
  fi

  # Non-login tmux panes often lack user-local PATH (Cursor CLI, Homebrew, etc.).
  export PATH="${HOME}/.local/bin:${HOME}/.cursor/bin:/opt/homebrew/bin:/usr/local/bin:${PATH}"

  # tmux session env is authoritative; current shell env may be stale/missing.
  local current_session=""
  if [[ -n "${TMUX:-}" ]]; then
    current_session="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$current_session" ]]; then
    while IFS= read -r line; do
      [[ "$line" == AMUX_*=* ]] || continue
      key="${line%%=*}"
      value="${line#*=}"
      export "$key=$value"
    done < <(tmux show-environment -t "$current_session" 2>/dev/null || true)
  fi

  local -a candidates=()
  if [[ "$requested_adapter" == "auto" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      candidates+=("$line")
    done < <(resolve_auto_candidates || true)
  else
    candidates=("$requested_adapter")
  fi

  if ((${#candidates[@]} == 0)); then
    candidates=("codex")
  fi

  local rc=127
  local selected_adapter=""
  local adapter_cmd=""
  local candidate=""
  for candidate in "${candidates[@]}"; do
    adapter_cmd="$(resolve_adapter_cmd_path "$candidate" || true)"
    if [[ ! -x "$adapter_cmd" ]]; then
      rc=127
      if [[ "$requested_adapter" == "auto" ]]; then
        continue
      fi
      echo "adapter start not found: $candidate" >&2
      break
    fi

    selected_adapter="$candidate"
    export AMUX_ADAPTER="$selected_adapter"
    export AMUX_ADAPTER_SELECTED="$selected_adapter"
    if [[ -n "$current_session" ]]; then
      tmux set-environment -t "$current_session" AMUX_ADAPTER "$selected_adapter"
      tmux set-environment -t "$current_session" AMUX_ADAPTER_REQUESTED "$requested_adapter"
      tmux set-environment -t "$current_session" AMUX_ADAPTER_SELECTED "$selected_adapter"
    fi

    inject_control_file "$(pwd)"

    rc=0
    if ((${#adapter_args[@]})); then
      "$adapter_cmd" start "${adapter_args[@]}" || rc=$?
    else
      "$adapter_cmd" start || rc=$?
    fi

    if [[ "$rc" -eq 0 ]]; then
      break
    fi

    # For auto mode, only fall through on launch-time adapter unavailability.
    if [[ "$requested_adapter" == "auto" && "$rc" -eq 127 ]]; then
      continue
    fi
    break
  done

  if [[ -z "$selected_adapter" ]]; then
    echo "no adapter available" >&2
    rc=127
  fi

  local session_name="${AMUX_SESSION_NAME:-}"
  if [[ -z "$session_name" && -n "${TMUX:-}" ]]; then
    session_name="$(tmux display-message -p '#S' 2>/dev/null || true)"
  fi
  if [[ -n "$session_name" ]] && tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name" >/dev/null 2>&1 || true
  fi
  exit "$rc"
}

start_session() {
  local name=""
  local adapter="codex"
  local team="${AMUX_TEAM:-}"
  local intelligence="${AMUX_INTELLIGENCE:-20}"
  local name_explicit=0
  local -a forward_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name="${2:-}"
        name_explicit=1
        shift 2
        ;;
      --adapter)
        adapter="${2:-}"
        shift 2
        ;;
      --)
        shift
        forward_args=("$@")
        break
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  local source_root="${AMUX_SOURCE_ROOT:-${AMUX_HOME}/src/amux}"

  if [[ "$name_explicit" -eq 0 ]]; then
    local n
    n="$(
      (tmux list-sessions -F '#{session_name}' 2>/dev/null || true) \
        | awk -v p="^amux-${repo_name}-agent-[0-9]+$" '$0 ~ p { c++ } END { print c+0 }'
    )"
    name="agent-$n"
    while tmux has-session -t "amux-${repo_name}-${name}" 2>/dev/null; do
      n=$((n + 1))
      name="agent-$n"
    done
  fi

  local session="amux-${repo_name}-${name}"
  local worktree="$AMUX_HOME/agents/${repo_name}-${name}"
  local branch="amux-${repo_name}-${name}"

  if tmux has-session -t "$session" 2>/dev/null; then
    local existing_adapter existing_worktree existing_source_root existing_manager existing_role existing_team existing_intelligence
    existing_adapter="$(tmux show-environment -t "$session" AMUX_ADAPTER 2>/dev/null | sed -n 's/^AMUX_ADAPTER=//p' || true)"
    existing_worktree="$(tmux show-environment -t "$session" AMUX_WORKTREE 2>/dev/null | sed -n 's/^AMUX_WORKTREE=//p' || true)"
    existing_source_root="$(tmux show-environment -t "$session" AMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^AMUX_SOURCE_ROOT=//p' || true)"
    existing_manager="$(tmux show-environment -t "$session" AMUX_MANAGER 2>/dev/null | sed -n 's/^AMUX_MANAGER=//p' || true)"
    existing_role="$(tmux show-environment -t "$session" AMUX_ROLE 2>/dev/null | sed -n 's/^AMUX_ROLE=//p' || true)"
    existing_team="$(tmux show-environment -t "$session" AMUX_TEAM 2>/dev/null | sed -n 's/^AMUX_TEAM=//p' || true)"
    existing_intelligence="$(tmux show-environment -t "$session" AMUX_INTELLIGENCE 2>/dev/null | sed -n 's/^AMUX_INTELLIGENCE=//p' || true)"
    if [[ -n "$existing_adapter" ]]; then
      export AMUX_ADAPTER="$existing_adapter"
    else
      export AMUX_ADAPTER="$adapter"
    fi
    export AMUX_REPO="$repo_name"
    export AMUX_MANAGER="$existing_manager"
    export AMUX_ROLE="$existing_role"
    if [[ -n "$existing_team" ]]; then
      export AMUX_TEAM="$existing_team"
    else
      export AMUX_TEAM="$team"
    fi
    if [[ -n "$existing_intelligence" ]]; then
      export AMUX_INTELLIGENCE="$existing_intelligence"
    else
      export AMUX_INTELLIGENCE="$intelligence"
    fi
    if [[ -n "$existing_source_root" && -d "$existing_source_root" ]]; then
      export AMUX_SOURCE_ROOT="$existing_source_root"
    else
      export AMUX_SOURCE_ROOT="$repo_root"
    fi
    if [[ -n "$existing_worktree" && -d "$existing_worktree" ]]; then
      inject_control_file "$existing_worktree"
    else
      inject_control_file "$repo_root"
    fi
    if [[ -n "$existing_manager" ]]; then
      local existing_idle
      existing_idle="$(tmux show-environment -t "$session" AMUX_MONITOR_IDLE_SECONDS 2>/dev/null | sed -n 's/^AMUX_MONITOR_IDLE_SECONDS=//p' || true)"
      if [[ -z "$existing_idle" ]]; then
        tmux set-environment -t "$session" AMUX_MONITOR_IDLE_SECONDS "${AMUX_MONITOR_IDLE_SECONDS:-30}"
      fi
    fi
    ensure_tmux_scroll_enabled
    start_monitor_if_needed "$source_root" "$session"
    start_children_monitor_if_needed "$session"
    attach_or_switch "$session"
    return
  fi

  mkdir -p "$AMUX_HOME/agents"

  if [[ -e "$worktree" ]]; then
    if ! git -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo "path exists and is not a git worktree: $worktree" >&2
      exit 1
    fi
  else
    worktree_err="$(
      git -C "$repo_root" worktree add -B "$branch" "$worktree" HEAD 2>&1
    )" || {
      if printf '%s\n' "$worktree_err" | grep -Eq 'cannot lock ref|Operation not permitted|Permission denied'; then
        echo "branch creation failed; retrying detached worktree for $worktree" >&2
        git -C "$repo_root" worktree add "$worktree" HEAD >/dev/null
      else
        printf '%s\n' "$worktree_err" >&2
        exit 1
      fi
    }
  fi

  local session_id
  session_id="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 12 || true)"
  if [[ -z "$session_id" ]]; then
    session_id="$(date +%s)-$$"
  fi

  tmux new-session -d -s "$session" -n "$session" -c "$worktree"
  ensure_tmux_scroll_enabled
  tmux set-environment -t "$session" AMUX_REPO "$repo_name"
  tmux set-environment -t "$session" AMUX_SESSION_ID "$session_id"
  tmux set-environment -t "$session" AMUX_SESSION_NAME "$session"
  tmux set-environment -t "$session" AMUX_WORKTREE "$worktree"
  tmux set-environment -t "$session" AMUX_SOURCE_ROOT "$source_root"
  tmux set-environment -t "$session" AMUX_AGENT_NAME "$name"
  tmux set-environment -t "$session" AMUX_ADAPTER "$adapter"
  tmux set-environment -t "$session" AMUX_ADAPTER_REQUESTED "$adapter"
  tmux set-environment -t "$session" AMUX_ADAPTER_SELECTED "$adapter"
  tmux set-environment -t "$session" AMUX_INTELLIGENCE "$intelligence"
  if [[ "$adapter" == "codex" || "$adapter" == "auto" ]]; then
    tmux set-environment -t "$session" AMUX_BOOTSTRAP_STATE pending
  else
    tmux set-environment -t "$session" AMUX_BOOTSTRAP_STATE ready
  fi
  if [[ -n "${AMUX_ROLE:-}" ]]; then
    tmux set-environment -t "$session" AMUX_ROLE "$AMUX_ROLE"
  fi
  if [[ -n "${AMUX_MANAGER:-}" ]]; then
    tmux set-environment -t "$session" AMUX_MANAGER "$AMUX_MANAGER"
    tmux set-environment -t "$session" AMUX_MONITOR_IDLE_SECONDS "${AMUX_MONITOR_IDLE_SECONDS:-30}"
    if [[ -n "${AMUX_MONITOR_INTERVAL_SECONDS:-}" ]]; then
      tmux set-environment -t "$session" AMUX_MONITOR_INTERVAL_SECONDS "$AMUX_MONITOR_INTERVAL_SECONDS"
    fi
    if [[ -n "${AMUX_MONITOR_CAPTURE_LINES:-}" ]]; then
      tmux set-environment -t "$session" AMUX_MONITOR_CAPTURE_LINES "$AMUX_MONITOR_CAPTURE_LINES"
    fi
    if [[ -n "${AMUX_MONITOR_CAPTURE_MAX_CHARS:-}" ]]; then
      tmux set-environment -t "$session" AMUX_MONITOR_CAPTURE_MAX_CHARS "$AMUX_MONITOR_CAPTURE_MAX_CHARS"
    fi
  fi
  if [[ -n "${AMUX_TEAM:-}" ]]; then
    tmux set-environment -t "$session" AMUX_TEAM "$AMUX_TEAM"
  fi

  local -a cmd=("$source_root/bin/(amux)/session" "_run-adapter" "--adapter" "$adapter")
  if ((${#forward_args[@]})); then
    cmd+=("--" "${forward_args[@]}")
  fi

  local launch
  printf -v launch '%q ' "${cmd[@]}"
  local launch_pane
  launch_pane="$(primary_pane_for_session "$session")"
  if [[ -z "$launch_pane" ]]; then
    echo "cannot find pane for session: $session" >&2
    exit 1
  fi
  tmux send-keys -t "$launch_pane" "$launch" C-m
  start_monitor_if_needed "$source_root" "$session"
  start_children_monitor_if_needed "$session"

  attach_or_switch "$session"
}

attach_session() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "usage: amux session attach <name|session>" >&2
    exit 2
  fi

  local repo_root repo_name
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)
  local source_root="${AMUX_SOURCE_ROOT:-${AMUX_HOME}/src/amux}"

  local session
  if tmux has-session -t "$target" 2>/dev/null; then
    session="$target"
  elif [[ "$target" == amux-* ]]; then
    session="$target"
  elif [[ "$target" == "${repo_name}-"* ]] && tmux has-session -t "amux-${target}" 2>/dev/null; then
    session="amux-${target}"
  else
    session="amux-${repo_name}-${target}"
  fi

  if ! tmux has-session -t "$session" 2>/dev/null; then
    echo "session not found: $session" >&2
    exit 1
  fi

  local existing_adapter existing_worktree existing_source_root existing_repo existing_manager existing_role existing_team
  existing_adapter="$(tmux show-environment -t "$session" AMUX_ADAPTER 2>/dev/null | sed -n 's/^AMUX_ADAPTER=//p' || true)"
  existing_worktree="$(tmux show-environment -t "$session" AMUX_WORKTREE 2>/dev/null | sed -n 's/^AMUX_WORKTREE=//p' || true)"
  existing_source_root="$(tmux show-environment -t "$session" AMUX_SOURCE_ROOT 2>/dev/null | sed -n 's/^AMUX_SOURCE_ROOT=//p' || true)"
  existing_repo="$(tmux show-environment -t "$session" AMUX_REPO 2>/dev/null | sed -n 's/^AMUX_REPO=//p' || true)"
  existing_manager="$(tmux show-environment -t "$session" AMUX_MANAGER 2>/dev/null | sed -n 's/^AMUX_MANAGER=//p' || true)"
  existing_role="$(tmux show-environment -t "$session" AMUX_ROLE 2>/dev/null | sed -n 's/^AMUX_ROLE=//p' || true)"
  existing_team="$(tmux show-environment -t "$session" AMUX_TEAM 2>/dev/null | sed -n 's/^AMUX_TEAM=//p' || true)"
  if [[ -n "$existing_adapter" ]]; then
    export AMUX_ADAPTER="$existing_adapter"
  fi
  if [[ -n "$existing_repo" ]]; then
    export AMUX_REPO="$existing_repo"
  else
    export AMUX_REPO="$repo_name"
  fi
  export AMUX_MANAGER="$existing_manager"
  export AMUX_ROLE="$existing_role"
  export AMUX_TEAM="$existing_team"
  if [[ -n "$existing_source_root" && -d "$existing_source_root" ]]; then
    export AMUX_SOURCE_ROOT="$existing_source_root"
  else
    export AMUX_SOURCE_ROOT="$repo_root"
  fi
  if [[ -n "$existing_worktree" && -d "$existing_worktree" ]]; then
    inject_control_file "$existing_worktree"
  else
    inject_control_file "$repo_root"
  fi
  if [[ -n "$existing_manager" ]]; then
    local existing_idle
    existing_idle="$(tmux show-environment -t "$session" AMUX_MONITOR_IDLE_SECONDS 2>/dev/null | sed -n 's/^AMUX_MONITOR_IDLE_SECONDS=//p' || true)"
    if [[ -z "$existing_idle" ]]; then
      tmux set-environment -t "$session" AMUX_MONITOR_IDLE_SECONDS "${AMUX_MONITOR_IDLE_SECONDS:-30}"
    fi
  fi
  ensure_tmux_scroll_enabled
  start_monitor_if_needed "$source_root" "$session"
  start_children_monitor_if_needed "$session"

  attach_or_switch "$session"
}

monitor_session() {
  local session="${1:-}"
  if [[ -z "$session" ]]; then
    echo "usage: amux session _monitor <session>" >&2
    exit 2
  fi

  local interval idle_seconds capture_lines capture_max_chars
  interval="$(get_session_env "$session" AMUX_MONITOR_INTERVAL_SECONDS)"
  if [[ -z "$interval" ]]; then
    interval="${AMUX_MONITOR_INTERVAL_SECONDS:-2}"
  fi
  idle_seconds="$(get_session_env "$session" AMUX_MONITOR_IDLE_SECONDS)"
  if [[ -z "$idle_seconds" ]]; then
    idle_seconds="${AMUX_MONITOR_IDLE_SECONDS:-30}"
  fi
  capture_lines="$(get_session_env "$session" AMUX_MONITOR_CAPTURE_LINES)"
  if [[ -z "$capture_lines" ]]; then
    capture_lines="${AMUX_MONITOR_CAPTURE_LINES:-80}"
  fi
  capture_max_chars="$(get_session_env "$session" AMUX_MONITOR_CAPTURE_MAX_CHARS)"
  if [[ -z "$capture_max_chars" ]]; then
    capture_max_chars="${AMUX_MONITOR_CAPTURE_MAX_CHARS:-4000}"
  fi

  local repo manager agent adapter_name
  repo="$(get_session_env "$session" AMUX_REPO)"
  manager="$(get_session_env "$session" AMUX_MANAGER)"
  agent="$(get_session_env "$session" AMUX_AGENT_NAME)"
  adapter_name="$(get_session_env "$session" AMUX_ADAPTER)"
  [[ -n "$adapter_name" ]] || adapter_name="unknown"
  [[ -n "$repo" && -n "$agent" ]] || exit 0

  resolve_manager_session() {
    local canonical discovered_session s s_repo s_agent
    [[ -n "$manager" ]] || return 1
    if tmux has-session -t "$manager" 2>/dev/null; then
      printf '%s\n' "$manager"
      return 0
    fi
    canonical="amux-${repo}-${manager}"
    if tmux has-session -t "$canonical" 2>/dev/null; then
      printf '%s\n' "$canonical"
      return 0
    fi
    if [[ "$manager" == amux-* ]] && tmux has-session -t "$manager" 2>/dev/null; then
      printf '%s\n' "$manager"
      return 0
    fi
    discovered_session=""
    while IFS= read -r s; do
      [[ -z "$s" ]] && continue
      s_repo="$(get_session_env "$s" AMUX_REPO)"
      s_agent="$(get_session_env "$s" AMUX_AGENT_NAME)"
      if [[ "$s_repo" == "$repo" && "$s_agent" == "$manager" ]]; then
        discovered_session="$s"
        break
      fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)
    [[ -n "$discovered_session" ]] && printf '%s\n' "$discovered_session"
  }

  local last_hash="" last_change_ts notified
  local prompt_cooldown prompt_last_notify_ts prompt_active
  last_change_ts="$(date +%s)"
  notified=0
  prompt_cooldown="${AMUX_MONITOR_PROMPT_COOLDOWN_SECONDS:-30}"
  prompt_last_notify_ts=0
  prompt_active=0

  while tmux has-session -t "$session" 2>/dev/null; do
    local loop_now
    loop_now="$(date +%s)"
    tmux set-environment -t "$session" AMUX_MONITOR_HEARTBEAT_TS "$loop_now" >/dev/null 2>&1 || true
    manager="$(get_session_env "$session" AMUX_MANAGER)"

    local pane
    pane="$(tmux list-panes -a -F '#{session_name} #{pane_id}' 2>/dev/null | awk -v s="$session" '$1==s { print $2; exit }')"
    if [[ -z "$pane" ]]; then
      sleep "$interval"
      continue
    fi

    local snap hash now idle_for
    local selection_prompt recent
    snap="$(tmux capture-pane -p -t "$pane" -S "-$capture_lines" 2>/dev/null | tr -d '\r' || true)"
    if [[ "$capture_max_chars" =~ ^[0-9]+$ ]] && (( capture_max_chars > 0 )); then
      if ((${#snap} > capture_max_chars)); then
        snap="${snap: -capture_max_chars}"
      fi
    fi
    hash="$(printf '%s' "$snap" | cksum | awk '{print $1 ":" $2}')"
    now="$(date +%s)"
    selection_prompt=0

    # Only inspect recent lines for transient interaction/busy hints.
    # Older history frequently contains words like "thinking"/"processing"
    # that should not suppress idle notifications forever.
    recent="$(printf '%s\n' "$snap" | tail -n 30)"
    if printf '%s\n' "$recent" | grep -Fq 'Enter to select' && printf '%s\n' "$recent" | grep -Fq 'Esc to cancel'; then
      selection_prompt=1
    fi

    if [[ "$hash" != "$last_hash" ]]; then
      last_hash="$hash"
      last_change_ts="$now"
      notified=0
    fi

    idle_for=$((now - last_change_ts))

    if (( selection_prompt == 1 )); then
      local should_notify_prompt
      should_notify_prompt=0
      if (( prompt_active == 0 )); then
        should_notify_prompt=1
      elif (( now - prompt_last_notify_ts >= prompt_cooldown )); then
        should_notify_prompt=1
      fi
      if (( should_notify_prompt == 1 )) && [[ -n "$manager" ]]; then
        local manager_session="" manager_pane="" prompt_xml from prompt_message prompt_message_esc
        manager_session="$(resolve_manager_session || true)"
        if tmux has-session -t "$manager_session" 2>/dev/null; then
          manager_pane="$(primary_pane_for_session "$manager_session")"
          if [[ -n "$manager_pane" ]]; then
            from="$(xml_escape "$session")"
            prompt_message="Interactive selection prompt detected for agent \"$agent\" on pane \"$pane\" (adapter \"$adapter_name\"). Please provide selection input."
            prompt_message_esc="$(xml_escape "$prompt_message")"
            prompt_xml="<amux><message from=\"${from}\" reply_required=\"true\">${prompt_message_esc}</message></amux>"
            if AMUX_SEND_ATTEMPTS=1 AMUX_SEND_DOUBLE_ENTER=0 send_payload_to_pane "$manager_pane" "$prompt_xml" >/dev/null 2>&1; then
              prompt_last_notify_ts="$now"
              prompt_active=1
            fi
          fi
        fi
      fi
    else
      prompt_active=0
    fi

    if (( idle_for >= idle_seconds )) && (( notified == 0 )) && [[ -n "$manager" ]]; then
      local manager_session=""
      manager_session="$(resolve_manager_session || true)"
      if tmux has-session -t "$manager_session" 2>/dev/null; then
        local line xml from manager_pane agent_esc idle_esc pane_esc line_esc capture_esc
        line="$(printf '%s\n' "$snap" | awk 'NF { l=$0 } END { print l }')"
        line="${line//$'\n'/ }"
        from="$(xml_escape "$session")"
        agent_esc="$(xml_escape "$agent")"
        idle_esc="$(xml_escape "$idle_for")"
        pane_esc="$(xml_escape "$pane")"
        line_esc="$(xml_escape "$line")"
        capture_esc="$(xml_escape "$snap")"
        xml="<amux><message from=\"${from}\" reply_required=\"false\"><idle agent=\"${agent_esc}\" pane=\"${pane_esc}\" idle_seconds=\"${idle_esc}\" state=\"idle\"><last_line>${line_esc}</last_line><capture>${capture_esc}</capture></idle></message></amux>"
        manager_pane="$(primary_pane_for_session "$manager_session")"
        if [[ -n "$manager_pane" ]]; then
          if AMUX_SEND_ATTEMPTS=1 AMUX_SEND_DOUBLE_ENTER=0 send_payload_to_pane "$manager_pane" "$xml" >/dev/null 2>&1; then
            notified=1
          fi
        fi
      fi
    fi

    sleep "$interval"
  done
}

monitor_supervisor() {
  local session="${1:-}"
  if [[ -z "$session" ]]; then
    echo "usage: amux session _monitor-supervisor <session>" >&2
    exit 2
  fi
  local monitor_rc

  while tmux has-session -t "$session" 2>/dev/null; do
    tmux set-environment -t "$session" AMUX_MONITOR_HEARTBEAT_TS "$(date +%s)" >/dev/null 2>&1 || true
    monitor_rc=0
    if "$0" _monitor "$session" >/dev/null 2>&1; then
      monitor_rc=0
    else
      monitor_rc=$?
    fi
    if [[ "$monitor_rc" -ne 0 ]] && tmux has-session -t "$session" 2>/dev/null; then
      notify_manager_monitor_error "$session" "idle monitor crashed for ${session} (exit ${monitor_rc}); restarting"
    fi
    sleep 1
  done
}

children_monitor_supervisor() {
  local manager_session="${1:-}"
  if [[ -z "$manager_session" ]]; then
    echo "usage: amux session _children-monitor-supervisor <manager-session>" >&2
    exit 2
  fi

  local interval repo manager_name now s s_repo s_manager canonical_manager
  interval="${AMUX_CHILD_MONITOR_INTERVAL_SECONDS:-5}"

  repo="$(get_session_env "$manager_session" AMUX_REPO)"
  manager_name="$(get_session_env "$manager_session" AMUX_AGENT_NAME)"
  [[ -n "$repo" && -n "$manager_name" ]] || exit 0
  canonical_manager="amux-${repo}-${manager_name}"

  while tmux has-session -t "$manager_session" 2>/dev/null; do
    while IFS= read -r s; do
      [[ -n "$s" ]] || continue
      [[ "$s" == "$manager_session" ]] && continue
      s_repo="$(get_session_env "$s" AMUX_REPO)"
      [[ "$s_repo" == "$repo" ]] || continue
      s_manager="$(get_session_env "$s" AMUX_MANAGER)"
      [[ -n "$s_manager" ]] || continue

      if [[ "$s_manager" == "$manager_name" || "$s_manager" == "$manager_session" || "$s_manager" == "$canonical_manager" ]]; then
        ensure_monitor_for_session "$s" >/dev/null 2>&1 || true
      fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '/^amux-/ {print}' || true)

    now="$(date +%s)"
    tmux set-environment -t "$manager_session" AMUX_CHILD_MONITOR_HEARTBEAT_TS "$now" >/dev/null 2>&1 || true
    sleep "$interval"
  done
}

sub="${1:-}"
shift || true

case "$sub" in
  list|ls)
    tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '/^amux-/ { print }'
    ;;
  start)
    start_session "$@"
    ;;
  attach)
    attach_session "${1:-}"
    ;;
  _run-adapter)
    run_adapter "$@"
    ;;
  _monitor)
    monitor_session "$@"
    ;;
  _monitor-supervisor)
    monitor_supervisor "$@"
    ;;
  _children-monitor-supervisor)
    children_monitor_supervisor "$@"
    ;;
  _ensure-monitor)
    ensure_monitor_for_session "${1:-}"
    ;;
  _bootstrap-unlock)
    bootstrap_unlock_worker "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown session command: $sub" >&2
    exit 2
    ;;
esac
