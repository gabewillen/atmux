#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux schedule (--interval <duration> | --once <duration>) [--no-detach] --notification <text>
  atmux schedule (--interval <duration> | --once <duration>) [--no-detach] -- <command> [args...]

Description:
  Schedule a future or repeating action. Use `--notification` to queue an
  ATMUX notification to the current session, or use `-- <command...>`
  to run any command after the delay.

  Notification mode:
    - Always targets the current agent/session.

  Command mode:
    - Runs the provided command in the current environment.
    - If you want to schedule a message, schedule the command directly:
      `atmux schedule --once 10m -- atmux send --to worker "status check"`

  --no-detach  Run in the foreground (blocking). By default, the scheduled
               task runs in a detached tmux window and the command returns
               immediately.

Durations:
  Supports integer values with optional unit suffix:
    ms  milliseconds
    s   seconds
    m   minutes
    h   hours
    d   days
  If no suffix is provided, seconds are assumed.

Examples:
  atmux schedule --interval 30m --notification "check on long-running jobs"
  atmux schedule --once 45s -- atmux send --to atmux-myrepo-worker "follow up"
USAGE
}

resolve_atmux_bin() {
  local script_dir repo_root=""
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  repo_root="$(cd -- "$script_dir/../.." && pwd)"
  if [[ -x "$repo_root/bin/atmux" ]]; then
    printf '%s\n' "$repo_root/bin/atmux"
    return 0
  fi
  if [[ -x "$ATMUX_HOME/bin/atmux" ]]; then
    printf '%s\n' "$ATMUX_HOME/bin/atmux"
    return 0
  fi
  echo "atmux binary not found" >&2
  exit 1
}

parse_duration_seconds() {
  local raw="${1:-}"
  local value unit multiplier

  if [[ ! "$raw" =~ ^([0-9]+)(ms|s|m|h|d)?$ ]]; then
    echo "invalid duration: $raw" >&2
    exit 2
  fi

  value="${BASH_REMATCH[1]}"
  unit="${BASH_REMATCH[2]:-s}"

  case "$unit" in
    ms) multiplier="0.001" ;;
    s) multiplier="1" ;;
    m) multiplier="60" ;;
    h) multiplier="3600" ;;
    d) multiplier="86400" ;;
    *)
      echo "invalid duration unit: $unit" >&2
      exit 2
      ;;
  esac

  awk -v value="$value" -v multiplier="$multiplier" 'BEGIN { printf "%.3f\n", value * multiplier }'
}

sleep_for_duration() {
  local duration_seconds="$1"
  sleep "$duration_seconds"
}

current_session_name() {
  if [[ -n "${ATMUX_SESSION_NAME:-}" ]]; then
    printf '%s\n' "$ATMUX_SESSION_NAME"
    return 0
  fi
  if [[ -n "${ATMUX_AGENT_NAME:-}" ]]; then
    local repo_name=""
    repo_name="$(repo_name_from_context)"
    if [[ -n "$repo_name" ]]; then
      printf 'atmux-%s-%s\n' "$repo_name" "${ATMUX_AGENT_NAME}"
      return 0
    fi
  fi
  printf '\n'
}

default_notification_target() {
  local self_session=""
  self_session="$(current_session_name)"
  if [[ -n "$self_session" ]]; then
    printf '%s\n' "$self_session"
    return 0
  fi
  if [[ -n "${ATMUX_AGENT_NAME:-}" ]]; then
    printf '%s\n' "$ATMUX_AGENT_NAME"
    return 0
  fi
  echo "unable to infer notification target; use --to" >&2
  exit 2
}

notification_sender() {
  local from=""
  from="$(current_session_name)"
  if [[ -n "$from" ]]; then
    printf '%s\n' "$from"
    return 0
  fi
  printf 'schedule\n'
}

send_scheduled_notification() {
  local notification_text="$1"
  local from_session="" payload="" target_session="" target_pane=""

  from_session="$(notification_sender)"
  payload="$(build_notification "scheduled" "$from_session" "" "text=$notification_text")"
  target_session="$(default_notification_target)"
  target_pane="$(primary_pane_for_session "$target_session")"
  if [[ -z "$target_pane" ]]; then
    echo "failed to locate pane for session: $target_session" >&2
    exit 1
  fi
  send_payload_to_pane "$target_pane" "$payload"
}

describe_command() {
  local cmd=("$@")
  local joined=""
  local part=""
  for part in "${cmd[@]}"; do
    if [[ -n "$joined" ]]; then
      joined+=" "
    fi
    printf -v part '%q' "$part"
    joined+="$part"
  done
  printf '%s\n' "$joined"
}

target_name=""
reply_required=0
interval_raw=""
once_raw=""
no_detach=0
notification_text=""
command_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --to)
      target_name="${2:-}"
      shift 2
      ;;
    --reply-required)
      reply_required=1
      shift
      ;;
    --notification)
      notification_text="${2:-}"
      shift 2
      ;;
    --interval)
      interval_raw="${2:-}"
      shift 2
      ;;
    --once)
      once_raw="${2:-}"
      shift 2
      ;;
    --no-detach)
      no_detach=1
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    --)
      shift
      command_args=("$@")
      break
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -n "$interval_raw" && -n "$once_raw" ]]; then
  echo "use exactly one of --interval or --once" >&2
  exit 2
fi
if [[ -z "$interval_raw" && -z "$once_raw" ]]; then
  echo "missing required flag: --interval <duration> or --once <duration>" >&2
  exit 2
fi
if [[ -n "$notification_text" && ${#command_args[@]} -gt 0 ]]; then
  echo "use either --notification or -- <command...>, not both" >&2
  exit 2
fi
if [[ -z "$notification_text" && ${#command_args[@]} -eq 0 ]]; then
  echo "missing scheduled action: use --notification <text> or -- <command...>" >&2
  exit 2
fi
if [[ "$reply_required" -eq 1 ]]; then
  echo "schedule no longer accepts --reply-required; schedule the send command instead" >&2
  exit 2
fi
if [[ -n "$target_name" ]]; then
  echo "--to is not valid for schedule; schedule a command like 'atmux send --to ...' instead" >&2
  exit 2
fi

mode_kind="command"
if [[ -n "$notification_text" ]]; then
  mode_kind="notification"
fi

atmux_bin="$(resolve_atmux_bin)"

if [[ "$no_detach" -eq 0 ]]; then
  inner_args=(schedule --no-detach)
  if [[ -n "$once_raw" ]]; then
    inner_args+=(--once "$once_raw")
  else
    inner_args+=(--interval "$interval_raw")
  fi
  if [[ "$mode_kind" == "notification" ]]; then
    inner_args+=(--notification "$notification_text")
  else
    inner_args+=(-- "${command_args[@]}")
  fi

  detach_out="$("$atmux_bin" exec --detach -- "$atmux_bin" "${inner_args[@]}")"
  pid="$(printf '%s' "$detach_out" | sed -n 's/.*pid="\([^"]*\)".*/\1/p')"
  pane="$(printf '%s' "$detach_out" | sed -n 's/.*pane="\([^"]*\)".*/\1/p')"

  mode="once"
  duration="$once_raw"
  if [[ -n "$interval_raw" ]]; then
    mode="interval"
    duration="$interval_raw"
  fi

  if [[ "$mode_kind" == "notification" ]]; then
    printf '<schedule kind="notification" to="%s" mode="%s" duration="%s" pid="%s" pane="%s" />\n' \
      "$(xml_escape "$(default_notification_target)")" \
      "$(xml_escape "$mode")" \
      "$(xml_escape "$duration")" \
      "$(xml_escape "$pid")" \
      "$(xml_escape "$pane")"
  else
    printf '<schedule kind="command" mode="%s" duration="%s" pid="%s" pane="%s" command="%s" />\n' \
      "$(xml_escape "$mode")" \
      "$(xml_escape "$duration")" \
      "$(xml_escape "$pid")" \
      "$(xml_escape "$pane")" \
      "$(xml_escape "$(describe_command "${command_args[@]}")")"
  fi
  exit 0
fi

if [[ -n "$once_raw" ]]; then
  once_seconds="$(parse_duration_seconds "$once_raw")"
  sleep_for_duration "$once_seconds"
  if [[ "$mode_kind" == "notification" ]]; then
    send_scheduled_notification "$notification_text"
    exit 0
  fi
  exec "${command_args[@]}"
fi

interval_seconds="$(parse_duration_seconds "$interval_raw")"
count=0

while true; do
  sleep_for_duration "$interval_seconds"
  if [[ "$mode_kind" == "notification" ]]; then
    send_scheduled_notification "$notification_text"
    count=$((count + 1))
    printf '<schedule kind="notification" to="%s" mode="interval" duration="%s" iteration="%s" />\n' \
      "$(xml_escape "$(default_notification_target)")" \
      "$(xml_escape "$interval_raw")" \
      "$(xml_escape "$count")"
    continue
  fi

  rc=0
  if "${command_args[@]}"; then
    rc=0
  else
    rc=$?
  fi
  count=$((count + 1))
  printf '<schedule kind="command" mode="interval" duration="%s" iteration="%s" exit_code="%s" command="%s" />\n' \
    "$(xml_escape "$interval_raw")" \
    "$(xml_escape "$count")" \
    "$(xml_escape "$rc")" \
    "$(xml_escape "$(describe_command "${command_args[@]}")")"
done
