#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="idle${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 "cat"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

# Simulate input that never goes idle (text stays on input line)
sleep 0.3
tmux send-keys -t "$pane" -l "> I am typing and won't stop"

# wait_for_input_idle should timeout and return 1
ATMUX_INPUT_IDLE_INTERVAL=0.2 start_ts="$(date +%s)"
set +e
wait_for_input_idle "$pane" '^> *$' 2
rc=$?
set -e
elapsed=$(( $(date +%s) - start_ts ))

[[ "$rc" -eq 1 ]] || { echo "expected exit 1 on timeout, got $rc" >&2; exit 1; }
[[ "$elapsed" -ge 1 ]] || { echo "timeout too fast: ${elapsed}s" >&2; exit 1; }

echo "ok: wait_for_input_idle returns 1 on timeout"
