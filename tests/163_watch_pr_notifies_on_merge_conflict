#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_count() {
  local target="$1"
  local needle="$2"
  local expected="$3"
  local timeout="${4:-20}"
  local deadline now snap compact count
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    count="$(printf '%s' "$compact" | grep -Fo "$needle" | wc -l | tr -d ' ')"
    if (( count >= expected )); then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-pr-conflict.XXXXXX")"
atmux_home="$tmp_root/.atmux"
repo_name="prconflict$RANDOM"
session="atmux-${repo_name}-watcher"
trigger_file="$tmp_root/trigger-conflict"
comment_file="$tmp_root/trigger-comment"
late_comment_file="$tmp_root/trigger-late-comment"
stub_dir="$tmp_root/bin"
snapshot_file="$atmux_home/watch-pr/octo_example_pr_88/snapshot"
watchers_dir="$atmux_home/watch-pr/octo_example_pr_88/watchers"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$tmp_root"
}
trap cleanup EXIT

mkdir -p "$stub_dir"
cat > "$stub_dir/gh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" != "api" || "${2:-}" != "graphql" ]]; then
  echo "unexpected gh invocation: $*" >&2
  exit 1
fi

printf '%s\n' 'STATE|open'
if [[ -f "${ATMUX_TEST_PR_CONFLICT_TRIGGER:-}" ]]; then
  printf '%s\n' '0000-01-01T00:00:00Z|merge_conflict|merge_conflict:dirty|github|DIRTY|merge conflict with base branch'
fi
if [[ -f "${ATMUX_TEST_PR_COMMENT_TRIGGER:-}" ]]; then
  printf '%s\n' '2026-04-23T00:00:10Z|issue_comment|IC_1|octocat||conflict appeared with a comment'
fi
if [[ -f "${ATMUX_TEST_PR_LATE_COMMENT_TRIGGER:-}" ]]; then
  printf '%s\n' '2026-04-23T00:00:11Z|issue_comment|IC_2|octocat||please take another look'
fi
EOF
chmod +x "$stub_dir/gh"

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session" ATMUX_AGENT_NAME "watcher"
tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "missing watcher pane" >&2; exit 1; }

tmux send-keys -t "$pane" \
  "ATMUX_HOME=\"$atmux_home\" ATMUX_GH_BIN=\"$stub_dir/gh\" ATMUX_TEST_PR_CONFLICT_TRIGGER=\"$trigger_file\" ATMUX_TEST_PR_COMMENT_TRIGGER=\"$comment_file\" ATMUX_TEST_PR_LATE_COMMENT_TRIGGER=\"$late_comment_file\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watcher\" ATMUX_SESSION_NAME=\"$session\" \"$ATMUX_BIN\" pr watch \"https://github.com/octo/example/pull/88\" --interval 0.2 --timeout 10" \
  C-m

if ! wait_for_text "$pane" '<watch type="pr"' 10; then
  echo "pr watch did not register" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

deadline=$(( $(date +%s) + 10 ))
while [[ ! -f "$snapshot_file" ]]; do
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr never produced a baseline snapshot" >&2
    tmux capture-pane -p -t "$pane" -S -200 >&2 || true
    exit 1
  fi
  sleep 0.05
done

deadline=$(( $(date +%s) + 10 ))
while true; do
  wcount=0
  if [[ -d "$watchers_dir" ]]; then
    wcount="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')"
  fi
  if [[ "${wcount:-0}" -ge 1 ]]; then
    break
  fi
  now="$(date +%s)"
  if (( now >= deadline )); then
    echo "watch --pr did not leave an active watcher registration" >&2
    exit 1
  fi
  sleep 0.1
done

touch "$trigger_file" "$comment_file"

if ! wait_for_text "$pane" 'kind="merge_conflict"' 15; then
  echo "watch --pr did not deliver a merge_conflict notification" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'state="DIRTY"' 15; then
  echo "watch --pr merge_conflict notification missing DIRTY state" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'merge conflict with base branch' 15; then
  echo "watch --pr merge_conflict notification missing conflict text" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'gh pr view 88 --repo octo/example --json mergeStateStatus,mergeable' 15; then
  echo "watch --pr merge_conflict notification missing gh pr view hint" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'conflict appeared with a comment' 15; then
  echo "watch --pr did not deliver simultaneous comment with merge conflict" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

touch "$late_comment_file"

if ! wait_for_count "$pane" 'kind="issue_comment"' 2 15; then
  echo "watch --pr did not deliver later comment while merge conflict persisted" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi
if ! wait_for_text "$pane" 'please take another look' 15; then
  echo "watch --pr later comment notification missing comment text" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: watch --pr emits notification on merge conflict"
