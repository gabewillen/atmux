#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux pr create --title <title> [--description <description>]
                  [--source <branch>] [--target <branch>]
                  [--todo <todo>]... [--repo <repo>]
  atmux pr list [--repo <repo>]
  atmux pr ls [--repo <repo>]
  atmux pr get <id> [--repo <repo>]
  atmux pr show <id> [--repo <repo>]
  atmux pr assign <id> --to <agent|session> [--repo <repo>]
  atmux pr claim <id> [--by <agent|session>] [--repo <repo>]
  atmux pr comment <id> "message" [--repo <repo>]
  atmux pr watch <id|atmux-uri|github-url> [--repo <repo>] [--timeout <s>] [--interval <s>]
  atmux pr watch --feed <repo|url> [--timeout <s>] [--interval <s>]

Description:
  Repo-scoped pull request tickets on filesystem.
  Pull requests are stored at: ~/.atmux/pull-requests/<repo>/<id>/

  `watch <id>` watches a single pull request (filesystem ticket or GitHub URL).
  `watch --feed <repo>` watches a GitHub repo for newly-filed pull requests.
USAGE
}

resolve_repo_name() {
  local explicit_repo="${1:-}"
  local repo=""
  if [[ -n "$explicit_repo" ]]; then
    repo="$explicit_repo"
  elif [[ -n "${ATMUX_REPO:-}" ]]; then
    repo="${ATMUX_REPO}"
  elif [[ -n "${TMUX:-}" ]]; then
    repo="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo="$(basename "$repo_root")"
    fi
  fi
  if [[ -z "$repo" ]]; then
    echo "unable to resolve repo; pass --repo <repo> or run inside a git repo" >&2
    exit 2
  fi
  normalize_name "$repo"
}

current_actor_name() {
  local repo="${1:-}"
  local actor="${ATMUX_AGENT_NAME:-}"
  if [[ -z "$actor" && -n "${TMUX:-}" ]]; then
    actor="$(tmux show-environment ATMUX_AGENT_NAME 2>/dev/null | sed -n 's/^ATMUX_AGENT_NAME=//p' || true)"
  fi
  if [[ -n "$actor" ]]; then
    printf '%s\n' "$actor"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    local session=""
    session="$(tmux display-message -p '#S' 2>/dev/null || true)"
    if [[ -n "$session" ]]; then
      session_short_name "$session" "$repo"
      return
    fi
  fi
  printf '%s\n' "external"
}

now_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

read_field() {
  local file="$1"
  cat "$file" 2>/dev/null || true
}

identity_matches() {
  local left="$1"
  local right="$2"
  local repo="$3"
  local left_short="$left"
  local right_short="$right"

  [[ -n "$left" && -n "$right" ]] || return 1
  [[ "$left" == "$right" ]] && return 0

  if [[ -n "$repo" ]]; then
    left_short="$(session_short_name "$left" "$repo")"
    right_short="$(session_short_name "$right" "$repo")"
    [[ "$left_short" == "$right_short" ]] && return 0
    [[ "atmux-${repo}-${left_short}" == "$right" ]] && return 0
    [[ "atmux-${repo}-${right_short}" == "$left" ]] && return 0
  fi

  return 1
}

ensure_can_assign() {
  local manager="${ATMUX_MANAGER:-}"
  if [[ -z "$manager" && -n "${TMUX:-}" ]]; then
    manager="$(tmux show-environment ATMUX_MANAGER 2>/dev/null | sed -n 's/^ATMUX_MANAGER=//p' || true)"
  fi
  if [[ -n "$manager" ]]; then
    echo "managed agents cannot assign pull requests; use 'atmux pr claim' instead" >&2
    exit 1
  fi
}

create_pr() {
  local title=""
  local description=""
  local source_branch=""
  local target_branch=""
  local explicit_repo=""
  local todos=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)
        title="${2:-}"
        shift 2
        ;;
      --description)
        description="${2:-}"
        shift 2
        ;;
      --source)
        source_branch="${2:-}"
        shift 2
        ;;
      --target)
        target_branch="${2:-}"
        shift 2
        ;;
      --todo|--todos)
        todos+=("${2:-}")
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$title" ]]; then
    echo "missing required flag: --title" >&2
    exit 2
  fi

  if [[ "${#todos[@]}" -gt 0 ]]; then
    local t=""
    if [[ -n "$description" ]]; then
      description+=$'\n\n'
    fi
    description+="Todos:"
    for t in "${todos[@]}"; do
      [[ -n "$t" ]] || continue
      description+=$'\n'"- $t"
    done
  fi

  local repo root id dir created_at
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(pull_request_root_for_repo "$repo")"
  mkdir -p "$root"

  id="$(id)"
  dir="$(pull_request_dir_for_id "$root" "$id")"
  created_at="$(now_utc)"

  mkdir -p "$dir"
  write_field "$dir/title" "$title"
  write_field "$dir/description" "$description"
  write_field "$dir/source" "$source_branch"
  write_field "$dir/target" "$target_branch"
  write_field "$dir/state" "open"
  write_field "$dir/created_at" "$created_at"
  write_field "$dir/updated_at" "$created_at"
  write_field "$dir/assigned_to" ""
  write_field "$dir/assigned_by" ""
  write_field "$dir/assigned_at" ""
  write_field "$dir/claimed_by" ""
  write_field "$dir/claimed_at" ""

  printf '<pull-request id="%s" repo="%s" state="open" uri="%s" path="%s" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "atmux://pull-request/$repo/$id")" \
    "$(xml_escape "$dir")"
}

list_prs() {
  local explicit_repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir id title state created_at updated_at assigned_to claimed_by source_branch target_branch
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(pull_request_root_for_repo "$repo")"

  printf '<pull-requests repo="%s">\n' "$(xml_escape "$repo")"
  if [[ -d "$root" ]]; then
    while IFS= read -r dir; do
      [[ -d "$dir" ]] || continue
      id="$(basename "$dir")"
      title="$(read_field "$dir/title")"
      state="$(read_field "$dir/state")"
      created_at="$(read_field "$dir/created_at")"
      updated_at="$(read_field "$dir/updated_at")"
      assigned_to="$(read_field "$dir/assigned_to")"
      claimed_by="$(read_field "$dir/claimed_by")"
      source_branch="$(read_field "$dir/source")"
      target_branch="$(read_field "$dir/target")"
      printf '  <pull-request id="%s" state="%s" created_at="%s" updated_at="%s" assigned_to="%s" claimed_by="%s" source="%s" target="%s" uri="%s" title="%s" />\n' \
        "$(xml_escape "$id")" \
        "$(xml_escape "$state")" \
        "$(xml_escape "$created_at")" \
        "$(xml_escape "$updated_at")" \
        "$(xml_escape "$assigned_to")" \
        "$(xml_escape "$claimed_by")" \
        "$(xml_escape "$source_branch")" \
        "$(xml_escape "$target_branch")" \
        "$(xml_escape "atmux://pull-request/$repo/$id")" \
        "$(xml_escape "$title")"
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d | sort)
  fi
  printf '</pull-requests>\n'
}

get_pr() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux pr get <id> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir title description state created_at updated_at
  local assigned_to assigned_by assigned_at claimed_by claimed_at source_branch target_branch
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(pull_request_root_for_repo "$repo")"
  dir="$(pull_request_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "pull request not found: $id" >&2
    exit 1
  fi

  title="$(read_field "$dir/title")"
  description="$(read_field "$dir/description")"
  source_branch="$(read_field "$dir/source")"
  target_branch="$(read_field "$dir/target")"
  state="$(read_field "$dir/state")"
  created_at="$(read_field "$dir/created_at")"
  updated_at="$(read_field "$dir/updated_at")"
  assigned_to="$(read_field "$dir/assigned_to")"
  assigned_by="$(read_field "$dir/assigned_by")"
  assigned_at="$(read_field "$dir/assigned_at")"
  claimed_by="$(read_field "$dir/claimed_by")"
  claimed_at="$(read_field "$dir/claimed_at")"

  printf '<pull-request id="%s" repo="%s" state="%s" created_at="%s" updated_at="%s" uri="%s">\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$state")" \
    "$(xml_escape "$created_at")" \
    "$(xml_escape "$updated_at")" \
    "$(xml_escape "atmux://pull-request/$repo/$id")"
  printf '  <title>%s</title>\n' "$(xml_escape "$title")"
  printf '  <description>%s</description>\n' "$(xml_escape "$description")"
  printf '  <branches source="%s" target="%s" />\n' \
    "$(xml_escape "$source_branch")" \
    "$(xml_escape "$target_branch")"
  printf '  <assignment to="%s" by="%s" at="%s" />\n' \
    "$(xml_escape "$assigned_to")" \
    "$(xml_escape "$assigned_by")" \
    "$(xml_escape "$assigned_at")"
  printf '  <claim by="%s" at="%s" />\n' \
    "$(xml_escape "$claimed_by")" \
    "$(xml_escape "$claimed_at")"
  printf '</pull-request>\n'
}

assign_pr() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""
  local to=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux pr assign <id> --to <agent|session> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)
        to="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$to" ]]; then
    echo "missing required flag: --to" >&2
    exit 2
  fi

  ensure_can_assign

  local repo root dir now assigned_by
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(pull_request_root_for_repo "$repo")"
  dir="$(pull_request_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "pull request not found: $id" >&2
    exit 1
  fi

  now="$(now_utc)"
  assigned_by="$(current_actor_name "$repo")"

  write_field "$dir/assigned_to" "$to"
  write_field "$dir/assigned_by" "$assigned_by"
  write_field "$dir/assigned_at" "$now"
  write_field "$dir/claimed_by" ""
  write_field "$dir/claimed_at" ""
  write_field "$dir/state" "assigned"
  write_field "$dir/updated_at" "$now"

  printf '<pull-request id="%s" repo="%s" state="assigned" assigned_to="%s" assigned_by="%s" assigned_at="%s" claimed_by="" claimed_at="" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$to")" \
    "$(xml_escape "$assigned_by")" \
    "$(xml_escape "$now")"

  local actor_pane assignee_session assignee_pane notification_xml
  actor_pane="$(current_pane)"
  assignee_session="$("$HERE/agent" resolve "$to" "$repo" 2>/dev/null || true)"
  if [[ -n "$assignee_session" ]]; then
    assignee_pane="$(primary_pane_for_session "$assignee_session")"
  fi
  notification_xml="$(build_notification "pull-request" "assign" "atmux pr get $id" "state=assigned")"
  if [[ -n "${assignee_pane:-}" && "$assignee_pane" != "$actor_pane" ]]; then
    send_notification "$assignee_pane" "$notification_xml"
  fi
  notify_pull_request_watchers "$dir" "$actor_pane" "$notification_xml"
}

claim_pr() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""
  local by=""

  if [[ -z "$id" ]]; then
    echo "usage: atmux pr claim <id> [--by <agent|session>] [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --by)
        by="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir assigned_to claimed_by now
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(pull_request_root_for_repo "$repo")"
  dir="$(pull_request_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "pull request not found: $id" >&2
    exit 1
  fi

  if [[ -z "$by" ]]; then
    by="$(current_actor_name "$repo")"
  fi

  if [[ -z "$by" || "$by" == "external" ]]; then
    echo "unable to infer claimer; pass --by <agent|session>" >&2
    exit 2
  fi

  assigned_to="$(read_field "$dir/assigned_to")"
  if [[ -n "$assigned_to" ]] && ! identity_matches "$assigned_to" "$by" "$repo"; then
    echo "pull request is assigned to '$assigned_to'; '$by' cannot claim it" >&2
    exit 1
  fi

  claimed_by="$(read_field "$dir/claimed_by")"
  if [[ -n "$claimed_by" ]] && ! identity_matches "$claimed_by" "$by" "$repo"; then
    echo "pull request already claimed by '$claimed_by'" >&2
    exit 1
  fi

  now="$(now_utc)"
  if [[ -z "$assigned_to" ]]; then
    write_field "$dir/assigned_to" "$by"
    write_field "$dir/assigned_by" "self-claim"
    write_field "$dir/assigned_at" "$now"
    assigned_to="$by"
  fi
  write_field "$dir/claimed_by" "$by"
  write_field "$dir/claimed_at" "$now"
  write_field "$dir/state" "in_progress"
  write_field "$dir/updated_at" "$now"

  printf '<pull-request id="%s" repo="%s" state="in_progress" assigned_to="%s" claimed_by="%s" claimed_at="%s" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$assigned_to")" \
    "$(xml_escape "$by")" \
    "$(xml_escape "$now")"

  local actor_pane notification_xml
  actor_pane="$(current_pane)"
  notification_xml="$(build_notification "pull-request" "claim" "atmux pr get $id" "state=in_progress")"
  notify_pull_request_watchers "$dir" "$actor_pane" "$notification_xml"
}

sub="${1:-}"
shift || true

case "$sub" in
  create)
    create_pr "$@"
    ;;
  list|ls)
    list_prs "$@"
    ;;
  get|show)
    get_pr "$@"
    ;;
  assign)
    assign_pr "$@"
    ;;
  claim)
    claim_pr "$@"
    ;;
  comment)
    here_pr="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ $# -lt 2 ]]; then
      echo "usage: atmux pr comment <id> \"message\" [--repo R]" >&2
      exit 2
    fi
    pr_id="$1"; shift
    comment_msg="$1"; shift
    exec "$here_pr/(internal)/comment" "$comment_msg" --pr "$pr_id" "$@"
    ;;
  watch)
    here_pr="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    # --feed <repo> selects the new-PRs stream watcher; otherwise first
    # positional is a PR id, atmux-uri, or GitHub URL. The legacy `watch --pr`
    # routing checked if the arg was a GitHub URL to pick `[watch]/pr` vs
    # `[watch]/pull-request`; we mirror that here.
    feed_repo=""
    forward_args=()
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --feed)   feed_repo="${2:-}"; shift 2 ;;
        --feed=*) feed_repo="${1#--feed=}"; shift ;;
        *)        forward_args+=("$1"); shift ;;
      esac
    done
    if [[ -n "$feed_repo" ]]; then
      exec "$here_pr/[watch]/prs" "$feed_repo" "${forward_args[@]}"
    fi
    if [[ ${#forward_args[@]} -eq 0 || "${forward_args[0]:0:1}" == "-" ]]; then
      echo "usage: atmux pr watch <id|atmux-uri|github-url> [--repo R]   |   atmux pr watch --feed <repo>" >&2
      exit 2
    fi
    pr_id="${forward_args[0]}"
    forward_args=("${forward_args[@]:1}")
    case "$pr_id" in
      https://github.com/*|github.com/*|atmux://*)
        exec "$here_pr/[watch]/pr" --pr "$pr_id" "${forward_args[@]}"
        ;;
      *)
        exec "$here_pr/[watch]/pull-request" --pull-request "$pr_id" "${forward_args[@]}"
        ;;
    esac
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown pr command: $sub" >&2
    exit 2
    ;;
esac
