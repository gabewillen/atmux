#!/usr/bin/env bash
set -euo pipefail

# Test that queue_self_notification (async path) waits for input idle
# on root manager panes before delivering.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="qidle${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
# Use cat process — no shell prompt, simulates adapter CLI
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 "cat"

# Root manager: no ATMUX_MANAGER, has ATMUX_ADAPTER
tmux set-environment -t "$session" ATMUX_ADAPTER "claude-code"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

# Simulate user typing (non-idle)
sleep 0.3
tmux send-keys -t "$pane" -l "> user is typing here"

# Queue a notification — it should wait for idle before sending
marker="queuetest-$RANDOM"
payload="$(build_notification "test" "$marker" "")"
ATMUX_INPUT_IDLE_TIMEOUT=10 queue_self_notification "$pane" "$payload"

# Notification should NOT appear yet (user is typing)
sleep 1
snap="$(tmux capture-pane -p -t "$pane" -S -400 2>/dev/null | tr -d '\r\n' || true)"
if printf '%s' "$snap" | grep -Fq "$marker"; then
  echo "notification delivered while user was typing — idle check failed" >&2
  exit 1
fi

# Now clear the input to simulate user finishing — put prompt on its own line
tmux send-keys -t "$pane" C-u
sleep 0.1
tmux send-keys -t "$pane" Enter
sleep 0.1
tmux send-keys -t "$pane" -l "> "
tmux send-keys -t "$pane" Enter

# Notification should arrive after input becomes idle
if ! wait_for_text "$pane" "$marker" 15; then
  echo "notification not delivered after input became idle" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: queue_self_notification waits for input idle on root manager pane"
