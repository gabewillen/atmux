#!/usr/bin/env bash
# ATMUX_AGENT_HELP_HIDE=1
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
ATMUX_GITHUB_REPO="${ATMUX_GITHUB_REPO:-gabewillen/atmux}"
ATMUX_API_BASE="https://api.github.com/repos/${ATMUX_GITHUB_REPO}"

CHECK_ONLY=0
TARGET_VERSION=""
PROJECT_MODE=0
PROJECT_ROOT=""
ACTION="update"

usage() {
  cat <<'EOF'
Usage:
  atmux update [--project] [--project-root <dir>] [--check] [--version <version>]
  atmux update [--project] [--project-root <dir>] --auto
  atmux update [--project] [--project-root <dir>] --no-auto

Description:
  Update atmux from the latest GitHub release.

Options:
  --check              Only report whether an update is available; do not install.
  --version <version>  Install a specific version (e.g. 0.2.0). Defaults to latest.
  --project            Update the current project's <project>/.atmux install.
  --project-root <dir> Project directory for --project (default: git root or cwd).
  --auto               Enable background auto-update on every atmux command (hourly throttle).
  --no-auto            Disable background auto-update.

Examples:
  atmux update
  atmux update --project
  atmux update --check
  atmux update --version 0.2.0
  atmux update --auto
  atmux update --no-auto
EOF
}

installed_version() {
  local home="$1"
  local f="$home/src/atmux/VERSION"
  if [[ -f "$f" ]]; then
    tr -d '[:space:]' < "$f"
  else
    echo "0.0.0"
  fi
}

install_scope() {
  local home="$1"
  local f="$home/config/install/scope"
  if [[ -f "$f" ]]; then
    case "$(tr -d '[:space:]' < "$f")" in
      project) echo "project"; return ;;
      system) echo "system"; return ;;
    esac
  fi
  echo "system"
}

install_project_root() {
  local home="$1"
  local f="$home/config/install/project-root"
  if [[ -f "$f" ]]; then
    tr -d '\n' < "$f"
    return
  fi

  case "$home" in
    */.atmux)
      dirname "$home"
      ;;
    *)
      pwd
      ;;
  esac
}

default_project_root() {
  if [[ -n "$PROJECT_ROOT" ]]; then
    (cd "$PROJECT_ROOT" && pwd)
    return 0
  fi

  local git_root
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    printf '%s\n' "$git_root"
  else
    pwd
  fi
}

# Returns 0 if $1 > $2 (semver comparison)
semver_gt() {
  [[ "$1" == "$2" ]] && return 1
  local winner
  winner="$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)"
  [[ "$winner" == "$1" ]]
}

fetch_release_info() {
  local endpoint="$1"
  curl -fsSL --max-time 15 \
    -H "Accept: application/vnd.github+json" \
    "$ATMUX_API_BASE/releases/${endpoint}"
}

parse_tag() {
  grep -o '"tag_name": *"[^"]*"' | head -1 | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/'
}

parse_tarball_url() {
  grep -o '"tarball_url": *"[^"]*"' | head -1 | sed 's/.*"tarball_url": *"\([^"]*\)".*/\1/'
}

main() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --check) CHECK_ONLY=1; shift ;;
      --version) TARGET_VERSION="$2"; shift 2 ;;
      --project) PROJECT_MODE=1; shift ;;
      --project-root)
        [[ $# -ge 2 ]] || { echo "--project-root requires a path" >&2; exit 2; }
        PROJECT_ROOT="$2"
        PROJECT_MODE=1
        shift 2
        ;;
      --project-root=*)
        PROJECT_ROOT="${1#--project-root=}"
        PROJECT_MODE=1
        shift
        ;;
      --auto)
        ACTION="auto"
        shift
        ;;
      --no-auto)
        ACTION="no-auto"
        shift
        ;;
      -h|--help) usage; exit 0 ;;
      *) echo "unknown flag: $1" >&2; usage >&2; exit 2 ;;
    esac
  done

  local target_home
  if [[ "$PROJECT_MODE" -eq 1 ]]; then
    PROJECT_ROOT="$(default_project_root)"
    target_home="$PROJECT_ROOT/.atmux"
  else
    target_home="$ATMUX_HOME"
  fi

  case "$ACTION" in
    auto)
      mkdir -p "$target_home/config/update"
      printf '1\n' > "$target_home/config/update/auto"
      if [[ "$PROJECT_MODE" -eq 1 ]]; then
        echo "auto-update enabled for project: $PROJECT_ROOT"
      else
        echo "auto-update enabled"
      fi
      exit 0
      ;;
    no-auto)
      rm -f "$target_home/config/update/auto"
      rmdir "$target_home/config/update" 2>/dev/null || true
      if [[ "$PROJECT_MODE" -eq 1 ]]; then
        echo "auto-update disabled for project: $PROJECT_ROOT"
      else
        echo "auto-update disabled"
      fi
      exit 0
      ;;
  esac

  local current
  current="$(installed_version "$target_home")"
  echo "installed: ${current}"

  # Fetch release info
  local api_payload tag latest_version
  if [[ -n "$TARGET_VERSION" ]]; then
    api_payload="$(fetch_release_info "tags/v${TARGET_VERSION}")" || {
      echo "error: version ${TARGET_VERSION} not found on GitHub" >&2
      exit 1
    }
  else
    api_payload="$(fetch_release_info "latest")" || {
      echo "error: could not reach GitHub releases API" >&2
      exit 1
    }
  fi

  tag="$(printf '%s' "$api_payload" | parse_tag)"
  latest_version="${tag#v}"

  if [[ -z "$latest_version" ]]; then
    echo "error: could not determine latest version from GitHub" >&2
    exit 1
  fi

  echo "latest:    ${latest_version}"

  if [[ -z "$TARGET_VERSION" ]] && ! semver_gt "$latest_version" "$current"; then
    echo "atmux is up to date"
    exit 0
  fi

  if [[ -n "$TARGET_VERSION" && "$TARGET_VERSION" == "$current" ]]; then
    echo "requested version ${TARGET_VERSION} is already installed"
    exit 0
  fi

  if [[ -z "$TARGET_VERSION" ]]; then
    echo "update available: ${current} -> ${latest_version}"
  else
    echo "installing version: ${latest_version}"
  fi

  if [[ "$CHECK_ONLY" -eq 1 ]]; then
    exit 0
  fi

  # Download release tarball and re-run install
  local tarball_url tmpdir
  tarball_url="$(printf '%s' "$api_payload" | parse_tarball_url)"
  if [[ -z "$tarball_url" ]]; then
    # Fall back to the standard GitHub source archive URL
    tarball_url="https://github.com/${ATMUX_GITHUB_REPO}/archive/refs/tags/${tag}.tar.gz"
  fi

  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/atmux-update.XXXXXX")"
  # Bake the path into the trap so it doesn't deref a local that's
  # already gone out of scope by the time the EXIT trap fires (under
  # `set -u` the deferred deref would be reported as "unbound variable"
  # and turn a successful update into a non-zero exit).
  trap "rm -rf -- $(printf '%q' "$tmpdir")" EXIT

  echo "downloading ${tarball_url} ..."
  curl -fsSL --max-time 120 -L "$tarball_url" | tar xz -C "$tmpdir" --strip-components=1

  local install_script="$tmpdir/install.sh"
  if [[ ! -f "$install_script" ]]; then
    echo "error: install.sh not found in release archive" >&2
    exit 1
  fi
  chmod +x "$install_script"

  local scope
  if [[ "$PROJECT_MODE" -eq 1 ]]; then
    scope="project"
  else
    scope="$(install_scope "$target_home")"
  fi
  if [[ "$scope" == "project" ]]; then
    local project_root
    if [[ "$PROJECT_MODE" -eq 1 ]]; then
      project_root="$PROJECT_ROOT"
    else
      project_root="$(install_project_root "$target_home")"
    fi
    ATMUX_HOME="$target_home" "$install_script" --project --project-root "$project_root" --no-slash-commands
  else
    ATMUX_HOME="$target_home" "$install_script" --system --no-slash-commands
  fi
  echo ""
  echo "updated to ${latest_version}"
}

main "$@"
