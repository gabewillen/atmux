#!/usr/bin/env bash
set -euo pipefail

resolve_real_tmux() {
  local self_dir self_path dir candidate candidate_dir candidate_path
  self_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
  self_path="$self_dir/$(basename -- "${BASH_SOURCE[0]}")"

  IFS=':' read -r -a path_parts <<<"${PATH:-}"
  for dir in "${path_parts[@]}"; do
    [[ -n "$dir" ]] || dir="."
    candidate="$dir/tmux"
    [[ -x "$candidate" ]] || continue
    candidate_dir="$(cd -- "$(dirname -- "$candidate")" 2>/dev/null && pwd -P || true)"
    [[ -n "$candidate_dir" ]] || continue
    candidate_path="$candidate_dir/$(basename -- "$candidate")"
    [[ "$candidate_path" != "$self_path" ]] || continue
    [[ -x "$candidate_dir/atmux" && -d "$candidate_dir/(atmux)" ]] && continue
    printf '%s\n' "$candidate_path"
    return 0
  done
  return 1
}

if [[ "${ATMUX_ALLOW_REAL_TMUX:-}" == "1" ]]; then
  real_tmux="${ATMUX_REAL_TMUX:-}"
  if [[ -z "$real_tmux" || ! -x "$real_tmux" ]]; then
    real_tmux="$(resolve_real_tmux || true)"
  fi
  if [[ -n "$real_tmux" && -x "$real_tmux" ]]; then
    socket="${ATMUX_TMUX_SOCKET:-}"
    if [[ -z "$socket" && -n "${TMUX:-}" ]]; then
      socket="${TMUX%%,*}"
    fi
    if [[ -n "$socket" ]]; then
      has_socket_flag=0
      for arg in "$@"; do
        case "$arg" in
          -S|-L) has_socket_flag=1 ;;
        esac
      done
      if [[ "$has_socket_flag" -eq 0 ]]; then
        exec env TMUX= "$real_tmux" -S "$socket" "$@"
      fi
    fi
    exec env TMUX= "$real_tmux" "$@"
  fi
  echo "atmux tmux shim: real tmux binary is unavailable" >&2
  exit 127
fi

atmux_bin=""
if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "$ATMUX_SOURCE_ROOT/bin/atmux" ]]; then
  atmux_bin="$ATMUX_SOURCE_ROOT/bin/atmux"
elif command -v atmux >/dev/null 2>&1; then
  atmux_bin="$(command -v atmux)"
fi

if [[ -z "$atmux_bin" ]]; then
  echo "atmux tmux shim: atmux command is unavailable" >&2
  exit 127
fi

exec "$atmux_bin" "$@"
