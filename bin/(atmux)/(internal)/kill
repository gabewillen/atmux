#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify  # accessed via $HERE/../notify
source "$HERE/../notify"

usage() {
  cat <<'USAGE'
Internal kill backend. Invoked by the noun-first front-ends:

  atmux process kill <pid> [--timeout <seconds>] [--signal <NAME>]
  atmux watcher kill <id> [--timeout <seconds>]
  atmux agent kill <name|pattern> [name|pattern...]
  atmux agent kill --all [--yes]

Direct invocation (--pid, --watcher, --agent, --all) is for internal callers
only and is not part of the user-facing CLI surface.
USAGE
}

# --- PID mode helpers ---

wait_for_completion_or_timeout() {
  local exec_dir="$1"
  local timeout_sec="$2"
  local deadline now st
  deadline=$(( $(date +%s) + timeout_sec ))
  while true; do
    if [[ -f "$exec_dir/notified" ]]; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      st="$(read_state_field "$exec_dir/state")"
      if [[ "$st" == "exited" ]]; then
        sleep 0.5
        return 0
      fi
      return 1
    fi
    sleep 0.05
  done
}

process_group_signal_target() {
  local pid="$1"
  local pgid

  pgid="$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d '[:space:]' || true)"
  if [[ -n "$pgid" && "$pgid" == "$pid" ]]; then
    printf -- '-%s\n' "$pgid"
    return 0
  fi

  printf '%s\n' "$pid"
}

kill_pid() {
  local pid="$1"
  local timeout_sec="$2"
  local signal_name="$3"

  local repo_name
  repo_name="$(repo_name_from_context)"
  local exec_dir
  exec_dir="$(exec_dir_for_repo_pid "$repo_name" "$pid")"

  if ! validate_exec_ownership "$exec_dir" "$pid" "$repo_name"; then
    echo "atmux process kill: not an atmux-owned exec PID for this repo: $pid" >&2
    exit 2
  fi

  local st
  st="$(read_state_field "$exec_dir/state")"

  if [[ "$st" != "exited" ]]; then
    if kill -0 "$pid" 2>/dev/null; then
      local signal_target
      signal_target="$(process_group_signal_target "$pid")"
      kill "-${signal_name}" "$signal_target" 2>/dev/null || true
      local deadline now
      deadline=$(( $(date +%s) + timeout_sec ))
      while kill -0 "$pid" 2>/dev/null; do
        now="$(date +%s)"
        if (( now >= deadline )); then
          kill -KILL "$signal_target" 2>/dev/null || true
          sleep 0.05
          break
        fi
        sleep 0.1
      done
    fi
  fi

  if ! wait_for_completion_or_timeout "$exec_dir" "$timeout_sec"; then
    echo "atmux process kill: timeout waiting for exec completion" >&2
    exit 124
  fi

  if [[ -d "$exec_dir" ]]; then
    rm -rf "$exec_dir"
  fi
  exit 0
}

# --- Watcher mode helpers ---

pr_watch_dir() {
  local key="$1"
  printf '%s/watch-pr/%s\n' "$ATMUX_HOME" "$key"
}

issues_watch_dir() {
  local key="$1"
  printf '%s/watch-issues/%s\n' "$ATMUX_HOME" "$key"
}

prs_watch_dir() {
  local key="$1"
  printf '%s/watch-prs/%s\n' "$ATMUX_HOME" "$key"
}

pr_watch_watchers_dir() {
  local key="$1"
  printf '%s/watchers\n' "$(pr_watch_dir "$key")"
}

issues_watch_watchers_dir() {
  local key="$1"
  printf '%s/watchers\n' "$(issues_watch_dir "$key")"
}

prs_watch_watchers_dir() {
  local key="$1"
  printf '%s/watchers\n' "$(prs_watch_dir "$key")"
}

pr_watch_pid_file() {
  local key="$1"
  printf '%s/worker.pid\n' "$(pr_watch_dir "$key")"
}

issues_watch_pid_file() {
  local key="$1"
  printf '%s/worker.pid\n' "$(issues_watch_dir "$key")"
}

prs_watch_pid_file() {
  local key="$1"
  printf '%s/worker.pid\n' "$(prs_watch_dir "$key")"
}

read_trimmed_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  tr -d '\r\n' < "$file" 2>/dev/null || true
}

pr_worker_running_for_key() {
  local key="$1" pid=""
  pid="$(read_trimmed_file "$(pr_watch_pid_file "$key")")"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

issues_worker_running_for_key() {
  local key="$1" pid=""
  pid="$(read_trimmed_file "$(issues_watch_pid_file "$key")")"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

prs_worker_running_for_key() {
  local key="$1" pid=""
  pid="$(read_trimmed_file "$(prs_watch_pid_file "$key")")"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

wait_for_pr_worker_exit() {
  local key="$1"
  local timeout_sec="$2"
  local deadline now

  deadline=$(( $(date +%s) + timeout_sec ))
  while pr_worker_running_for_key "$key" || [[ -f "$(pr_watch_pid_file "$key")" ]]; do
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
  return 0
}

wait_for_issues_worker_exit() {
  local key="$1"
  local timeout_sec="$2"
  local deadline now

  deadline=$(( $(date +%s) + timeout_sec ))
  while issues_worker_running_for_key "$key" || [[ -f "$(issues_watch_pid_file "$key")" ]]; do
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
  return 0
}

wait_for_prs_worker_exit() {
  local key="$1"
  local timeout_sec="$2"
  local deadline now

  deadline=$(( $(date +%s) + timeout_sec ))
  while prs_worker_running_for_key "$key" || [[ -f "$(prs_watch_pid_file "$key")" ]]; do
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
  return 0
}

kill_watcher() {
  local watcher_id="$1"
  local timeout_sec="$2"
  local kind="" key="" watcher_name="" extra=""

  IFS=':' read -r kind key watcher_name extra <<< "$watcher_id"
  if [[ -z "$kind" || -z "$key" || -z "$watcher_name" || -n "$extra" ]]; then
    echo "atmux watcher kill: invalid watcher id: $watcher_id" >&2
    exit 2
  fi

  case "$kind" in
    pr)
      local watcher_file watchers_dir remaining=0
      watcher_file="$(pr_watch_watchers_dir "$key")/$watcher_name"
      if [[ ! -f "$watcher_file" ]]; then
        # Sweep an orphan exec sidecar if one was left behind by a prior crash.
        if [[ -f "${watcher_file}.exec" ]]; then
          rm -f "${watcher_file}.exec"
        fi
        echo "atmux watcher kill: watcher not found: $watcher_id" >&2
        exit 2
      fi

      rm -f "$watcher_file" "${watcher_file}.exec"
      watchers_dir="$(pr_watch_watchers_dir "$key")"
      if [[ -d "$watchers_dir" ]]; then
        remaining="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f ! -name '*.exec' 2>/dev/null | wc -l | tr -d ' ')"
      fi

      if [[ "${remaining:-0}" -eq 0 ]] && pr_worker_running_for_key "$key"; then
        wait_for_pr_worker_exit "$key" "$timeout_sec" || true
      fi
      ;;
    issues)
      local watcher_file watchers_dir remaining=0
      watcher_file="$(issues_watch_watchers_dir "$key")/$watcher_name"
      if [[ ! -f "$watcher_file" ]]; then
        if [[ -f "${watcher_file}.exec" ]]; then
          rm -f "${watcher_file}.exec"
        fi
        echo "atmux watcher kill: watcher not found: $watcher_id" >&2
        exit 2
      fi

      rm -f "$watcher_file" "${watcher_file}.exec"
      watchers_dir="$(issues_watch_watchers_dir "$key")"
      if [[ -d "$watchers_dir" ]]; then
        remaining="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f ! -name '*.exec' 2>/dev/null | wc -l | tr -d ' ')"
      fi

      if [[ "${remaining:-0}" -eq 0 ]] && issues_worker_running_for_key "$key"; then
        wait_for_issues_worker_exit "$key" "$timeout_sec" || true
      fi
      ;;
    prs)
      local watcher_file watchers_dir remaining=0
      watcher_file="$(prs_watch_watchers_dir "$key")/$watcher_name"
      if [[ ! -f "$watcher_file" ]]; then
        if [[ -f "${watcher_file}.exec" ]]; then
          rm -f "${watcher_file}.exec"
        fi
        echo "atmux watcher kill: watcher not found: $watcher_id" >&2
        exit 2
      fi

      rm -f "$watcher_file" "${watcher_file}.exec"
      watchers_dir="$(prs_watch_watchers_dir "$key")"
      if [[ -d "$watchers_dir" ]]; then
        remaining="$(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f ! -name '*.exec' 2>/dev/null | wc -l | tr -d ' ')"
      fi

      if [[ "${remaining:-0}" -eq 0 ]] && prs_worker_running_for_key "$key"; then
        wait_for_prs_worker_exit "$key" "$timeout_sec" || true
      fi
      ;;
    *)
      echo "atmux watcher kill: unsupported watcher type: $kind" >&2
      exit 2
      ;;
  esac
}

# --- Agent mode helpers ---

normalize_repo_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "must be run from a git repository" >&2
    exit 1
  fi
  repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_repo_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

matches_any_pattern() {
  local value="$1"
  shift || true
  local pattern
  for pattern in "$@"; do
    # shellcheck disable=SC2053
    if [[ "$value" == $pattern ]]; then
      return 0
    fi
  done
  return 1
}

run_role_hook() {
  local cmd="$1"
  [[ -n "$cmd" ]] || return 0
  if [[ -x "$cmd" && -f "$cmd" ]]; then
    "$cmd"
  else
    bash -c "$cmd"
  fi
}

run_role_hook_bounded() {
  # Runs a role hook in the background and enforces a wall-clock budget so a
  # misbehaving stop hook can never block kill_agents indefinitely. Returns
  # 124 if the budget expires; otherwise the hook's own exit code.
  local cmd="$1"
  local budget_secs="${2:-30}"
  local pid deadline now
  [[ -n "$cmd" ]] || return 0
  ( run_role_hook "$cmd" ) &
  pid=$!
  deadline=$(( $(date +%s) + budget_secs ))
  while kill -0 "$pid" 2>/dev/null; do
    now="$(date +%s)"
    if (( now >= deadline )); then
      kill -TERM "$pid" 2>/dev/null || true
      sleep 0.5
      kill -KILL "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
      return 124
    fi
    sleep 0.2
  done
  wait "$pid"
}

signal_adapter_pane() {
  # Sends TERM to the adapter process running in a session's primary pane and
  # waits up to wait_secs seconds for it to exit. Best-effort: returns 0 even
  # when the process doesn't exit in time so the caller can proceed to kill
  # the session anyway.
  local session="$1"
  local wait_secs="${2:-5}"
  local pane pid i
  pane="$(primary_pane_for_session "$session")"
  [[ -n "$pane" ]] || return 0
  pid="$(tmux display-message -t "$pane" -p '#{pane_pid}' 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 0
  kill -TERM "$pid" 2>/dev/null || true
  i=0
  while (( i < wait_secs * 10 )); do
    kill -0 "$pid" 2>/dev/null || return 0
    sleep 0.1
    i=$((i + 1))
  done
  return 0
}

kill_agents() {
  local repo_root="" repo_name=""
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  local atmux_home="${ATMUX_HOME:-$HOME/.atmux}"
  local worktree_root="$atmux_home/agents"
  local prefix="atmux-${repo_name}-"

  local candidates
  candidates="$(
    {
      tmux list-sessions -F '#{session_name}' 2>/dev/null | awk -v p="$prefix" 'index($0,p)==1 { print }'
      if [[ -d "$worktree_root" ]]; then
        find "$worktree_root" -maxdepth 1 -mindepth 1 -type d -name "${repo_name}-*" -exec basename {} \; | sed 's/^/atmux-/'
      fi
      git -C "$repo_root" for-each-ref --format='%(refname:short)' "refs/heads/${prefix}*" 2>/dev/null
    } | awk -v p="$prefix" 'index($0,p)==1 { print }' | sort -u
  )"

  local removed_any=0
  local results_xml=""
  local session
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue

    # Match against full session name, short name (without atmux-repo- prefix), or agent name
    local short_name="${session#"$prefix"}"
    if ! matches_any_pattern "$session" "$@" && \
       ! matches_any_pattern "$short_name" "$@"; then
      continue
    fi

    removed_any=1
    local state="removed"
    local removed_session="false"
    local removed_worktree="false"
    local removed_branch="false"
    local note=""

    if tmux has-session -t "$session" 2>/dev/null; then
      # Wind the adapter down first so the role.stop hook below sees the
      # adapter process gone but the session env still readable.
      signal_adapter_pane "$session" 5
      role_stop="$(get_session_env "$session" ATMUX_ROLE_STOP)"
      if [[ -n "$role_stop" ]]; then
        role_dir="$(get_session_env "$session" ATMUX_ROLE_DIR)"
        role_state_dir="$(get_session_env "$session" ATMUX_ROLE_STATE_DIR)"
        role_name="$(get_session_env "$session" ATMUX_ROLE)"
        ATMUX_AGENT_NAME="$short_name" \
        ATMUX_AGENT_SESSION="$session" \
        ATMUX_REPO="$repo_name" \
        ATMUX_ROLE="$role_name" \
        ATMUX_ROLE_DIR="$role_dir" \
        ATMUX_ROLE_STATE_DIR="$role_state_dir" \
        run_role_hook_bounded "$role_stop" "${ATMUX_ROLE_STOP_TIMEOUT:-30}" || true
      fi
      tmux kill-session -t "$session"
      removed_session="true"
    fi

    local suffix="${session#atmux-}"
    local worktree="$worktree_root/$suffix"
    if [[ -d "$worktree" ]]; then
      if git -C "$repo_root" worktree list --porcelain 2>/dev/null | grep -Fqx "worktree $worktree"; then
        git -C "$repo_root" worktree remove -f "$worktree" >/dev/null 2>&1 || true
        if [[ -d "$worktree" ]]; then
          state="errored"
        else
          removed_worktree="true"
        fi
      else
        rm -rf -- "$worktree"
        if [[ -d "$worktree" ]]; then
          state="errored"
          note="worktree-unregistered-remove-failed"
        else
          removed_worktree="true"
          note="worktree-unregistered-pruned"
        fi
      fi
    fi

    if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$session"; then
      git -C "$repo_root" branch -D "$session" >/dev/null 2>&1 || true
      if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$session"; then
        state="errored"
      else
        removed_branch="true"
      fi
    fi

    local agent_name="${session#atmux-"${repo_name}"-}"
    if [[ "$agent_name" == "$session" ]]; then
      agent_name="$session"
    fi

    results_xml+="  <agent name=\"$(xml_escape "$agent_name")\" session=\"$(xml_escape "$session")\">"
    if [[ -n "$note" ]]; then
      results_xml+="<status state=\"$(xml_escape "$state")\" removed_session=\"$removed_session\" removed_worktree=\"$removed_worktree\" removed_branch=\"$removed_branch\" note=\"$(xml_escape "$note")\" />"
    else
      results_xml+="<status state=\"$(xml_escape "$state")\" removed_session=\"$removed_session\" removed_worktree=\"$removed_worktree\" removed_branch=\"$removed_branch\" />"
    fi
    results_xml+="</agent>"$'\n'
  done <<< "$candidates"

  if [[ "$removed_any" -eq 0 ]]; then
    echo "no agents matched: $*" >&2
    exit 1
  fi

  printf '<agents>\n%s</agents>\n' "$results_xml"
}

# --- Main ---

inside_atmux_session() {
  if [[ -n "${ATMUX_SESSION_NAME:-}" || -n "${ATMUX_MANAGER:-}" ]]; then
    return 0
  fi
  if [[ -n "${TMUX:-}" ]]; then
    local cur
    cur="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    [[ "$cur" == atmux-* ]] && return 0
  fi
  return 1
}

confirm_kill_all() {
  local repo_name="$1"
  if [[ ! -t 0 ]]; then
    echo "atmux agent kill --all: stdin is not a tty; pass --yes to skip prompt" >&2
    exit 2
  fi
  printf 'atmux agent kill --all will destroy every session, worktree, and branch for repo "%s".\nContinue? [y/N] ' "$repo_name" >&2
  local reply=""
  IFS= read -r reply || reply=""
  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *)
      echo "aborted" >&2
      exit 1
      ;;
  esac
}

main() {
  local pid=""
  local watcher_id=""
  local timeout_sec="60"
  local signal_name="TERM"
  local watcher_mode=0
  local agent_mode=0
  local all_mode=0
  local assume_yes=0
  local -a agent_targets=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pid)
        pid="${2:-}"
        shift 2
        ;;
      --watcher)
        watcher_mode=1
        watcher_id="${2:-}"
        shift 2
        ;;
      --agent)
        agent_mode=1
        shift
        # Collect all remaining non-flag args as agent targets
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --timeout|--signal)
              break
              ;;
            -h|--help|help)
              usage
              exit 0
              ;;
            *)
              agent_targets+=("$1")
              shift
              ;;
          esac
        done
        ;;
      --all)
        all_mode=1
        shift
        ;;
      --yes|-y)
        assume_yes=1
        shift
        ;;
      --timeout)
        timeout_sec="${2:-}"
        shift 2
        ;;
      --signal)
        signal_name="${2:-}"
        shift 2
        ;;
      -h|--help|help)
        usage
        exit 0
        ;;
      *)
        echo "unknown flag: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
  done

  if [[ "$all_mode" -eq 1 ]]; then
    if [[ "$agent_mode" -eq 1 || "$watcher_mode" -eq 1 || -n "$pid" ]]; then
      echo "--all cannot be combined with --agent, --watcher, or --pid" >&2
      exit 2
    fi
    if inside_atmux_session; then
      echo "atmux agent kill --all: refusing to run from inside an atmux session" >&2
      exit 2
    fi
    local repo_root="" repo_name=""
    {
      IFS= read -r repo_root
      IFS= read -r repo_name
    } < <(repo_context)
    if [[ "$assume_yes" -ne 1 ]]; then
      confirm_kill_all "$repo_name"
    fi
    kill_agents '*'
    exit $?
  fi

  if [[ "$watcher_mode" -eq 1 ]]; then
    if [[ -z "$watcher_id" ]]; then
      echo "missing watcher id" >&2
      usage >&2
      exit 2
    fi
    if [[ "$agent_mode" -eq 1 || -n "$pid" ]]; then
      echo "--watcher cannot be combined with --agent or --pid" >&2
      exit 2
    fi
    kill_watcher "$watcher_id" "$timeout_sec"
    exit $?
  fi

  if [[ "$agent_mode" -eq 1 ]]; then
    if [[ "${#agent_targets[@]}" -eq 0 ]]; then
      echo "missing agent name or pattern" >&2
      usage >&2
      exit 2
    fi
    kill_agents "${agent_targets[@]}"
    exit $?
  fi

  if [[ -n "$pid" ]]; then
    kill_pid "$pid" "$timeout_sec" "$signal_name"
  fi

  echo "missing --pid, --watcher, --agent, or --all" >&2
  usage >&2
  exit 2
}

main "$@"
