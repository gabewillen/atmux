#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -200 2>/dev/null | tr -d '\r' || true)"
    if printf '%s' "$snap" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

repo_name="attach-only-${RANDOM}"
target_session="atmux-${repo_name}-target"
runner_session="atmux-${repo_name}-runner"

cleanup() {
  tmux kill-session -t "$runner_session" >/dev/null 2>&1 || true
  tmux kill-session -t "$target_session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$runner_session" >/dev/null 2>&1 || true
tmux kill-session -t "$target_session" >/dev/null 2>&1 || true

tmux new-session -d -s "$target_session" -n "$target_session" -x 120 -y 30 -c "$REPO_ROOT" "cat"
tmux new-session -d -s "$runner_session" -n "$runner_session" -x 120 -y 30 -c "$REPO_ROOT" \
  "/bin/bash -lc 'cd \"$REPO_ROOT\" && \"$ATMUX_BIN\" agent attach \"$target_session\" 2>&1; printf \"__EXIT:%s__\\n\" \"\$?\"; sleep 30'"
runner_pane="$(tmux list-panes -t "$runner_session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$runner_pane" ]] || { echo "runner pane missing" >&2; exit 1; }

if ! wait_for_text "$runner_pane" "__EXIT:2__" 15; then
  tmux capture-pane -p -t "$runner_pane" -S -200 >&2 || true
  echo "agent attach did not exit with code 2 inside tmux" >&2
  exit 1
fi

attach_out="$(tmux capture-pane -p -t "$runner_pane" -S -200 2>/dev/null | tr -d '\r' || true)"
printf '%s\n' "$attach_out" | grep -Fq "atmux agent attach must be run outside tmux"

echo "ok: agent attach is rejected inside tmux"
