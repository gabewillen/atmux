#!/usr/bin/env bash
set -euo pipefail

# Tests invoke atmux from the host shell (not a tmux pane); allow without TMUX.
export ATMUX_ALLOW_OUTSIDE_TMUX="${ATMUX_ALLOW_OUTSIDE_TMUX:-1}"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
CLEANUP_ORPHANS="$TESTS_DIR/scripts/cleanup-orphans"

# Isolate the tmux socket so tests never touch the developer's real tmux server.
# Setting TMUX_TMPDIR redirects where tmux looks for/creates its socket; any
# child `tmux ...` invocation in this process tree spawns/uses a private server
# at $TMUX_TMPDIR/tmux-$UID/default instead of the user's default socket.
if [[ -z "${ATMUX_TESTS_TMUX_TMPDIR:-}" ]]; then
  ATMUX_TESTS_TMUX_TMPDIR="$(mktemp -d "${TMPDIR:-/tmp}/atmux-tests-tmux.XXXXXX")"
  export ATMUX_TESTS_TMUX_TMPDIR
  cleanup_isolated_tmux() {
    if [[ -n "${ATMUX_TESTS_TMUX_TMPDIR:-}" && -d "$ATMUX_TESTS_TMUX_TMPDIR" ]]; then
      TMUX_TMPDIR="$ATMUX_TESTS_TMUX_TMPDIR" tmux kill-server >/dev/null 2>&1 || true
      rm -rf "$ATMUX_TESTS_TMUX_TMPDIR"
    fi
  }
  trap cleanup_isolated_tmux EXIT INT TERM
fi
export TMUX_TMPDIR="$ATMUX_TESTS_TMUX_TMPDIR"
export ATMUX_TMUX_SOCKET="$ATMUX_TESTS_TMUX_TMPDIR/tmux-$(id -u)/default"
mkdir -p "$(dirname -- "$ATMUX_TMUX_SOCKET")"
chmod 700 "$(dirname -- "$ATMUX_TMUX_SOCKET")"

# Notify-queue state in the developer's ~/.atmux/notify-queue/ is keyed on
# (session_name, pane_id). With an isolated tmux server, pane ids reset to
# %0,%1,... and collide with stale entries left by previous test runs that
# used the same session names (atmux-<repo>-sender, etc). Wipe queue dirs
# matching test session prefixes before the suite runs, but never touch
# anything else under ~/.atmux.
purge_test_notify_queues() {
  local home_atmux="${ATMUX_HOME:-$HOME/.atmux}"
  local queues="$home_atmux/notify-queue"
  [[ -d "$queues" ]] || return 0
  local d base
  for d in "$queues"/atmux-*-_*; do
    [[ -d "$d" ]] || continue
    base="$(basename "$d")"
    case "$base" in
      atmux-*-sender-_*|atmux-*-receiver-_*|atmux-*-team-*-_*|atmux-*-par-_*|atmux-*-worker-_*|atmux-*-manager-_*)
        rm -rf "$d"
        ;;
    esac
  done
}
purge_test_notify_queues

log() {
  printf '[atmux-tests] %s\n' "$*"
}

usage() {
  cat <<'USAGE'
Usage: tests/runner [--shard N/TOTAL]

  --shard N/TOTAL  Run only the Nth slice of TOTAL using round-robin
                   selection across the test list. Used by CI to spread
                   the suite over a matrix of GitHub Actions runners.
                   Default: 1/1 (entire suite).

Live tests (suffix "_live") are skipped unless
ATMUX_RUN_LIVE_ADAPTER_TESTS=1 is exported.
USAGE
}

SHARD_INDEX=1
SHARD_TOTAL=1

parse_shard() {
  local spec="$1"
  if [[ ! "$spec" =~ ^([0-9]+)/([0-9]+)$ ]]; then
    echo "error: --shard expects N/TOTAL (e.g. 3/8), got '$spec'" >&2
    exit 2
  fi
  SHARD_INDEX="${BASH_REMATCH[1]}"
  SHARD_TOTAL="${BASH_REMATCH[2]}"
  if (( SHARD_INDEX < 1 || SHARD_INDEX > SHARD_TOTAL || SHARD_TOTAL < 1 )); then
    echo "error: --shard $spec is out of range" >&2
    exit 2
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --shard)       parse_shard "${2:-}"; shift 2 ;;
    --shard=*)     parse_shard "${1#--shard=}"; shift ;;
    -h|--help)     usage; exit 0 ;;
    *)             echo "error: unknown argument: $1" >&2; usage >&2; exit 2 ;;
  esac
done

should_skip_test() {
  local test_name="$1"
  case "${ATMUX_RUN_LIVE_ADAPTER_TESTS:-0}" in
    1|true|TRUE|yes|YES) return 1 ;;
  esac
  case "$test_name" in
    *_live) return 0 ;;
  esac
  return 1
}

# Kill any leftover detached `atmux schedule` and notify workers between
# tests so stale notifications can't leak into a later test's pane.
# Also re-purge the test notify queue dirs — items written before a
# session was killed survive in the filesystem and tmux often reuses
# pane ids when a session is recreated, so the next test's worker would
# pick up stale items keyed on the same (session, pane_id) pair.
purge_between_tests() {
  pkill -TERM -f 'atmux/exec _run .*atmux schedule' 2>/dev/null || true
  pkill -TERM -f 'bin/atmux schedule --no-detach --interval' 2>/dev/null || true
  pkill -TERM -f 'bin/atmux schedule --no-detach --once' 2>/dev/null || true
  purge_test_notify_queues
}

main() {
  local test_script i=0 owner ran=0
  for test_script in "$TESTS_DIR"/[0-9]*_*; do
    [[ -f "$test_script" ]] || continue
    [[ -x "$test_script" ]] || chmod +x "$test_script"
    owner=$(( i % SHARD_TOTAL + 1 ))
    i=$(( i + 1 ))
    if (( owner != SHARD_INDEX )); then
      continue
    fi
    [[ ! -x "$CLEANUP_ORPHANS" ]] || "$CLEANUP_ORPHANS" || true
    purge_between_tests
    if should_skip_test "$(basename "$test_script")"; then
      log "skipping $(basename "$test_script") (set ATMUX_RUN_LIVE_ADAPTER_TESTS=1 to include live adapter tests)"
      continue
    fi
    log "running $(basename "$test_script")"
    if ! "$test_script"; then
      [[ ! -x "$CLEANUP_ORPHANS" ]] || "$CLEANUP_ORPHANS" || true
      purge_between_tests
      return 1
    fi
    [[ ! -x "$CLEANUP_ORPHANS" ]] || "$CLEANUP_ORPHANS" || true
    purge_between_tests
    ran=$((ran + 1))
  done
  if (( SHARD_TOTAL > 1 )); then
    log "shard $SHARD_INDEX/$SHARD_TOTAL complete ($ran tests)"
  else
    log "suite complete ($ran tests)"
  fi
}

main "$@"
