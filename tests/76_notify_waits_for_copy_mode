#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -600 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_no_text() {
  local target="$1"
  local needle="$2"
  local duration="${3:-2}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + duration ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -600 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 1
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 0
    fi
    sleep 0.1
  done
}

ATMUX_HOME="${TMPDIR:-/tmp}/atmux-notify-${RANDOM}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="notifymode${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$ATMUX_HOME"
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 120 -y 30 "cat"
tmux set-environment -t "$session" ATMUX_ADAPTER "claude-code"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

sleep 0.3
for idx in $(seq 1 80); do
  tmux send-keys -t "$pane" -l "history-line-$idx"
  tmux send-keys -t "$pane" Enter
done

tmux copy-mode -t "$pane"
tmux send-keys -t "$pane" -X page-up
sleep 0.3

mode_state="$(tmux display-message -t "$pane" -p '#{pane_in_mode} #{pane_mode} #{scroll_position}' 2>/dev/null || true)"
printf '%s\n' "$mode_state" | grep -Eq '^1 '

marker="copy-mode-wait-${RANDOM}"
payload="$(build_notification "test" "$marker" "")"
send_notification "$pane" "$payload"

if ! wait_for_no_text "$pane" "$marker" 3; then
  echo "notification was delivered while pane was in copy mode" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

tmux send-keys -t "$pane" -X cancel

if ! wait_for_text "$pane" "$marker" 15; then
  echo "notification was not delivered after exiting copy mode" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

echo "ok: notify waits until copy mode exits before delivering"
