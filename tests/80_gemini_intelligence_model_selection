#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
START_SCRIPT="$REPO_ROOT/adapter/gemini/scripts/start"

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/atmux-gemini-intelligence.XXXXXX")"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

mkdir -p "$tmp_dir/bin" "$tmp_dir/work"
cat > "$tmp_dir/bin/gemini" <<'SH'
#!/usr/bin/env bash
printf '%s\n' "$@" > "$ATMUX_FAKE_ARGS"
SH
chmod +x "$tmp_dir/bin/gemini"

assert_selected_model() {
  local intelligence="$1"
  local expected_model="$2"
  local args_file="$tmp_dir/args-$intelligence"
  local home_dir="$tmp_dir/home-$intelligence"
  local worktree="$tmp_dir/work-$intelligence"

  mkdir -p "$worktree"
  (
    cd "$worktree"
    PATH="$tmp_dir/bin:$PATH" \
      ATMUX_HOME="$home_dir" \
      ATMUX_FAKE_ARGS="$args_file" \
      ATMUX_INTELLIGENCE="$intelligence" \
      "$START_SCRIPT" >/dev/null
  )

  grep -Fx -- "--model" "$args_file" >/dev/null || {
    echo "missing --model for intelligence $intelligence" >&2
    cat "$args_file" >&2
    exit 1
  }
  grep -Fx "$expected_model" "$args_file" >/dev/null || {
    echo "expected $expected_model for intelligence $intelligence" >&2
    cat "$args_file" >&2
    exit 1
  }
  grep -Fx -- "-y" "$args_file" >/dev/null || {
    echo "missing -y for intelligence $intelligence" >&2
    cat "$args_file" >&2
    exit 1
  }
}

assert_selected_model 0 gemini-3.1-flash-lite-preview
assert_selected_model 50 gemini-3-flash-preview
assert_selected_model 95 gemini-3.1-pro-preview

approval_args="$tmp_dir/args-approval-mode"
approval_home="$tmp_dir/home-approval-mode"
approval_worktree="$tmp_dir/work-approval-mode"
mkdir -p "$approval_worktree"
(
  cd "$approval_worktree"
  PATH="$tmp_dir/bin:$PATH" \
    ATMUX_HOME="$approval_home" \
    ATMUX_FAKE_ARGS="$approval_args" \
    "$START_SCRIPT" --approval-mode default >/dev/null
)
if grep -Fx -- "-y" "$approval_args" >/dev/null; then
  echo "unexpected -y when --approval-mode is present" >&2
  cat "$approval_args" >&2
  exit 1
fi
grep -Fx -- "--approval-mode" "$approval_args" >/dev/null || {
  echo "missing explicit --approval-mode" >&2
  cat "$approval_args" >&2
  exit 1
}

echo "ok: gemini intelligence selects lite, flash, and pro tiers"
