#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-20}"
  local deadline now snap
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -1200 2>/dev/null | tr -d '\r' || true)"
    if printf '%s' "$snap" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.2
  done
}

setup_out="$(ATMUX_ALLOW_OUTSIDE_TMUX=1 "$SCRIPTS_DIR/setup")"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"
pane_id="$(printf '%s\n' "$setup_out" | sed -n 's/^PANE_ID=//p' | tail -n 1)"
if [[ -z "$session_name" || -z "$pane_id" ]]; then
  echo "missing setup output (SESSION_NAME or PANE_ID)" >&2
  exit 1
fi

cleanup() {
  ATMUX_ALLOW_OUTSIDE_TMUX=1 "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux set-environment -t "$session_name" ATMUX_ADAPTER "codex"
tmux set-environment -t "$session_name" ATMUX_SESSION_NAME "$session_name"

partial_text="partial-codex-live-${RANDOM}"
notification_xml="<notification type=\"test\" from=\"notify-codex-live-${RANDOM}\" />"

tmux send-keys -t "$pane_id" -l "$partial_text"
sleep 0.5
ATMUX_ALLOW_OUTSIDE_TMUX=1 "$ATMUX_BIN" notify --pane "$pane_id" --xml "$notification_xml"

if ! wait_for_text "$pane_id" "$notification_xml" 20; then
  tmux capture-pane -p -t "$pane_id" -S -220 >&2 || true
  echo "live codex pane did not display notification xml" >&2
  exit 1
fi

if ! wait_for_text "$pane_id" "$partial_text" 20; then
  tmux capture-pane -p -t "$pane_id" -S -220 >&2 || true
  echo "live codex pane did not restore partial input" >&2
  exit 1
fi

echo "PASS 10_notification_restore_live"
