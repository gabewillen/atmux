#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux team create <name>
  atmux team list
  atmux team ls
  atmux team capture <name> [--lines <n>]
  atmux team kill <name|pattern> [...]
  atmux team resolve <name> [<repo_name>]

Description:
  Manage repo-scoped team tmux sessions.
  Team session format: atmux-<repo>-team-<name>
USAGE
}

repo_context() {
  local repo_root repo_name
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "atmux team must be run from a git repository" >&2
    exit 1
  fi

  repo_name="${ATMUX_REPO:-}"
  if [[ -z "$repo_name" && -n "${TMUX:-}" ]]; then
    repo_name="$(tmux show-environment ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
  fi
  if [[ -z "$repo_name" ]]; then
    repo_name="$(basename "$repo_root")"
  fi
  repo_name="$(normalize_name "$repo_name")"
  printf '%s\n%s\n' "$repo_root" "$repo_name"
}

ensure_tmux_scroll_enabled() {
  local history_limit
  history_limit="${ATMUX_TMUX_HISTORY_LIMIT:-200000}"
  tmux set-option -g mouse on >/dev/null 2>&1 || true
  tmux set-window-option -g history-limit "$history_limit" >/dev/null 2>&1 || true
}

create_team() {
  local raw_name="${1:-}"
  if [[ -z "$raw_name" ]]; then
    echo "usage: atmux team create <name>" >&2
    exit 2
  fi

  local repo_root repo_name team_name session
  {
    IFS= read -r repo_root
    IFS= read -r repo_name
  } < <(repo_context)

  team_name="$(normalize_name "$raw_name")"
  session="atmux-${repo_name}-team-${team_name}"

  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -n "$session" -c "$repo_root"
    ensure_tmux_scroll_enabled
    tmux set-environment -t "$session" ATMUX_REPO "$repo_name"
    tmux set-environment -t "$session" ATMUX_TEAM "$team_name"
    tmux set-environment -t "$session" ATMUX_SESSION_NAME "$session"
    tmux set-environment -t "$session" ATMUX_SESSION_KIND "team"
  fi

  # When invoked from within a repo agent session, remember this as the
  # default team for subsequent `atmux agent create ...` calls.
  if [[ -n "${TMUX:-}" ]]; then
    local caller_session caller_repo
    caller_session="$(tmux display-message -p '#S' 2>/dev/null || true)"
    if [[ -n "$caller_session" ]] && tmux has-session -t "$caller_session" 2>/dev/null; then
      caller_repo="$(tmux show-environment -t "$caller_session" ATMUX_REPO 2>/dev/null | sed -n 's/^ATMUX_REPO=//p' || true)"
      if [[ -z "$caller_repo" || "$caller_repo" == "$repo_name" ]]; then
        tmux set-environment -t "$caller_session" ATMUX_TEAM "$team_name" >/dev/null 2>&1 || true
      fi
    fi
  fi

  printf '<team name="%s" repo="%s" session="%s" />\n' \
    "$(xml_escape "$team_name")" \
    "$(xml_escape "$repo_name")" \
    "$(xml_escape "$session")"
}

list_teams() {
  local repo_name
  {
    IFS= read -r _
    IFS= read -r repo_name
  } < <(repo_context)

  printf '<teams repo="%s">\n' "$(xml_escape "$repo_name")"
  while IFS= read -r session; do
    [[ -z "$session" ]] && continue
    if [[ "$session" == "atmux-${repo_name}-team-"* ]]; then
      local name="${session#atmux-${repo_name}-team-}"
      printf '  <team name="%s" repo="%s" session="%s" />\n' \
        "$(xml_escape "$name")" \
        "$(xml_escape "$repo_name")" \
        "$(xml_escape "$session")"
    fi
  done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
  printf '</teams>\n'
}

is_team_session() {
  local session="$1"
  local repo_name="${2:-}"
  local kind team_name

  kind="$(get_session_env "$session" ATMUX_SESSION_KIND)"
  [[ "$kind" == "team" ]] && return 0

  team_name="$(get_session_env "$session" ATMUX_TEAM)"
  [[ -n "$team_name" ]] && return 0

  if [[ -n "$repo_name" && "$session" == "atmux-${repo_name}-team-"* ]]; then
    return 0
  fi

  return 1
}

sub="${1:-}"
shift || true

case "$sub" in
  create|_create)
    create_team "${1:-}"
    ;;
  list|ls)
    list_teams
    ;;
  capture)
    here_team="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux team capture <name> [--lines N]" >&2
      exit 2
    fi
    target_name="$1"; shift
    exec "$here_team/capture" --team "$target_name" "$@"
    ;;
  kill)
    here_team="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    if [[ $# -eq 0 || "${1:0:1}" == "-" ]]; then
      echo "usage: atmux team kill <name|pattern> [...]" >&2
      exit 2
    fi
    # Team sessions are named atmux-<repo>-team-<name>; the underlying
    # `kill --agent` accepts session names so we resolve and forward.
    r_repo="$(repo_name_from_context)"
    resolved=()
    for tname in "$@"; do
      if [[ "$tname" == atmux-* ]]; then
        resolved+=("$tname")
      elif [[ -n "$r_repo" ]]; then
        resolved+=("atmux-${r_repo}-team-${tname}")
      else
        resolved+=("$tname")
      fi
    done
    exec "$here_team/kill" --agent "${resolved[@]}"
    ;;
  resolve)
    target="${1:-}"
    if [[ -z "$target" ]]; then
      echo "usage: atmux team resolve <name> [<repo_name>]" >&2
      exit 2
    fi
    r_repo="${2:-}"
    if [[ -z "$r_repo" ]]; then
      r_repo="$(repo_name_from_context)"
    fi

    if tmux has-session -t "$target" 2>/dev/null; then
      if is_team_session "$target" "$r_repo"; then
        printf '%s\n' "$target"
        exit 0
      fi
      exit 1
    fi
    if [[ -n "$r_repo" ]]; then
      candidate="atmux-${r_repo}-team-${target}"
      if tmux has-session -t "$candidate" 2>/dev/null && is_team_session "$candidate" "$r_repo"; then
        printf '%s\n' "$candidate"
        exit 0
      fi
      if [[ "$target" == "team-"* ]]; then
        candidate="atmux-${r_repo}-${target}"
        if tmux has-session -t "$candidate" 2>/dev/null && is_team_session "$candidate" "$r_repo"; then
          printf '%s\n' "$candidate"
          exit 0
        fi
      fi
      if [[ "$target" == "${r_repo}-team-"* ]]; then
        candidate="atmux-${target}"
        if tmux has-session -t "$candidate" 2>/dev/null && is_team_session "$candidate" "$r_repo"; then
          printf '%s\n' "$candidate"
          exit 0
        fi
      fi
    fi
    exit 1
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown team command: $sub" >&2
    exit 2
    ;;
esac
