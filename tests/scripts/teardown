#!/usr/bin/env bash
set -euo pipefail

team_session="${TEAM_SESSION:-}"
agent1_session="${AGENT1_SESSION:-}"
agent2_session="${AGENT2_SESSION:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --team-session)
      team_session="${2:-}"
      shift 2
      ;;
    --agent1-session)
      agent1_session="${2:-}"
      shift 2
      ;;
    --agent2-session)
      agent2_session="${2:-}"
      shift 2
      ;;
    *)
      echo "unknown flag: $1" >&2
      exit 2
      ;;
  esac
done

for s in "$team_session" "$agent1_session" "$agent2_session"; do
  [[ -n "$s" ]] || continue
  if tmux has-session -t "$s" 2>/dev/null; then
    tmux kill-session -t "$s" >/dev/null 2>&1 || true
  fi
done

cleanup_orphans="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/cleanup-orphans"
if [[ -x "$cleanup_orphans" ]]; then
  "$cleanup_orphans" >/dev/null 2>&1 || true
fi
