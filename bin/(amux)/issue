#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  amux issue create --title <title> [--description <description>] [--repo <repo>]
  amux issue list [--repo <repo>]
  amux issue ls [--repo <repo>]
  amux issue get <id> [--repo <repo>]
  amux issue show <id> [--repo <repo>]
  amux issue assign <id> --to <agent|session> [--repo <repo>]
  amux issue claim <id> [--by <agent|session>] [--repo <repo>]

Description:
  Repo-scoped issue tickets on filesystem.
  Issues are stored at: ~/.amux/issues/<repo>/<id>/
USAGE
}

normalize_repo_name() {
  local raw="${1:-}"
  local normalized=""
  normalized="$(printf '%s' "$raw" | sed -E 's/[^A-Za-z0-9_-]+/_/g; s/_+/_/g; s/^_+//; s/_+$//')"
  if [[ -z "$normalized" ]]; then
    normalized="repo"
  fi
  printf '%s\n' "$normalized"
}

xml_escape() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g' -e "s/'/\&apos;/g"
}

resolve_repo_name() {
  local explicit_repo="${1:-}"
  local repo=""

  if [[ -n "$explicit_repo" ]]; then
    repo="$explicit_repo"
  elif [[ -n "${AMUX_REPO:-}" ]]; then
    repo="${AMUX_REPO}"
  elif [[ -n "${TMUX:-}" ]]; then
    repo="$(tmux show-environment AMUX_REPO 2>/dev/null | sed -n 's/^AMUX_REPO=//p' || true)"
  fi

  if [[ -z "$repo" ]]; then
    local repo_root=""
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      repo="$(basename "$repo_root")"
    fi
  fi

  if [[ -z "$repo" ]]; then
    echo "unable to resolve repo; pass --repo <repo> or run inside a git repo" >&2
    exit 2
  fi

  normalize_repo_name "$repo"
}

now_utc() {
  date -u +%Y-%m-%dT%H:%M:%SZ
}

read_field() {
  local file="$1"
  cat "$file" 2>/dev/null || true
}

write_field() {
  local file="$1"
  local value="${2:-}"
  printf '%s\n' "$value" > "$file"
}

tmux_env_value() {
  local key="$1"
  if [[ -z "${TMUX:-}" ]]; then
    return 0
  fi
  tmux show-environment "$key" 2>/dev/null | sed -n "s/^${key}=//p" || true
}

current_env_value() {
  local key="$1"
  local value="${!key:-}"
  if [[ -z "$value" ]]; then
    value="$(tmux_env_value "$key")"
  fi
  printf '%s\n' "$value"
}

current_session_name() {
  if [[ -z "${TMUX:-}" ]]; then
    return 0
  fi
  tmux display-message -p '#S' 2>/dev/null || true
}

session_short_name() {
  local session="$1"
  local repo="$2"
  local prefix="amux-${repo}-"
  if [[ -n "$repo" && "$session" == "$prefix"* ]]; then
    printf '%s\n' "${session#"$prefix"}"
    return
  fi
  printf '%s\n' "$session"
}

identity_matches() {
  local left="$1"
  local right="$2"
  local repo="$3"
  local left_short="$left"
  local right_short="$right"

  [[ -n "$left" && -n "$right" ]] || return 1
  [[ "$left" == "$right" ]] && return 0

  if [[ -n "$repo" ]]; then
    left_short="$(session_short_name "$left" "$repo")"
    right_short="$(session_short_name "$right" "$repo")"
    [[ "$left_short" == "$right_short" ]] && return 0
    [[ "amux-${repo}-${left_short}" == "$right" ]] && return 0
    [[ "amux-${repo}-${right_short}" == "$left" ]] && return 0
  fi

  return 1
}

current_actor_name() {
  local repo="$1"
  local actor=""
  local session=""
  actor="$(current_env_value AMUX_AGENT_NAME)"
  if [[ -n "$actor" ]]; then
    printf '%s\n' "$actor"
    return
  fi
  session="$(current_session_name)"
  if [[ -n "$session" ]]; then
    session_short_name "$session" "$repo"
    return
  fi
  printf '%s\n' "external"
}

ensure_can_assign() {
  local manager=""
  manager="$(current_env_value AMUX_MANAGER)"
  if [[ -n "$manager" ]]; then
    echo "managed agents cannot assign issues; use 'amux issue claim' instead" >&2
    exit 1
  fi
}

issue_root_for_repo() {
  local repo="$1"
  local amux_home="${AMUX_HOME:-$HOME/.amux}"
  printf '%s/issues/%s\n' "$amux_home" "$repo"
}

issue_dir_for_id() {
  local root="$1"
  local id="$2"
  printf '%s/%s\n' "$root" "$id"
}

create_issue() {
  local title=""
  local description=""
  local explicit_repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title)
        title="${2:-}"
        shift 2
        ;;
      --description)
        description="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$title" ]]; then
    echo "missing required flag: --title" >&2
    exit 2
  fi

  local repo root id dir created_at
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  mkdir -p "$root"

  id="$(uuidgen | tr '[:upper:]' '[:lower:]')"
  dir="$(issue_dir_for_id "$root" "$id")"
  created_at="$(now_utc)"

  mkdir -p "$dir"
  write_field "$dir/title" "$title"
  write_field "$dir/description" "$description"
  write_field "$dir/state" "open"
  write_field "$dir/created_at" "$created_at"
  write_field "$dir/updated_at" "$created_at"
  write_field "$dir/assigned_to" ""
  write_field "$dir/assigned_by" ""
  write_field "$dir/assigned_at" ""
  write_field "$dir/claimed_by" ""
  write_field "$dir/claimed_at" ""

  printf '<issue id="%s" repo="%s" state="open" path="%s" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$dir")"
}

list_issues() {
  local explicit_repo=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir id title state created_at updated_at assigned_to claimed_by
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"

  printf '<issues repo="%s">\n' "$(xml_escape "$repo")"
  if [[ -d "$root" ]]; then
    while IFS= read -r dir; do
      [[ -d "$dir" ]] || continue
      id="$(basename "$dir")"
      title="$(read_field "$dir/title")"
      state="$(read_field "$dir/state")"
      created_at="$(read_field "$dir/created_at")"
      updated_at="$(read_field "$dir/updated_at")"
      assigned_to="$(read_field "$dir/assigned_to")"
      claimed_by="$(read_field "$dir/claimed_by")"
      printf '  <issue id="%s" state="%s" created_at="%s" updated_at="%s" assigned_to="%s" claimed_by="%s" title="%s" />\n' \
        "$(xml_escape "$id")" \
        "$(xml_escape "$state")" \
        "$(xml_escape "$created_at")" \
        "$(xml_escape "$updated_at")" \
        "$(xml_escape "$assigned_to")" \
        "$(xml_escape "$claimed_by")" \
        "$(xml_escape "$title")"
    done < <(find "$root" -mindepth 1 -maxdepth 1 -type d | sort)
  fi
  printf '</issues>\n'
}

get_issue() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""

  if [[ -z "$id" ]]; then
    echo "usage: amux issue get <id> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir title description state created_at updated_at
  local assigned_to assigned_by assigned_at claimed_by claimed_at
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  dir="$(issue_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "issue not found: $id" >&2
    exit 1
  fi

  title="$(read_field "$dir/title")"
  description="$(read_field "$dir/description")"
  state="$(read_field "$dir/state")"
  created_at="$(read_field "$dir/created_at")"
  updated_at="$(read_field "$dir/updated_at")"
  assigned_to="$(read_field "$dir/assigned_to")"
  assigned_by="$(read_field "$dir/assigned_by")"
  assigned_at="$(read_field "$dir/assigned_at")"
  claimed_by="$(read_field "$dir/claimed_by")"
  claimed_at="$(read_field "$dir/claimed_at")"

  printf '<issue id="%s" repo="%s" state="%s" created_at="%s" updated_at="%s">\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$state")" \
    "$(xml_escape "$created_at")" \
    "$(xml_escape "$updated_at")"
  printf '  <title>%s</title>\n' "$(xml_escape "$title")"
  printf '  <description>%s</description>\n' "$(xml_escape "$description")"
  printf '  <assignment to="%s" by="%s" at="%s" />\n' \
    "$(xml_escape "$assigned_to")" \
    "$(xml_escape "$assigned_by")" \
    "$(xml_escape "$assigned_at")"
  printf '  <claim by="%s" at="%s" />\n' \
    "$(xml_escape "$claimed_by")" \
    "$(xml_escape "$claimed_at")"
  printf '</issue>\n'
}

assign_issue() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""
  local to=""

  if [[ -z "$id" ]]; then
    echo "usage: amux issue assign <id> --to <agent|session> [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)
        to="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  if [[ -z "$to" ]]; then
    echo "missing required flag: --to" >&2
    exit 2
  fi

  ensure_can_assign

  local repo root dir now assigned_by
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  dir="$(issue_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "issue not found: $id" >&2
    exit 1
  fi

  now="$(now_utc)"
  assigned_by="$(current_actor_name "$repo")"

  write_field "$dir/assigned_to" "$to"
  write_field "$dir/assigned_by" "$assigned_by"
  write_field "$dir/assigned_at" "$now"
  write_field "$dir/claimed_by" ""
  write_field "$dir/claimed_at" ""
  write_field "$dir/state" "assigned"
  write_field "$dir/updated_at" "$now"

  printf '<issue id="%s" repo="%s" state="assigned" assigned_to="%s" assigned_by="%s" assigned_at="%s" claimed_by="" claimed_at="" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$to")" \
    "$(xml_escape "$assigned_by")" \
    "$(xml_escape "$now")"
}

claim_issue() {
  local id="${1:-}"
  shift || true
  local explicit_repo=""
  local by=""

  if [[ -z "$id" ]]; then
    echo "usage: amux issue claim <id> [--by <agent|session>] [--repo <repo>]" >&2
    exit 2
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --by)
        by="${2:-}"
        shift 2
        ;;
      --repo)
        explicit_repo="${2:-}"
        shift 2
        ;;
      *)
        echo "unknown flag: $1" >&2
        exit 2
        ;;
    esac
  done

  local repo root dir assigned_to claimed_by now
  repo="$(resolve_repo_name "$explicit_repo")"
  root="$(issue_root_for_repo "$repo")"
  dir="$(issue_dir_for_id "$root" "$id")"

  if [[ ! -d "$dir" ]]; then
    echo "issue not found: $id" >&2
    exit 1
  fi

  if [[ -z "$by" ]]; then
    by="$(current_actor_name "$repo")"
  fi

  if [[ -z "$by" || "$by" == "external" ]]; then
    echo "unable to infer claimer; pass --by <agent|session>" >&2
    exit 2
  fi

  assigned_to="$(read_field "$dir/assigned_to")"
  if [[ -n "$assigned_to" ]] && ! identity_matches "$assigned_to" "$by" "$repo"; then
    echo "issue is assigned to '$assigned_to'; '$by' cannot claim it" >&2
    exit 1
  fi

  claimed_by="$(read_field "$dir/claimed_by")"
  if [[ -n "$claimed_by" ]] && ! identity_matches "$claimed_by" "$by" "$repo"; then
    echo "issue already claimed by '$claimed_by'" >&2
    exit 1
  fi

  now="$(now_utc)"
  if [[ -z "$assigned_to" ]]; then
    write_field "$dir/assigned_to" "$by"
    write_field "$dir/assigned_by" "self-claim"
    write_field "$dir/assigned_at" "$now"
    assigned_to="$by"
  fi
  write_field "$dir/claimed_by" "$by"
  write_field "$dir/claimed_at" "$now"
  write_field "$dir/state" "in_progress"
  write_field "$dir/updated_at" "$now"

  printf '<issue id="%s" repo="%s" state="in_progress" assigned_to="%s" claimed_by="%s" claimed_at="%s" />\n' \
    "$(xml_escape "$id")" \
    "$(xml_escape "$repo")" \
    "$(xml_escape "$assigned_to")" \
    "$(xml_escape "$by")" \
    "$(xml_escape "$now")"
}

sub="${1:-}"
shift || true

case "$sub" in
  create)
    create_issue "$@"
    ;;
  list|ls)
    list_issues "$@"
    ;;
  get|show)
    get_issue "$@"
    ;;
  assign)
    assign_issue "$@"
    ;;
  claim)
    claim_issue "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown issue command: $sub" >&2
    exit 2
    ;;
esac
