#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-issue-to.XXXXXX")"
repo_name="it${RANDOM}"
atmux_home="$tmp_home/.atmux"

cleanup() {
  rm -rf "$tmp_home"
}
trap cleanup EXIT

# Create an issue
create_out="$(ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" "$ATMUX_BIN" issue create --title "timeout-test" --repo "$repo_name")"
issue_id="$(printf '%s\n' "$create_out" | sed -n 's/.*id="\([^"]*\)".*/\1/p' | head -n1)"
[[ -n "$issue_id" ]] || { echo "failed to parse issue id" >&2; exit 1; }

# Watch with short timeout — no updates will happen
set +e
ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
  "$ATMUX_BIN" watch --issue "$issue_id" --timeout 2
rc=$?
set -e

[[ "$rc" -eq 124 ]] || { echo "expected exit 124 on watch --issue timeout, got $rc" >&2; exit 1; }

echo "ok: watch --issue exits 124 on timeout"
