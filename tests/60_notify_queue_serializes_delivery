#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

# Test that multiple rapid notifications to the same prompt-driven pane are
# serialized and leave the user's partial input intact. `cat` echoes each input
# line twice in this harness: once from terminal echo and once from cat itself.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

wait_for_count() {
  local target="$1"
  local needle="$2"
  local expected_count="$3"
  local timeout="${4:-15}"
  local deadline now snap compact count
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -500 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    count="$(printf '%s' "$compact" | { grep -F -o "$needle" || true; } | wc -l | tr -d ' ')"
    if [[ -n "$count" ]] && (( count >= expected_count )); then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

count_matches() {
  local target="$1"
  local needle="$2"
  local snap compact
  snap="$(tmux capture-pane -p -t "$target" -S -500 2>/dev/null || true)"
  compact="$(printf '%s' "$snap" | tr -d '\r\n')"
  printf '%s' "$compact" | { grep -F -o "$needle" || true; } | wc -l | tr -d ' '
}

ATMUX_HOME="${TMPDIR:-/tmp}/atmux-notify-${RANDOM}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="notifyq${RANDOM}"
session="atmux-${repo_name}-mgr"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  rm -rf "$ATMUX_HOME"
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux new-session -d -s "$session" -n "$session" -x 120 -y 30 "cat"
tmux set-environment -t "$session" ATMUX_ADAPTER "claude-code"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

sleep 0.3
tmux send-keys -t "$pane" -l "❯ "
tmux send-keys -t "$pane" Enter
sleep 0.3
user_text="my partial input must survive"
tmux send-keys -t "$pane" -l "❯ ${user_text}"
# Wait for the typed input to land in the pane buffer before queueing
# the burst — otherwise on slower hosts (Linux CI) the worker can
# save_input/C-u/restore while the original send-keys is still
# draining, clipping the tail.
if ! wait_for_count "$pane" "$user_text" 1 5; then
  echo "user_text never landed in pane before notify burst" >&2
  tmux capture-pane -p -t "$pane" -S -40 >&2 || true
  exit 1
fi

markers=()
for idx in 1 2 3 4 5; do
  marker="burst-${idx}-${RANDOM}"
  markers+=("$marker")
  payload="$(build_notification "test" "$marker" "")"
  send_notification "$pane" "$payload"
done

for marker in "${markers[@]}"; do
  if ! wait_for_count "$pane" "$marker" 2 20; then
    echo "marker $marker did not arrive twice in time" >&2
    tmux capture-pane -p -t "$pane" -S -200 >&2 || true
    exit 1
  fi
  count="$(count_matches "$pane" "$marker")"
  [[ "$count" == "2" ]] || {
    echo "marker $marker expected twice in cat harness, got $count" >&2
    tmux capture-pane -p -t "$pane" -S -200 >&2 || true
    exit 1
  }
done

if ! wait_for_count "$pane" "$user_text" 1 10; then
  echo "user input was not restored after burst delivery" >&2
  tmux capture-pane -p -t "$pane" -S -40 >&2 || true
  exit 1
fi

echo "ok: notify queue serializes delivery and preserves prompt input"
