#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}/atmux-notify-submit-${RANDOM}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
ATMUX_SEND_SUBMIT_RETRY_ATTEMPTS=2
ATMUX_SEND_SUBMIT_VERIFY_SECONDS=1
source "$NOTIFY_SCRIPT"

prompt_prefix="›"
# Built via the canonical builder so the fixture matches the real
# notification format (single hint attr, no legacy cmd/hint duplicate).
prompt_input="$(build_notification "message" "large-paste" "atmux message read abc --repo repo")"
cursor_y=3
enter_count=0

cleanup() {
  rm -rf "$ATMUX_HOME"
}
trap cleanup EXIT

cursor_x_for_input() {
  printf '%s' "$prompt_prefix $prompt_input" | wc -m | tr -d ' '
}

tmux() {
  if [[ "$1" == "capture-pane" ]]; then
    printf 'banner\n%s %s\nfooter\n' "$prompt_prefix" "$prompt_input"
    return 0
  fi

  if [[ "$1" == "display-message" ]]; then
    local fmt="${@: -1}"
    case "$fmt" in
      "#{cursor_x}") cursor_x_for_input ;;
      "#{cursor_y}") printf '%s\n' "$cursor_y" ;;
      *) return 1 ;;
    esac
    return 0
  fi

  if [[ "$1" == "send-keys" ]]; then
    local key="${@: -1}"
    if [[ "$key" == "Enter" ]]; then
      enter_count=$((enter_count + 1))
      if (( enter_count >= 2 )); then
        prompt_input=""
        cursor_y=$((cursor_y + 1))
      fi
    fi
    return 0
  fi

  command tmux "$@"
}

submit_notification_input "%mock" "$prompt_prefix" "Enter" "0"

if [[ "$enter_count" -ne 2 ]]; then
  echo "expected submit retry to press Enter twice, got $enter_count" >&2
  exit 1
fi

echo "ok: notification submit retries when prompt input remains after Enter"
