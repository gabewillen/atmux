#!/usr/bin/env bash
set -euo pipefail

# Reads atmux prompt content from stdin, writes it to a per-agent sidecar file
# under $ATMUX_HOME (so the worktree stays clean), and emits a single
# GEMINI_SYSTEM_MD env directive pointing at it. Gemini's GEMINI_SYSTEM_MD is
# replace-only: the built-in prompt is dropped. We accept that tradeoff -
# atmux content is what the agent needs and the user can re-add their own
# preamble in $ATMUX_HOME/state/agents/<repo>/<agent>/gemini-system.md if desired.

args_file="${ATMUX_PREP_ARGS_FILE:-}"
env_file="${ATMUX_PREP_ENV_FILE:-}"
[[ -n "$args_file" ]] || { echo "prepare-prompt: ATMUX_PREP_ARGS_FILE not set" >&2; exit 2; }
[[ -n "$env_file" ]]  || { echo "prepare-prompt: ATMUX_PREP_ENV_FILE not set"  >&2; exit 2; }

content="$(cat)"
[[ -n "$content" ]] || exit 0

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
repo="${ATMUX_REPO:-repo}"
agent="${ATMUX_AGENT_NAME:-agent}"
prep_dir="$ATMUX_HOME/state/agents/$repo/$agent"
mkdir -p "$prep_dir"

system_md="$prep_dir/gemini-system.md"
printf '%s\n' "$content" > "$system_md"

printf 'GEMINI_SYSTEM_MD=%s\n' "$system_md" >> "$env_file"
