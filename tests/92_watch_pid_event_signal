#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-watch-pid-event.XXXXXX")"
repo_name="pe${RANDOM}"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"
rc_file="$tmp_home/watch.rc"

cleanup() {
  if [[ -n "${watch_pid:-}" ]] && kill -0 "$watch_pid" >/dev/null 2>&1; then
    kill "$watch_pid" >/dev/null 2>&1 || true
    wait "$watch_pid" >/dev/null 2>&1 || true
  fi
  if [[ -n "${exec_cmd_pid:-}" ]] && kill -0 "$exec_cmd_pid" >/dev/null 2>&1; then
    kill "$exec_cmd_pid" >/dev/null 2>&1 || true
    wait "$exec_cmd_pid" >/dev/null 2>&1 || true
  fi
  rm -rf "$tmp_home"
}
trap cleanup EXIT

ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
  "$ATMUX_BIN" exec -- sleep 1 > "$tmp_home/exec.out" 2> "$tmp_home/exec.err" &
exec_cmd_pid=$!

pid=""
deadline=$(( $(date +%s) + 5 ))
while [[ -z "$pid" ]]; do
  if (( $(date +%s) >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    for exec_dir in "$exec_root"/*; do
      [[ -d "$exec_dir" && -f "$exec_dir/pid" ]] || continue
      candidate="$(tr -d '\r\n' < "$exec_dir/pid" 2>/dev/null || true)"
      if [[ -n "$candidate" && "$candidate" =~ ^[0-9]+$ ]]; then
        pid="$candidate"
        break
      fi
    done
  fi
  [[ -n "$pid" ]] || sleep 0.05
done

(
  set +e
  ATMUX_HOME="$atmux_home" ATMUX_REPO="$repo_name" ATMUX_ALLOW_OUTSIDE_TMUX=1 \
    "$ATMUX_BIN" watch --pid "$pid" --interval 999 --timeout 30
  printf '%s\n' "$?" > "$rc_file"
) &
watch_pid=$!

wait "$exec_cmd_pid"

deadline=$(( $(date +%s) + 5 ))
while kill -0 "$watch_pid" >/dev/null 2>&1; do
  if (( $(date +%s) >= deadline )); then
    echo "watch --pid did not wake from exec event" >&2
    exit 1
  fi
  sleep 0.1
done
wait "$watch_pid" || true

watch_rc="$(tr -d '\r\n' < "$rc_file" 2>/dev/null || true)"
[[ "$watch_rc" == "0" ]] || { echo "expected watch rc 0, got ${watch_rc:-missing}" >&2; exit 1; }

echo "ok: watch --pid wakes from exec event without polling interval"
