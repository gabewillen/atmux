#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-10}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

tmp_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-stdio-event.XXXXXX")"
repo_name="wse${RANDOM}"
session_exec="atmux-${repo_name}-exec"
session_watch="atmux-${repo_name}-watch"
atmux_home="$tmp_home/.atmux"
exec_root="$atmux_home/exec/$repo_name"

cleanup() {
  tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true
  rm -rf "$tmp_home"
}
trap cleanup EXIT

tmux kill-session -t "$session_exec" >/dev/null 2>&1 || true
tmux kill-session -t "$session_watch" >/dev/null 2>&1 || true
tmux new-session -d -s "$session_exec" -n "$session_exec" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux new-session -d -s "$session_watch" -n "$session_watch" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l

pane_exec="$(tmux list-panes -t "$session_exec" -F '#{pane_id}' 2>/dev/null | head -n1)"
pane_watch="$(tmux list-panes -t "$session_watch" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_exec" && -n "$pane_watch" ]] || { echo "missing panes" >&2; exit 1; }

tmux send-keys -t "$pane_exec" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"exec\" ATMUX_SESSION_NAME=\"$session_exec\" \"$ATMUX_BIN\" exec --detach -- bash -lc 'sleep 1; echo event-wave; sleep 1'" C-m

deadline=$(( $(date +%s) + 10 ))
pid=""
while [[ -z "$pid" ]]; do
  if (( $(date +%s) >= deadline )); then
    echo "timeout waiting for exec metadata" >&2
    exit 1
  fi
  if [[ -d "$exec_root" ]]; then
    for exec_dir in "$exec_root"/*; do
      [[ -d "$exec_dir" && -f "$exec_dir/pid" ]] || continue
      candidate="$(tr -d '\r\n' < "$exec_dir/pid" 2>/dev/null || true)"
      if [[ -n "$candidate" && "$candidate" =~ ^[0-9]+$ ]]; then
        pid="$candidate"
        break
      fi
    done
  fi
  [[ -n "$pid" ]] || sleep 0.05
done

tmux send-keys -t "$pane_watch" "ATMUX_HOME=\"$atmux_home\" ATMUX_REPO=\"$repo_name\" ATMUX_AGENT_NAME=\"watch\" ATMUX_SESSION_NAME=\"$session_watch\" \"$ATMUX_BIN\" process watch \"$pid\" --stdio --duration 10 --timeout 5 --interval 999" C-m

if ! wait_for_text "$pane_watch" 'type="exec_output"' 8; then
  echo "process watch --stdio did not notify from pane output event" >&2
  tmux capture-pane -p -t "$pane_watch" -S -200 >&2 || true
  exit 1
fi

echo "ok: watch --stdio wakes from pane output without polling interval"
