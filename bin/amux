#!/usr/bin/env bash
set -euo pipefail

AMUX_HOME="${AMUX_HOME:-$HOME/.amux}"
AMUX_BIN_ORIGIN="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

# In agent sessions, always route to the source repo's amux so help/behavior
# stays current even if the worktree copy is stale.
if [[ -n "${AMUX_SOURCE_ROOT:-}" && -x "${AMUX_SOURCE_ROOT}/bin/amux" ]]; then
  if [[ "$AMUX_BIN_ORIGIN" != "$(cd -- "${AMUX_SOURCE_ROOT}/bin" && pwd)" ]]; then
    exec "${AMUX_SOURCE_ROOT}/bin/amux" "$@"
  fi
fi

usage() {
  local -a cmds=()
  cmds+=(install)

  local -a script_dirs=()
  if [[ -d "$AMUX_HOME/bin/scripts" ]]; then
    script_dirs+=("$AMUX_HOME/bin/scripts")
  fi
  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -d "$repo_root/bin/scripts" ]]; then
      script_dirs+=("$repo_root/bin/scripts")
    fi
  fi

  local dir
  for dir in "${script_dirs[@]}"; do
    while IFS= read -r name; do
      [[ -z "$name" ]] && continue
      cmds+=("$name")
    done < <(find "$dir" -maxdepth 1 -type f -perm -u+x -exec basename {} \; | sort)
  done

  local -a uniq_cmds=()
  while IFS= read -r c; do
    [[ -n "$c" ]] && uniq_cmds+=("$c")
  done < <(printf '%s\n' "${cmds[@]}" | awk 'NF' | sort -u)
  cmds=("${uniq_cmds[@]}")

  echo "Usage:"
  echo "  amux <subcommand> [args...]"
  echo
  echo "amux is an agent multiplexer across adapters."
  echo
  echo "Purpose:"
  echo "  Manage amux agent sessions, adapters, and agent messaging."
  echo
  echo "Available subcommands:"
  for c in "${cmds[@]}"; do
    echo "  $c"
  done
  echo
  echo "Run:"
  echo "  amux <subcommand> --help"
  echo "for more information."
}

ensure_amux_home() {
  mkdir -p "$AMUX_HOME/bin" "$AMUX_HOME/bin/scripts" "$AMUX_HOME/agents" "$AMUX_HOME/adapters"
}

attach_or_switch() {
  local session="$1"
  if [[ ! -t 0 || ! -t 1 ]]; then
    printf '%s\n' "$session"
    return
  fi
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

normalize_github_repo() {
  local input="$1"
  local repo_path=""

  case "$input" in
    https://github.com/*)
      repo_path="${input#https://github.com/}"
      ;;
    github.com/*)
      repo_path="${input#github.com/}"
      ;;
    */*)
      repo_path="$input"
      ;;
    *)
      echo "invalid github repo: $input" >&2
      exit 2
      ;;
  esac

  repo_path="${repo_path%.git}"
  repo_path="${repo_path%/}"
  printf '%s\n' "$repo_path"
}

run_script_subcommand() {
  local cmd="$1"
  shift || true

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    local local_script="$repo_root/bin/scripts/$cmd"
    if [[ -x "$local_script" ]]; then
      exec "$local_script" "$@"
    fi
  fi

  local installed_script="$AMUX_HOME/bin/scripts/$cmd"
  if [[ -x "$installed_script" ]]; then
    exec "$installed_script" "$@"
  fi

  return 1
}

cmd_install() {
  local repo_root
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    echo "not in a git repository" >&2
    exit 1
  fi
  local installer="$repo_root/scripts/install"
  if [[ ! -x "$installer" ]]; then
    echo "installer not found: $installer" >&2
    exit 1
  fi
  exec "$installer"
}

main() {
  ensure_amux_home

  if [[ $# -lt 1 ]]; then
    usage
    exit 1
  fi

  case "$1" in
    install)
      shift
      cmd_install "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      cmd="$1"
      shift
      if ! run_script_subcommand "$cmd" "$@"; then
        echo "unknown command: $cmd" >&2
        usage
        exit 1
      fi
      ;;
  esac
}

main "$@"
