#!/usr/bin/env bash
set -euo pipefail

# Isolate the tmux socket so this test can never touch the developer's
# default tmux server. Idempotent if the runner already isolated.
source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

# Test that notification to a root caller pane:
# 1. Saves user input before delivering
# 2. Delivers the notification
# 3. Restores the user's input afterward

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

repo_name="qidle${RANDOM}"
session="atmux-${repo_name}-caller"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session" >/dev/null 2>&1 || true
# Use cat — simulates adapter CLI (no shell prompt)
tmux new-session -d -s "$session" -n "$session" -x 160 -y 40 "cat"

# Root caller with adapter metadata.
tmux set-environment -t "$session" ATMUX_ADAPTER "claude-code"

pane="$(tmux list-panes -t "$session" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane" ]] || { echo "pane missing" >&2; exit 1; }

# Simulate user typing on an idle prompt
user_text="my important partial input"
sleep 0.3
tmux send-keys -t "$pane" -l "❯ "
tmux send-keys -t "$pane" Enter
sleep 0.3
tmux send-keys -t "$pane" -l "❯ ${user_text}"
# Wait for the typed input to land in the pane buffer before queueing
# the notification — otherwise on slower hosts (Linux CI) the worker
# can save_input/C-u/restore while the original send-keys is still
# draining, clipping the tail.
if ! wait_for_text "$pane" "$user_text" 5; then
  echo "user_text never landed in pane before notify" >&2
  tmux capture-pane -p -t "$pane" -S -40 >&2 || true
  exit 1
fi

# Queue a notification
marker="queuetest-$RANDOM"
payload="$(build_notification "test" "$marker" "")"
send_notification "$pane" "$payload"

# Notification should be delivered (runner saves input, delivers, restores)
if ! wait_for_text "$pane" "$marker" 15; then
  echo "notification not delivered" >&2
  tmux capture-pane -p -t "$pane" -S -200 >&2 || true
  exit 1
fi

# User's input should be restored on the current line
sleep 2
if ! wait_for_text "$pane" "$user_text" 10; then
  echo "user input not restored after notification" >&2
  tmux capture-pane -p -t "$pane" -S -20 >&2 || true
  exit 1
fi

echo "ok: send_notification saves input, delivers, and restores on root caller"
