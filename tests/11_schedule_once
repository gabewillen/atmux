#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-8}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -300 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

eval "$("$SCRIPTS_DIR/setup")"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"" EXIT

marker="schedule-once-$RANDOM-$(date +%s)"
receiver_pane="$(tmux list-panes -t "$AGENT2_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$receiver_pane" ]] || { echo "receiver pane missing" >&2; exit 1; }

out="$(AMUX_REPO="$REPO_NAME" AMUX_AGENT_NAME="sender" AMUX_SESSION_NAME="$AGENT1_SESSION" "$AMUX_BIN" schedule --to receiver --once 1s "$marker")"
printf '%s\n' "$out" | grep -Fq '<send to="agent"'
printf '%s\n' "$out" | grep -Fq "session=\"$AGENT2_SESSION\""

if ! wait_for_text "$receiver_pane" "$marker" 10; then
  echo "scheduled marker not found in receiver pane: $marker" >&2
  tmux capture-pane -p -t "$receiver_pane" -S -120 >&2 || true
  exit 1
fi

echo "ok: schedule --once delivered to agent target"
