#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

eval "$("$SCRIPTS_DIR/setup")"
amux_home_tmp="$(mktemp -d)"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"; rm -rf \"$amux_home_tmp\"" EXIT

title="issue-assign-$RANDOM"
desc="stabilize parser"
out="$(AMUX_HOME="$amux_home_tmp" AMUX_REPO="$REPO_NAME" AMUX_AGENT_NAME="sender" AMUX_SESSION_NAME="$AGENT1_SESSION" "$AMUX_BIN" assign --to receiver --title "$title" --description "$desc" --todo "write failing test first" --todo "implement fix")"

printf '%s\n' "$out" | grep -Fq '<assignment '
printf '%s\n' "$out" | grep -Fq 'created="true"'
printf '%s\n' "$out" | grep -Fq '<issue '
printf '%s\n' "$out" | grep -Fq "state=\"assigned\""

issue_id="$(printf '%s\n' "$out" | sed -n 's/.*issue_id="\([^"]*\)".*/\1/p' | head -n1)"
[[ -n "$issue_id" ]] || { echo "failed to parse issue id from output" >&2; exit 1; }

get_out="$(AMUX_HOME="$amux_home_tmp" AMUX_REPO="$REPO_NAME" "$AMUX_BIN" issue get "$issue_id")"
printf '%s\n' "$get_out" | grep -Fq "state=\"assigned\""
printf '%s\n' "$get_out" | grep -Fq "to=\"amux-${REPO_NAME}-receiver\""
printf '%s\n' "$get_out" | grep -Fq "<title>$title</title>"

echo "ok: assign creates and assigns filesystem issue"

