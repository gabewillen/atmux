#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "${BASH_SOURCE[0]}")/lib/isolate-tmux.sh"

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-10}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -300 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    (( now < deadline )) || return 1
    sleep 0.1
  done
}

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-team-message-notify.XXXXXX")"
atmux_home="$tmp_root/.atmux"

cleanup() {
  if [[ -n "${TEAM_SESSION:-}" ]]; then
    "$SCRIPTS_DIR/teardown" --team-session "$TEAM_SESSION" --agent1-session "$AGENT1_SESSION" --agent2-session "$AGENT2_SESSION"
  fi
  rm -rf "$tmp_root"
}
trap cleanup EXIT

setup_out="$(ATMUX_HOME="$atmux_home" "$SCRIPTS_DIR/setup")"
eval "$setup_out"

sender_pane="$(tmux list-panes -t "$AGENT1_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
receiver_pane="$(tmux list-panes -t "$AGENT2_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$sender_pane" && -n "$receiver_pane" ]] || { echo "missing member panes" >&2; exit 1; }

send_out="$(ATMUX_HOME="$atmux_home" ATMUX_REPO="$REPO_NAME" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="$AGENT1_SESSION" \
  "$ATMUX_BIN" send --to "$TEAM_NAME" "notify-all-members-${RANDOM}")"
message_id="$(printf '%s\n' "$send_out" | sed -n 's/.*message_id="\([^"]*\)".*/\1/p' | head -n1)"
[[ -n "$message_id" ]] || { echo "failed to parse team message id" >&2; exit 1; }

printf '%s\n' "$send_out" | grep -Fq 'attempted="2"'
printf '%s\n' "$send_out" | grep -Fq 'kind="member"'

if ! wait_for_text "$sender_pane" '<notification type="team_message"' 10; then
  echo "sender did not receive team message notification" >&2
  tmux capture-pane -p -t "$sender_pane" -S -120 >&2 || true
  exit 1
fi
if ! wait_for_text "$receiver_pane" '<notification type="team_message"' 10; then
  echo "receiver did not receive team message notification" >&2
  tmux capture-pane -p -t "$receiver_pane" -S -120 >&2 || true
  exit 1
fi
if ! wait_for_text "$receiver_pane" "atmux message read $message_id --team $TEAM_NAME --repo $REPO_NAME" 5; then
  echo "team notification did not include team-scoped read command" >&2
  tmux capture-pane -p -t "$receiver_pane" -S -120 >&2 || true
  exit 1
fi

echo "ok: team message notifications fan out to every team member"
