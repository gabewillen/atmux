#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'USAGE'
Usage:
  atmux watcher list
  atmux watcher kill <id> [--timeout <seconds>]

Description:
  List or remove background watcher registrations created by `atmux pr watch
  --feed`, `atmux issue watch --feed`, and `atmux pr watch <id|url>` (the
  long-running fan-out modes).

  Watcher ids have the form <kind>:<key>:<watcher_name>, e.g.:
    pr:owner_repo_pr_123:atmux-myrepo-worker-_12
    issues:owner_repo_issues:atmux-myrepo-worker-_12
    prs:owner_repo_prs:atmux-myrepo-worker-_12
USAGE
}

list_watchers() {
  local kind dir watchers_dir watcher_file id
  for kind in pr issues prs; do
    dir="$ATMUX_HOME/watch-$kind"
    [[ -d "$dir" ]] || continue
    while IFS= read -r watchers_dir; do
      [[ -d "$watchers_dir" ]] || continue
      local key
      key="$(basename "$(dirname "$watchers_dir")")"
      while IFS= read -r watcher_file; do
        [[ -f "$watcher_file" ]] || continue
        local watcher_name
        watcher_name="$(basename "$watcher_file")"
        # Skip the .exec sidecar files emitted by --exec watchers.
        case "$watcher_name" in *.exec) continue ;; esac
        id="${kind}:${key}:${watcher_name}"
        printf '%s\n' "$id"
      done < <(find "$watchers_dir" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | sort)
    done < <(find "$dir" -mindepth 2 -maxdepth 2 -type d -name watchers 2>/dev/null | sort)
  done
}

verb="${1:-}"
shift || true

case "$verb" in
  list)
    list_watchers
    ;;
  kill)
    id="${1:-}"
    if [[ -z "$id" || "${id:0:1}" == "-" ]]; then
      echo "usage: atmux watcher kill <id> [--timeout N]" >&2
      exit 2
    fi
    shift
    exec "$HERE/(internal)/kill" --watcher "$id" "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "unknown watcher command: $verb" >&2
    usage >&2
    exit 2
    ;;
esac
