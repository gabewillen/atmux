#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-8}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -300 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

eval "$("$SCRIPTS_DIR/setup")"
trap "$SCRIPTS_DIR/teardown --team-session \"$TEAM_SESSION\" --agent1-session \"$AGENT1_SESSION\" --agent2-session \"$AGENT2_SESSION\"" EXIT

out="$(ATMUX_REPO="$REPO_NAME" ATMUX_AGENT_NAME="sender" ATMUX_SESSION_NAME="$AGENT1_SESSION" "$ATMUX_BIN" send --to "$TEAM_NAME" "hello")"

printf '%s\n' "$out" | grep -Fq "<send to=\"team\""
printf '%s\n' "$out" | grep -Fq "attempted=\"2\""
printf '%s\n' "$out" | grep -Fq "delivered=\"2\""

sender_pane="$(tmux list-panes -t "$AGENT1_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
receiver_pane="$(tmux list-panes -t "$AGENT2_SESSION" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$sender_pane" ]] || { echo "sender pane missing" >&2; exit 1; }
[[ -n "$receiver_pane" ]] || { echo "receiver pane missing" >&2; exit 1; }

if ! wait_for_text "$sender_pane" '<notification' 10; then
  echo "notification not found in sender pane" >&2
  tmux capture-pane -p -t "$sender_pane" -S -120 >&2 || true
  exit 1
fi
if ! wait_for_text "$receiver_pane" '<notification' 10; then
  echo "notification not found in receiver pane" >&2
  tmux capture-pane -p -t "$receiver_pane" -S -120 >&2 || true
  exit 1
fi

echo "ok: top-level send to team reached all member panes"
