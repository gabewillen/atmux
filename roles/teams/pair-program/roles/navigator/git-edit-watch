#!/usr/bin/env bash
# git-edit-watch: bridge from `atmux path watch` to a navigator
# notification.
#
# `atmux path watch` is event-driven (fswatch on macOS, inotifywait
# on Linux), so it fires within milliseconds of a filesystem change.
# This script discards path-watch's payload (we only need the trigger)
# and emits one canonical `<notification type="git-change" .../>` to
# the navigator's pane carrying a `hint` the navigator runs at review
# time:
#
#   <notification type="git-change" from="<watch-id>"
#                 hint="run `git snapshot --id <watch-id>`"/>
#
# The navigator's role.md tells it: when this notification arrives,
# run the hint command. That returns the rolling diff *as of read
# time*, not whatever was current when the fs event fired — so reviews
# can't go stale during LLM reasoning latency, and a burst of edits
# collapses into one cumulative diff at review time instead of a queue
# of point-in-time snapshots.
#
# Args: <git-watch-id> <nav-pane>
set -euo pipefail

watch_id="$1"
nav_pane="$2"

# Drain path-watch's stdin; we only care about the trigger.
cat >/dev/null

# Build the canonical notification XML and hand it to the queue.
xml="$(atmux notify build "git-change" "$watch_id" "git snapshot --id $watch_id")"
exec atmux notify --pane "$nav_pane" --xml "$xml"
