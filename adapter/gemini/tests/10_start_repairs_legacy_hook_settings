#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_DIR="$TESTS_DIR/scripts"
ADAPTER_DIR="$(cd -- "$TESTS_DIR/.." && pwd)"
REPO_ROOT="$(cd -- "$ADAPTER_DIR/../.." && pwd)"

atmux_home="$(mktemp -d "${TMPDIR:-/tmp}/atmux-gemini-repair.XXXXXX")"
worktree_dir="$(mktemp -d "${TMPDIR:-/tmp}/atmux-gemini-worktree.XXXXXX")"
settings_dir="$worktree_dir/.gemini"
settings_file="$settings_dir/settings.json"

cleanup() {
  [[ -n "${session_name:-}" ]] && "$SCRIPTS_DIR/teardown" --session "$session_name" >/dev/null 2>&1 || true
  rm -rf "$atmux_home" "$worktree_dir"
}
trap cleanup EXIT

mkdir -p "$settings_dir"
cat > "$settings_file" <<'EOF'
{
  "hooks": {
    "enabled": true,
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "atmux-stop-notify",
            "type": "command",
            "command": "/tmp/legacy-atmux-stop-notify",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
EOF

start_cmd="ATMUX_HOME='$atmux_home' ATMUX_WORKTREE='$worktree_dir' '$ADAPTER_DIR/scripts/start'"
setup_out="$("$SCRIPTS_DIR/setup" --command "$start_cmd" --wait-text 'Type your message')"
session_name="$(printf '%s\n' "$setup_out" | sed -n 's/^SESSION_NAME=//p' | tail -n 1)"

[[ -f "$settings_file" ]] || { echo "missing repaired settings file" >&2; exit 1; }

grep -F '"hooksConfig"' "$settings_file" >/dev/null
grep -F '"AfterAgent"' "$settings_file" >/dev/null
grep -F '"atmux-stop-notify"' "$settings_file" >/dev/null
if tr -d '\n\r\t ' < "$settings_file" | grep -F '"hooks":{"enabled"' >/dev/null; then
  echo "legacy hooks.enabled schema was not repaired" >&2
  cat "$settings_file" >&2
  exit 1
fi

echo "PASS 10_start_repairs_legacy_hook_settings"
