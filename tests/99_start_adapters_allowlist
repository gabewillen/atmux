#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/atmux-start-adapters.XXXXXX")"
tmp_home="$tmp_root/home"
atmux_home="$tmp_home/.atmux"
repo_name="amux_sh"
agent="allowlist-${RANDOM}"
bad_agent="disallowed-${RANDOM}"
session="atmux-${repo_name}-${agent}"
bad_session="atmux-${repo_name}-${bad_agent}"

cleanup() {
  tmux kill-session -t "$session" >/dev/null 2>&1 || true
  tmux kill-session -t "$bad_session" >/dev/null 2>&1 || true
  rm -rf "$tmp_root"
}
trap cleanup EXIT

make_adapter() {
  local name="$1"
  local dir="$atmux_home/adapters/$name"
  mkdir -p "$dir"
  cat > "$dir/cmd" <<ADAPTER
#!/usr/bin/env bash
set -euo pipefail
case "\${1:-}" in
  control-file)
    ;;
  start)
    printf '%s\n' "$name" > "\$ATMUX_HOME/selected-adapter"
    sleep 30
    ;;
  status)
    printf '<adapter-state state="idle" />\n'
    ;;
  *)
    ;;
esac
ADAPTER
  chmod +x "$dir/cmd"
}

mkdir -p "$tmp_home" "$atmux_home/adapters"
make_adapter alpha
make_adapter beta

tmux kill-session -t "$session" >/dev/null 2>&1 || true
tmux kill-session -t "$bad_session" >/dev/null 2>&1 || true

(
  cd "$REPO_ROOT"
  HOME="$tmp_home" \
    ATMUX_HOME="$atmux_home" \
    ATMUX_SOURCE_ROOT="$REPO_ROOT" \
    ATMUX_ALLOW_OUTSIDE_TMUX=1 \
    "$ATMUX_BIN" start --name "$agent" --no-worktree --adapters beta >/dev/null
)

deadline=$(( $(date +%s) + 10 ))
while [[ ! -f "$atmux_home/selected-adapter" ]]; do
  if (( $(date +%s) >= deadline )); then
    echo "timed out waiting for allowlisted adapter start" >&2
    exit 1
  fi
  sleep 0.1
done

selected="$(tr -d '\r\n' < "$atmux_home/selected-adapter")"
[[ "$selected" == "beta" ]] || { echo "expected beta adapter, got ${selected:-missing}" >&2; exit 1; }

session_selected="$(tmux show-environment -t "$session" ATMUX_ADAPTER_SELECTED 2>/dev/null | sed -n 's/^ATMUX_ADAPTER_SELECTED=//p' || true)"
[[ "$session_selected" == "beta" ]] || { echo "expected session selected adapter beta, got ${session_selected:-missing}" >&2; exit 1; }

set +e
(
  cd "$REPO_ROOT"
  HOME="$tmp_home" \
    ATMUX_HOME="$atmux_home" \
    ATMUX_SOURCE_ROOT="$REPO_ROOT" \
    ATMUX_ALLOW_OUTSIDE_TMUX=1 \
    "$ATMUX_BIN" start --name "$bad_agent" --no-worktree --adapter alpha --adapters beta >/dev/null 2>&1
)
rc=$?
set -e

[[ "$rc" -eq 2 ]] || { echo "expected disallowed explicit adapter to exit 2, got $rc" >&2; exit 1; }
if tmux has-session -t "$bad_session" 2>/dev/null; then
  echo "disallowed adapter should not create a session" >&2
  exit 1
fi

echo "ok: atmux start --adapters restricts adapter selection"
