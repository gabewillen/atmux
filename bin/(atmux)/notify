#!/usr/bin/env bash
# shellcheck shell=bash
# Shared helpers for exec, issue, watch --pid, watch --issue; also `atmux notify` CLI when executed.
# When sourced, only function definitions run (see bottom).

ATMUX_NOTIFY_SCRIPT_PATH="${BASH_SOURCE[0]}"
ATMUX_NOTIFY_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
# shellcheck source=bin/(atmux)/(lib)/tmux
source "$ATMUX_NOTIFY_DIR/(lib)/tmux"
# shellcheck source=bin/(atmux)/(lib)/manifest
source "$ATMUX_NOTIFY_DIR/(lib)/manifest"
# shellcheck source=bin/(atmux)/(lib)/xml
source "$ATMUX_NOTIFY_DIR/(lib)/xml"
# shellcheck source=bin/(atmux)/(lib)/resolver
source "$ATMUX_NOTIFY_DIR/(lib)/resolver"
# shellcheck source=bin/(atmux)/(lib)/fs
source "$ATMUX_NOTIFY_DIR/(lib)/fs"
# shellcheck source=bin/(atmux)/(lib)/notification
source "$ATMUX_NOTIFY_DIR/(lib)/notification"

debug_notify_enabled() {
  case "${ATMUX_DEBUG_NOTIFY:-0}" in
    1|true|TRUE|yes|YES)
      return 0
      ;;
  esac
  return 1
}

debug_notify_log_file() {
  printf '%s/logs/notify-debug.log\n' "$ATMUX_HOME"
}

payload_debug_summary() {
  local payload="${1:-}"
  local compact type from cmd
  compact="$(printf '%s' "$payload" | tr '\n' ' ' | tr -s ' ')"
  type="$(printf '%s' "$compact" | sed -n 's/.*type="\([^"]*\)".*/\1/p' | head -n1)"
  from="$(printf '%s' "$compact" | sed -n 's/.*from="\([^"]*\)".*/\1/p' | head -n1)"
  cmd="$(printf '%s' "$compact" | sed -n 's/.*cmd="\([^"]*\)".*/\1/p' | head -n1)"
  compact="${compact:0:220}"
  printf 'type=%q from=%q cmd=%q payload=%q' "${type:-}" "${from:-}" "${cmd:-}" "$compact"
}

debug_notify() {
  debug_notify_enabled || return 0
  local log_file
  log_file="$(debug_notify_log_file)"
  mkdir -p "$(dirname "$log_file")"
  printf '%s pid=%s %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$$" "$*" >>"$log_file"
}

ensure_internal_real_tmux() {
  if [[ -n "${ATMUX_REAL_TMUX:-}" && -x "$ATMUX_REAL_TMUX" ]]; then
    export ATMUX_ALLOW_REAL_TMUX=1
  fi
}

ensure_internal_real_tmux

team_message_root_for_team() {
  local repo="$1" team="$2"
  printf '%s/team-messages/%s/%s\n' "$ATMUX_HOME" "$repo" "$team"
}

team_state_dir() {
  local repo="$1" team="$2"
  printf '%s/teams/%s/%s\n' "$ATMUX_HOME" "$repo" "$team"
}

team_members_dir() {
  local repo="$1" team="$2"
  printf '%s/members\n' "$(team_state_dir "$repo" "$team")"
}

team_member_key() {
  local session="$1"
  atmux_resolve_normalized_name "$session"
}

team_member_dir() {
  local repo="$1" team="$2" session="$3"
  printf '%s/%s\n' "$(team_members_dir "$repo" "$team")" "$(team_member_key "$session")"
}

team_state_exists() {
  local repo="$1" team="$2"
  local dir
  dir="$(team_state_dir "$repo" "$team")"
  [[ -f "$dir/name" || -d "$dir/members" ]]
}

resolve_team_name() {
  local target="$1" repo_name="$2" team_name
  team_name="$(atmux_resolve_normalized_name "$target")"
  if team_state_exists "$repo_name" "$team_name"; then
    printf '%s\n' "$team_name"
    return 0
  fi
  if [[ "$target" == "atmux-${repo_name}-team-"* ]]; then
    team_name="${target#atmux-"${repo_name}"-team-}"
    if team_state_exists "$repo_name" "$team_name"; then
      printf '%s\n' "$team_name"
      return 0
    fi
  fi
  if [[ "$target" == "${repo_name}-team-"* ]]; then
    team_name="${target#"${repo_name}"-team-}"
    if team_state_exists "$repo_name" "$team_name"; then
      printf '%s\n' "$team_name"
      return 0
    fi
  fi
  return 1
}

team_member_sessions_from_state() {
  local repo="$1" team="$2" members_dir file session
  members_dir="$(team_members_dir "$repo" "$team")"
  [[ -d "$members_dir" ]] || return 0
  while IFS= read -r file; do
    [[ -e "$file" ]] || continue
    if [[ -d "$file" ]]; then
      session="$(cat "$file/session" 2>/dev/null || true)"
    else
      session="$(cat "$file" 2>/dev/null || true)"
    fi
    [[ -n "$session" ]] && printf '%s\n' "$session"
  done < <(find "$members_dir" -mindepth 1 -maxdepth 1 \( -type f -o -type d \) 2>/dev/null | sort)
}

record_team_member_state() {
  local repo="$1" team="$2" session="$3" name="${4:-}" role="${5:-}" adapter="${6:-}"
  local dir
  [[ -n "$repo" && -n "$team" && -n "$session" ]] || return 0
  dir="$(team_member_dir "$repo" "$team" "$session")"
  mkdir -p "$dir"
  atmux_fs_write_field "$dir/session" "$session"
  atmux_fs_write_field "$dir/name" "$name"
  atmux_fs_write_field "$dir/role" "$role"
  atmux_fs_write_field "$dir/adapter" "$adapter"
  atmux_fs_write_field "$dir/joined_at" "$(timestamp_utc)"
}

