#!/usr/bin/env bash
set -euo pipefail

ATMUX_HOME="${ATMUX_HOME:-$HOME/.atmux}"
HERE="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/(atmux)/notify
source "$HERE/notify"

usage() {
  cat <<'USAGE'
Usage:
  atmux assign --to <agent|session> --title <title> [--description <description>] [--given <context>] [--when <action>] [--then <outcome>] [--todo <todo>]... [--repo <repo>]
  atmux assign --issue <id> --to <agent|session> [--repo <repo>]

Description:
  Assign work using filesystem issues.
  - Without --issue: creates a new issue, then assigns it.
  - With --issue: assigns an existing issue id.
USAGE
}

resolve_script() {
  local name="$1"
  if [[ -n "${ATMUX_SOURCE_ROOT:-}" && -x "${ATMUX_SOURCE_ROOT}/bin/(atmux)/${name}" ]]; then
    printf '%s\n' "${ATMUX_SOURCE_ROOT}/bin/(atmux)/${name}"
    return 0
  fi

  local repo_root=""
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -x "${repo_root}/bin/(atmux)/${name}" ]]; then
      printf '%s\n' "${repo_root}/bin/(atmux)/${name}"
      return 0
    fi
  fi

  if [[ -x "${ATMUX_HOME}/src/atmux/bin/(atmux)/${name}" ]]; then
    printf '%s\n' "${ATMUX_HOME}/src/atmux/bin/(atmux)/${name}"
    return 0
  fi

  if [[ -x "${ATMUX_HOME}/bin/scripts/${name}" ]]; then
    printf '%s\n' "${ATMUX_HOME}/bin/scripts/${name}"
    return 0
  fi

  return 1
}

issue_id=""
target=""
title=""
description=""
given=""
when=""
then_=""
acceptance=""
explicit_repo=""
todos=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue)
      issue_id="${2:-}"
      shift 2
      ;;
    --to)
      target="${2:-}"
      shift 2
      ;;
    --title)
      title="${2:-}"
      shift 2
      ;;
    --description)
      description="${2:-}"
      shift 2
      ;;
    --given)
      given="${2:-}"
      shift 2
      ;;
    --when)
      when="${2:-}"
      shift 2
      ;;
    --then)
      then_="${2:-}"
      shift 2
      ;;
    --todo|--todos)
      todos+=("${2:-}")
      shift 2
      ;;
    --repo)
      explicit_repo="${2:-}"
      shift 2
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "$target" ]]; then
  echo "missing required flag: --to <agent|session>" >&2
  exit 2
fi
if [[ -z "$issue_id" && -z "$title" ]]; then
  echo "missing required flag: --title <title> (or pass --issue <id>)" >&2
  exit 2
fi
if [[ -n "$issue_id" && ( -n "$title" || -n "$description" || -n "$given" || -n "$when" || -n "$then_" || "${#todos[@]}" -gt 0 ) ]]; then
  echo "--issue cannot be combined with --title/--description/--given/--when/--then/--todo" >&2
  exit 2
fi

repo_name="$explicit_repo"
if [[ -z "$repo_name" ]]; then
  repo_name="$(repo_name_from_context)"
fi
resolved_target="$("$HERE/agent" resolve "$target" "$repo_name" || true)"
if [[ -z "$resolved_target" ]]; then
  resolved_target="$target"
fi

issue_script="$(resolve_script issue || true)"
if [[ -z "$issue_script" ]]; then
  echo "issue subcommand script not found" >&2
  exit 127
fi

created="false"
if [[ -z "$issue_id" ]]; then
  create_cmd=("$issue_script" create --title "$title")
  if [[ -n "$explicit_repo" ]]; then
    create_cmd+=(--repo "$explicit_repo")
  fi
  if [[ -n "$given" ]]; then
    create_cmd+=(--given "$given")
  fi
  if [[ -n "$when" ]]; then
    create_cmd+=(--when "$when")
  fi
  if [[ -n "$then_" ]]; then
    create_cmd+=(--then "$then_")
  fi
  if [[ -n "$acceptance" ]]; then
    create_cmd+=(--acceptance "$acceptance")
  fi
  local_todo=""
  for local_todo in ${todos[@]+"${todos[@]}"}; do
    [[ -n "$local_todo" ]] || continue
    create_cmd+=(--todo "$local_todo")
  done
  if [[ -n "$description" ]]; then
    create_cmd+=(--description "$description")
  fi

  create_out="$("${create_cmd[@]}")"
  issue_id="$(printf '%s\n' "$create_out" | sed -n 's/.*id="\([^"]*\)".*/\1/p' | head -n1)"
  if [[ -z "$issue_id" ]]; then
    echo "failed to parse created issue id" >&2
    printf '%s\n' "$create_out" >&2
    exit 1
  fi
  created="true"
fi

assign_cmd=("$issue_script" assign "$issue_id" --to "$resolved_target")
if [[ -n "$explicit_repo" ]]; then
  assign_cmd+=(--repo "$explicit_repo")
fi
"${assign_cmd[@]}" >/dev/null

get_cmd=("$issue_script" get "$issue_id")
if [[ -n "$explicit_repo" ]]; then
  get_cmd+=(--repo "$explicit_repo")
fi
issue_node="$("${get_cmd[@]}")"

printf '<assignment issue_id="%s" to="%s" created="%s">\n' \
  "$(xml_escape "$issue_id")" \
  "$(xml_escape "$resolved_target")" \
  "$(xml_escape "$created")"
printf '%s\n' "$issue_node"
printf '</assignment>\n'

