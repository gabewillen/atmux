#!/usr/bin/env bash
set -euo pipefail

# Test that each adapter's input_idle pattern matches its idle prompt
# and rejects non-idle states.

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
NOTIFY_SCRIPT="$REPO_ROOT/bin/(atmux)/notify"

ATMUX_HOME="${TMPDIR:-/tmp}"
ATMUX_SOURCE_ROOT="$REPO_ROOT"
source "$NOTIFY_SCRIPT"

test_pattern() {
  local adapter="$1"
  local input="$2"
  local expect="$3"  # "match" or "nomatch"
  local pattern

  pattern="$(resolve_input_idle_pattern "$adapter")"
  if printf '%s' "$input" | grep -Eq "$pattern" 2>/dev/null; then
    if [[ "$expect" == "nomatch" ]]; then
      echo "FAIL: $adapter pattern matched but shouldn't: '$input'" >&2
      return 1
    fi
  else
    if [[ "$expect" == "match" ]]; then
      echo "FAIL: $adapter pattern didn't match but should: '$input'" >&2
      return 1
    fi
  fi
  return 0
}

failures=0

# Claude Code: pattern ^> *$
test_pattern "claude-code" ">"          "match"   || failures=$((failures+1))
test_pattern "claude-code" "> "         "match"   || failures=$((failures+1))
test_pattern "claude-code" ">   "       "match"   || failures=$((failures+1))
test_pattern "claude-code" "> hello"    "nomatch" || failures=$((failures+1))
test_pattern "claude-code" "> /help"    "nomatch" || failures=$((failures+1))
test_pattern "claude-code" "processing" "nomatch" || failures=$((failures+1))
test_pattern "claude-code" ""           "nomatch" || failures=$((failures+1))

# Codex: pattern ^> *$
test_pattern "codex" ">"               "match"   || failures=$((failures+1))
test_pattern "codex" "> "              "match"   || failures=$((failures+1))
test_pattern "codex" "> typing here"   "nomatch" || failures=$((failures+1))
test_pattern "codex" "OpenAI Codex"    "nomatch" || failures=$((failures+1))

# Gemini: pattern ^[>❯] *$
test_pattern "gemini" ">"              "match"   || failures=$((failures+1))
test_pattern "gemini" "❯"              "match"   || failures=$((failures+1))
test_pattern "gemini" "❯ "             "match"   || failures=$((failures+1))
test_pattern "gemini" "> "             "match"   || failures=$((failures+1))
test_pattern "gemini" "❯ some input"   "nomatch" || failures=$((failures+1))
test_pattern "gemini" "Generating..."  "nomatch" || failures=$((failures+1))

# Cursor: pattern ^> *$
test_pattern "cursor-agent" ">"        "match"   || failures=$((failures+1))
test_pattern "cursor-agent" "> "       "match"   || failures=$((failures+1))
test_pattern "cursor-agent" "> cmd"    "nomatch" || failures=$((failures+1))

[[ "$failures" -eq 0 ]] || { echo "$failures pattern tests failed" >&2; exit 1; }

echo "ok: all adapter input_idle patterns match idle prompts and reject non-idle states"
