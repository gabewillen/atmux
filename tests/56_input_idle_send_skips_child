#!/usr/bin/env bash
set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"
ATMUX_BIN="$REPO_ROOT/bin/atmux"

wait_for_text() {
  local target="$1"
  local needle="$2"
  local timeout="${3:-15}"
  local deadline now snap compact
  deadline=$(( $(date +%s) + timeout ))
  while true; do
    snap="$(tmux capture-pane -p -t "$target" -S -400 2>/dev/null || true)"
    compact="$(printf '%s' "$snap" | tr -d '\r\n')"
    if printf '%s' "$compact" | grep -Fq "$needle"; then
      return 0
    fi
    now="$(date +%s)"
    if (( now >= deadline )); then
      return 1
    fi
    sleep 0.1
  done
}

wait_for_absence() {
  local target="$1"
  local needle="$2"
  local duration="${3:-1}"
  local end now
  end=$(( $(date +%s) + duration ))
  while true; do
    if wait_for_text "$target" "$needle" 1; then
      return 1
    fi
    now="$(date +%s)"
    if (( now >= end )); then
      return 0
    fi
  done
}

repo_name="idle${RANDOM}"
session_mgr="atmux-${repo_name}-mgr"
session_child="atmux-${repo_name}-child"

cleanup() {
  tmux kill-session -t "$session_mgr" >/dev/null 2>&1 || true
  tmux kill-session -t "$session_child" >/dev/null 2>&1 || true
}
trap cleanup EXIT

tmux kill-session -t "$session_mgr" >/dev/null 2>&1 || true
tmux kill-session -t "$session_child" >/dev/null 2>&1 || true

# Manager session
tmux new-session -d -s "$session_mgr" -n "$session_mgr" -x 160 -y 40 -c "$REPO_ROOT" "/bin/bash" -l
tmux set-environment -t "$session_mgr" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_mgr" ATMUX_AGENT_NAME "mgr"
tmux set-environment -t "$session_mgr" ATMUX_SESSION_NAME "$session_mgr"

# Child agent session (has ATMUX_MANAGER, has ATMUX_ADAPTER). Use cat to
# simulate an adapter pane without a shell prompt prefix.
tmux new-session -d -s "$session_child" -n "$session_child" -x 160 -y 40 -c "$REPO_ROOT" "cat"
tmux set-environment -t "$session_child" ATMUX_REPO "$repo_name"
tmux set-environment -t "$session_child" ATMUX_AGENT_NAME "child"
tmux set-environment -t "$session_child" ATMUX_SESSION_NAME "$session_child"
tmux set-environment -t "$session_child" ATMUX_MANAGER "mgr"
tmux set-environment -t "$session_child" ATMUX_ADAPTER "claude-code"
tmux set-environment -t "$session_child" ATMUX_SOURCE_ROOT "$REPO_ROOT"

pane_child="$(tmux list-panes -t "$session_child" -F '#{pane_id}' 2>/dev/null | head -n1)"
[[ -n "$pane_child" ]] || { echo "child pane missing" >&2; exit 1; }

# Put startup text in the child pane before the adapter input prompt exists.
sleep 0.5
tmux send-keys -t "$pane_child" -l "some output here, not a prompt"
tmux send-keys -t "$pane_child" Enter

# Manager sends to child. The CLI should return quickly because delivery is
# queued in the background, but the worker must not paste until input is ready.
start_ts="$(date +%s)"
ATMUX_REPO="$repo_name" ATMUX_AGENT_NAME="mgr" ATMUX_SESSION_NAME="$session_mgr" ATMUX_SOURCE_ROOT="$REPO_ROOT" \
  "$ATMUX_BIN" send --to child "do this task" >/dev/null
elapsed=$(( $(date +%s) - start_ts ))

# Should complete quickly (< 5s) even though delivery is waiting in the worker.
[[ "$elapsed" -le 5 ]] || { echo "send to child took too long to queue: ${elapsed}s" >&2; exit 1; }

# Notification should not be pasted before the child prompt appears.
if ! wait_for_absence "$pane_child" '<notification' 1; then
  echo "notification delivered before child prompt was ready" >&2
  tmux capture-pane -p -t "$pane_child" -S -200 >&2 || true
  exit 1
fi

tmux send-keys -t "$pane_child" -l "❯ "
tmux send-keys -t "$pane_child" Enter

# Notification should arrive once the prompt is present.
if ! wait_for_text "$pane_child" '<notification' 10; then
  echo "notification not delivered to child" >&2
  tmux capture-pane -p -t "$pane_child" -S -200 >&2 || true
  exit 1
fi

echo "ok: send to child agent queues quickly and waits for input prompt"
